---
/**
 * cag-blog-post — Style D (760px) blog post layout wrapper.
 * Use as a page layout: pass frontmatter props, slot in body content.
 *
 * Includes:
 *   - Post header (eyebrow tag, H1, meta row, featured image)
 *   - cag-jump-nav (sticky, 760px context)
 *   - <slot /> for body content
 *   - Key Takeaway callout via <slot name="key-takeaway" />
 *   - Inline horizontal bird card (optional)
 *   - Footer CTA
 */
import CagJumpNav from './cag-jump-nav.astro';
import CagBirdCardV2 from './cag-bird-card-v2.astro';

export interface Props {
  eyebrow?: string;
  title: string;
  author?: string;
  date?: string;
  readTime?: string;
  featuredImageSrc?: string;
  featuredImageAlt?: string;
  jumpLinks?: { label: string; href: string }[];
  inlineBird?: {
    name: string;
    species?: 'Congo African Grey' | 'Timneh African Grey';
    sex: 'Male' | 'Female' | 'Pair';
    age: string;
    price: string;
    imageSrc?: string;
  };
  footerCtaText?: string;
  footerCtaHref?: string;
}

const {
  eyebrow = "Buyer's Guide",
  title,
  author = 'Mark Benjamin',
  date,
  readTime = '8 min read',
  featuredImageSrc,
  featuredImageAlt,
  jumpLinks,
  inlineBird,
  footerCtaText = 'See Available Congo & Timneh Greys →',
  footerCtaHref = '/african-grey-parrots-for-sale/',
} = Astro.props;
---

<article class="blog-post-wrap">
  <!-- ── Header ── -->
  <header class="blog-header">
    <span class="blog-eyebrow font-sora">{eyebrow}</span>
    <h1 class="font-lora blog-title">{title}</h1>
    <div class="blog-meta font-sora">
      By {author}
      {date && <> · {date}</>}
      · {readTime}
      · <span class="blog-meta-site">CongoAfricanGreys.com</span>
    </div>

    {featuredImageSrc
      ? <img
          src={featuredImageSrc}
          alt={featuredImageAlt ?? title}
          class="blog-featured-img"
          loading="eager"
          fetchpriority="high"
        />
      : <div class="blog-featured-placeholder" aria-hidden="true">
          <img src="/emoji/cag-congo.png" alt="" style="width:100px;height:100px;object-fit:contain;opacity:.45;" loading="eager" />
        </div>
    }
  </header>

  <!-- ── Jump nav ── -->
  {jumpLinks && jumpLinks.length > 0 && (
    <div class="blog-jump-nav-wrap">
      <CagJumpNav links={jumpLinks} sticky={true} />
    </div>
  )}

  <!-- ── Body content slot ── -->
  <div class="blog-body">
    <slot />

    <!-- Key Takeaway callout slot (insert between body sections) -->
    <slot name="key-takeaway" />
  </div>

  <!-- ── Inline bird card (horizontal, 760px wide) ── -->
  {inlineBird && (
    <div class="blog-inline-bird">
      <CagBirdCardV2 horizontal={true} {...inlineBird} />
    </div>
  )}

  <!-- ── Footer CTA ── -->
  <div class="blog-footer-cta">
    <h3 class="font-lora blog-footer-heading">Ready to choose?</h3>
    <a href={footerCtaHref} class="blog-footer-btn font-sora">{footerCtaText}</a>
  </div>
</article>

<style>
  .blog-post-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 64px;
  }

  /* Header */
  .blog-header { margin-bottom: 24px; }
  .blog-eyebrow {
    display: inline-block;
    background: #eaf4ef;
    color: #2D6A4F;
    border: 1px solid rgba(45, 106, 79, 0.2);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 50px;
    padding: 5px 14px;
    margin-bottom: 14px;
  }
  .blog-title {
    font-size: clamp(1.75rem, 3vw + 0.8rem, 2.4rem);
    font-weight: 700;
    color: #1c1a18;
    line-height: 1.2;
    margin: 0 0 14px;
  }
  .blog-meta {
    font-size: 13px;
    color: #9b9189;
    margin-bottom: 24px;
  }
  .blog-meta-site { color: #2D6A4F; font-weight: 600; }
  .blog-featured-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }
  .blog-featured-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(145deg, #f5e6d8, #e8c4b0);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Jump nav spacing */
  .blog-jump-nav-wrap { margin: 20px 0 32px; }

  /* Body — typography for slot content */
  .blog-body {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: #5a5248;
  }
  .blog-body :global(h2) {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(1.3rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 700;
    color: #1c1a18;
    margin: 36px 0 14px;
    line-height: 1.25;
  }
  .blog-body :global(h3) {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1c1a18;
    margin: 28px 0 10px;
  }
  .blog-body :global(p) {
    margin: 0 0 18px;
    max-width: 70ch;
  }
  .blog-body :global(ul),
  .blog-body :global(ol) {
    padding-left: 20px;
    margin: 0 0 18px;
  }
  .blog-body :global(li) { margin-bottom: 8px; }

  /* Key Takeaway callout (use via <slot name="key-takeaway"> or inject directly) */
  .blog-body :global(.key-takeaway) {
    border-left: 4px solid #e8604c;
    background: #fdf6ec;
    border-radius: 0 12px 12px 0;
    padding: 20px 24px;
    margin: 28px 0;
  }
  .blog-body :global(.key-takeaway-eyebrow) {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #2D6A4F;
    margin-bottom: 6px;
  }
  .blog-body :global(.key-takeaway p) {
    font-size: 15px;
    font-weight: 500;
    color: #1c1a18;
    margin: 0;
    line-height: 1.55;
    max-width: none;
  }

  /* Inline bird card */
  .blog-inline-bird { margin: 32px 0; }

  /* Footer CTA */
  .blog-footer-cta {
    margin-top: 48px;
    padding: 36px 32px;
    background: linear-gradient(135deg, #fde8e3 0%, #fdf6ec 100%);
    border-radius: 20px;
    text-align: center;
  }
  .blog-footer-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1c1a18;
    margin: 0 0 16px;
  }
  .blog-footer-btn {
    display: inline-block;
    background: #e8604c;
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(232, 96, 76, 0.38);
    transition: background 0.2s, box-shadow 0.2s;
  }
  .blog-footer-btn:hover {
    background: #c94d3a;
    box-shadow: 0 10px 28px rgba(232, 96, 76, 0.48);
  }

  @media (max-width: 640px) {
    .blog-post-wrap { padding: 32px 16px 48px; }
    .blog-footer-cta { padding: 28px 20px; }
  }
</style>
