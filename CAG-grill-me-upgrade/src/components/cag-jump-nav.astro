---
/**
 * cag-jump-nav — Sticky section-to-section jump link bar.
 * Horizontal pill bar, cream bg, clay active state.
 * Works at both Style E (1100px) and Style D (760px) widths.
 * Mobile: horizontal scroll, no scrollbar visible.
 */
export interface NavLink {
  label: string;
  href: string;
}

export interface Props {
  links?: NavLink[];
  sticky?: boolean;
  activeHref?: string;
}

const {
  links = [
    { label: 'Available Birds', href: '#available-birds' },
    { label: 'Shipping Info',   href: '#shipping' },
    { label: 'CITES Docs',      href: '#cites' },
    { label: 'FAQ',             href: '#faq' },
    { label: 'Contact Us',      href: '/contact-us/' },
  ],
  sticky = true,
  activeHref = '',
} = Astro.props;
---

<nav
  class:list={['cag-jump-nav', { 'cag-jump-sticky': sticky }]}
  aria-label="Page sections"
>
  <div class="cag-jump-inner">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['cag-jump-link font-sora', { 'cag-jump-active': link.href === activeHref }]}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .cag-jump-nav {
    background: #faf7f4;
    border: 1px solid #ede5dc;
    border-radius: 50px;
    box-shadow: 0 2px 12px rgba(60, 30, 10, 0.07);
    padding: 6px 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .cag-jump-nav::-webkit-scrollbar { display: none; }

  .cag-jump-sticky {
    position: sticky;
    top: 72px;
    z-index: 100;
  }

  .cag-jump-inner {
    display: flex;
    gap: 4px;
    white-space: nowrap;
    min-width: max-content;
  }

  .cag-jump-link {
    font-size: 13px;
    font-weight: 600;
    color: #5a5248;
    padding: 8px 16px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .cag-jump-link:hover {
    background: #f0e8e4;
    color: #e8604c;
  }
  .cag-jump-active {
    background: #e8604c;
    color: #fff !important;
    box-shadow: 0 3px 10px rgba(232, 96, 76, 0.3);
  }
  .cag-jump-active:hover {
    background: #c94d3a;
    color: #fff;
  }

  @media (max-width: 767px) {
    .cag-jump-sticky { top: 60px; }
    .cag-jump-link { font-size: 12px; padding: 7px 14px; }
  }
</style>
