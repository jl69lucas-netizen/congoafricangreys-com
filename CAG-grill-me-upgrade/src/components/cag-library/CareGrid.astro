---
/**
 * CareGrid — numbered "best practices" card grid.
 *
 * @prop variant — 'classic' (numbered cards w/ CTA tile) | 'editorial' (two-tone bars) | 'dark' (sectioned strips)
 */
export interface CareItem {
  title: string;
  body: string;
}
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  title?: string;
  body?: string;
  items?: CareItem[];
}
const {
  variant = 'classic',
  title = "Raising a Grey — <em>they're smarter than you think</em>",
  body = "African Greys are arguably the most intelligent companion bird. Success comes from understanding their psychology, not forcing routines.",
  items = [
    { title: 'Positive reinforcement', body: 'Greys are sensitive and shut down with harsh corrections. Reward, never punish.' },
    { title: 'Short training sessions', body: '10–15 minute sessions, twice daily, work better than long ones. Quit while they\'re winning.' },
    { title: 'Consistent commands', body: 'Same words. Same tone. Every time. Grey memory rewards consistency relentlessly.' },
    { title: 'Mental enrichment daily', body: 'Foraging toys, puzzles, and rotated novelty. A bored Grey is a destructive Grey.' },
    { title: 'Early socialization', body: 'Expose to varied people, sounds, and environments in the first six months — confidence for life.' },
  ],
} = Astro.props;
---

<style>
@media (max-width: 768px) {
  .care-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 480px) {
  .care-grid { grid-template-columns: 1fr !important; }
}
</style>

{variant === 'classic' && (
  <div>
    <h3 class="font-display font-bold text-3xl mb-2" set:html={title} />
    <p class="text-mid mb-8 max-w-2xl text-[15px]">{body}</p>
    <div class="care-grid grid md:grid-cols-3 gap-5">
      {items.map((it, i) => (
        <article class="bg-warm rounded-2xl border border-line p-7">
          <div class="font-display text-clay font-bold text-2xl">{String(i+1).padStart(2,'0')}</div>
          <h4 class="font-display font-bold text-xl mt-3">{it.title}</h4>
          <p class="text-mid mt-2 text-[14px] leading-relaxed">{it.body}</p>
        </article>
      ))}
      <article class="bg-clay rounded-2xl p-7 text-white relative overflow-hidden">
        <div class="absolute -right-4 -top-4 opacity-10 leading-none"><img src="/emoji/cag-congo.png" alt="" style="width:120px;height:120px;object-fit:contain;" loading="lazy" /></div>
        <div class="font-display font-bold text-2xl">Need a hand?</div>
        <p class="mt-2 text-[14px] text-white/90 leading-relaxed">We're on the phone with new owners through year one — call or text any time.</p>
        <a class="mt-4 inline-block bg-white text-clay rounded-full px-4 py-2 text-[13px] font-semibold">Read our care guide →</a>
      </article>
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="bg-white rounded-3xl cag-warm-shadow border border-line overflow-hidden">
    <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-line">
      {items.slice(0, 4).map((it, i) => (
        <div class={`p-10 ${i % 2 === 1 ? 'bg-warm' : ''}`}>
          <div class="text-clay font-display text-3xl font-bold mb-1">{String(i+1).padStart(2,'0')}</div>
          <h4 class="font-display font-bold text-xl">{it.title}</h4>
          <p class="text-mid mt-2 text-[14px]">{it.body}</p>
        </div>
      ))}
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-10 text-white">
    <h3 class="font-display font-bold text-3xl mb-2" set:html={title} />
    <p class="text-white/60 mb-8 max-w-2xl">{body}</p>
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-3">
      {items.map((it, i) => (
        <div class="border-b border-white/10 pb-3 flex gap-4 items-start">
          <span class="font-display text-clay font-bold text-2xl shrink-0">{String(i+1).padStart(2,'0')}</span>
          <div>
            <div class="font-display font-bold text-lg leading-snug">{it.title}</div>
            <div class="text-[13px] text-white/60">{it.body}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}
