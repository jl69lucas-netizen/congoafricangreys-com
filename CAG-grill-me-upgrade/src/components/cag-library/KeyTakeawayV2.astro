---
/**
 * cag-key-takeaway-v2:02 — "Stat-forward grid"
 * Source design: page-components-desktop.html → TakeawaysStats (green header band + stat grid).
 * Ported to site Tailwind tokens. Answer-engine / featured-snippet summary box.
 * Content = homepage key takeaways (verified facts only · CITES Appendix I · C.A.Gs voice).
 */
interface Item { stat: string; label: string; body: string; }
interface Props {
  eyebrow?: string;
  heading?: string;          // rendered as H2
  badge?: string;
  items?: Item[];
}
const {
  eyebrow = "The short version",
  heading = "What Makes C.A.Gs a Trusted African Grey Breeder?",
  badge = "8 facts · 90-sec read",
  items = [
    { stat: "2014",      label: "Family Aviary",       body: "Mark & Teri Benjamin hand-raise every Congo and Timneh African Grey in their Midland, Texas home." },
    { stat: "100%",      label: "Captive-Bred",        body: "Each of our Greys is hatched in the USA with full CITES Appendix I documentation — never wild-caught." },
    { stat: "DNA",       label: "Sexed & Vet-Checked", body: "Each Grey ships with a DNA sex certificate and an avian-veterinarian health certificate." },
    { stat: "$1,500+",   label: "Honest Pricing",      body: "Timneh Greys from $1,500 and Congos from $1,700 — no $400 bait listings, ever." },
    { stat: "40–60 yr",  label: "Lifetime Companion",  body: "African Greys live for decades, so we back every Grey with support for its whole life." },
    { stat: "USDA",      label: "AWA Licensed",        body: "C.A.Gs holds a USDA Animal Welfare Act license you can verify before you pay anything." },
    { stat: "Nationwide",label: "IATA Shipping",       body: "Birds travel safely to your nearest major airport in a USDA-approved travel crate." },
    { stat: "24h",       label: "Reply Guarantee",     body: "Send an inquiry and hear back from Mark or Teri within one business day." },
  ],
} = Astro.props;

const borderByIndex = (i: number) => {
  const cls: string[] = [];
  if (i % 2 === 1) cls.push("border-l border-black/[0.07]");        // mobile 2-col
  if (i >= 2)      cls.push("border-t border-black/[0.07]");        // mobile rows
  cls.push("md:border-t-0");                                         // no top border on desktop
  if (i % 4 !== 0) cls.push("md:border-l md:border-black/[0.07]");  // desktop 4-col dividers
  if (i % 2 === 0) cls.push("md:border-l-0");                        // reset mobile-left on desktop where needed
  if (i % 4 === 0) cls.push("border-l-0");
  return cls.join(" ");
};
---

<section class="key-takeaway-v2 py-12 px-4 bg-warm-white md:py-16" aria-labelledby="kt-heading">
  <div class="container mx-auto max-w-[1100px]">
    <div class="overflow-hidden rounded-[20px] border border-black/[0.07] bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">

      <!-- green header band -->
      <div class="flex flex-col items-start justify-between gap-3 bg-green px-6 py-6 md:flex-row md:items-center md:px-9">
        <div>
          <p class="font-sora text-[11px] font-bold uppercase tracking-[0.16em] text-white/90">{eyebrow}</p>
          <h2 id="kt-heading" class="font-lora mt-1.5 text-2xl font-bold leading-tight text-white md:text-[26px]">
            {heading}
          </h2>
        </div>
        <span class="font-sora inline-flex flex-shrink-0 items-center gap-2 rounded-full bg-white/12 px-3.5 py-1.5 text-xs font-semibold tracking-wide text-white">
          {badge}
        </span>
      </div>

      <!-- stat grid -->
      <div class="grid grid-cols-2 md:grid-cols-4">
        {items.map((it, i) => (
          <div class={`px-5 py-6 ${borderByIndex(i)}`}>
            <div class="font-lora text-2xl font-bold leading-none text-clay md:text-[30px]">{it.stat}</div>
            <div class="font-sora mt-2 text-[11px] font-bold uppercase tracking-[0.12em] text-green">{it.label}</div>
            <p class="font-sora mt-2 text-[13.5px] leading-relaxed text-stone-600">{it.body}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
