---
interface Props {
  categoryLabel: string;
  title: string;
  height?: number;
  columns?: 3 | 4;
  items: Array<{ icon: string; title: string; desc: string }>;
}

const {
  categoryLabel,
  title,
  height = 320,
  columns = 3,
  items,
} = Astro.props;

const clampedHeight = Math.min(350, Math.max(300, height));
---

<div
  aria-label={title}
  style={`background:#2D6A4F;color:#fff;height:${clampedHeight}px;min-height:300px;max-height:350px;border-radius:12px;overflow:hidden;font-family:'Sora',sans-serif;box-shadow:0 4px 24px rgba(0,0,0,0.2);display:flex;flex-direction:column;padding:12px 16px;`}
>
  <div style="text-align:center;margin-bottom:10px;flex-shrink:0;">
    <div style="font-size:11px;font-weight:800;color:#e8604c;letter-spacing:0.08em;text-transform:uppercase;">{categoryLabel}</div>
    <div style="font-family:'Lora',serif;font-size:14px;font-weight:700;line-height:1.2;">{title}</div>
  </div>
  <div style={`display:grid;grid-template-columns:repeat(${columns},1fr);gap:6px;flex:1;align-content:start;`}>
    {items.map((item) => (
      <div style="background:rgba(255,255,255,0.08);border-radius:8px;padding:7px 8px;display:flex;flex-direction:column;gap:3px;">
        <div style="font-size:14px;">{item.icon}</div>
        <div style="font-size:9px;font-weight:800;line-height:1.2;color:#fff;">{item.title}</div>
        <div style="font-size:8px;color:rgba(255,255,255,0.65);line-height:1.3;">{item.desc}</div>
      </div>
    ))}
  </div>
</div>
