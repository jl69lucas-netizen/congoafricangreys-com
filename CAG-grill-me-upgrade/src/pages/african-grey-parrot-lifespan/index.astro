---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrot Lifespan | 40–60 Years: What You Need to Know";
const description = "African Grey parrots live 40–60 years in captivity. What affects lifespan, vet care at each life stage, and how to plan for a bird that may outlive you.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-lifespan/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Lifespan", url: "/african-grey-parrot-lifespan/" },
];

const faqs = [
  {
    q: "How long do African Grey parrots live?",
    a: "Captive African Grey parrots commonly live 40 to 60 years with proper diet, veterinary care, and enrichment. Some documented individuals have reached 70–80 years. Wild African Greys have a shorter average lifespan due to predation, disease, and habitat loss.",
  },
  {
    q: "What shortens an African Grey's lifespan?",
    a: "The most common lifespan-shortening factors in captivity are seed-heavy diets (hypovitaminosis A causing chronic infection), PTFE/Teflon fume exposure, delayed veterinary care (prey-animal instinct to hide illness), feather destructive behavior leading to self-mutilation, and chronic stress from understimulation.",
  },
  {
    q: "How old is an African Grey in human years?",
    a: "African Greys mature sexually at 3–5 years, reach behavioral maturity at 10–12 years, and are considered middle-aged at 20–25 years. A 40-year-old African Grey is in the final quarter of its natural lifespan — roughly equivalent to a 75-year-old human.",
  },
  {
    q: "What should I do if my African Grey outlives me?",
    a: "Include your bird in your estate planning. Designate a guardian in your will and provide them with the bird's complete medical history, diet log, behavioral notes, and CITES documentation. The African Parrot Society and World Parrot Trust maintain rehoming networks for parrots that outlive their owners.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="life-hero">
    <div class="page-container">
      <h1 class="life-h1">African Grey Parrot Lifespan</h1>
      <p class="life-sub">
        40 to 60 years. Possibly longer than your mortgage. Understanding what that means —
        and planning for it — is part of responsible African Grey ownership.
      </p>
      <a class="btn-primary" href="/african-grey-parrot-care-guide/">Full Care Guide</a>
    </div>
  </section>

  <!-- HOW LONG -->
  <section class="life-section">
    <div class="page-container text-wrap">
      <h2 class="life-h2">How Long Do African Greys Live?</h2>
      <p>
        In captivity, with proper nutrition, veterinary care, and enrichment, African Grey parrots
        commonly live <strong>40 to 60 years</strong>. This is not an upper bound — it is the
        standard range for a well-kept bird. Some documented individuals have reached 70 to 80
        years. These are legitimate records, not apocryphal stories.
      </p>
      <p>
        Wild African Greys have a shorter average lifespan. Predation by raptors, disease, habitat
        fragmentation, and food scarcity all reduce life expectancy significantly below captive
        averages. A wild African Grey reaching 20 years is doing well; a captive bird at 20 years
        is a young adult with 30–40 more years ahead.
      </p>
      <p>
        The comparison between Congo and Timneh is essentially equal. Both subspecies have the
        same 40–60 year captive lifespan when cared for properly. Choosing between them should not
        be based on lifespan expectations.
      </p>
    </div>
  </section>

  <!-- LIFE STAGES -->
  <section class="life-section life-alt">
    <div class="page-container text-wrap">
      <h2 class="life-h2">Life Stages: What to Expect at Each Age</h2>

      <div class="life-stages">
        <div class="life-stage-card">
          <h3 class="life-h3">Baby (0–1 year)</h3>
          <p>Weaning period (12–16 weeks), rapid feather development, first vocalizations.
          Highly impressionable — socialization during this window shapes temperament for life.
          Annual first vet exam should occur by 6 months.</p>
        </div>
        <div class="life-stage-card">
          <h3 class="life-h3">Juvenile (1–5 years)</h3>
          <p>Vocabulary acquisition begins in earnest, sexual maturity onset at 3–5 years.
          Hormonal periods may begin (seasonal behavior changes, mild aggression). Birds
          develop strong individual personality during this stage.</p>
        </div>
        <div class="life-stage-card">
          <h3 class="life-h3">Young Adult (5–15 years)</h3>
          <p>Peak cognitive and vocal ability. Behavioral maturity around age 10–12. Birds
          become deeply bonded to their primary person. Routine and stability are especially
          important during this phase.</p>
        </div>
        <div class="life-stage-card">
          <h3 class="life-h3">Mature Adult (15–30 years)</h3>
          <p>Stable, predictable personality. Some birds become calmer and more tolerant.
          Annual bloodwork becomes increasingly important for early detection of age-related
          organ changes. Dietary quality continues to matter enormously.</p>
        </div>
        <div class="life-stage-card">
          <h3 class="life-h3">Senior (30+ years)</h3>
          <p>Arthritis may affect foot grip — provide lower perches and easier cage navigation.
          More frequent veterinary monitoring (twice yearly recommended). Vision may decline.
          Senior birds often remain highly vocal and engaged well into their 40s and 50s.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TOP CAUSES OF EARLY DEATH -->
  <section class="life-section">
    <div class="page-container text-wrap">
      <h2 class="life-h2">Top Causes of Early Death in Captive African Greys</h2>
      <p>
        Understanding what kills African Greys prematurely is as important as understanding
        what keeps them healthy. The most common causes of death before age 20 in captive birds:
      </p>
      <ul class="life-list">
        <li>
          <strong>Seed-heavy diet → Hypovitaminosis A:</strong> Chronic vitamin A deficiency
          suppresses the immune system, causes chronic sinus infections, and leads to secondary
          bacterial pneumonia. This is the single most preventable cause of early death.
        </li>
        <li>
          <strong>PTFE/Teflon fume exposure:</strong> Overheated non-stick cookware releases
          aerosolized particles lethal to birds within minutes. This is not a risk that can be
          managed by opening windows — it is an instant, catastrophic event.
        </li>
        <li>
          <strong>Delayed veterinary care:</strong> African Greys instinctively hide illness (a
          prey-animal survival mechanism). By the time visible symptoms appear, the disease is
          often advanced. Annual proactive exams catch problems before they become fatal.
        </li>
        <li>
          <strong>Feather destructive behavior → Self-mutilation:</strong> What begins as
          feather plucking from boredom or stress can progress to self-mutilation of the skin.
          Severe cases lead to infection and sepsis if not addressed.
        </li>
        <li>
          <strong>Chronic psychological stress:</strong> Understimulation, inconsistent routine,
          frequent rehoming, and social isolation all cause chronic cortisol elevation that
          suppresses immunity and shortens lifespan.
        </li>
      </ul>
    </div>
  </section>

  <!-- VET CARE BY STAGE -->
  <section class="life-section life-alt">
    <div class="page-container text-wrap">
      <h2 class="life-h2">Veterinary Care by Life Stage</h2>
      <p>
        African Greys require veterinary attention with an <strong>avian-certified veterinarian</strong>,
        not a general practice vet. Avian medicine is a specialized field; a vet without specific
        bird training may miss early disease markers or administer incorrect drug doses.
      </p>
      <p>
        From age 0–10 years, annual wellness exams with a CBC, gram stain, and weight check are
        the standard of care. From age 10–25 years, annual exams with the addition of a basic
        chemistry panel to monitor kidney and liver function. From age 25+, twice-yearly exams
        are recommended. Watch blood calcium levels at every stage — African Greys are uniquely
        prone to hypocalcemia throughout their lives.
      </p>
      <p>
        Establish your avian vet relationship before you need it urgently. Know where your
        nearest avian emergency clinic is. In an avian emergency — toxin exposure, seizure,
        respiratory distress — response time matters. Do this research before you bring your
        bird home.
      </p>
    </div>
  </section>

  <!-- ESTATE PLANNING -->
  <section class="life-section">
    <div class="page-container text-wrap">
      <h2 class="life-h2">Planning for a Bird That Will Outlive You</h2>
      <p>
        A 40–60 year lifespan means that statistically, many African Greys will outlive their
        first owners. This is not a morbid consideration — it is responsible ownership. Every
        African Grey owner should have a plan.
      </p>
      <p>
        At minimum, include the following in your estate planning: designate a guardian for the
        bird in your will; give that person the bird's complete medical history including
        vaccination records, vet contacts, and blood panel results; provide the diet log and
        behavioral notes; and transfer all CITES documentation to the new guardian. CITES papers
        stay with the bird for its entire life and must be passed on with any change of ownership.
      </p>
      <p>
        Organizations including the <strong>African Parrot Society</strong> and the
        <strong>World Parrot Trust</strong> maintain rehoming networks for parrots that outlive
        their owners or must be re-homed for other reasons. Connect with these organizations
        early — not in a crisis — so your bird has a qualified safety net.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="life-section life-alt">
    <div class="page-container text-wrap">
      <h2 class="life-h2">African Grey Lifespan: Frequently Asked Questions</h2>
      <div class="life-faq">
        {faqs.map((f) => (
          <details class="life-faq-item">
            <summary class="life-faq-q">{f.q}</summary>
            <p class="life-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div style="text-align:center;padding:8px 0 32px;font-family:Sora,sans-serif;font-size:0.88rem;color:#6b6560;">
    This guide is part of the <a href="/african-grey-care/" style="color:#2D6A4F;font-weight:600;text-decoration:none;">African Grey Care Hub</a> →
  </div>

  <CTA
    headline="Ready to Make a 40-Year Commitment?"
    sub="Every bird from CongoAfricanGreys.com is captive-bred, hand-raised, CITES-documented, and vet-certified. We are here to support you for the full lifespan of your bird."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap { max-width: 760px; }
  .life-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .life-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .life-h3 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }
  .life-hero {
    background: #2D6A4F;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .life-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto 1.75rem;
  }
  .btn-primary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.9rem;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    background: #e8604c;
    color: #fff;
    transition: background 0.2s ease;
  }
  .btn-primary:hover { background: #d44e3b; }
  .life-section { padding: 3rem 0; }
  .life-alt { background: #faf7f4; }
  .life-section p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.2rem;
  }
  .life-list {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    padding-left: 1.5rem;
    margin: 0.5rem 0 1.2rem;
  }
  .life-list li { margin-bottom: 0.75rem; max-width: 70ch; }
  .life-stages {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .life-stage-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 1px 4px rgba(60,30,10,0.06);
  }
  .life-stage-card p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0;
    max-width: 70ch;
  }
  .life-faq { display: flex; flex-direction: column; gap: 0.75rem; }
  .life-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .life-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .life-faq-q::-webkit-details-marker { display: none; }
  .life-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) { .page-container { padding: 0 16px; } }
  @media (min-width: 768px) and (max-width: 1024px) { .page-container { padding: 0 32px; } }
</style>
