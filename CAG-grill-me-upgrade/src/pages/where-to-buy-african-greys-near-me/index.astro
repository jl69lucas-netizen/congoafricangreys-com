---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "Where to Buy African Grey Parrots Near Me | Verified Breeders";
const description = "Looking to buy an African Grey parrot near you? We ship nationwide to your closest airport. USDA-licensed, CITES-documented — not a pet store.";
const canonical = "https://congoafricangreys.com/where-to-buy-african-greys-near-me/";

const states = [
  { name: 'Texas', href: '/african-grey-parrot-for-sale-texas/' },
  { name: 'New York', href: '/african-grey-parrot-for-sale-new-york/' },
  { name: 'Ohio', href: '/african-grey-parrot-for-sale-ohio/' },
  { name: 'Florida', href: '/african-grey-parrot-for-sale/' },
  { name: 'California', href: '/african-grey-parrot-for-sale/' },
  { name: 'All Other States', href: '/african-grey-parrot-for-sale/' },
];
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <!-- Hero -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Where to Buy African Greys Near Me", url: "/where-to-buy-african-greys-near-me/" }
      ]} />
  </div>

  <section class="bg-green text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-3">Ships to All 50 States</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Where to Buy African Greys Near Me</h1>
      <p class="text-white/80 text-lg">If you're searching for where to buy African Greys near you, your search ends here. Hand-fed, DNA-tested, CITES-documented Congo African Greys shipped nationwide from Midland, TX.</p>
    </div>
  </section>

  <TrustBar />

  <!-- Intro -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">We Come to You — Anywhere in the U.S.</h2>
      <p class="text-stone-600 max-w-2xl mx-auto text-lg leading-relaxed">You don't need to find a local breeder. We specialize in providing hand-fed, DNA-tested, and well-socialized Congo African Grey parrots with nationwide IATA-compliant shipping for just $185. Your bird arrives at your nearest airport within 3–8 hours of departure.</p>
    </div>
  </section>

  <!-- State Grid -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8 text-center">Browse Birds by State</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {states.map(state => (
          <a href={state.href} class="flex items-center justify-between p-5 bg-white border border-stone-100 rounded-xl shadow-sm hover:border-green hover:shadow-md transition-all group">
            <span class="font-lora font-semibold text-logo-dark group-hover:text-green transition-colors">{state.name}</span>
            <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose CAG -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8 text-center">Why Buy From Congo African Greys?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>', title: 'Home Raised', body: 'Birds raised in our Midland, TX family home — socialized with people from hatch.' },
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>', title: 'CITES Documented', body: 'Full CITES Appendix I captive-bred documentation on every bird. 100% legal.' },
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M9 3h6"/><path d="M10 3v6l-4.6 9.2A1.5 1.5 0 0 0 6.7 21h10.6a1.5 1.5 0 0 0 1.3-2.8L14 9V3"/></svg>', title: 'DNA Sexed', body: 'Know the sex of your bird before purchase. Every bird comes with a DNA sexing certificate.' },
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>', title: 'Ships From $185', body: 'IATA-compliant airline shipping to all 50 states. Your bird arrives within 3–8 hours.' },
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M10.5 20.5 3.5 13.5a4.95 4.95 0 0 1 7-7l7 7a4.95 4.95 0 0 1-7 7z"/><line x1="8.5" y1="8.5" x2="15.5" y2="15.5"/></svg>', title: '3-Day Health Guarantee', body: "Written guarantee covering Polyoma, Pacheco's, Psittacosis, and PBFD." },
          { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>', title: 'Lifetime Breeder Support', body: 'Mark and Teri answer questions about diet, behavior, and enrichment long after your bird comes home.' },
        ].map(item => (
          <div class="flex gap-4 p-5 bg-warm-white rounded-xl border border-stone-100">
            <span class="text-2xl mt-0.5" set:html={item.icon}></span>
            <div>
              <h3 class="font-lora font-semibold text-logo-dark text-base mb-1">{item.title}</h3>
              <p class="text-stone-500 text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA headline="Find Your African Grey — Ships to Your City" sub="Contact us today. We'll match you with the right bird and handle all shipping." />
</BaseLayout>
