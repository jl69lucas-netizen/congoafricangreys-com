---
/**
 * cag-inquiry-compact — SHORT inquiry form (5 fields) for content pages that need a
 * low-friction contact box, not the full 10-field adoption application (cag-inquiry-form).
 * AA-safe: green header with white heading + scoped light subtext (beats the Direction-D
 * `h2 + p {color:--ink}` rule via class specificity, so no dark-on-green trap).
 * Formspree xrejpnvn. Props let a page set its own framing + keep ids unique across instances.
 */
interface Props {
  heading?: string;
  subtext?: string;
  subject?: string;
  page?: string;
  idPrefix?: string;
}
const {
  heading = 'Ask a Verified Breeder',
  subtext = 'Send us your question and we reply within 24 hours.',
  subject = 'C.A.Gs Website Inquiry',
  page = '',
  idPrefix = '',
} = Astro.props;
const formAction = 'https://formspree.io/f/xrejpnvn';
---

<div class="cf-card">
  <div class="cf-head">
    <h2 class="cf-title font-lora">{heading}</h2>
    <p class="cf-sub font-sora">{subtext}</p>
  </div>
  <form class="cf-form font-sora" action={formAction} method="POST">
    <div class="cf-row">
      <div class="cf-group">
        <label for={idPrefix + 'cf-name'}>Your Name <span class="cf-req">*</span></label>
        <input type="text" id={idPrefix + 'cf-name'} name="name" required placeholder="First &amp; Last Name" autocomplete="name" />
      </div>
      <div class="cf-group">
        <label for={idPrefix + 'cf-email'}>Email Address <span class="cf-req">*</span></label>
        <input type="email" id={idPrefix + 'cf-email'} name="email" required placeholder="you@email.com" autocomplete="email" />
      </div>
    </div>
    <div class="cf-row">
      <div class="cf-group">
        <label for={idPrefix + 'cf-phone'}>Phone Number</label>
        <input type="tel" id={idPrefix + 'cf-phone'} name="phone" placeholder="(555) 000-0000" autocomplete="tel" />
      </div>
      <div class="cf-group">
        <label for={idPrefix + 'cf-interest'}>Interested In</label>
        <select id={idPrefix + 'cf-interest'} name="interest">
          <option value="">Select an option</option>
          <option>Congo African Grey ($1,500–$3,500)</option>
          <option>Timneh African Grey ($1,200–$2,500)</option>
          <option>Breeding Pair</option>
          <option>Fertile Eggs</option>
          <option>Just vetting a listing</option>
          <option>General question</option>
        </select>
      </div>
    </div>
    <div class="cf-group">
      <label for={idPrefix + 'cf-msg'}>Your Message or Listing Link</label>
      <textarea id={idPrefix + 'cf-msg'} name="message" rows="3" placeholder="Paste a suspicious listing, or tell us which Grey you're after."></textarea>
    </div>
    <input type="hidden" name="_subject" value={subject} />
    {page && <input type="hidden" name="page" value={page} />}
    <button type="submit" class="cf-submit">Send to C.A.Gs — Free, No Pressure &#10003;</button>
  </form>
  <div class="cf-pills">
    <span>&#10003; USDA AWA Licensed</span>
    <span>&#10003; CITES Appendix I</span>
    <span>&#10003; DNA Sexed</span>
    <span>&#10003; Avian Vet Certified</span>
    <span>&#10003; Ships Nationwide</span>
  </div>
</div>

<style>
  .cf-card{ max-width:640px; margin:0 auto; background:#fff; border:1px solid #ede5dc; border-radius:18px; overflow:hidden; box-shadow:0 4px 24px rgba(60,30,10,.07); }
  .cf-head{ background:linear-gradient(135deg,#1f4d38,#2D6A4F); padding:22px 28px; text-align:center; }
  .cf-title{ color:#fff; margin:0; font-size:1.3rem; font-weight:700; line-height:1.25; }
  .cf-sub{ color:#f1ebe4; margin:8px 0 0; font-size:13.5px; line-height:1.55; }
  .cf-form{ padding:22px 24px; display:flex; flex-direction:column; gap:14px; }
  .cf-row{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .cf-group{ display:flex; flex-direction:column; gap:5px; }
  .cf-group label{ font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#5a5248; }
  .cf-req{ color:#b04228; }
  .cf-group input,.cf-group select,.cf-group textarea{ padding:11px 14px; border:1.5px solid #ede5dc; border-radius:10px; font-size:14px; font-family:inherit; color:#1c1a18; background:#fff9f6; outline:none; transition:border-color .15s,box-shadow .15s; }
  .cf-group input:focus,.cf-group select:focus,.cf-group textarea:focus{ border-color:#e8604c; box-shadow:0 0 0 3px rgba(232,96,76,.1); background:#fff; }
  .cf-group textarea{ resize:vertical; min-height:84px; }
  .cf-submit{ background:#bd4129; color:#fff; border:none; padding:13px; border-radius:50px; font-size:15px; font-weight:700; font-family:inherit; cursor:pointer; box-shadow:0 6px 20px rgba(232,96,76,.32); transition:background .2s,transform .15s; }
  .cf-submit:hover{ background:#a8381f; transform:translateY(-1px); }
  .cf-pills{ display:flex; flex-wrap:wrap; gap:8px; justify-content:center; padding:0 24px 22px; }
  .cf-pills span{ background:#eaf4ef; color:#2D6A4F; border:1px solid rgba(45,106,79,.2); border-radius:50px; padding:5px 14px; font-size:11.5px; font-weight:700; letter-spacing:.03em; }
  @media(max-width:560px){ .cf-row{ grid-template-columns:1fr; } .cf-head{ padding:20px 20px; } .cf-form{ padding:20px 18px; } .cf-pills{ padding:0 18px 18px; } }
</style>
