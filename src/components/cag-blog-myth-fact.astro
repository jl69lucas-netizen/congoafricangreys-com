---
/**
 * cag-blog-myth-fact — Two-column myth-versus-fact card.
 * Myth column: neutral muted bg with a struck-feel label.
 * Fact column: forest-accent green bg with a forest left-border.
 * Columns stack to single-column at ≤640px.
 * Labels ("Myth" / "Fact") are <strong> elements — not headings —
 * so the optional small heading above is the only hN in this component.
 *
 * Usage:
 *   <MythFact
 *     myth="African Greys bond to only one person and ignore everyone else."
 *     fact="With proper early socialisation, Greys build trust with every member of the household — we deliberately handle every chick in rotation from day one."
 *   />
 */

export interface Props {
  /** The myth text to display */
  myth: string;
  /** The fact / correction to display */
  fact: string;
  /** Optional small heading above the two columns */
  heading?: string;
  /** Heading level — defaults to h3 */
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { myth, fact, heading, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<div class="cag-myth-fact" role="region" aria-label={heading ?? 'Myth vs Fact'}>
  {heading && <Heading class="cag-myth-fact__heading font-lora">{heading}</Heading>}
  <div class="cag-myth-fact__cols">
    <div class="cag-myth-fact__col cag-myth-fact__col--myth">
      <strong class="cag-myth-fact__label font-sora">Myth</strong>
      <p class="cag-myth-fact__text font-sora">{myth}</p>
    </div>
    <div class="cag-myth-fact__col cag-myth-fact__col--fact">
      <strong class="cag-myth-fact__label font-sora">Fact</strong>
      <p class="cag-myth-fact__text font-sora">{fact}</p>
    </div>
  </div>
</div>

<style>
  .cag-myth-fact {
    margin: 1.5rem 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border, #ede5dc);
    box-shadow: 0 2px 10px rgba(60, 30, 10, .06);
  }

  .cag-myth-fact__heading {
    margin: 0;
    padding: .65rem 1.25rem;
    background: #2D6A4F;
    color: #faf7f4;
    font-size: 1rem;
  }

  .cag-myth-fact__cols {
    display: flex;
    gap: 0;
  }

  .cag-myth-fact__col {
    flex: 1 1 0;
    padding: 1.1rem 1.25rem;
  }

  .cag-myth-fact__col--myth {
    background: #fff9f6;
    border-right: 1px solid var(--border, #ede5dc);
  }

  .cag-myth-fact__col--fact {
    background: #eaf4ef;
    border-left: 4px solid #2D6A4F;
  }

  .cag-myth-fact__label {
    display: block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .09em;
    text-transform: uppercase;
    margin-bottom: .45rem;
  }

  .cag-myth-fact__col--myth .cag-myth-fact__label {
    color: #5a5248;
  }

  .cag-myth-fact__col--fact .cag-myth-fact__label {
    color: #2D6A4F;
  }

  .cag-myth-fact__text {
    margin: 0;
    font-size: .95rem;
    line-height: 1.6;
    color: #3a2c22;
  }

  .cag-myth-fact__col--myth .cag-myth-fact__text {
    text-decoration-line: none;
    opacity: .8;
  }

  @media (max-width: 640px) {
    .cag-myth-fact__cols {
      flex-direction: column;
    }
    .cag-myth-fact__col--myth {
      border-right: none;
      border-bottom: 1px solid var(--border, #ede5dc);
    }
    .cag-myth-fact__col--fact {
      border-left: none;
      border-top: 4px solid #2D6A4F;
    }
  }
</style>
