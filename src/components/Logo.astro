---
interface Props {
  height?: number;
  class?: string;
}
const { height = 44, class: className = '' } = Astro.props;
---

<a href="/" class:list={['flex items-center shrink-0 group', className]}>
  <img
    src="/cag-header-logo.png"
    alt="C.A.Gs — Congo African Greys, Midland TX"
    width="auto"
    height={height}
    class="transition-opacity duration-300 group-hover:opacity-80"
    style={`height:${height}px;width:auto`}
  />
</a>
