---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<a href="/" class:list={['flex items-center gap-3 shrink-0 group', className]}>
  <img
    src="/african-grey-parrot-store-logo.png"
    alt="Congo African Greys logo"
    width={size}
    height={size}
    class="rounded-full transition-transform duration-300 group-hover:scale-110"
  />
</a>
