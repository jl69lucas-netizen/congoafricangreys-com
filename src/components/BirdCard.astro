---
interface Props {
  id: string;
  name: string;
  sex: string;
  age: string;
  price: string;
  tag: string;
  tagType: 'new' | 'talker' | 'family' | 'value';
  notes: string;
  hook: string;
  image?: string;
  variant?: string;
  objectPos?: string;
  /** Where the Inquire CTA points. Defaults to the standalone contact page.
   *  Pass an on-page anchor (e.g. "#contact") on pages that render the inquiry
   *  form so the CTA jumps straight to it instead of redirecting. */
  inquireHref?: string;
}

const { id, name, sex, age, price, tag, tagType, notes, hook,
  image = '/african-grey-hero.webp', variant = 'Congo African Grey',
  objectPos = 'object-center', inquireHref } = Astro.props;

const ctaHref = inquireHref ?? `/contact-us/?bird=${id}`;

const tagColors: Record<string, string> = {
  new:    'bg-clay text-white',
  talker: 'bg-green text-white',
  family: 'bg-amber-500 text-amber-950',
  value:  'bg-stone-600 text-white',
};

const tagClass = tagColors[tagType] ?? tagColors.new;
---

<article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-stone-100 flex flex-col hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
  <!-- Photo -->
  <div class="relative bg-green/10 h-72 overflow-hidden">
    <img
      src={image}
      alt={`${name} — ${sex} ${variant} parrot, captive-bred, Midland TX`}
      class={`w-full h-full object-cover ${objectPos}`}
      loading="lazy"
      width="400"
      height="256"
    />
    <span class={`absolute top-3 left-3 text-xs font-semibold px-3 py-1 rounded-full ${tagClass}`}>
      {tag}
    </span>
    <span class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-stone-600 text-xs font-sora px-2 py-1 rounded-full">
      <svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Midland, TX
    </span>
  </div>

  <!-- Body -->
  <div class="p-5 flex flex-col flex-1">
    <!-- Name + meta row -->
    <div class="mb-2">
      <h3 class="font-lora font-bold text-xl text-logo-dark leading-tight">{name}</h3>
      <p class="text-stone-500 text-xs font-sora mt-0.5">{sex} · {age} · {variant}</p>
    </div>

    <!-- Personality hook -->
    <p class="text-stone-700 text-sm font-semibold leading-snug mb-2 italic">"{hook}"</p>

    <!-- Supporting notes -->
    <p class="text-stone-500 text-sm leading-relaxed mb-4 flex-1">{notes}</p>

    <!-- Trust micro-badges -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">CITES Cert</span>
      <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">PCR DNA-Sexed</span>
      <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">Vet Certified</span>
      <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">PBFD &amp; APV Screened</span>
      <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">Fully Weaned</span>
    </div>

    <!-- Shipping cost line -->
    <p class="flex items-center gap-1.5 text-xs font-sora text-stone-500 mb-4 -mt-1">
      <svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg>
      Ships nationwide · <strong class="text-logo-dark font-semibold">$185</strong> airport · <strong class="text-logo-dark font-semibold">$350</strong> home
    </p>

    <!-- Price + CTA -->
    <div class="flex items-center justify-between pt-4 border-t border-stone-100">
      <div>
        <span class="font-lora font-bold text-2xl text-clay">{price}</span>
        <span class="text-stone-500 text-xs font-sora ml-1">+ $200 deposit</span>
      </div>
      <a
        href={ctaHref}
        class="bg-clay text-white text-xs font-semibold px-5 py-2.5 rounded-full hover:bg-clay-dk transition-colors"
      >
        Inquire →
      </a>
    </div>
  </div>
</article>
