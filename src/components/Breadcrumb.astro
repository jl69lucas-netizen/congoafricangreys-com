---
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": `https://congoafricangreys.com${item.url}`
  }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<div class="bc-pill-wrap">
  <ol class="bc-pill" aria-label="Breadcrumb">
    {items.map((item, i) => (
      <li class="bc-item">
        {i < items.length - 1 ? (
          <a href={item.url} class="bc-link">{item.name}</a>
        ) : (
          <span aria-current="page" class="bc-current">{item.name}</span>
        )}
        {i < items.length - 1 && <span class="bc-sep" aria-hidden="true"> › </span>}
      </li>
    ))}
  </ol>
</div>

<style>
/* Design B: own strip between nav and hero, cream bg, dark green text */
.bc-pill-wrap {
  display: block;
  text-align: left;
  padding: 0.55rem 1.5rem;
  font-family: 'Sora', sans-serif;
  font-size: 0.8rem;
  background: transparent;
  /* Long 3-level trails (e.g. "Home › African Grey Care › How to Tame an
     African Grey") exceed a 375px viewport. Let the strip scroll horizontally
     within its own width instead of pushing document width (13px overflow fix).
     No visual change when the trail already fits. */
  max-width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.bc-pill-wrap::-webkit-scrollbar { display: none; }
@media (max-width: 1024px) {
  .bc-pill-wrap {
    font-size: 0.75rem; /* 12px */
  }
}
.bc-pill {
  display: inline-flex;
  align-items: center;
  flex-wrap: nowrap;
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  list-style: none;
  margin: 0;
}
.bc-item {
  display: flex;
  align-items: center;
  white-space: nowrap;
}
.bc-link {
  color: #2D6A4F;
  text-decoration: none;
  transition: color 0.15s;
}
.bc-link:hover {
  color: #1a3d2e;
  text-decoration: underline;
}
.bc-sep {
  color: #9ca3af;
  padding: 0 5px;
}
.bc-current {
  color: #1a3d2e;
  font-weight: 600;
}
</style>
