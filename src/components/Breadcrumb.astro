---
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": `https://congoafricangreys.com${item.url}`
  }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<nav aria-label="Breadcrumb" class="breadcrumb-nav">
  <ol class="breadcrumb-list">
    {items.map((item, i) => (
      <li class="breadcrumb-item">
        {i < items.length - 1 ? (
          <a href={item.url} class="breadcrumb-link">{item.name}</a>
        ) : (
          <span aria-current="page" class="breadcrumb-current">{item.name}</span>
        )}
        {i < items.length - 1 && <span class="breadcrumb-sep" aria-hidden="true"> › </span>}
      </li>
    ))}
  </ol>
</nav>

<style>
.breadcrumb-nav {
  padding: 8px 0 16px;
  font-family: 'Sora', sans-serif;
  font-size: 0.85rem;
}
.breadcrumb-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0;
}
.breadcrumb-item {
  display: flex;
  align-items: center;
}
.breadcrumb-link {
  color: #2D6A4F;
  text-decoration: none;
}
.breadcrumb-link:hover {
  color: #e8604c;
  text-decoration: underline;
}
.breadcrumb-sep {
  color: #999;
  padding: 0 4px;
}
.breadcrumb-current {
  color: #666;
}
</style>
