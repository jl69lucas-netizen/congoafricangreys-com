---
import LogoBadge from './LogoBadge.astro';
const year = new Date().getFullYear();
---

<footer class="bg-logo-dark text-cream/80 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 items-start">

    <!-- Column 1: Brand -->
    <div>
      <a href="/" class="block mb-4 hover:opacity-80 transition-opacity">
        <img src="/cag-footer-logo.png" alt="C.A.Gs — Congo African Greys" width="auto" height="48" style="height:48px;width:auto;max-width:160px" />
      </a>
      <p class="text-sm leading-relaxed text-cream/70 mb-4">
        Your trusted source for captive-bred, CITES-documented African Grey parrots. USDA-licensed. Ships nationwide.
      </p>
      <!-- Social icons -->
      <div class="flex items-center gap-2">
        <a href="#" aria-label="Pinterest" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 text-xs font-bold text-cream/70 hover:text-gold hover:border-gold transition-colors">P</a>
        <a href="#" aria-label="Instagram" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 text-xs font-bold text-cream/70 hover:text-gold hover:border-gold transition-colors">IG</a>
        <a href="#" aria-label="Facebook" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 text-xs font-bold text-cream/70 hover:text-gold hover:border-gold transition-colors">FB</a>
      </div>
    </div>

    <!-- Column 2: African Greys (Shop) -->
    <div>
      <h3 class="font-lora font-semibold text-gold text-sm uppercase tracking-wider mb-4">African Greys</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/congo-african-grey-for-sale/" class="hover:text-gold transition-colors">Congo African Grey</a></li>
        <li><a href="/male-african-gray-for-sale/" class="hover:text-gold transition-colors">Male African Greys</a></li>
        <li><a href="/grey-african-parrots-for-sale/" class="hover:text-gold transition-colors">Grey Parrots For Sale</a></li>
        <li><a href="/african-grey-parrot-bird-eggs-for-sale-usa/" class="hover:text-gold transition-colors">Fertile Bird Eggs</a></li>
        <li><a href="/african-grey-breeding-pair-for-sale/" class="hover:text-gold transition-colors">Breeding Pairs</a></li>
        <li><a href="/where-to-buy-african-greys-near-me/" class="hover:text-gold transition-colors">Where to Buy</a></li>
        <li><a href="/african-grey-parrot-for-sale-near-me/" class="hover:text-gold transition-colors">Greys Near Me</a></li>
      </ul>
    </div>

    <!-- Column 3: Grey Resources (Info) -->
    <div>
      <h3 class="font-lora font-semibold text-gold text-sm uppercase tracking-wider mb-4">Grey Resources</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/trusted-african-grey-parrot-breeders/" class="hover:text-gold transition-colors">Our Breeders</a></li>
        <li><a href="/african-grey-reviews/" class="hover:text-gold transition-colors">Bird Reviews</a></li>
        <li><a href="/male-vs-female-african-grey-parrots-for-sale/" class="hover:text-gold transition-colors">Male vs Female</a></li>
        <li><a href="/best-african-grey-parrot-food/" class="hover:text-gold transition-colors">Parrot Food</a></li>
        <li><a href="/cites-african-grey-documentation/" class="hover:text-gold transition-colors">CITES Docs</a></li>
        <li><a href="/how-to-avoid-african-grey-parrot-scams/" class="hover:text-gold transition-colors">Avoid Scams</a></li>
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div>
      <h3 class="font-lora font-semibold text-gold text-sm uppercase tracking-wider mb-4">Contact</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="tel:+19565646067" class="hover:text-gold transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.01l-2.2 2.22z"/></svg>
            (956) 564-6067
          </a>
        </li>
        <li>
          <a href="mailto:Info@congoafricangreys.com" class="hover:text-gold transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Email Us
          </a>
        </li>
        <li><a href="/contact-us/" class="hover:text-gold transition-colors">Contact Page</a></li>
        <li><a href="/african-greys-for-sale-with-health-guarantee/" class="hover:text-gold transition-colors">Health Guarantee</a></li>
        <li><a href="/buy-african-grey-parrots-with-shipping/" class="hover:text-gold transition-colors">Live Shipping</a></li>
        <li><a href="/privacy-policy/" class="hover:text-gold transition-colors">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- Column 5: Newsletter -->
    <div>
      <h3 class="font-lora font-semibold text-gold text-sm uppercase tracking-wider mb-4">Newsletter</h3>
      <p class="text-sm text-cream/70 mb-4">Be first to know when new clutches arrive.</p>
      <form class="flex flex-col gap-3">
        <input
          type="email"
          placeholder="Your email address"
          class="px-4 py-2 rounded-lg text-sm bg-white/10 border border-white/20 text-cream placeholder-cream/40 focus:outline-none focus:border-gold"
        />
        <button
          type="submit"
          class="bg-clay text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-clay-dk transition-colors"
        >
          Subscribe &rarr;
        </button>
      </form>
    </div>

  </div>

  <!-- Trust bar bottom -->
  <div class="border-t border-gold/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-cream/50">
      <p>Copyright &copy; {year} &middot; congoafricangreys.com &middot; All Rights Reserved</p>
      <div class="flex items-center gap-3">
        <LogoBadge size={64} class="opacity-70 hover:opacity-100 transition-opacity" />
        <p class="text-center">CITES Appendix II Compliant &middot; USDA AWA Licensed</p>
      </div>
    </div>
  </div>
</footer>
