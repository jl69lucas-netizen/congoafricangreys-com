---
import LogoBadge from './LogoBadge.astro';
import locationsData from '../../data/locations.json';

const year = new Date().getFullYear();

// Get top 5 live state pages
const liveStates = (locationsData.live_states || [])
  .filter((s: any) => s.status === 'live')
  .slice(0, 5);
---

<footer class="bg-green text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 items-start">

    <!-- Column 1: Brand -->
    <div class="sm:col-span-2 lg:col-span-1">
      <a href="/" class="block mb-4 hover:opacity-80 transition-opacity">
        <img src="/cag-footer-logo.png" alt="CongoAfricanGreys.com — Captive-Bred African Grey Breeders" width="200" height="66" loading="lazy" decoding="async" style="height:48px;width:auto;max-width:160px" />
      </a>
      <p class="text-sm leading-relaxed text-white/80 mb-5">
        USDA AWA licensed captive-bred African Grey breeders. All birds come with CITES documentation.
      </p>
      <!-- Social icons (SVG) -->
      <div class="flex items-center gap-2 mb-5">
        <a href="#" aria-label="Pinterest" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 hover:border-clay hover:text-clay text-white/80 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 hover:border-clay hover:text-clay text-white/80 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="#" aria-label="Facebook" class="w-8 h-8 flex items-center justify-center rounded-full border border-white/20 hover:border-clay hover:text-clay text-white/80 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
      <p class="text-xs text-white/80 leading-relaxed">USDA AWA Licensed · CITES Appendix I Compliant</p>
    </div>

    <!-- Column 2: Shop African Greys -->
    <div>
      <h3 class="font-lora font-bold text-base mb-4 pb-2 border-b border-clay/40 text-white">Shop African Greys</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/congo-african-grey-for-sale/" class="text-white/80 hover:text-clay transition-colors">Congo African Grey for Sale</a></li>
        <li><a href="/timneh-african-grey-for-sale/" class="text-white/80 hover:text-clay transition-colors">Timneh African Grey for Sale</a></li>
        <li><a href="/african-grey-parrot-for-sale/" class="text-white/80 hover:text-clay transition-colors">Baby African Grey for Sale</a></li>
        <li><a href="/african-grey-adoption/" class="text-white/80 hover:text-clay transition-colors">African Grey Adoption</a></li>
        <li><a href="/african-grey-breeding-pair-for-sale/" class="text-white/80 hover:text-clay transition-colors">African Grey Breeding Pair</a></li>
        <li><a href="/african-grey-parrot-bird-eggs-for-sale-usa/" class="text-white/80 hover:text-clay transition-colors">African Grey Eggs for Sale</a></li>
        <li><a href="/african-grey-parrot-price/" class="text-white/80 hover:text-clay transition-colors">African Grey Parrot Price</a></li>
      </ul>
    </div>

    <!-- Column 3: By Location -->
    <div>
      <h3 class="font-lora font-bold text-base mb-4 pb-2 border-b border-clay/40 text-white">By Location</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/african-grey-parrots-for-sale/" class="text-white/80 hover:text-clay transition-colors">African Greys for Sale</a></li>
        {liveStates.map((s: any) => (
          <li>
            <a href={`/${s.slug}/`} class="text-white/80 hover:text-clay transition-colors">
              African Grey for Sale in {s.state}
            </a>
          </li>
        ))}
        <li class="pt-1">
          <a href="/african-grey-parrots-for-sale/" class="text-white hover:underline font-semibold text-sm transition-colors">
            View All States &rarr;
          </a>
        </li>
      </ul>
    </div>

    <!-- Column 4: Resources & Trust -->
    <div>
      <h3 class="font-lora font-bold text-base mb-4 pb-2 border-b border-clay/40 text-white">Resources & Trust</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/trusted-african-grey-parrot-breeders/" class="text-white/80 hover:text-clay transition-colors">Trusted Breeders</a></li>
        <li><a href="/african-grey-care/" class="text-white/80 hover:text-clay transition-colors">African Grey Care Hub</a></li>
        <li><a href="/cites-african-grey-documentation/" class="text-white/80 hover:text-clay transition-colors">CITES Documentation</a></li>
        <li><a href="/how-to-avoid-african-grey-parrot-scams/" class="text-white/80 hover:text-clay transition-colors">Scam Prevention Guide</a></li>
        <li><a href="/african-grey-parrot-health-guarantee/" class="text-white/80 hover:text-clay transition-colors">Health Guarantee</a></li>
        <li><a href="/buy-african-grey-parrots-with-shipping/" class="text-white/80 hover:text-clay transition-colors">Live Shipping Info</a></li>
        <li><a href="/blog/" class="text-white/80 hover:text-clay transition-colors">Blog &amp; Resources</a></li>
        <li><a href="/african-grey-comparison/" class="text-white/80 hover:text-clay transition-colors">Compare Parrots</a></li>
      </ul>
    </div>

    <!-- Column 5: Contact -->
    <div>
      <h3 class="font-lora font-bold text-base mb-4 pb-2 border-b border-clay/40 text-white">Contact</h3>
      <ul class="space-y-3 text-sm mb-5">
        <li>
          <a href="tel:2815453169" class="flex items-start gap-2 text-white/80 hover:text-clay transition-colors">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.56 1 1 0 01-.25 1.01l-2.2 2.22z"/></svg>
            281-545-3169
          </a>
        </li>
        <li>
          <a href="mailto:info@congoafricangreys.com" class="flex items-start gap-2 text-white/80 hover:text-clay transition-colors">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@congoafricangreys.com
          </a>
        </li>
        <li class="flex items-start gap-2 text-white/80">
          <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Monday–Sunday, Open 24/7
        </li>
      </ul>
      <a
        href="/contact-us/"
        class="inline-block bg-clay text-white font-semibold text-sm px-5 py-2.5 rounded-full hover:bg-clay-dk transition-colors mb-4"
      >
        Inquire Now
      </a>
      <ul class="space-y-2 text-sm">
        <li><a href="/privacy-policy/" class="text-white/80 hover:text-clay transition-colors text-xs">Privacy Policy</a></li>
        <li><a href="/sitemap.xml" class="text-white/80 hover:text-clay transition-colors text-xs">Sitemap</a></li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 bg-green/90">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-white/80">

      <p>&copy; {year} CongoAfricanGreys.com &middot; All Rights Reserved &middot; USDA AWA Licensed &middot; CITES Appendix I Compliant &middot; Midland, TX</p>

      <div class="flex items-center gap-3">
        <LogoBadge size={64} class="opacity-80 hover:opacity-100 transition-opacity" />
        <span class="text-white/80 text-xs font-medium whitespace-nowrap">C.A.Gs — Certified African Grey Breeders</span>
      </div>

    </div>
  </div>
</footer>
