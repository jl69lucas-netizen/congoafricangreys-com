---
/**
 * cag-blog-quick-answer — AEO "Quick Answer / Key-Takeaway" box.
 * Renders a definition list of label→value rows with a forest-green
 * header band and cream body. Place near the top of any blog post or
 * care-guide page to target Featured Snippet / AI Overview capture.
 *
 * Usage:
 *   <QuickAnswer title="African Grey Cage Quick Answer" rows={[
 *     { label: 'Minimum cage', value: '36" × 24" × 48"' },
 *     { label: 'Recommended', value: '48" wide, 5–7 perches' },
 *   ]} />
 */

export interface Row {
  label: string;
  value: string;
}

export interface Props {
  /** Box heading — defaults to "Quick Answer" */
  title?: string;
  /** One or more label / value pairs to display */
  rows: Row[];
  /** Heading level — defaults to h3; override when the box sits under a non-H2 section */
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { title = 'Quick Answer', rows, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<aside class="cag-blog-qa" aria-label={title}>
  <Heading class="cag-blog-qa__title font-lora">{title}</Heading>
  <dl class="cag-blog-qa__grid">
    {rows.map((r) => (
      <div class="cag-blog-qa__row">
        <dt>{r.label}</dt>
        <dd>{r.value}</dd>
      </div>
    ))}
  </dl>
</aside>

<style>
  .cag-blog-qa {
    border: 1px solid var(--border, #ede5dc);
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 2px 10px rgba(60, 30, 10, .06);
    overflow: hidden;
    margin: 1.5rem 0;
  }

  .cag-blog-qa__title {
    background: #2D6A4F;
    color: #faf7f4;
    margin: 0;
    padding: .75rem 1.25rem;
    font-size: 1.15rem;
  }

  .cag-blog-qa__grid {
    margin: 0;
    padding: .5rem 1.25rem 1rem;
  }

  .cag-blog-qa__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .55rem 0;
    border-bottom: 1px solid var(--line, #ede5dc);
  }

  .cag-blog-qa__row:last-child {
    border-bottom: 0;
  }

  .cag-blog-qa__row dt {
    font-weight: 600;
    color: #3a2c22;
  }

  .cag-blog-qa__row dd {
    margin: 0;
    color: #5a5248;
    text-align: right;
  }
</style>
