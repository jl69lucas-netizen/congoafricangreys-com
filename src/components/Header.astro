---
import Logo from './Logo.astro';

const phone = '(956) 564-6067';
const phoneHref = 'tel:+19565646067';

const nav = [
  { label: 'Home',             href: '/' },
  { label: 'Shop',             href: '/african-grey-parrot-for-sale/' },
  { label: 'About',            href: '/trusted-african-grey-parrot-breeders/' },
  { label: 'Reviews',          href: '/testimonials/' },
  { label: 'Shipping',         href: '/buy-african-grey-parrots-with-shipping/' },
  { label: 'Health Guarantee', href: '/african-greys-for-sale-with-health-guarantee/' },
  { label: 'Contact',          href: '/contact-us/' },
];

const current = Astro.url.pathname;
---

<header class="bg-green text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <Logo />

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-5 text-sm font-sora font-medium">
        {nav.map(link => (
          <a
            href={link.href}
            class:list={[
              'transition-colors hover:text-gold',
              current === link.href ? 'text-gold underline underline-offset-4' : 'text-white/90'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Search icon + Inquire Now CTA -->
      <div class="hidden sm:flex items-center gap-2">
        <button aria-label="Search" class="text-white/80 hover:text-gold p-2 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7 7 0 1116.65 16.65z"/>
          </svg>
        </button>
        <a
          href="/contact-us/"
          class="inline-flex items-center gap-2 bg-clay text-white font-semibold text-sm px-5 py-2 rounded-full hover:bg-clay-dk transition-colors"
        >
          Inquire Now
        </a>
      </div>

      <!-- Mobile menu -->
      <details class="lg:hidden relative">
        <summary class="list-none cursor-pointer text-white/90 hover:text-gold p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </summary>
        <nav class="absolute right-0 top-10 bg-green border border-white/20 rounded-lg shadow-xl p-4 flex flex-col gap-3 min-w-52">
          {nav.map(link => (
            <a href={link.href} class="text-white/90 hover:text-gold text-sm font-medium">
              {link.label}
            </a>
          ))}
          <a href={phoneHref} class="text-gold font-semibold text-sm">{phone}</a>
        </nav>
      </details>

    </div>
  </div>
</header>
