---
import Logo from './Logo.astro';

const current = Astro.url.pathname;

const nav = [
  { label: 'Home', href: '/' },
  {
    label: 'Shop Parrots',
    children: [
      { label: 'Congo African Grey for Sale',   href: '/congo-african-grey-for-sale/' },
      { label: 'Timneh African Grey for Sale',  href: '/timneh-african-grey-for-sale/' },
      { label: 'Baby African Grey for Sale',    href: '/baby-african-grey-parrot-for-sale/' },
      { label: 'African Grey Adoption',         href: '/african-grey-adoption/' },
      { divider: true },
      { label: 'Browse by State',               href: '/african-grey-parrots-for-sale/' },
    ],
  },
  {
    label: 'Compare',
    children: [
      { label: 'Congo vs Timneh',              href: '/congo-vs-timneh-african-grey/' },
      { label: 'Male vs Female',               href: '/male-vs-female-african-grey-parrots-for-sale/' },
      { label: 'African Grey vs Macaw',        href: '/african-grey-vs-macaw/' },
      { label: 'African Grey vs Cockatoo',     href: '/african-grey-vs-cockatoo/' },
      { label: 'African Grey vs Amazon',       href: '/african-grey-vs-amazon-parrot/' },
      { label: 'African Grey Pros & Cons',     href: '/african-grey-pros-and-cons/' },
      { divider: true },
      { label: 'All Comparisons',              href: '/african-grey-comparison/' },
    ],
  },
  {
    label: 'Care Guides',
    children: [
      { label: 'African Grey Care Guide',      href: '/african-grey-parrot-care-guide/' },
      { label: 'Diet & Nutrition',             href: '/african-grey-parrot-diet/' },
      { label: 'Best African Grey Food',       href: '/best-african-grey-parrot-food/' },
      { label: 'Lifespan & Health',            href: '/african-grey-parrot-lifespan/' },
      { label: 'Species Guide',                href: '/african-grey-parrot-guide/' },
    ],
  },
  { label: 'Blog',    href: '/blog/' },
  { label: 'Reviews', href: '/african-grey-reviews/' },
];

function isActive(href: string) {
  return current === href || current === href.replace(/\/$/, '');
}

function hasActiveChild(children: any[]) {
  return children.some(c => c.href && isActive(c.href));
}
---

<header class="bg-green text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24">

      <!-- Logo -->
      <div class="flex items-center gap-3 shrink-0">
        <Logo />
      </div>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1 text-sm font-sora font-medium" aria-label="Main navigation">
        {nav.map(item => (
          item.children ? (
            <div class="nav-dropdown-wrap relative">
              <button
                type="button"
                class:list={[
                  'nav-dropdown-btn flex items-center gap-1 px-3 py-2 rounded transition-colors hover:text-white',
                  hasActiveChild(item.children) ? 'text-white underline underline-offset-4' : 'text-white/90'
                ]}
                aria-haspopup="true"
                aria-expanded="false"
              >
                {item.label}
                <svg class="w-3.5 h-3.5 opacity-70 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <ul class="nav-dropdown absolute top-full left-0 mt-1 min-w-56 bg-white rounded-xl shadow-lg border border-stone-100 py-2 hidden" role="menu">
                {item.children.map(child => (
                  child.divider ? (
                    <li role="separator" class="my-1 border-t border-stone-100"></li>
                  ) : (
                    <li role="none">
                      <a
                        href={child.href}
                        role="menuitem"
                        class:list={[
                          'block px-4 py-2 text-sm text-stone-700 hover:text-clay hover:bg-cream transition-colors',
                          isActive(child.href) ? 'text-clay font-semibold' : ''
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  )
                ))}
              </ul>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded transition-colors hover:text-white',
                isActive(item.href) ? 'text-white underline underline-offset-4 font-semibold' : 'text-white/90'
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Desktop CTA -->
      <a
        href="/contact-us/"
        class="hidden lg:inline-flex items-center gap-2 bg-clay text-white font-semibold text-sm px-5 py-2.5 rounded-full hover:bg-clay-dk transition-colors shrink-0"
      >
        Inquire Now
      </a>

      <!-- Mobile/tablet search bar (hidden on desktop ≥1024px) -->
      <form
        action="/search/"
        method="get"
        class="flex lg:hidden items-center gap-1.5 flex-1 mx-2 max-w-[200px]"
        role="search"
        aria-label="Site search"
      >
        <input
          type="search"
          name="q"
          placeholder="Search…"
          aria-label="Search congoafricangreys.com"
          class="w-full min-w-0 bg-white/10 border border-white/30 text-white rounded-full px-3 py-1.5 text-xs placeholder-white/50 outline-none focus:border-clay transition-colors [appearance:none] [-webkit-appearance:none]"
        />
        <button
          type="submit"
          class="shrink-0 bg-clay text-white rounded-full px-3 py-1.5 text-xs font-bold whitespace-nowrap hover:bg-clay-dk transition-colors"
        >
          Go
        </button>
      </form>

      <!-- Mobile: CTA + hamburger -->
      <div class="flex lg:hidden items-center gap-3">
        <a
          href="/contact-us/"
          class="hidden sm:inline-flex items-center bg-clay text-white font-bold text-sm px-4 py-2 rounded-full hover:bg-clay-dk transition-colors shadow-sm"
        >
          Contact Us
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          class="text-white/90 hover:text-white p-2 rounded transition-colors"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <!-- Hamburger icon (shown when closed) -->
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <!-- X icon (shown when open) -->
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-white/10 bg-green"
    aria-label="Mobile navigation"
  >
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1 text-sm font-sora font-medium">
      {nav.map(item => (
        item.children ? (
          <div class="mobile-section">
            <p class="text-white/50 text-xs uppercase tracking-widest px-3 pt-3 pb-1 font-semibold">{item.label}</p>
            {item.children.map(child => (
              child.divider ? (
                <hr class="border-white/10 my-1" />
              ) : (
                <a
                  href={child.href}
                  class:list={[
                    'block px-4 py-2 rounded-lg transition-colors hover:text-white hover:bg-white/10',
                    isActive(child.href) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/90'
                  ]}
                  aria-current={isActive(child.href) ? 'page' : undefined}
                >
                  {child.label}
                </a>
              )
            ))}
          </div>
        ) : (
          item.href === '/' ? (
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2 rounded-lg transition-colors hover:text-white hover:bg-white/10',
                isActive(item.href) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/90'
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2 rounded-lg transition-colors hover:text-white hover:bg-white/10',
                isActive(item.href) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/90'
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          )
        )
      ))}
      <!-- Mobile CTA -->
      <div class="pt-3 pb-2 border-t border-white/10 mt-2">
        <a
          href="/contact-us/"
          class="block w-full text-center bg-clay text-white font-semibold px-5 py-3 rounded-full hover:bg-clay-dk transition-colors"
        >
          Inquire Now
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Desktop dropdown: show on hover via CSS */
  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap:focus-within .nav-dropdown {
    display: block;
  }
  .nav-dropdown-wrap:hover .nav-dropdown-btn svg,
  .nav-dropdown-wrap:focus-within .nav-dropdown-btn svg {
    transform: rotate(180deg);
  }
  /* Also handle JS aria-expanded for accessibility */
  .nav-dropdown-btn[aria-expanded="true"] + .nav-dropdown {
    display: block;
  }
  .nav-dropdown-btn[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
</style>

<script>
  // Desktop dropdown: click toggle + close on outside click
  const dropdownWraps = document.querySelectorAll<HTMLElement>('.nav-dropdown-wrap');
  dropdownWraps.forEach(wrap => {
    const btn = wrap.querySelector<HTMLButtonElement>('.nav-dropdown-btn');
    const menu = wrap.querySelector<HTMLElement>('.nav-dropdown');
    if (!btn || !menu) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      // Close all others
      dropdownWraps.forEach(w => {
        const b = w.querySelector<HTMLButtonElement>('.nav-dropdown-btn');
        if (b && b !== btn) b.setAttribute('aria-expanded', 'false');
      });
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  // Close dropdowns on outside click
  document.addEventListener('click', () => {
    dropdownWraps.forEach(wrap => {
      const btn = wrap.querySelector<HTMLButtonElement>('.nav-dropdown-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropdownWraps.forEach(wrap => {
        const btn = wrap.querySelector<HTMLButtonElement>('.nav-dropdown-btn');
        if (btn) {
          btn.setAttribute('aria-expanded', 'false');
          // Restore focus to the trigger button
          if (wrap.contains(document.activeElement) && document.activeElement !== btn) {
            btn.focus();
          }
        }
      });
    }
  });

  // Mobile hamburger toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden', !isOpen);
      mobileBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      iconOpen?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });
  }
</script>
