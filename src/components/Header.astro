---
import Logo from './Logo.astro';

const nav = [
  { label: 'Home',             href: '/' },
  { label: 'Shop',             href: '/african-grey-parrot-for-sale/' },
  { label: 'About',            href: '/trusted-african-grey-parrot-breeders/' },
  { label: 'Reviews',          href: '/testimonials/' },
  { label: 'Shipping',         href: '/buy-african-grey-parrots-with-shipping/' },
  { label: 'Health Guarantee', href: '/african-greys-for-sale-with-health-guarantee/' },
  { label: 'Contact',          href: '/contact-us/' },
];

const current = Astro.url.pathname;
---

<header class="bg-green text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <Logo />

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-5 text-sm font-sora font-medium">
        {nav.map(link => (
          <a
            href={link.href}
            class:list={[
              'transition-colors hover:text-gold',
              current === link.href ? 'text-gold underline underline-offset-4' : 'text-white/90'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Search icon + Inquire Now CTA -->
      <div class="hidden sm:flex items-center gap-2">
        <button id="search-btn" aria-label="Search" class="text-white/80 hover:text-gold p-2 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7 7 0 1116.65 16.65z"/>
          </svg>
        </button>
        <a
          href="/contact-us/"
          class="inline-flex items-center gap-2 bg-clay text-white font-semibold text-sm px-5 py-2 rounded-full hover:bg-clay-dk transition-colors"
        >
          Inquire Now
        </a>
      </div>

      <!-- Mobile menu -->
      <details class="lg:hidden relative">
        <summary class="list-none cursor-pointer text-white/90 hover:text-gold p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </summary>
        <nav class="absolute right-0 top-10 bg-green border border-white/20 rounded-lg shadow-xl p-4 flex flex-col gap-3 min-w-52">
          {nav.map(link => (
            <a href={link.href} class="text-white/90 hover:text-gold text-sm font-medium">
              {link.label}
            </a>
          ))}
        </nav>
      </details>

    </div>
  </div>
  <!-- Search overlay (hidden by default) -->
  <div id="search-overlay" class="hidden border-t border-white/20 bg-green px-4 py-3">
    <form action="https://www.google.com/search" method="get" class="max-w-2xl mx-auto flex gap-2">
      <input type="hidden" name="sitesearch" value="congoafricangreys.com" />
      <input
        id="search-input"
        name="q"
        type="search"
        placeholder="Search CongoAfricanGreys.com…"
        class="flex-1 bg-white/10 border border-white/30 text-white placeholder:text-white/50 rounded-full px-4 py-2 text-sm focus:outline-none focus:border-gold focus:bg-white/20"
      />
      <button type="submit" class="bg-clay text-white font-semibold text-sm px-5 py-2 rounded-full hover:bg-clay-dk transition-colors">
        Search
      </button>
    </form>
  </div>

  <script>
    document.getElementById('search-btn')?.addEventListener('click', () => {
      const overlay = document.getElementById('search-overlay');
      const input = document.getElementById('search-input') as HTMLInputElement;
      overlay?.classList.toggle('hidden');
      if (!overlay?.classList.contains('hidden')) input?.focus();
    });
  </script>
</header>
