---
import Logo from './Logo.astro';

const nav = [
  { label: 'Home',             href: '/' },
  { label: 'African Greys',   href: '/african-grey-parrot-for-sale/' },
  { label: 'Our Breeders',    href: '/trusted-african-grey-parrot-breeders/' },
  { label: 'Bird Reviews',    href: '/african-grey-reviews/' },
  { label: 'Live Shipping',   href: '/buy-african-grey-parrots-with-shipping/' },
  { label: 'Health Guarantee', href: '/african-greys-for-sale-with-health-guarantee/' },
  { label: 'Contact',          href: '/contact-us/' },
];

const current = Astro.url.pathname;
---

<header class="bg-green text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24">

      <!-- Left: Logo + Desktop search as a unit -->
      <div class="flex items-center gap-3 shrink-0">
        <Logo />
        <form action="/search/" method="get" class="hidden lg:flex gap-2">
          <input
            name="q"
            type="search"
            placeholder="Search…"
            class="w-20 bg-white/10 border border-white/30 text-white placeholder:text-white/50 rounded-full px-3 py-1.5 text-xs focus:outline-none focus:border-clay"
          />
          <button type="submit" class="bg-clay text-white text-xs font-semibold px-3 py-1.5 rounded-full hover:bg-clay-dk transition-colors">
            Go
          </button>
        </form>
      </div>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-5 text-sm font-sora font-medium">
        {nav.map(link => (
          <a
            href={link.href}
            class:list={[
              'transition-colors hover:text-clay',
              current === link.href ? 'text-clay underline underline-offset-4' : 'text-white/90'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Inquire Now CTA (desktop/tablet only) -->
      <a
        href="/contact-us/"
        class="hidden sm:inline-flex items-center gap-2 bg-clay text-white font-semibold text-sm px-5 py-2 rounded-full hover:bg-clay-dk transition-colors"
      >
        Inquire Now
      </a>

      <!-- Mobile search: centered between logo and hamburger -->
      <form action="/search/" method="get" class="flex lg:hidden flex-1 justify-center px-2">
        <input type="hidden" name="sitesearch" value="congoafricangreys.com" />
        <div class="flex items-center gap-1.5">
          <input
            name="q"
            type="search"
            placeholder="Search…"
            class="w-28 bg-white/10 border border-white/30 text-white placeholder:text-white/50 rounded-full px-3 py-1.5 text-xs focus:outline-none focus:border-clay"
          />
          <button type="submit" class="bg-clay text-white text-xs font-semibold px-3 py-1.5 rounded-full hover:bg-clay-dk transition-colors">
            Go
          </button>
        </div>
      </form>

      <!-- Mobile hamburger: fixed at right edge -->
      <details class="lg:hidden shrink-0 relative">
        <summary class="list-none cursor-pointer text-white/90 hover:text-clay p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </summary>
        <nav class="absolute right-0 top-10 bg-green border border-white/20 rounded-lg shadow-xl p-4 flex flex-col gap-3 min-w-56">
          {nav.map(link => link.href === '/contact-us/' ? (
            <a
              href={link.href}
              class="bg-clay text-white font-semibold text-sm px-4 py-2 rounded-full text-center hover:bg-clay-dk transition-colors"
            >
              {link.label}
            </a>
          ) : (
            <a href={link.href} class="text-white/90 hover:text-clay text-sm font-medium">
              {link.label}
            </a>
          ))}
        </nav>
      </details>

    </div>
  </div>

</header>
