---
/**
 * cag-blog-decision-tree — Modern decision card-grid.
 * Heading, then a responsive grid of branch cards: a clay "condition" pill
 * (the answer/scenario) over the recommendation text. No green header bar.
 * 1 column on mobile, 2 columns ≥560px. Accessible: heading + <ul>/<li>.
 * Locked palette only (clay #b04228 on light, cream/stone neutrals).
 *
 * Usage:
 *   <DecisionTree
 *     question="Which cage setup fits your Grey?"
 *     branches={[
 *       { answer: 'Congo + room to spare', result: 'Go 40"×30"×60" at 7/8"–1" spacing.' },
 *       { answer: 'Timneh African Grey',    result: 'Drop to 30"×20"×40" at 5/8"–3/4".' },
 *     ]}
 *   />
 */

export interface Branch {
  /** Short scenario / condition label, e.g. "Congo + room to spare" */
  answer: string;
  /** The resulting recommendation or next step */
  result: string;
}

export interface Props {
  /** The decision question — rendered as the configurable heading */
  question: string;
  /** Array of answer → result branches */
  branches: Branch[];
  /** Heading level — defaults to h3 */
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { question, branches, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<div class="cag-dtree">
  <Heading class="cag-dtree__q font-lora">{question}</Heading>
  <ul class="cag-dtree__grid" role="list">
    {branches.map((branch) => (
      <li class="cag-dtree__card font-sora">
        <span class="cag-dtree__cond">{branch.answer}</span>
        <p class="cag-dtree__rec">{branch.result}</p>
      </li>
    ))}
  </ul>
</div>

<style>
  .cag-dtree { margin: 1.75rem 0; }

  .cag-dtree__q {
    margin: 0 0 1rem;
    font-size: 1.15rem;
    font-weight: 700;
    color: #2d241c;
    line-height: 1.3;
  }

  .cag-dtree__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: .8rem;
  }

  @media (min-width: 560px) {
    .cag-dtree__grid { grid-template-columns: 1fr 1fr; }
  }

  .cag-dtree__card {
    position: relative;
    background: #fff;
    border: 1px solid #ece3da;
    border-radius: 14px;
    padding: 1.05rem 1.1rem 1.1rem;
    box-shadow: 0 1px 3px rgba(60, 30, 10, .05);
    transition: box-shadow .2s ease, transform .2s ease, border-color .2s ease;
  }

  .cag-dtree__card:hover {
    box-shadow: 0 10px 24px rgba(60, 30, 10, .09);
    transform: translateY(-2px);
    border-color: #e3cfc6;
  }

  .cag-dtree__cond {
    display: inline-block;
    font-weight: 600;
    font-size: .72rem;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #b04228;
    background: #fdeee9;
    border-radius: 999px;
    padding: .3rem .72rem;
    margin-bottom: .65rem;
  }

  .cag-dtree__rec {
    margin: 0;
    color: #4a4239;
    font-size: .95rem;
    line-height: 1.55;
  }
</style>
