---
/**
 * cag-blog-decision-tree — Vertical decision-tree block.
 * Renders a configurable heading, then a <ul> of branch rows.
 * Each row shows the answer label → clay arrow-right SVG → result text.
 * Arrow is an inline Feather-style chevron/arrow-right SVG.
 * Accessible: semantic <ul> with visible answer + result per <li>.
 *
 * Usage:
 *   <DecisionTree
 *     question="Is an African Grey parrot right for you?"
 *     branches={[
 *       { answer: 'Yes — I have 4+ hrs daily', result: 'A Congo Grey is a great fit.' },
 *       { answer: 'No — under 2 hrs daily',    result: 'Consider a less-demanding companion species first.' },
 *     ]}
 *   />
 */

export interface Branch {
  /** Short answer / condition label, e.g. "Yes", "No", "Sometimes" */
  answer: string;
  /** The resulting recommendation or next step */
  result: string;
}

export interface Props {
  /** The decision question — rendered as the configurable heading */
  question: string;
  /** Array of answer → result branches */
  branches: Branch[];
  /** Heading level — defaults to h3 */
  headingLevel?: 'h2' | 'h3' | 'h4';
}

const { question, branches, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<div class="cag-decision-tree">
  <Heading class="cag-decision-tree__question font-lora">{question}</Heading>
  <ul class="cag-decision-tree__list" role="list">
    {branches.map((branch) => (
      <li class="cag-decision-tree__item font-sora">
        <span class="cag-decision-tree__answer">{branch.answer}</span>
        <span class="cag-decision-tree__arrow" aria-hidden="true">
          <!-- Feather arrow-right icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </span>
        <span class="cag-decision-tree__result">{branch.result}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .cag-decision-tree {
    margin: 1.5rem 0;
    border: 1px solid var(--border, #ede5dc);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 10px rgba(60, 30, 10, .06);
  }

  .cag-decision-tree__question {
    margin: 0;
    padding: .75rem 1.25rem;
    background: #2D6A4F;
    color: #faf7f4;
    font-size: 1.05rem;
  }

  .cag-decision-tree__list {
    list-style: none;
    margin: 0;
    padding: .5rem 0;
  }

  .cag-decision-tree__item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .7rem 1.25rem;
    border-bottom: 1px solid var(--line, #ede5dc);
    font-size: .95rem;
    line-height: 1.5;
  }

  .cag-decision-tree__item:last-child {
    border-bottom: none;
  }

  .cag-decision-tree__answer {
    font-weight: 700;
    color: #3a2c22;
    white-space: nowrap;
    min-width: 0;
    flex-shrink: 0;
  }

  .cag-decision-tree__arrow {
    display: flex;
    align-items: center;
    color: #b04228;
    flex-shrink: 0;
  }

  .cag-decision-tree__result {
    color: #5a5248;
    flex: 1 1 0;
    min-width: 0;
  }

  @media (max-width: 480px) {
    .cag-decision-tree__item {
      flex-wrap: wrap;
      gap: .35rem;
    }
    .cag-decision-tree__arrow {
      display: none;
    }
    .cag-decision-tree__result {
      flex-basis: 100%;
      padding-left: .25rem;
    }
  }
</style>
