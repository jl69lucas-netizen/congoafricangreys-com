---
/**
 * cag-blog-sticky-cta — Fixed mobile-only clay CTA bar.
 * Shown ONLY on mobile (hidden at ≥768px via CSS).
 * The entire bar is a same-tab <a> link — clay pill feel.
 * Padding-bottom accounts for iOS safe-area (notch / home indicator).
 * z-index: 40 keeps it below the site header.
 *
 * Usage:
 *   <StickyCta />
 *   <StickyCta label="Reserve your African Grey" href="/contact-us/" />
 */

export interface Props {
  /** Button / bar label — defaults to 'See available African Greys' */
  label?: string;
  /** Destination URL — defaults to '/available/' */
  href?: string;
}

const {
  label = 'See available African Greys',
  href  = '/available/',
} = Astro.props;
---

<a href={href} class="cag-sticky-cta font-sora" aria-label={label}>
  <span class="cag-sticky-cta__label">{label}</span>
  <!-- Feather chevron-right -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <polyline points="9 18 15 12 9 6"></polyline>
  </svg>
</a>

<style>
  .cag-sticky-cta {
    /* Mobile-only fixed bar */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;

    background: #e8604c;
    color: #fff;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .01em;

    padding: .9rem 1.5rem;
    /* iOS safe area — home indicator / notch */
    padding-bottom: calc(.9rem + env(safe-area-inset-bottom));

    /* Clay pill feel on the top corners */
    border-radius: 20px 20px 0 0;

    /* Active / press feedback */
    transition: background 0.15s;
  }

  .cag-sticky-cta:active {
    background: #c94d3a;
  }

  .cag-sticky-cta__label {
    line-height: 1;
  }

  /* Hide on tablet and desktop */
  @media (min-width: 768px) {
    .cag-sticky-cta {
      display: none;
    }
  }
</style>
