---
/**
 * FaqAccordion — questions list, native <details>.
 *
 * @prop variant — 'classic' (split heading + list) | 'editorial' (2-column compact) | 'dark' (stacked w/ badge numbers)
 */
export interface FaqItem { q: string; a: string; }
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  title?: string;
  items?: FaqItem[];
}
const {
  variant = 'classic',
  title = 'Common questions before adopting an African Grey',
  items = [
    { q: 'How much does a Congo African Grey cost?', a: 'Our hand-raised Congo Greys are $1,700–$2,500 for individual birds. Our Timneh African Greys are $1,500–$1,600. All prices include CITES paperwork, DNA-sexing, vet-clearance, and our health guarantee.' },
    { q: 'Do you ship nationwide?',                    a: "Yes — Delta Cargo's climate-controlled program reaches 48 states from Midland International. Shipping starts at $185. We never use ground transport." },
    { q: 'Are the birds DNA-sexed?',                  a: 'Every chick is DNA-sexed by Avian Biotech before listing. You receive the lab certificate with your bird.' },
    { q: "What's the deposit, and is it refundable?", a: '$200 holding deposit, applied to the final price. Refundable any time before the bird is shipped.' },
    { q: 'Can I visit the aviary?',                    a: "Yes — by appointment. We're in Midland, TX, twenty minutes from the airport. Most buyers do a video tour first." },
  ],
} = Astro.props;
---

<style>
  details[open] .cag-faq-icon { transform: rotate(45deg); }
  .cag-faq-icon { transition: transform .25s cubic-bezier(.4,0,.2,1); }
  details > summary { list-style: none; cursor: pointer; }
  details > summary::-webkit-details-marker { display: none; }
</style>

{variant === 'classic' && (
  <div class="grid md:grid-cols-[1fr_2fr] gap-10">
    <div>
      <div class="cag-tag text-clay">QUESTIONS BEFORE ADOPTING</div>
      <h3 class="font-display font-bold text-3xl mt-3 leading-tight">{title}</h3>
      <p class="text-mid mt-4 text-[14px] leading-relaxed">Can't find what you need? Email <a class="text-clay underline">teri@congoafricangreys.com</a> — read personally, replied within 24h.</p>
    </div>
    <div class="space-y-3">
      {items.map((it, i) => (
        <details class="bg-white rounded-2xl border border-line p-5" open={i===0}>
          <summary class="flex items-center justify-between gap-4">
            <span class="font-display font-bold text-[17px]">{it.q}</span>
            <span class="cag-faq-icon text-clay text-2xl font-light shrink-0">+</span>
          </summary>
          <div class="mt-3 text-mid text-[14px] leading-relaxed">{it.a}</div>
        </details>
      ))}
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="bg-warm rounded-3xl border border-line p-10">
    <h3 class="font-display font-bold text-3xl mb-2 text-center">{title}</h3>
    <p class="text-mid text-center mb-8 max-w-2xl mx-auto">Quick answers — tap any question to expand.</p>
    <div class="grid md:grid-cols-2 gap-3">
      {items.map(it => (
        <details class="bg-white rounded-xl border border-line px-5 py-4">
          <summary class="flex items-center justify-between font-display font-bold text-[15px]">
            {it.q} <span class="cag-faq-icon text-clay">+</span>
          </summary>
          <p class="text-[13px] text-mid mt-2">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-10 text-white">
    <div class="grid md:grid-cols-[1fr_2fr] gap-10">
      <div>
        <div class="cag-tag text-clay">FAQ · 30 SECONDS EACH</div>
        <h3 class="font-display font-bold text-3xl mt-3 leading-tight">{title}</h3>
        <p class="text-white/60 mt-4 text-[14px]">If your seller can't answer these, walk away.</p>
      </div>
      <div>
        {items.map((it, i) => (
          <details class="border-b border-white/10 py-4" open={i===0}>
            <summary class="flex items-center gap-4">
              <span class="font-display text-clay font-bold text-2xl shrink-0">{String(i+1).padStart(2,'0')}</span>
              <span class="font-display font-bold text-[17px] flex-1">{it.q}</span>
              <span class="cag-faq-icon text-clay text-2xl shrink-0">+</span>
            </summary>
            <p class="text-white/70 text-[14px] mt-3 ml-14">{it.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
)}
