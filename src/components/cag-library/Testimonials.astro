---
/**
 * Testimonials — buyer-review block.
 *
 * @prop variant — 'grid' (3-up cards) | 'mosaic' (featured + supporting) | 'feature' (dark single review)
 */
export interface Testimonial {
  rating?: number;        // 1–5 stars (defaults to 5)
  headline?: string;
  quote: string;
  name: string;
  location?: string;
  meta?: string;          // "Adopted Mango · March 2025"
  avatarSrc?: string;
}
export interface Props {
  variant?: 'grid' | 'mosaic' | 'feature';
  testimonials?: Testimonial[];
}
const {
  variant = 'grid',
  testimonials = [
    {
      headline: "Bella arrived already saying her name.",
      quote: "Teri sent us weekly videos of our girl for the six weeks leading up to pickup. By the time we met her in person we already knew her quirks. Couldn't recommend more.",
      name: 'Sarah & Tom', location: 'Austin, TX', meta: 'Adopted Mango · March 2025',
    },
    {
      headline: "After three breeder scams, finding CAG was a relief.",
      quote: "USDA license verifiable, CITES papers in hand at pickup, an avian-vet exam before shipping. This is what real captive breeding looks like.",
      name: 'Devin Hart', location: 'Denver, CO', meta: 'Adopted Pepper · July 2024',
    },
    {
      headline: "They're still on the phone with us a year later.",
      quote: "Six months in, our girl had a feather-pluck issue and Teri spent forty minutes on the phone walking us through diet. That kind of support is worth more than the bird's price.",
      name: 'The Park Family', location: 'Brooklyn, NY', meta: 'Adopted Olive · Nov 2023',
    },
  ],
} = Astro.props;

const stars = (n: number = 5) => '⭐'.repeat(n);
---

<style>
@media (max-width: 1024px) {
  .testimonials-grid {
    display: flex !important;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding: 0 20px 16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .testimonials-grid::-webkit-scrollbar { display: none; }
  .testimonials-grid > * {
    flex: 0 0 85vw;
    max-width: 340px;
    scroll-snap-align: start;
  }
}
</style>

{variant === 'grid' && (
  <div class="testimonials-grid grid md:grid-cols-3 gap-5">
    {testimonials.map(t => (
      <article class="bg-white border border-line rounded-3xl cag-warm-shadow p-5 flex flex-col">
        <div class="text-clay text-base">{stars(t.rating)}</div>
        {t.headline && <h4 class="font-display font-semibold text-[15px] mt-2 leading-snug">"{t.headline}"</h4>}
        <p class="text-mid text-[13px] mt-2 leading-relaxed flex-1">{t.quote}</p>
        <div class="mt-4 pt-4 border-t border-line flex items-center gap-3">
          {t.avatarSrc
            ? <img src={t.avatarSrc} alt={t.name} loading="lazy" class="w-12 h-12 rounded-full object-cover flex-shrink-0" />
            : <div class="w-12 h-12 rounded-full bg-clay-50 grid place-items-center text-clay text-xl flex-shrink-0">📷</div>}
          <div>
            <div class="font-display font-semibold text-[14px]">{t.name}{t.location && `, ${t.location}`}</div>
            {t.meta && <div class="text-[12px] text-mid">{t.meta}</div>}
          </div>
        </div>
      </article>
    ))}
  </div>
)}

{variant === 'mosaic' && (
  <div class="grid md:grid-cols-3 gap-5">
    <article class="md:col-span-2 md:row-span-2 bg-clay rounded-3xl text-white p-10 flex flex-col justify-between relative overflow-hidden">
      <div class="absolute -right-12 -top-12 text-[280px] opacity-10 leading-none">"</div>
      <div class="relative">
        <div class="text-white text-2xl">{stars(testimonials[0]?.rating)}</div>
        <blockquote class="font-display text-lg md:text-3xl mt-6 leading-[1.15]">"{testimonials[0]?.quote}"</blockquote>
      </div>
      <div class="relative mt-8 pt-8 border-t border-white/20 flex items-center gap-4">
        {testimonials[0]?.avatarSrc
          ? <img src={testimonials[0].avatarSrc} alt={testimonials[0].name} class="w-16 h-16 rounded-full object-cover" />
          : <div class="w-16 h-16 rounded-full bg-white/10 grid place-items-center text-2xl">📷</div>}
        <div>
          <div class="font-display font-bold text-xl">{testimonials[0]?.name}</div>
          <div class="text-white/80 text-[14px]">{testimonials[0]?.location} · {testimonials[0]?.meta}</div>
        </div>
      </div>
    </article>
    {testimonials.slice(1, 3).map(t => (
      <article class="bg-white border border-line rounded-3xl cag-warm-shadow p-6">
        <div class="text-clay">{stars(t.rating)}</div>
        <p class="font-display text-[16px] mt-3 leading-snug">"{t.headline || t.quote.slice(0, 80)}"</p>
        <div class="mt-4 text-[13px] text-mid font-semibold">{t.name} · {t.location}</div>
      </article>
    ))}
  </div>
)}

{variant === 'feature' && (
  <div class="bg-panel rounded-3xl p-6 md:p-12 text-white">
    <div class="grid md:grid-cols-[1fr_2fr] gap-10 items-center">
      <div class="relative">
        {testimonials[0]?.avatarSrc
          ? <img src={testimonials[0].avatarSrc} alt={testimonials[0].name} loading="lazy" class="w-full aspect-square object-cover rounded-3xl md:max-w-[300px]" />
          : <div class="w-full aspect-square rounded-3xl bg-white/5 border border-white/10 grid place-items-center text-6xl md:max-w-[300px]">📷</div>}
        <div class="absolute -top-3 -left-3 bg-clay rounded-full px-3 py-1.5 cag-tag text-white cag-glow">VERIFIED</div>
      </div>
      <div>
        <div class="text-clay text-2xl">{stars(testimonials[0]?.rating)}</div>
        <blockquote class="font-display text-base md:text-xl mt-5 leading-snug">"{testimonials[0]?.quote}"</blockquote>
        <div class="mt-8 flex items-center justify-between flex-wrap gap-4">
          <div>
            <div class="font-display font-bold text-xl">{testimonials[0]?.name}</div>
            <div class="text-white/60 text-[14px]">{testimonials[0]?.location} · {testimonials[0]?.meta}</div>
          </div>
          <div class="flex gap-2">
            <button class="w-10 h-10 rounded-full bg-white/10 hover:bg-clay grid place-items-center transition">←</button>
            <button class="w-10 h-10 rounded-full bg-white/10 hover:bg-clay grid place-items-center transition">→</button>
          </div>
        </div>
      </div>
    </div>
  </div>
)}
