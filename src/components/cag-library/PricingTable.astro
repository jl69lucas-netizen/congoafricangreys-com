---
/**
 * PricingTable — subspecies / pricing comparison.
 *
 * @prop variant — 'classic' (table with clay header) | 'tiers' (3-up cards) | 'matrix' (outlined matrix with badge)
 */
export interface Row {
  breed: string;
  weight?: string;
  fit?: string;
  ability?: string;
  price: string;
  topPick?: boolean;
}
export interface Props {
  variant?: 'classic' | 'tiers' | 'matrix';
  rows?: Row[];
  note?: string;
}
const {
  variant = 'classic',
  note = "Anyone listing a Congo Grey under $1,500 is either selling a wild-caught bird, a sick bird, or no bird at all.",
  rows = [
    { breed: 'CONGO GREY',         weight: '400–490 g',  fit: 'Quiet apartments / experienced owners', ability: 'Exceptional · 500+ words', price: '$2,200–$2,800', topPick: true },
    { breed: 'TIMNEH GREY',        weight: '275–375 g',  fit: 'Active families / first-time grey owners', ability: 'Excellent · 300+ words', price: '$1,800–$2,400' },
    { breed: 'CONGO · TAME ADULT', weight: '400–490 g',  fit: 'Calm households / no children', ability: 'Pre-trained vocabulary', price: '$2,500–$3,500' },
    { breed: 'WEANED CHICK',       weight: 'Growing · 320 g+', fit: 'Bond-from-day-one buyers', ability: 'Learning · imprinted on humans', price: '$1,500–$2,200' },
  ],
} = Astro.props;
---

{variant === 'classic' && (
  <div>
    <div class="bg-white rounded-3xl border border-line cag-warm-shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-clay text-white">
            <th class="p-5 text-left cag-tag">Subspecies</th>
            <th class="p-5 text-left cag-tag">Adult weight</th>
            <th class="p-5 text-left cag-tag">Best fit / lifestyle</th>
            <th class="p-5 text-left cag-tag">Talking ability</th>
            <th class="p-5 text-right cag-tag">Price</th>
          </tr>
        </thead>
        <tbody class="text-[14px]">
          {rows.map((r, i) => (
            <tr class={`border-b border-line ${i % 2 === 1 ? 'bg-warm' : ''}`}>
              <td class="p-5"><span class="cag-tag text-clay">{r.breed}</span></td>
              <td class="p-5 text-mid">{r.weight}</td>
              <td class="p-5 text-mid">{r.fit}</td>
              <td class="p-5 text-mid">{r.ability}</td>
              <td class="p-5 text-right font-display font-bold text-clay">{r.price}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {note && (
      <div class="bg-warm rounded-2xl border-l-4 border-clay p-6 mt-5">
        <div class="cag-tag text-clay">EXPERT TAKE · TERI BENJAMIN</div>
        <p class="text-ink mt-2 text-[15px] leading-relaxed">"{note}"</p>
      </div>
    )}
  </div>
)}

<style>
@media (max-width: 1024px) {
  .pricing-track {
    display: flex !important;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding: 0 20px 16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .pricing-track::-webkit-scrollbar { display: none; }
  .pricing-track > * {
    flex: 0 0 80vw;
    max-width: 300px;
    scroll-snap-align: start;
  }
}
</style>

{variant === 'tiers' && (
  <div class="pricing-track grid md:grid-cols-3 gap-5">
    {rows.slice(0,3).map((r, i) => {
      const isPick = r.topPick || i === 1;
      return isPick
        ? (
          <article class="bg-clay rounded-3xl text-white p-7 relative cag-warm-shadow-lg -translate-y-2">
            <span class="absolute -top-3 right-6 bg-white text-clay cag-tag rounded-full px-3 py-1.5 cag-warm-shadow">MOST RESERVED</span>
            <div class="cag-tag text-white/80">{r.breed}</div>
            <div class="font-display font-bold text-4xl mt-3">{r.price}</div>
            <div class="text-[13px] text-white/80">+ $200 holding deposit</div>
            <div class="mt-5 pt-5 border-t border-white/20 space-y-2 text-[14px]">
              {r.weight && <div class="flex items-start gap-2"><span>✓</span><span>{r.weight} adult</span></div>}
              {r.fit && <div class="flex items-start gap-2"><span>✓</span><span>{r.fit}</span></div>}
              {r.ability && <div class="flex items-start gap-2"><span>✓</span><span>{r.ability}</span></div>}
              <div class="flex items-start gap-2"><span>✓</span><span>3-year written health guarantee</span></div>
            </div>
            <a class="mt-6 block text-center bg-white text-clay hover:bg-cream rounded-full px-5 py-3 font-semibold text-[14px]">View {r.breed.toLowerCase()}s</a>
          </article>
        )
        : (
          <article class="bg-white rounded-3xl border border-line cag-warm-shadow p-7">
            <div class="cag-tag text-forest">{r.breed}</div>
            <div class="font-display font-bold text-4xl mt-3 text-clay">{r.price}</div>
            <div class="text-[13px] text-mid">+ $200 holding deposit</div>
            <div class="mt-5 pt-5 border-t border-line space-y-2 text-[14px] text-mid">
              {r.weight && <div class="flex items-start gap-2"><span class="text-forest">✓</span><span>{r.weight} adult</span></div>}
              {r.fit && <div class="flex items-start gap-2"><span class="text-forest">✓</span><span>{r.fit}</span></div>}
              {r.ability && <div class="flex items-start gap-2"><span class="text-forest">✓</span><span>{r.ability}</span></div>}
              <div class="flex items-start gap-2"><span class="text-forest">✓</span><span>CITES + DNA + vet docs</span></div>
            </div>
            <a class="mt-6 block text-center border-2 border-clay text-clay hover:bg-clay hover:text-white transition rounded-full px-5 py-3 font-semibold text-[14px]">View {r.breed.toLowerCase()}s</a>
          </article>
        );
    })}
  </div>
)}

{variant === 'matrix' && (
  <div class="bg-warm rounded-3xl border-2 border-clay p-2 cag-warm-shadow">
    <div class="bg-white rounded-2xl overflow-hidden">
      <div class="bg-clay text-white p-8 text-center">
        <div class="font-display font-bold text-3xl">African Grey Subspecies Matrix</div>
        <div class="text-white/80 text-[14px] mt-1">Which Grey fits your home, your noise level, your patience?</div>
      </div>
      <table class="w-full text-[14px]">
        <thead class="bg-cream">
          <tr>
            <th class="p-4 text-left font-display font-bold">Breed</th>
            <th class="p-4 text-left font-display font-bold">Price band</th>
            <th class="p-4 text-left font-display font-bold">Best fit</th>
            <th class="p-4 text-left font-display font-bold">Talking</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(r => (
            <tr class={`border-t border-line ${r.topPick ? 'bg-clay-50' : ''}`}>
              <td class="p-4">
                <div class="font-display font-bold">{r.breed}</div>
                {r.topPick && <span class="cag-tag bg-clay text-white rounded-full px-2 py-0.5 mt-1 inline-block">TOP PICK</span>}
              </td>
              <td class="p-4 text-mid">{r.price}</td>
              <td class="p-4 text-mid">{r.fit}</td>
              <td class="p-4 text-mid">{r.ability}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
)}
