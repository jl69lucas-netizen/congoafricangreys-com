---
/**
 * ContactForm — buyer inquiry form.
 *
 * @prop variant — 'classic' (info card + form) | 'application' (multi-step style) | 'sidebar' (bird-page sidebar)
 * @prop action  — form POST endpoint, default '/api/inquiry'
 */
export interface Props {
  variant?: 'classic' | 'application' | 'sidebar';
  action?: string;
  birdName?: string;       // sidebar variant
  birdPrice?: number;
  birdDeposit?: number;
}
const {
  variant = 'classic',
  action = '/api/inquiry',
  birdName = 'Amie',
  birdPrice = 2700,
  birdDeposit = 200,
} = Astro.props;
---

{variant === 'classic' && (
  <div class="grid md:grid-cols-[1fr_1.3fr] gap-8 items-start">
    <aside class="bg-white border border-line rounded-3xl cag-warm-shadow overflow-hidden">
      <div class="bg-forest text-white p-6">
        <div class="cag-tag opacity-80">REACH MARK &amp; TERI DIRECTLY</div>
        <div class="font-display font-bold text-2xl mt-1">We read every inquiry personally.</div>
      </div>
      <div class="p-6 space-y-4">
        <div class="flex items-start gap-3">
          <span class="text-2xl">📞</span>
          <div>
            <div class="cag-tag text-mid">PHONE</div>
            <a href="tel:+14325550119" class="font-display font-bold text-lg text-ink hover:text-clay">(432) 555-0119</a>
            <div class="text-[12px] text-mute">Mon–Sat · 9 AM–6 PM CT</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">✉️</span>
          <div>
            <div class="cag-tag text-mid">EMAIL</div>
            <a href="mailto:teri@congoafricangreys.com" class="font-display font-bold text-lg text-ink hover:text-clay break-all">teri@congoafricangreys.com</a>
            <div class="text-[12px] text-mute">Reply within 24–48 hours</div>
          </div>
        </div>
        <div class="bg-forest-lt rounded-xl p-4 mt-2">
          <div class="cag-tag text-forest">24h REPLY GUARANTEE</div>
          <div class="text-[13px] text-mid mt-1">If we don't reply within a business day, we'll knock $50 off your bird's price.</div>
        </div>
      </div>
    </aside>

    <form action={action} method="post" class="bg-white border border-line rounded-3xl cag-warm-shadow p-8">
      <h3 class="font-display font-bold text-2xl">Tell us about your home</h3>
      <p class="text-mid text-[14px] mt-1">The more you share, the better we can match you with the right bird.</p>
      <div class="mt-6 grid grid-cols-2 gap-4">
        <label class="block">
          <span class="cag-tag text-ink">YOUR NAME</span>
          <input type="text" name="name" required class="mt-1.5 w-full bg-warm border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
        </label>
        <label class="block">
          <span class="cag-tag text-ink">EMAIL</span>
          <input type="email" name="email" required class="mt-1.5 w-full bg-warm border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
        </label>
        <label class="block">
          <span class="cag-tag text-ink">PHONE (OPTIONAL)</span>
          <input type="tel" name="phone" class="mt-1.5 w-full bg-warm border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
        </label>
        <label class="block">
          <span class="cag-tag text-ink">STATE</span>
          <input type="text" name="state" placeholder="TX" class="mt-1.5 w-full bg-warm border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
        </label>
      </div>

      <div class="mt-5">
        <span class="cag-tag text-ink">WHICH GREY ARE YOU INTERESTED IN?</span>
        <div class="mt-2 flex flex-wrap gap-2">
          {['Congo Grey','Timneh Grey','Tame adult','Not sure yet'].map(opt => (
            <label class="cursor-pointer">
              <input type="radio" name="bird" value={opt} class="sr-only peer"/>
              <span class="block px-4 py-2 rounded-full bg-warm border-[1.5px] border-line text-[14px] peer-checked:bg-clay-50 peer-checked:border-clay peer-checked:text-clay-dk peer-checked:font-semibold transition">{opt}</span>
            </label>
          ))}
        </div>
      </div>

      <label class="block mt-5">
        <span class="cag-tag text-ink">TELL US ABOUT YOUR HOME</span>
        <textarea name="message" rows="4" class="mt-1.5 w-full bg-warm border-[1.5px] border-line rounded-xl px-4 py-3 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition resize-y" placeholder="Household members, other pets, schedule, what drew you to greys…"></textarea>
      </label>

      {/* honeypot — bots fill this, humans don't see it */}
      <input type="text" name="company" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true"/>

      <button type="submit" class="mt-6 w-full bg-clay hover:bg-clay-dk transition text-white rounded-xl px-5 py-4 font-semibold text-[15px] cag-glow">Send inquiry →</button>
      <p class="text-[11px] text-mute mt-3 text-center">By submitting you agree to our <a href="/privacy" class="underline">privacy policy</a>. We read every inquiry. No bots, no autoresponders.</p>
    </form>
  </div>
)}

{variant === 'sidebar' && (
  <form action={action} method="post" class="bg-warm border border-line rounded-3xl cag-warm-shadow p-7 md:sticky md:top-24">
    <div class="cag-tag text-clay">INTERESTED IN {birdName.toUpperCase()}?</div>
    <div class="font-display font-bold text-2xl mt-2 leading-tight">Ask about reserving her.</div>
    <div class="mt-5 pb-5 border-b border-line">
      <div class="flex items-baseline gap-2">
        <span class="font-display font-bold text-3xl text-clay">${birdPrice.toLocaleString()}</span>
        <span class="text-[12px] text-mute">+ ${birdDeposit} deposit</span>
      </div>
      <div class="text-[12px] text-forest mt-1">✓ Ships to your state · ✓ Health guarantee</div>
    </div>
    <input type="hidden" name="bird" value={birdName}/>
    <div class="mt-5 space-y-3">
      <input type="text" name="name" required placeholder="Your name" class="w-full bg-white border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
      <input type="email" name="email" required placeholder="Email address" class="w-full bg-white border-[1.5px] border-line rounded-xl px-4 py-2.5 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition"/>
      <textarea name="message" rows="3" placeholder={`Any questions about ${birdName}?`} class="w-full bg-white border-[1.5px] border-line rounded-xl px-4 py-3 outline-none focus:border-clay focus:ring-4 focus:ring-clay/15 transition resize-none"></textarea>
    </div>
    <input type="text" name="company" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true"/>
    <button type="submit" class="mt-4 w-full bg-clay hover:bg-clay-dk transition text-white rounded-xl px-5 py-3.5 font-semibold cag-glow">Inquire about {birdName} →</button>
    <div class="mt-4 pt-4 border-t border-line flex items-center justify-between text-[12px] text-mid">
      <span class="flex items-center gap-1.5">📞 (432) 555-0119</span>
      <span class="flex items-center gap-1.5">🕐 Replies within 24h</span>
    </div>
  </form>
)}

{variant === 'application' && (
  <form action={action} method="post" class="bg-white border border-line rounded-3xl cag-warm-shadow p-10">
    <div class="flex items-center justify-between mb-2">
      <div>
        <div class="cag-tag text-clay">STEP 2 OF 3</div>
        <h3 class="font-display font-bold text-2xl mt-1">About your future Grey</h3>
      </div>
      <div class="text-[13px] text-mid">Saves automatically · ~3 min total</div>
    </div>
    <div class="mt-4 flex gap-2 mb-8">
      <div class="flex-1 h-1.5 bg-clay rounded-full"></div>
      <div class="flex-1 h-1.5 bg-clay rounded-full"></div>
      <div class="flex-1 h-1.5 bg-line rounded-full"></div>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <label class="block">
          <span class="cag-tag text-ink">WHICH SUBSPECIES INTERESTS YOU?</span>
          <div class="mt-3 space-y-2">
            {[
              { v: 'congo',   t: 'Congo African Grey',  s: '400–490g · iconic mimicry · $1,700–$2,500' },
              { v: 'timneh',  t: 'Timneh African Grey', s: '275–375g · gentle · $1,500–$1,600' },
              { v: 'help',    t: "I'd like a recommendation", s: "We'll suggest based on your home" },
            ].map(o => (
              <label class="block cursor-pointer">
                <input type="radio" name="subspecies" value={o.v} class="sr-only peer"/>
                <div class="border-[1.5px] border-line rounded-xl p-4 peer-checked:border-clay peer-checked:bg-clay-50 transition">
                  <div class="font-display font-bold">{o.t}</div>
                  <div class="text-[12px] text-mid">{o.s}</div>
                </div>
              </label>
            ))}
          </div>
        </label>
      </div>
      <div>
        <label class="block">
          <span class="cag-tag text-ink">TIMEFRAME</span>
          <div class="mt-3 grid grid-cols-2 gap-2">
            {['Within 1 month','1–3 months','3–6 months','Just researching'].map(t => (
              <label class="cursor-pointer">
                <input type="radio" name="timeframe" value={t} class="sr-only peer"/>
                <div class="px-4 py-3 text-center border-[1.5px] border-line rounded-xl peer-checked:bg-clay-50 peer-checked:border-clay peer-checked:font-semibold text-[14px]">{t}</div>
              </label>
            ))}
          </div>
        </label>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-line flex items-center justify-between">
      <button type="button" class="text-mid hover:text-ink font-semibold text-[14px]">← Back</button>
      <button type="submit" class="bg-clay hover:bg-clay-dk transition text-white rounded-full px-6 py-3 font-semibold text-[14px] cag-glow">Continue → Step 3</button>
    </div>
  </form>
)}
