---
/**
 * cag-hero-v3:b — "Authority Green"
 * Source design: UNIQUE CAGs NEW COMPONENTS.zip → standalone/Hero B - Authority Green.html
 * Ported to the site's Tailwind tokens. Trust-first forest-green hero with a circular
 * framed bird photo, ring accent, floating availability pill, eyebrow + trust pills.
 * Content corrected to contract: C.A.Gs voice · CITES Appendix I · real photo · no phone.
 */
interface Props {
  availableCount?: number;
}
const { availableCount = 8 } = Astro.props;

const heroImg = "/african-grey-parrot-breeder-midland-tx-hero.webp";
const heroAlt =
  "Mark and Teri Benjamin's captive-bred Congo African Grey parrots photographed inside the C.A.Gs family aviary in Midland, Texas, showing the signature silver-scalloped grey plumage and bright red tail feathers of a healthy, hand-raised, DNA-sexed African Grey parrot that leaves with full CITES Appendix I documentation and an avian-veterinarian health certificate.";

const pills = [
  "USDA Licensed",
  "CITES Appendix I",
  "DNA Sexed",
  "10+ Year Support",
];
---

<section class="hero-v3-b relative overflow-hidden bg-green text-white">
  <!-- warm radial glow -->
  <div
    class="pointer-events-none absolute inset-0 opacity-60"
    style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"
  >
  </div>

  <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
    <div class="grid items-center gap-10 py-8 md:grid-cols-2 md:gap-8 md:py-12 lg:py-12">

      <!-- COPY -->
      <div class="order-2 text-center md:order-1 md:text-left">
        <span
          class="font-sora text-[10px] font-medium tracking-[0.12em] text-white/60 md:text-[11px]"
        >
          C.A.Gs &middot; Midland, Texas &middot; Family Aviary Since 2014
        </span>

        <h1
          class="font-lora mt-4 text-3xl font-bold leading-[1.08] sm:text-4xl md:text-[2.25rem] lg:text-[2.5rem] md:leading-[1.1]"
        >
          African Grey Parrot Breeder You Can <span class="text-clay">Trust</span>
        </h1>

        <p
          class="font-sora mx-auto mt-3 max-w-xl text-[15px] leading-relaxed text-white/80 md:mx-0 md:text-base"
        >
          At C.A.Gs, Mark &amp; Teri Benjamin have hand-raised captive-bred Congo and
          Timneh African Greys since 2014. Every bird is DNA-sexed, avian-vet certified,
          and placed with full CITES Appendix I documentation — never wild-caught, always
          with lifetime breeder support.
        </p>

        <div class="mt-5 flex flex-wrap justify-center gap-3 md:justify-start">
          <a
            href="#available-birds"
            class="font-sora rounded-full bg-clay px-8 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk"
          >
            View Available Greys →
          </a>
          <a
            href="#contact"
            class="font-sora rounded-full border-2 border-white/60 px-8 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green"
          >
            Reserve Yours Now →
          </a>
        </div>

        <ul
          class="mt-5 flex flex-wrap justify-center gap-x-5 gap-y-2.5 md:flex-nowrap md:justify-start"
          aria-label="Breeder credentials"
        >
          {pills.map((p) => (
            <li class="font-sora flex items-center gap-2 text-[13px] text-white/85 whitespace-nowrap">
              <span
                class="flex h-4 w-4 items-center justify-center rounded-full bg-clay text-[10px] font-bold text-white"
                aria-hidden="true"
              >✓</span>
              {p}
            </li>
          ))}
        </ul>
      </div>

      <!-- CIRCULAR IMAGE STAGE -->
      <div class="order-1 flex justify-center md:order-2 md:justify-end">
        <div class="relative">
          <div
            class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5"
            aria-hidden="true"
          >
          </div>
          <div
            class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]"
            style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);"
          >
            <img
              src={heroImg}
              alt={heroAlt}
              width="400"
              height="300"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="h-auto w-full object-contain"
            />
          </div>
          <span
            class="font-sora absolute -bottom-2 left-1/2 flex -translate-x-1/2 items-center gap-2 whitespace-nowrap rounded-full bg-white px-4 py-2 text-[13px] font-semibold text-green shadow-lg md:bottom-4 md:left-auto md:right-0 md:translate-x-0"
            style="box-shadow: 0 10px 30px rgba(60,30,10,0.22);"
          >
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-clay opacity-60"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-clay"></span>
            </span>
            {availableCount} Birds Available Now
          </span>
        </div>
      </div>

    </div>
  </div>
</section>
