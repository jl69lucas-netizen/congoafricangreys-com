---
// cag-newsletter (NEW CAG COMPONENTS · Component 7) — 3 variants, now copy-driven.
//   'top'    — light banner, headline + inline email (1100px)
//   'middle' — dark split: bird photo + email form (1100px)
//   'bottom' — slim centered footer bar (760px)
// No fabricated subscriber counts (no-fabrication rule). action defaults to '#'.
// Every text/image is a prop so each placement is unique to its page (defaults
// match the homepage so existing usage is unchanged).
export interface Props {
  variant?: 'top' | 'middle' | 'bottom';
  action?: string;
  heading?: string;
  sub?: string;
  cta?: string;
  eyebrow?: string;     // middle: pill label
  img?: string;         // middle: photo src
  imgAlt?: string;
  imgCaption?: string;  // middle: caption over the photo
  note?: string;        // middle: small print under the form
  bottomText?: string;  // bottom: lead line
}
const {
  variant = 'middle',
  action = '#',
  heading,
  sub,
  cta,
  eyebrow = 'New clutch alerts',
  img = '/amie-congo-african-grey-female-3-months.webp',
  imgAlt = 'Hand-raised Congo African Grey baby joining a family soon at C.A.Gs',
  imgCaption = 'Amie, 3 months, joining a family soon',
  note = 'We email about new African Grey clutches only, unsubscribe in one click.',
  bottomText = 'New African Greys available, get notified first.',
} = Astro.props;

const topHeading = heading ?? 'Be First to Know When New African Grey Babies Are Available';
const topSub = sub ?? "African Grey clutches are rare. Join our waitlist and hear about new Congo and Timneh chicks before they're listed publicly.";
const midHeading = heading ?? 'Parrots Sell Fast. Be First.';
const midSub = sub ?? 'Sign up for African Grey availability updates and reserve a hand-fed Congo or Timneh chick before we list it publicly.';
const topCta = cta ?? 'Join waitlist';
const midCta = cta ?? 'Notify me of new clutches';
const botCta = cta ?? 'Notify me';
---

{variant === 'top' && (
  <div class="px-4 py-9" style="background:linear-gradient(90deg,#f0f9f4,#faf7f4);border-left:4px solid #2D6A4F;">
    <div class="mx-auto grid items-center gap-8 md:grid-cols-[1.1fr_1fr]" style="max-width:1100px;">
      <div>
        <h2 class="font-lora text-2xl font-bold text-logo-dark mb-1.5">{topHeading}</h2>
        <p class="font-sora text-sm text-stone-600 m-0">{topSub}</p>
      </div>
      <form action={action} method="POST" class="flex flex-col gap-2">
        <input type="hidden" name="_gotcha" style="display:none" />
        <div class="flex flex-col gap-2.5 sm:flex-row">
          <input type="email" name="email" required placeholder="your@email.com"
            class="flex-1 rounded-[10px] border border-black/10 bg-warm-white px-4 py-3 font-sora text-sm text-ink outline-none transition focus:border-clay focus:ring-4 focus:ring-clay/15" />
          <button type="submit" class="shrink-0 rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk" style="box-shadow:0 4px 14px rgba(232,96,76,0.25);">{topCta}</button>
        </div>
        <p class="font-sora text-xs text-stone-600 m-0"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> No spam. Unsubscribe anytime.</p>
      </form>
    </div>
  </div>
)}

{variant === 'middle' && (
  <div class="px-4 py-14" style="background:#241c18;">
    <div class="mx-auto grid items-center gap-10 md:grid-cols-[1fr_1.1fr]" style="max-width:1100px;">
      <div class="relative h-[300px] overflow-hidden rounded-2xl md:h-[320px]" style="background:linear-gradient(160deg,#3a2a22,#2a1f1a);">
        <img src={img} alt={imgAlt}
          width="520" height="320" loading="lazy" decoding="async"
          class="h-full w-full object-cover opacity-90" />
        <div class="absolute inset-0" style="background:linear-gradient(180deg,transparent 40%,rgba(28,26,24,0.6));"></div>
        <div class="absolute bottom-4 left-4 font-sora text-[13px] font-semibold text-white">{imgCaption}</div>
      </div>
      <div>
        <span class="mb-3.5 inline-flex items-center gap-1.5 rounded-full bg-clay/15 px-3 py-1 font-sora text-[11px] font-bold uppercase tracking-[0.12em]" style="color:#f08070;">
          <img src="/emoji/cag-congo.png" alt="" width="14" height="14" style="width:14px;height:14px;object-fit:contain;" loading="lazy" /> {eyebrow}
        </span>
        <h2 class="font-lora text-lg font-bold leading-tight sm:text-2xl md:text-4xl" style="color:#faf7f4;">{midHeading}</h2>
        <p class="mt-3 font-sora text-[15px]" style="color:#b0a59b;max-width:42ch;">{midSub}</p>
        <form action={action} method="POST" class="mt-5" style="max-width:380px;">
          <input type="hidden" name="_gotcha" style="display:none" />
          <input type="email" name="email" required placeholder="your@email.com"
            class="mb-2.5 w-full rounded-[10px] px-4 py-3 font-sora text-sm outline-none transition focus:ring-4 focus:ring-clay/25"
            style="background:#2a2826;border:1.5px solid #3d3830;color:#faf7f4;" />
          <button type="submit" class="flex w-full items-center justify-center rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk" style="box-shadow:0 4px 14px rgba(232,96,76,0.3);">{midCta}</button>
          <p class="mt-3 font-sora text-xs m-0" style="color:#b0a59b;">{note}</p>
        </form>
      </div>
    </div>
  </div>
)}

{variant === 'bottom' && (
  <div class="bg-cream px-4 py-9" style="border-top:1px solid rgba(0,0,0,0.07);">
    <div class="mx-auto text-center" style="max-width:760px;">
      <div class="mb-3 font-sora text-sm font-medium text-ink">{bottomText}</div>
      <form action={action} method="POST" class="mx-auto flex justify-center gap-2" style="max-width:480px;">
        <input type="hidden" name="_gotcha" style="display:none" />
        <input type="email" name="email" required placeholder="your@email.com"
          class="flex-1 rounded-[10px] border border-black/10 bg-white px-4 py-3 font-sora text-[13px] text-ink outline-none transition focus:border-clay focus:ring-4 focus:ring-clay/15" />
        <button type="submit" class="shrink-0 rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk">{botCta}</button>
      </form>
    </div>
  </div>
)}
