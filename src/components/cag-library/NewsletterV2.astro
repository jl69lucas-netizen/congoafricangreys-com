---
// cag-newsletter (NEW CAG COMPONENTS · Component 7) — 3 variants.
//   'top'    — light banner, headline + inline email (1100px)
//   'middle' — dark split: bird photo + email form (1100px)
//   'bottom' — slim centered footer bar (760px)
// No fabricated subscriber counts (no-fabrication rule). action defaults to '#'.
export interface Props {
  variant?: 'top' | 'middle' | 'bottom';
  action?: string;
}
const { variant = 'middle', action = '#' } = Astro.props;
---

{variant === 'top' && (
  <div class="px-4 py-9" style="background:linear-gradient(90deg,#f0f9f4,#faf7f4);border-left:4px solid #2D6A4F;">
    <div class="mx-auto grid items-center gap-8 md:grid-cols-[1.1fr_1fr]" style="max-width:1100px;">
      <div>
        <h3 class="font-lora text-2xl font-bold text-logo-dark mb-1.5">Be First to Know When New African Grey Babies Are Available</h3>
        <p class="font-sora text-sm text-stone-600 m-0">African Grey clutches are rare. Join our waitlist and hear about new Congo and Timneh chicks before they're listed publicly.</p>
      </div>
      <form action={action} method="POST" class="flex flex-col gap-2">
        <input type="hidden" name="_gotcha" style="display:none" />
        <div class="flex flex-col gap-2.5 sm:flex-row">
          <input type="email" name="email" required placeholder="your@email.com"
            class="flex-1 rounded-[10px] border border-black/10 bg-warm-white px-4 py-3 font-sora text-sm text-ink outline-none transition focus:border-clay focus:ring-4 focus:ring-clay/15" />
          <button type="submit" class="shrink-0 rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk" style="box-shadow:0 4px 14px rgba(232,96,76,0.25);">Join waitlist</button>
        </div>
        <p class="font-sora text-xs text-stone-400 m-0">🔒 No spam. Unsubscribe anytime.</p>
      </form>
    </div>
  </div>
)}

{variant === 'middle' && (
  <div class="px-4 py-14" style="background:#241c18;">
    <div class="mx-auto grid items-center gap-10 md:grid-cols-[1fr_1.1fr]" style="max-width:1100px;">
      <div class="relative h-[300px] overflow-hidden rounded-2xl md:h-[320px]" style="background:linear-gradient(160deg,#3a2a22,#2a1f1a);">
        <img src="/amie-congo-african-grey-female-3-months.webp" alt="Hand-raised Congo African Grey baby joining a family soon at C.A.Gs"
          width="520" height="320" loading="lazy" decoding="async"
          class="h-full w-full object-cover opacity-90" />
        <div class="absolute inset-0" style="background:linear-gradient(180deg,transparent 40%,rgba(28,26,24,0.6));"></div>
        <div class="absolute bottom-4 left-4 font-sora text-[13px] font-semibold text-white">Amie · 3 months · joining a family soon</div>
      </div>
      <div>
        <span class="mb-3.5 inline-flex items-center gap-1.5 rounded-full bg-clay/15 px-3 py-1 font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">
          <img src="/emoji/cag-congo.png" alt="" width="14" height="14" style="width:14px;height:14px;object-fit:contain;" loading="lazy" /> New clutch alerts
        </span>
        <h2 class="font-lora text-lg font-bold leading-tight sm:text-2xl md:text-4xl whitespace-nowrap" style="color:#faf7f4;">Parrots Sell Fast. Be First.</h2>
        <p class="mt-3 font-sora text-[15px]" style="color:#9b9189;max-width:42ch;">Sign up for African Grey availability updates and reserve a hand-fed Congo or Timneh chick before we list it publicly.</p>
        <form action={action} method="POST" class="mt-5" style="max-width:380px;">
          <input type="hidden" name="_gotcha" style="display:none" />
          <input type="email" name="email" required placeholder="your@email.com"
            class="mb-2.5 w-full rounded-[10px] px-4 py-3 font-sora text-sm outline-none transition focus:ring-4 focus:ring-clay/25"
            style="background:#2a2826;border:1.5px solid #3d3830;color:#faf7f4;" />
          <button type="submit" class="flex w-full items-center justify-center rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk" style="box-shadow:0 4px 14px rgba(232,96,76,0.3);">Notify me of new clutches →</button>
          <p class="mt-3 font-sora text-xs m-0" style="color:#9b9189;">We email about new African Grey clutches only — unsubscribe in one click.</p>
        </form>
      </div>
    </div>
  </div>
)}

{variant === 'bottom' && (
  <div class="bg-cream px-4 py-9" style="border-top:1px solid rgba(0,0,0,0.07);">
    <div class="mx-auto text-center" style="max-width:760px;">
      <div class="mb-3 font-sora text-sm font-medium text-ink">New African Greys available — get notified first.</div>
      <form action={action} method="POST" class="mx-auto flex justify-center gap-2" style="max-width:480px;">
        <input type="hidden" name="_gotcha" style="display:none" />
        <input type="email" name="email" required placeholder="your@email.com"
          class="flex-1 rounded-[10px] border border-black/10 bg-white px-4 py-3 font-sora text-[13px] text-ink outline-none transition focus:border-clay focus:ring-4 focus:ring-clay/15" />
        <button type="submit" class="shrink-0 rounded-full bg-clay px-6 py-3 font-sora text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Notify me</button>
      </form>
    </div>
  </div>
)}
