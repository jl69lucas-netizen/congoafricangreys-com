---
/**
 * ScamAwareness — buyer-protection infographic.
 *
 * @prop variant — 'grid' (12 flag dark grid) | 'compare' (side-by-side scam vs legit) | 'checklist' (4-step)
 */
export interface Flag { icon: string; title: string; body: string; }
export interface Props {
  variant?: 'grid' | 'compare' | 'checklist';
  flags?: Flag[];
}
const {
  variant = 'grid',
  flags = [
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>', title: '01 · Price under $1,500', body: 'Legit range is $1,500–$3,500.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', title: '02 · Zelle / CashApp only', body: 'Untraceable = unrecoverable.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>', title: '03 · Stolen images', body: '92% of scams use lifted photos.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M12 3c-3.5 0-6 5-6 9a6 6 0 0 0 12 0c0-4-2.5-9-6-9z"/></svg>', title: '04 · "Parrot eggs for sale"', body: 'Virtually always a scam.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.9" y1="4.9" x2="19.1" y2="19.1"/></svg>', title: '05 · No CITES docs', body: 'Required by federal law.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', title: '06 · Site under 6 months old', body: 'Check age via WHOIS lookup.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.9" y1="4.9" x2="19.1" y2="19.1"/></svg>', title: '07 · Refuses video call', body: 'Real breeders show real birds.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>', title: '08 · Fake shipping fees', body: 'Beware "insurance" upcharges.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>', title: '09 · No physical address', body: 'Real aviaries are findable.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><circle cx="8" cy="12" r="2"/><line x1="13" y1="10" x2="18" y2="10"/><line x1="13" y1="14" x2="18" y2="14"/></svg>', title: '10 · No USDA AWA #', body: 'Verify at aphis.usda.gov.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',  title: '11 · "Pay today or lose it"', body: 'Urgency is the oldest scam.' },
    { icon: '<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M20.6 13.4 12 22l-9-9V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>', title: '12 · "Free / $150 rehome"', body: '"Shipping only" = scam.' },
  ],
} = Astro.props;

const compareRed = [
  { title: 'Price: $400–$800', body: 'Too cheap for a healthy, captive-bred Grey. Hook for a scam.' },
  { title: 'Payment: gift cards, Zelle only', body: "Untraceable methods you can't dispute." },
  { title: 'No USDA AWA license', body: "Can't or won't provide a verifiable license #." },
  { title: 'Refuses video calls', body: '"Camera broken" — every time.' },
];
const compareGreen = [
  { title: 'Price: $1,500–$3,500', body: 'Reflects real captive breeding and vet work.' },
  { title: 'Reversible payments', body: 'Credit card, PayPal Goods, bank wire — protections apply.' },
  { title: 'Active USDA AWA license', body: 'Verifiable on aphis.usda.gov.' },
  { title: 'Encourages video calls', body: 'Will show the bird in real time, on demand.' },
];
---

<style>
@media (max-width: 1024px) {
  .scam-grid { grid-template-columns: 1fr !important; }
  .scam-compare { flex-direction: column !important; }
}
</style>

{variant === 'grid' && (
  <div class="bg-panel rounded-3xl p-10 text-white">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
      <div>
        <span class="cag-tag bg-clay text-white rounded-full px-3 py-1.5"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> SCAM ALERT</span>
        <h3 class="font-display font-bold text-4xl mt-3">12 red flags: avoid Congo Grey scams</h3>
        <p class="text-white/60 mt-2 max-w-2xl">If a listing trips three or more of these, walk away.</p>
      </div>
    </div>
    <div class="scam-grid grid grid-cols-2 md:grid-cols-4 gap-3">
      {flags.map(f => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-4">
          <div class="text-clay text-2xl" set:html={f.icon}></div>
          <div class="cag-tag text-clay">{f.title}</div>
          <div class="text-[12px] text-white/70 mt-1">{f.body}</div>
        </div>
      ))}
    </div>
  </div>
)}

{variant === 'compare' && (
  <div class="bg-white rounded-3xl border border-line cag-warm-shadow overflow-hidden">
    <div class="p-8 border-b border-line text-center">
      <h3 class="font-display font-bold text-3xl md:text-4xl leading-tight">
        African Greys: spot the <span class="text-red-700">scam</span> vs find the <span class="text-forest">breeder</span>
      </h3>
    </div>
    <div class="scam-compare grid md:grid-cols-2">
      <div class="bg-red-50 p-8 border-r border-line">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-4xl"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg></span>
          <div>
            <div class="cag-tag text-red-700">RED FLAGS</div>
            <div class="font-display font-bold text-xl text-red-800">The scammer</div>
          </div>
        </div>
        <div class="space-y-4">
          {compareRed.map(c => (
            <div class="bg-white/70 rounded-xl p-4">
              <div class="font-display font-bold text-red-800">{c.title}</div>
              <p class="text-[13px] text-mid mt-1">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-forest-lt p-8">
        <div class="flex items-center gap-3 mb-5">
          <span class="text-4xl"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="#2D6A4F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="8 12.5 11 15.5 16.5 9"/></svg></span>
          <div>
            <div class="cag-tag text-forest">GREEN FLAGS</div>
            <div class="font-display font-bold text-xl text-forest">The legitimate breeder</div>
          </div>
        </div>
        <div class="space-y-4">
          {compareGreen.map(c => (
            <div class="bg-white/70 rounded-xl p-4">
              <div class="font-display font-bold text-forest">{c.title}</div>
              <p class="text-[13px] text-mid mt-1">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="bg-forest text-white p-6 text-center">
      <div class="cag-tag tracking-[2px] text-white/80">ALWAYS VERIFY BEFORE YOU BUY ✓</div>
      <div class="text-[14px] text-white/90 mt-1">Check the breeder's license at aphis.usda.gov before sending any money.</div>
    </div>
  </div>
)}

{variant === 'checklist' && (
  <div class="cag-hero-grad rounded-3xl border border-line p-10">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="cag-tag text-clay">BEFORE YOU SEND A DOLLAR</div>
        <h3 class="font-display font-bold text-3xl mt-2">Four checks that catch <em class="text-clay">99% of scams.</em></h3>
      </div>
      <a class="text-clay underline decoration-2 underline-offset-4 font-semibold text-[14px]">See all 12 flags →</a>
    </div>
    <div class="grid md:grid-cols-4 gap-4">
      {[
        { t: 'Verify USDA license', b: 'Cross-check the breeder\'s # at aphis.usda.gov. Takes 30 seconds.' },
        { t: 'Demand a live video call', b: 'Real breeders show the bird, the band number, today\'s date.' },
        { t: 'Reverse-image search', b: '92% of scam listings use photos lifted from real breeders.' },
        { t: 'Use reversible payment', b: 'Credit card or PayPal Goods. Never Zelle, CashApp, or gift cards.' },
      ].map((s, i) => (
        <div class="bg-white rounded-2xl cag-warm-shadow p-6">
          <div class="font-display text-clay text-3xl font-bold">{String(i+1).padStart(2,'0')}</div>
          <h4 class="font-display font-bold text-lg mt-3">{s.t}</h4>
          <p class="text-mid text-[13px] mt-2">{s.b}</p>
        </div>
      ))}
    </div>
  </div>
)}
