---
/**
 * ParentBirds — "Meet our breeding pairs" showcase.
 *
 * @prop variant — 'classic' (4-up portrait grid) | 'editorial' (featured pair) | 'dark' (gallery)
 */
export interface ParentBird {
  name: string;
  role: 'Dam' | 'Sire';
  breed?: string;
  age: string;
  weight?: string;
  cites?: string;
  health?: string;
  temperament?: string;
  imageSrc?: string;
}
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  parents?: ParentBird[];
  title?: string;
  body?: string;
}
const {
  variant = 'classic',
  title = "The health-tested hens & cocks behind every chick.",
  body = "Every chick listed on this site comes from parents we own and raise here in Midland — not contracted from somewhere else. You can video-call any of them, see lineage paperwork, and meet them before placing a deposit.",
  parents = [
    { name: 'Bella',  role: 'Dam',  breed: 'Congo Grey', age: '9 yr',  weight: '410 g', cites: 'Full papers', health: 'Clear', temperament: 'Calm, nurturing' },
    { name: 'Rosie',  role: 'Dam',  breed: 'Congo Grey', age: '7 yr',  weight: '395 g', cites: 'Full papers', health: 'Clear', temperament: 'Sweet, gentle' },
    { name: 'Oliver', role: 'Sire', breed: 'Congo Grey', age: '11 yr', weight: '460 g', cites: 'Full papers', health: 'Clear', temperament: 'Confident, vocal' },
    { name: 'Max',    role: 'Sire', breed: 'Congo Grey', age: '14 yr', weight: '475 g', cites: 'Full papers', health: 'Clear', temperament: 'Intelligent, gentle' },
  ],
} = Astro.props;
---

{variant === 'classic' && (
  <div>
    <div class="grid md:grid-cols-[1fr_2.5fr] gap-8 mb-8">
      <h3 class="font-display font-bold text-3xl leading-tight" set:html={title} />
      <p class="text-mid leading-relaxed">{body}</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {parents.map((p, i) => (
        <article class="bg-white rounded-2xl border border-line cag-warm-shadow overflow-hidden hover:-translate-y-1 hover:cag-warm-shadow-lg transition-all">
          <div class="cag-bird-ph aspect-square flex items-center justify-center text-[100px] opacity-70" style={`filter: saturate(${[100,50,150,100][i % 4]}%)`}>🦜</div>
          <div class="p-5">
            <a class="font-display font-bold text-lg underline decoration-clay decoration-2 underline-offset-4">{p.name}</a>
            <span class="text-mid"> – {p.role}</span>
            <ul class="mt-3 space-y-1.5 text-[13px] text-mid">
              <li>🦜 <b class="text-ink">Breed:</b> {p.breed}</li>
              <li>📅 <b class="text-ink">Age:</b> {p.age}</li>
              {p.weight && <li>⚖️ <b class="text-ink">Weight:</b> {p.weight}</li>}
              {p.cites && <li>📜 <b class="text-ink">CITES:</b> {p.cites}</li>}
              {p.health && <li>🩺 <b class="text-ink">PBFD/PDD:</b> {p.health}</li>}
              {p.temperament && <li>✨ <b class="text-ink">Temperament:</b> {p.temperament}</li>}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="cag-hero-grad rounded-3xl border border-line p-10">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div class="grid grid-cols-2 gap-3">
        <div class="cag-bird-ph aspect-[3/4] rounded-2xl cag-warm-shadow flex items-end justify-center text-[100px] opacity-70 pb-4">🦜</div>
        <div class="cag-bird-ph aspect-[3/4] rounded-2xl cag-warm-shadow flex items-end justify-center text-[100px] opacity-70 saturate-50 pb-4 mt-8">🦜</div>
      </div>
      <div>
        <div class="cag-tag text-clay">FEATURED BREEDING PAIR · CLUTCH OF 3</div>
        <h3 class="font-display font-bold text-4xl mt-3 leading-[1.1]">{parents[0]?.name} &amp; {parents[2]?.name} — <em class="text-clay">10 years pairing</em></h3>
        <p class="text-mid mt-5 leading-relaxed">Our most experienced pair. Their chicks are consistently the most well-socialized birds we place each year.</p>
        <div class="mt-6 grid grid-cols-2 gap-4 text-[13px]">
          <div class="bg-white/60 rounded-xl p-4 border border-line">
            <div class="cag-tag text-forest">DAM</div>
            <div class="font-display font-bold text-lg">{parents[0]?.name} · {parents[0]?.age}</div>
            <div class="text-mid">{parents[0]?.weight} · PBFD clear · {parents[0]?.temperament}</div>
          </div>
          <div class="bg-white/60 rounded-xl p-4 border border-line">
            <div class="cag-tag text-forest">SIRE</div>
            <div class="font-display font-bold text-lg">{parents[2]?.name} · {parents[2]?.age}</div>
            <div class="text-mid">{parents[2]?.weight} · PBFD clear · {parents[2]?.temperament}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-10 text-white">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="cag-tag text-clay">🦜 OUR BREEDING PROGRAM</div>
        <h3 class="font-display font-bold text-3xl mt-2">{parents.length} pairs. <em class="text-clay">Zero secrets.</em></h3>
      </div>
      <a class="border border-white/30 hover:bg-white/10 transition rounded-full px-5 py-2.5 text-[13px] font-semibold">Full lineage tree →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {parents.map((p, i) => (
        <article class="bg-white/5 rounded-2xl border border-white/10 overflow-hidden hover:border-clay/50 transition">
          <div class="cag-bird-ph aspect-square flex items-center justify-center text-[100px] opacity-70" style={`filter: saturate(${[100,150,50,100,50,150][i % 6]}%)`}>🦜</div>
          <div class="p-4">
            <div class="flex items-center justify-between">
              <h4 class="font-display font-bold text-lg">{p.name}</h4>
              <span class="cag-tag text-clay">{p.role.toUpperCase()} · {p.age.toUpperCase().replace(' ','')}</span>
            </div>
            {p.temperament && <div class="text-[12px] text-white/60 mt-1">{p.temperament}</div>}
          </div>
        </article>
      ))}
    </div>
  </div>
)}
