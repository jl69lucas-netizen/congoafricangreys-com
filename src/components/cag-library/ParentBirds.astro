---
/**
 * ParentBirds — "Meet our breeding pairs" showcase.
 *
 * @prop variant — 'classic' (4-up portrait grid) | 'editorial' (featured pair) | 'dark' (gallery)
 */
export interface ParentBird {
  name: string;
  role: 'Dam' | 'Sire';
  breed?: string;
  age: string;
  weight?: string;
  cites?: string;
  health?: string;
  temperament?: string;
  imageSrc?: string;
}
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  parents?: ParentBird[];
  title?: string;
  body?: string;
}
const {
  variant = 'classic',
  title = "The health-tested hens & cocks behind every chick.",
  body = "Every chick listed on this site comes from parents we own and raise here in Midland — not contracted from somewhere else. You can video-call any of them, see lineage paperwork, and meet them before placing a deposit.",
  parents = [
    { name: 'Bella',  role: 'Dam',  breed: 'Congo Grey', age: '9 yr',  weight: '410 g', cites: 'Full papers', health: 'Clear', temperament: 'Calm, nurturing' },
    { name: 'Rosie',  role: 'Dam',  breed: 'Congo Grey', age: '7 yr',  weight: '395 g', cites: 'Full papers', health: 'Clear', temperament: 'Sweet, gentle' },
    { name: 'Oliver', role: 'Sire', breed: 'Congo Grey', age: '11 yr', weight: '460 g', cites: 'Full papers', health: 'Clear', temperament: 'Confident, vocal' },
    { name: 'Max',    role: 'Sire', breed: 'Congo Grey', age: '14 yr', weight: '475 g', cites: 'Full papers', health: 'Clear', temperament: 'Intelligent, gentle' },
  ],
} = Astro.props;
---

<style>
@media (max-width: 768px) {
  .parents-grid { grid-template-columns: 1fr !important; }
}
</style>

{variant === 'classic' && (
  <div>
    <div class="grid md:grid-cols-[1fr_2.5fr] gap-8 mb-8">
      <h3 class="font-display font-bold text-3xl leading-tight" set:html={title} />
      <p class="text-mid leading-relaxed">{body}</p>
    </div>
    <div class="parents-grid grid grid-cols-2 md:grid-cols-4 gap-5">
      {parents.map((p, i) => (
        <article class="bg-white rounded-2xl border border-line cag-warm-shadow overflow-hidden hover:-translate-y-1 hover:cag-warm-shadow-lg transition-all">
          <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70" style={`filter: saturate(${[100,50,150,100][i % 4]}%)`}><img src="/emoji/cag-congo.png" alt="" style="width:100px;height:100px;object-fit:contain;" loading="lazy" /></div>
          <div class="p-5">
            <a class="font-display font-bold text-lg underline decoration-clay decoration-2 underline-offset-4">{p.name}</a>
            <span class="text-mid"> – {p.role}</span>
            <ul class="mt-3 space-y-1.5 text-[13px] text-mid">
              <li><img src="/emoji/cag-congo.png" alt="" class="cag-emoji" loading="lazy" /> <b class="text-ink">Breed:</b> {p.breed}</li>
              <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <b class="text-ink">Age:</b> {p.age}</li>
              {p.weight && <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M12 3v18"/><path d="M5 7h14"/><path d="M5 7 2 13a3 3 0 0 0 6 0z"/><path d="M19 7l3 6a3 3 0 0 1-6 0z"/><path d="M8 21h8"/></svg> <b class="text-ink">Weight:</b> {p.weight}</li>}
              {p.cites && <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg> <b class="text-ink">CITES:</b> {p.cites}</li>}
              {p.health && <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> <b class="text-ink">PBFD/PDD:</b> {p.health}</li>}
              {p.temperament && <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17l-1.9-5.1L4.5 10l5.6-1.4z"/></svg> <b class="text-ink">Temperament:</b> {p.temperament}</li>}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="cag-hero-grad rounded-3xl border border-line p-10">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div class="grid grid-cols-2 gap-3">
        <div class="cag-bird-ph aspect-[3/4] rounded-2xl cag-warm-shadow flex items-end justify-center opacity-70 pb-4"><img src="/emoji/cag-congo.png" alt="" style="width:100px;height:100px;object-fit:contain;" loading="lazy" /></div>
        <div class="cag-bird-ph aspect-[3/4] rounded-2xl cag-warm-shadow flex items-end justify-center opacity-70 saturate-50 pb-4 mt-8"><img src="/emoji/cag-congo.png" alt="" style="width:100px;height:100px;object-fit:contain;" loading="lazy" /></div>
      </div>
      <div>
        <div class="cag-tag text-clay">FEATURED BREEDING PAIR · CLUTCH OF 3</div>
        <h3 class="font-display font-bold text-4xl mt-3 leading-[1.1]">{parents[0]?.name} &amp; {parents[2]?.name} — <em class="text-clay">10 years pairing</em></h3>
        <p class="text-mid mt-5 leading-relaxed">Our most experienced pair. Their chicks are consistently the most well-socialized birds we place each year.</p>
        <div class="mt-6 grid grid-cols-2 gap-4 text-[13px]">
          <div class="bg-white/60 rounded-xl p-4 border border-line">
            <div class="cag-tag text-forest">DAM</div>
            <div class="font-display font-bold text-lg">{parents[0]?.name} · {parents[0]?.age}</div>
            <div class="text-mid">{parents[0]?.weight} · PBFD clear · {parents[0]?.temperament}</div>
          </div>
          <div class="bg-white/60 rounded-xl p-4 border border-line">
            <div class="cag-tag text-forest">SIRE</div>
            <div class="font-display font-bold text-lg">{parents[2]?.name} · {parents[2]?.age}</div>
            <div class="text-mid">{parents[2]?.weight} · PBFD clear · {parents[2]?.temperament}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-10 text-white">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="cag-tag text-clay"><img src="/emoji/cag-congo.png" alt="" class="cag-emoji" loading="lazy" /> OUR BREEDING PROGRAM</div>
        <h3 class="font-display font-bold text-3xl mt-2">{parents.length} pairs. <em class="text-clay">Zero secrets.</em></h3>
      </div>
      <a class="border border-white/30 hover:bg-white/10 transition rounded-full px-5 py-2.5 text-[13px] font-semibold">Full lineage tree →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {parents.map((p, i) => (
        <article class="bg-white/5 rounded-2xl border border-white/10 overflow-hidden hover:border-clay/50 transition">
          <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70" style={`filter: saturate(${[100,150,50,100,50,150][i % 6]}%)`}><img src="/emoji/cag-congo.png" alt="" style="width:100px;height:100px;object-fit:contain;" loading="lazy" /></div>
          <div class="p-4">
            <div class="flex items-center justify-between">
              <h4 class="font-display font-bold text-lg">{p.name}</h4>
              <span class="cag-tag text-clay">{p.role.toUpperCase()} · {p.age.toUpperCase().replace(' ','')}</span>
            </div>
            {p.temperament && <div class="text-[12px] text-white/60 mt-1">{p.temperament}</div>}
          </div>
        </article>
      ))}
    </div>
  </div>
)}
