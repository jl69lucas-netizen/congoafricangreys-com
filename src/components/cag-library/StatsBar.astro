---
/**
 * StatsBar — four-up trust metric ribbon.
 *
 * @prop variant — 'classic' (outlined white card) | 'editorial' (warm pill grid) | 'dark' (panel)
 * @prop stats   — array of { value, label, sub? } (exactly 4 recommended)
 */
export interface Stat {
  value: string;
  label: string;
  sub?: string;
}
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  stats?: Stat[];
}
const {
  variant = 'classic',
  stats = [
    { value: '12+',     label: 'Years aviary',  sub: 'Captive-bred since 2014' },
    { value: '100%',    label: 'CITES',         sub: 'Appendix II documented' },
    { value: '$1,500',  label: 'Floor price',   sub: 'Below this = scam' },
    { value: '24h',     label: 'Reply',         sub: 'Personal response, no bots' },
  ],
} = Astro.props;
---

<style>
@media (max-width: 480px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
</style>

{variant === 'classic' && (
  <div class="stats-grid bg-white border border-line rounded-2xl cag-warm-shadow grid grid-cols-2 md:grid-cols-4 divide-x divide-line">
    {stats.map(s => (
      <div class="p-8 text-center">
        <div class="font-display font-bold text-4xl text-forest">{s.value}</div>
        <div class="cag-tag text-mid mt-2">{s.label}</div>
      </div>
    ))}
  </div>
)}

{variant === 'editorial' && (
  <div class="stats-grid grid grid-cols-2 md:grid-cols-4 gap-4">
    {stats.map(s => (
      <div class="bg-warm rounded-3xl p-7 border border-line">
        <div class="cag-tag text-clay">{s.label}</div>
        <div class="font-display font-bold text-5xl text-ink mt-3 leading-none">{s.value}</div>
        {s.sub && <div class="text-[13px] text-mid mt-3 leading-snug">{s.sub}</div>}
      </div>
    ))}
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-10 text-white relative overflow-hidden">
    <div class="absolute -right-10 -bottom-10 opacity-[0.04] leading-none"><img src="/emoji/cag-congo.png" alt="" style="width:280px;height:280px;object-fit:contain;" loading="lazy" /></div>
    <div class="stats-grid relative grid md:grid-cols-4 gap-y-8 gap-x-4">
      {stats.map(s => (
        <div>
          <div class="font-display font-bold text-5xl text-clay leading-none">{s.value}</div>
          <div class="text-[12px] tracking-[1.5px] uppercase text-white/60 mt-3">{s.label}</div>
          {s.sub && <div class="text-[13px] text-white/80 mt-1">{s.sub}</div>}
        </div>
      ))}
    </div>
  </div>
)}
