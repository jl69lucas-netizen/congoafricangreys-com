---
/**
 * TrustStats — "Trust Speaks" credibility cards.
 *
 * @prop variant — 'classic' | 'editorial' | 'dark'
 */
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  eyebrow?: string;
  title?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  variant = 'classic',
  eyebrow = 'WHY FAMILIES CHOOSE US',
  title = 'Trust, in receipts',
  body = "We hand every buyer the paperwork before the wire. USDA license number, CITES certificate, DNA sex result, and a written health guarantee — verified independently if you ask.",
  ctaLabel = 'Our ethical standards',
  ctaHref = '#',
} = Astro.props;

// Consistent Feather-style line icons (forest green #2D6A4F) — replaced the
// off-brand emoji set flagged in the 2026-06-03 design audit (DESIGN.md
// §Iconography). Rendered via set:html below.
const items = [
  { // shield-check — written health guarantee
    icon: '<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    title: '3-day health guarantee', sub: 'Written, with lifetime owner support' },
  { // DNA double-helix — DNA-sexed + vet-cleared
    icon: '<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3c0 4.5 8 4.5 8 9s-8 4.5-8 9"/><path d="M16 3c0 4.5-8 4.5-8 9s8 4.5 8 9"/><line x1="9" y1="6.5" x2="15" y2="6.5"/><line x1="9.5" y1="12" x2="14.5" y2="12"/><line x1="9" y1="17.5" x2="15" y2="17.5"/></svg>',
    title: 'DNA-sexed + vet-cleared', sub: 'Every bird, no exceptions' },
  { // paper plane (send) — nationwide shipping
    icon: '<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>',
    title: 'Ships to all 50 states',  sub: 'IATA-compliant, vet-certified transport' },
  { // document — CITES paperwork
    icon: '<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>',
    title: 'CITES Appendix I',        sub: 'Legal paperwork on every bird' },
];
---

<style>
@media (max-width: 480px) {
  .trust-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
.trust-ico { line-height: 0; }
.trust-ico :global(svg) { display: block; }
</style>

{variant === 'classic' && (
  <div class="bg-white border border-line rounded-3xl cag-warm-shadow p-10 grid md:grid-cols-[1fr_1.2fr] gap-10 items-center">
    <div>
      <div class="cag-tag text-clay">{eyebrow}</div>
      <h3 class="font-display font-bold text-3xl mt-3" set:html={title} />
      <p class="text-mid mt-4 leading-relaxed text-[15px]">{body}</p>
      <a href={ctaHref} class="mt-6 inline-flex items-center gap-2 bg-clay hover:bg-clay-dk transition text-white rounded-full px-6 py-3 font-semibold text-[14px] cag-glow">
        {ctaLabel} →
      </a>
    </div>
    <div class="trust-grid grid grid-cols-2 gap-5">
      {items.map(i => (
        <div class="bg-warm rounded-2xl p-4 md:p-6 border border-line">
          <div class="trust-ico" set:html={i.icon} />
          <div class="font-display font-bold text-sm md:text-lg mt-2 md:mt-3 leading-tight">{i.title}</div>
          <div class="text-[11px] md:text-[13px] text-mid mt-1">{i.sub}</div>
        </div>
      ))}
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="cag-hero-grad rounded-3xl p-12 border border-line text-center">
    <div class="cag-tag text-clay">{eyebrow}</div>
    <h3 class="font-display font-bold text-4xl mt-3 max-w-2xl mx-auto leading-[1.1]" set:html={title} />
    <div class="trust-grid mt-10 grid grid-cols-2 md:grid-cols-4 gap-y-8 md:divide-x divide-line">
      {items.map(i => (
        <div class="px-4">
          <div class="trust-ico" set:html={i.icon} />
          <div class="font-display font-bold text-lg mt-2">{i.title}</div>
          <div class="text-[12px] text-mid mt-1">{i.sub}</div>
        </div>
      ))}
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl p-12 text-white grid md:grid-cols-[1.1fr_1fr] gap-10 items-center">
    <div>
      <div class="cag-tag text-clay"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> {eyebrow}</div>
      <h3 class="font-display font-bold text-4xl mt-3 leading-[1.1]" set:html={title} />
      <p class="text-white/70 mt-4 text-[15px] leading-relaxed">{body}</p>
    </div>
    <div class="trust-grid grid grid-cols-2 gap-3">
      {items.map(i => (
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-5 border border-white/10">
          <div class="trust-ico mb-3" set:html={i.icon} />
          <div class="font-display font-bold text-[17px]">{i.title}</div>
          <div class="text-[12px] text-white/60 mt-1">{i.sub}</div>
        </div>
      ))}
    </div>
  </div>
)}
