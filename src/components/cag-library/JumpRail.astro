---
/**
 * JumpRail.astro — Responsive in-page section nav for the homepage.
 *  - Desktop (≥1024px): fixed right-side dot rail, scroll-spy via IntersectionObserver.
 *  - Mobile/tablet (<1024px): a thumb-reachable "Sections" button (above the
 *    MobileTabBar) that opens a bottom-sheet listing all sections grouped by part,
 *    with the same scroll-spy active state. (Added 2026-06-03 — mobile had no
 *    in-page nav on the ~58-screen homepage; TocV3 is only a static top block.)
 */

interface Section {
  id: string;
  label: string;
  part: number;
}

const sections: Section[] = [
  // Part 1 — Meet C.A.Gs
  { id: 'about',           label: 'Our Breeders',   part: 1 },
  { id: 'available-birds', label: 'Available',       part: 1 },
  { id: 'eggs-pairs',      label: 'Eggs & Pairs',    part: 1 },
  // Part 2 — Choose your Grey
  { id: 'congo',           label: 'Congo Grey',      part: 2 },
  { id: 'timneh',          label: 'Timneh Grey',     part: 2 },
  { id: 'compare-species', label: 'Compare',         part: 2 },
  // Part 3 — Why trust us
  { id: 'why-us',          label: 'Why C.A.Gs',      part: 3 },
  { id: 'trust',           label: 'vs Scammers',     part: 3 },
  { id: 'history',         label: 'History',         part: 3 },
  { id: 'health',          label: 'Health',          part: 3 },
  // Part 4 — Pricing & buying
  { id: 'pricing',         label: 'Pricing',         part: 4 },
  { id: 'tools',           label: 'Cost Tools',      part: 4 },
  { id: 'shipping',        label: 'Shipping',        part: 4 },
  { id: 'reviews',         label: 'Reviews',         part: 4 },
  { id: 'blog',            label: 'Care Guides',     part: 4 },
  { id: 'faq',             label: 'FAQ',             part: 4 },
  { id: 'how-to-buy',      label: 'How to Buy',      part: 4 },
  { id: 'contact',         label: 'Contact',         part: 4 },
];

const partNames: Record<number, string> = {
  1: 'Meet C.A.Gs',
  2: 'Choose Your Grey',
  3: 'Why Families Trust Us',
  4: 'Pricing, Tools & Buying',
};
const parts = [1, 2, 3, 4];
---

<!-- Desktop (≥1024px): fixed dot rail -->
<nav id="cag-jump-rail" aria-label="Page sections">
  {sections.map((s, i) => {
    const isFirstOfPart = i === 0 || sections[i - 1].part !== s.part;
    return (
      <>
        {isFirstOfPart && i > 0 && <div class="rail-spacer" aria-hidden="true" />}
        <a href={`#${s.id}`} class="rail-item" data-target={s.id} aria-label={`Jump to: ${s.label}`}>
          <span class="rail-dot" data-dot={s.id} />
          <span class="rail-label">{s.label}</span>
        </a>
      </>
    );
  })}
</nav>

<!-- Mobile / tablet (<1024px): floating "Sections" button + bottom-sheet -->
<div class="cag-jump-mobile">
  <button id="cag-sections-fab" type="button" class="cag-fab"
          aria-haspopup="dialog" aria-expanded="false" aria-controls="cag-section-sheet">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/>
      <circle cx="4.5" cy="6" r="1.3" fill="currentColor" stroke="none"/>
      <circle cx="4.5" cy="12" r="1.3" fill="currentColor" stroke="none"/>
      <circle cx="4.5" cy="18" r="1.3" fill="currentColor" stroke="none"/>
    </svg>
    <span>Sections</span>
  </button>

  <div id="cag-sheet-scrim" class="cag-sheet-scrim" hidden></div>

  <div id="cag-section-sheet" class="cag-sheet" role="dialog" aria-modal="true" aria-label="Jump to a section" hidden>
    <div class="cag-sheet-head">
      <span class="cag-sheet-title">Jump to a section</span>
      <button id="cag-sheet-close" type="button" class="cag-sheet-close" aria-label="Close section menu">✕</button>
    </div>
    <div class="cag-sheet-body">
      {parts.map(part => (
        <div class="cag-sheet-group">
          <p class="cag-sheet-part">{partNames[part]}</p>
          {sections.filter(s => s.part === part).map(s => (
            <a href={`#${s.id}`} class="cag-sheet-item" data-sheet-target={s.id}>
              <span class="cag-sheet-dot" data-sheet-dot={s.id} aria-hidden="true"></span>
              <span>{s.label}</span>
            </a>
          ))}
        </div>
      ))}
    </div>
    <div class="cag-sheet-foot">
      <a href="#contact" class="cag-sheet-cta" data-sheet-target="contact">Reserve a Bird &rarr;</a>
    </div>
  </div>
</div>

<style>
  #cag-jump-rail {
    position: fixed;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 200;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 10px 8px;
    background: rgba(250, 247, 244, 0.92);
    border: 1px solid #ede5dc;
    border-radius: 50px;
    box-shadow: 0 4px 20px rgba(60, 30, 10, 0.10);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Hide the dot rail below 1024px — the mobile sheet takes over */
  @media (max-width: 1023px) {
    #cag-jump-rail { display: none; }
  }

  /* Also hide if viewport is too short */
  @media (max-height: 600px) {
    #cag-jump-rail { display: none; }
  }

  .rail-spacer {
    height: 6px;
    margin: 1px 0;
  }

  .rail-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 8px 6px 10px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.15s;
    cursor: pointer;
    min-height: 26px; /* WCAG 2.5.8 AA target-size (≥24px) */
  }

  .rail-item:hover {
    background: rgba(232, 96, 76, 0.08);
  }

  .rail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1.5px solid #c8bdb8;
    background: #fff;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .rail-dot.done {
    background: #2D6A4F;
    border-color: #2D6A4F;
  }

  .rail-dot.active {
    background: #e8604c;
    border-color: #e8604c;
    box-shadow: 0 0 0 3px rgba(232, 96, 76, 0.20);
    transform: scale(1.25);
  }

  .rail-label {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #6b5d54;   /* WCAG AA: 5.4:1 on the light rail */
    white-space: nowrap;
    transition: color 0.15s;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .rail-item:hover .rail-label { color: #b04228; }
  .rail-item.active-item .rail-label { color: #b04228; font-weight: 700; }
  .rail-item.done-item .rail-label { color: #2D6A4F; }

  /* ── Mobile / tablet section nav (<1024px) ───────────────────────────── */
  .cag-jump-mobile { display: block; }
  @media (min-width: 1024px) { .cag-jump-mobile { display: none; } }

  /* Floating trigger — sits above the 56px MobileTabBar, within thumb reach */
  .cag-fab {
    position: fixed;
    right: 14px;
    bottom: calc(68px + env(safe-area-inset-bottom));
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 17px;
    background: #c8472f;   /* AA-safe clay (white text 4.78:1) */
    color: #fff;
    border: none;
    border-radius: 50px;
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 6px 20px rgba(60, 30, 10, 0.28);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    /* Hidden over the hero; revealed once the user scrolls past it (JS) */
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .cag-fab.visible { opacity: 1; transform: none; pointer-events: auto; }
  .cag-fab svg { width: 16px; height: 16px; }
  .cag-fab.visible:active { transform: translateY(1px); }
  @media (prefers-reduced-motion: reduce) { .cag-fab { transition: opacity 0.2s ease; transform: none; } }

  .cag-sheet-scrim {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgba(28, 26, 24, 0.45);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .cag-sheet-scrim.open { opacity: 1; }

  .cag-sheet {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 71;
    max-height: 74vh;
    display: flex;
    flex-direction: column;
    background: #faf7f4;
    border-radius: 20px 20px 0 0;
    box-shadow: 0 -8px 40px rgba(60, 30, 10, 0.22);
    transform: translateY(100%);
    transition: transform 0.24s cubic-bezier(0.22, 1, 0.36, 1);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .cag-sheet.open { transform: translateY(0); }

  .cag-sheet-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 16px 11px;
    border-bottom: 1px solid #ede5dc;
    flex-shrink: 0;
  }
  .cag-sheet-title {
    font-family: 'Lora', Georgia, serif;
    font-size: 17px;
    font-weight: 700;
    color: #1c1a18;
  }
  .cag-sheet-close {
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    border: none;
    background: #f0e8e2;
    color: #5a5248;
    border-radius: 50%;
    font-size: 15px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .cag-sheet-body {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 4px 10px;
  }
  .cag-sheet-group { padding: 6px 0; }
  .cag-sheet-part {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #b04228;   /* AA clay text */
    padding: 8px 10px 4px;
  }
  .cag-sheet-item {
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 46px;
    padding: 6px 10px;
    border-radius: 12px;
    text-decoration: none;
    color: #3a352f;
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    line-height: 1.2;
    -webkit-tap-highlight-color: transparent;
  }
  .cag-sheet-item:active { background: rgba(232, 96, 76, 0.07); }
  .cag-sheet-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    border: 1.5px solid #c8bdb8;
    background: #fff;
    flex-shrink: 0;
  }
  .cag-sheet-dot.done { background: #2D6A4F; border-color: #2D6A4F; }
  .cag-sheet-item.active { background: rgba(232, 96, 76, 0.10); color: #b04228; font-weight: 700; }
  .cag-sheet-item.active .cag-sheet-dot { background: #e8604c; border-color: #e8604c; }

  .cag-sheet-foot {
    padding: 11px 16px 15px;
    border-top: 1px solid #ede5dc;
    flex-shrink: 0;
  }
  .cag-sheet-cta {
    display: block;
    text-align: center;
    background: #c8472f;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 14px;
    padding: 13px;
    border-radius: 50px;
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .cag-sheet, .cag-sheet-scrim { transition: none; }
  }
</style>

<script>
  (function () {
    const rail = document.getElementById('cag-jump-rail');
    const sheet = document.getElementById('cag-section-sheet');
    const fab = document.getElementById('cag-sections-fab');
    const scrim = document.getElementById('cag-sheet-scrim');
    const closeBtn = document.getElementById('cag-sheet-close');

    // Rail items (desktop) + sheet items (mobile) share section order 1:1.
    const railItems = rail ? Array.from(rail.querySelectorAll('.rail-item')) : [];
    const railDots  = rail ? Array.from(rail.querySelectorAll('.rail-dot')) : [];
    const sheetItems = sheet ? Array.from(sheet.querySelectorAll('.cag-sheet-item')) : [];
    const sheetDots  = sheetItems.map(el => el.querySelector('.cag-sheet-dot'));

    // Build the ordered id list from whichever nav exists.
    const order = (railItems.length ? railItems : sheetItems).map(el =>
      (el as HTMLElement).dataset.target ?? (el as HTMLElement).dataset.sheetTarget ?? ''
    );
    const idToIndex: Record<string, number> = {};
    order.forEach((id, i) => { if (id) idToIndex[id] = i; });

    let activeIdx = -1;

    function markRow(item: Element | undefined, dot: Element | null | undefined,
                     state: 'before' | 'active' | 'after',
                     activeCls: string, doneCls: string) {
      if (!item) return;
      item.classList.remove(activeCls, doneCls);
      if (dot) dot.classList.remove('active', 'done');
      if (state === 'before') {
        item.classList.add(doneCls);
        if (dot) dot.classList.add('done');
      } else if (state === 'active') {
        item.classList.add(activeCls);
        if (dot) dot.classList.add('active');
      }
    }

    function setActive(idx: number) {
      if (idx === activeIdx) return;
      activeIdx = idx;
      for (let i = 0; i < order.length; i++) {
        const state = i < idx ? 'before' : i === idx ? 'active' : 'after';
        // Desktop rail: item has .active-item/.done-item, dot has .active/.done
        markRow(railItems[i], railDots[i], state as any, 'active-item', 'done-item');
        // Mobile sheet: item has only .active (styles its dot via descendant);
        // the dot carries .done (green) for already-passed sections.
        const sItem = sheetItems[i];
        const sDot = sheetDots[i];
        if (sItem) sItem.classList.toggle('active', state === 'active');
        if (sDot) sDot.classList.toggle('done', state === 'before');
      }
    }

    // IntersectionObserver scroll-spy (drives both navs)
    const targets = order
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (targets.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              if (id in idToIndex) setActive(idToIndex[id]);
            }
          });
        },
        { rootMargin: '-10% 0px -55% 0px', threshold: 0 }
      );
      targets.forEach(t => observer.observe(t));
    }

    function smoothTo(id: string | undefined) {
      if (!id) return;
      const section = document.getElementById(id);
      if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Desktop rail clicks
    railItems.forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        smoothTo((el as HTMLElement).dataset.target);
      });
    });

    // ── Mobile bottom-sheet open/close ──────────────────────────────────
    let lastFocus: HTMLElement | null = null;

    function openSheet() {
      if (!sheet || !scrim || !fab) return;
      lastFocus = document.activeElement as HTMLElement;
      scrim.hidden = false;
      sheet.hidden = false;
      // force reflow so the transition runs
      void sheet.offsetHeight;
      scrim.classList.add('open');
      sheet.classList.add('open');
      fab.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      (closeBtn as HTMLElement | null)?.focus();
    }

    function closeSheet() {
      if (!sheet || !scrim || !fab) return;
      scrim.classList.remove('open');
      sheet.classList.remove('open');
      fab.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      const done = () => { scrim.hidden = true; sheet.hidden = true; };
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) { done(); } else { window.setTimeout(done, 240); }
      (lastFocus ?? fab).focus();
    }

    // Reveal the FAB only after the user scrolls past the hero (avoids
    // covering the hero CTAs at the top of the page).
    if (fab) {
      const REVEAL_AT = 600;
      const syncFab = () => fab.classList.toggle('visible', window.scrollY > REVEAL_AT);
      syncFab();
      window.addEventListener('scroll', syncFab, { passive: true });
    }

    fab?.addEventListener('click', openSheet);
    closeBtn?.addEventListener('click', closeSheet);
    scrim?.addEventListener('click', closeSheet);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && sheet && !sheet.hidden) closeSheet();
    });

    // Sheet item + CTA clicks → scroll then close
    const sheetLinks = sheet ? Array.from(sheet.querySelectorAll('[data-sheet-target]')) : [];
    sheetLinks.forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const id = (el as HTMLElement).dataset.sheetTarget;
        closeSheet();
        // let the sheet start closing, then scroll
        window.setTimeout(() => smoothTo(id), 60);
      });
    });
  })();
</script>
