---
/**
 * JumpRail.astro — Compact floating progress sidebar (Option C)
 * Fixed right-side dot rail, scroll-spy via IntersectionObserver.
 * Small dots + short labels. 1024px+ only; hidden on mobile/tablet.
 */

interface Section {
  id: string;
  label: string;
  part: number;
}

const sections: Section[] = [
  // Part 1 — Meet C.A.Gs
  { id: 'about',           label: 'Our Breeders',   part: 1 },
  { id: 'available-birds', label: 'Available',       part: 1 },
  { id: 'eggs-pairs',      label: 'Eggs & Pairs',    part: 1 },
  // Part 2 — Choose your Grey
  { id: 'congo',           label: 'Congo Grey',      part: 2 },
  { id: 'timneh',          label: 'Timneh Grey',     part: 2 },
  { id: 'compare-species', label: 'Compare',         part: 2 },
  // Part 3 — Why trust us
  { id: 'why-us',          label: 'Why C.A.Gs',      part: 3 },
  { id: 'trust',           label: 'vs Scammers',     part: 3 },
  { id: 'history',         label: 'History',         part: 3 },
  { id: 'health',          label: 'Health',          part: 3 },
  // Part 4 — Pricing & buying
  { id: 'pricing',         label: 'Pricing',         part: 4 },
  { id: 'tools',           label: 'Cost Tools',      part: 4 },
  { id: 'shipping',        label: 'Shipping',        part: 4 },
  { id: 'reviews',         label: 'Reviews',         part: 4 },
  { id: 'blog',            label: 'Care Guides',     part: 4 },
  { id: 'faq',             label: 'FAQ',             part: 4 },
  { id: 'how-to-buy',      label: 'How to Buy',      part: 4 },
  { id: 'contact',         label: 'Contact',         part: 4 },
];

const partColors = ['#2D6A4F', '#5a9e7a', '#c47b2a', '#e8604c'];
---

<nav id="cag-jump-rail" aria-label="Page sections">
  {sections.map((s, i) => {
    const isFirstOfPart = i === 0 || sections[i - 1].part !== s.part;
    return (
      <>
        {isFirstOfPart && i > 0 && <div class="rail-spacer" aria-hidden="true" />}
        <a href={`#${s.id}`} class="rail-item" data-target={s.id} aria-label={`Jump to: ${s.label}`}>
          <span class="rail-dot" data-dot={s.id} />
          <span class="rail-label">{s.label}</span>
        </a>
      </>
    );
  })}
</nav>

<style>
  #cag-jump-rail {
    position: fixed;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 200;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 10px 8px;
    background: rgba(250, 247, 244, 0.92);
    border: 1px solid #ede5dc;
    border-radius: 50px;
    box-shadow: 0 4px 20px rgba(60, 30, 10, 0.10);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Hide on anything below 1024px — TocV3 handles mobile nav */
  @media (max-width: 1023px) {
    #cag-jump-rail { display: none; }
  }

  /* Also hide if viewport is too short */
  @media (max-height: 600px) {
    #cag-jump-rail { display: none; }
  }

  .rail-spacer {
    height: 6px;
    margin: 1px 0;
  }

  .rail-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 4px 6px 4px 8px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.15s;
    cursor: pointer;
    min-height: 22px;
  }

  .rail-item:hover {
    background: rgba(232, 96, 76, 0.08);
  }

  .rail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1.5px solid #c8bdb8;
    background: #fff;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  /* done state — set by JS */
  .rail-dot.done {
    background: #2D6A4F;
    border-color: #2D6A4F;
  }

  /* active state — current section */
  .rail-dot.active {
    background: #e8604c;
    border-color: #e8604c;
    box-shadow: 0 0 0 3px rgba(232, 96, 76, 0.20);
    transform: scale(1.25);
  }

  .rail-label {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #6b5d54;   /* WCAG AA: was #8a7b72 (4.0:1) → 5.4:1 on the light rail */
    white-space: nowrap;
    transition: color 0.15s;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .rail-item:hover .rail-label { color: #e8604c; }

  /* active label */
  .rail-item.active-item .rail-label {
    color: #e8604c;
    font-weight: 700;
  }

  /* done label */
  .rail-item.done-item .rail-label { color: #2D6A4F; }
</style>

<script>
  (function () {
    const rail = document.getElementById('cag-jump-rail');
    if (!rail) return;

    const items = Array.from(rail.querySelectorAll('.rail-item'));
    const dots  = Array.from(rail.querySelectorAll('.rail-dot'));

    // Map id → index
    const idToIndex: Record<string, number> = {};
    items.forEach((el, i) => {
      const target = (el as HTMLElement).dataset.target ?? '';
      if (target) idToIndex[target] = i;
    });

    let activeIdx = -1;

    function setActive(idx: number) {
      if (idx === activeIdx) return;
      activeIdx = idx;
      items.forEach((el, i) => {
        const dot = dots[i];
        if (i < idx) {
          el.classList.replace('active-item', 'done-item') || el.classList.add('done-item');
          dot.classList.replace('active', 'done') || dot.classList.add('done');
          dot.classList.remove('active');
          el.classList.remove('active-item');
        } else if (i === idx) {
          el.classList.remove('done-item');
          el.classList.add('active-item');
          dot.classList.remove('done');
          dot.classList.add('active');
        } else {
          el.classList.remove('done-item', 'active-item');
          dot.classList.remove('done', 'active');
        }
      });
    }

    // IntersectionObserver — fire when section enters top ~40% of viewport
    const targets = items
      .map(el => document.getElementById((el as HTMLElement).dataset.target ?? ''))
      .filter(Boolean) as HTMLElement[];

    if (!targets.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            if (id in idToIndex) setActive(idToIndex[id]);
          }
        });
      },
      { rootMargin: '-10% 0px -55% 0px', threshold: 0 }
    );

    targets.forEach(t => observer.observe(t));

    // Smooth scroll on click (belt+suspenders)
    items.forEach(el => {
      el.addEventListener('click', (e) => {
        const target = (el as HTMLElement).dataset.target;
        if (!target) return;
        const section = document.getElementById(target);
        if (section) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  })();
</script>
