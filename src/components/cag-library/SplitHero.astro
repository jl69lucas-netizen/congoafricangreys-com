---
/**
 * SplitHero — landing-hero with bird image, value prop, and trust ribbon.
 *
 * @prop variant — 'classic' (white card, image left) | 'editorial' (warm gradient) | 'dark' (panel + photo grid)
 */
export interface Props {
  variant?: 'classic' | 'editorial' | 'dark';
  eyebrow?: string;
  title?: string;       // accepts HTML — wrap accent words in <em>
  body?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  imageSrc?: string;    // optional bird photo; if absent uses placeholder
}
const {
  variant = 'classic',
  eyebrow = 'OUR FAMILY AVIARY',
  title = "Bringing home an African Grey is a <em>30-year decision.</em>",
  body = "We've spent the last decade helping families make it well — hand-feeding, socialising, and placing captive-bred greys with people who'll love them for life.",
  primaryCta = { label: 'Reserve a grey', href: '#' },
  secondaryCta = { label: 'Meet our parents', href: '#' },
  imageSrc,
} = Astro.props;

const trust = [
  { icon: '🏅', label: 'USDA Licensed' },
  { icon: '📜', label: 'CITES Certified' },
  { icon: '🧬', label: 'DNA Sexed' },
  { icon: '✈️', label: 'Ships nationwide' },
];
---

{variant === 'classic' && (
  <div class="bg-white rounded-3xl cag-warm-shadow overflow-hidden border border-line">
    <div class="grid md:grid-cols-2">
      <div class="cag-bird-ph aspect-[5/4] md:aspect-auto relative">
        {imageSrc
          ? <img src={imageSrc} alt="African Grey" class="absolute inset-0 w-full h-full object-cover" />
          : <div class="absolute inset-0 flex items-center justify-center opacity-70"><img src="/emoji/cag-congo.png" alt="" style="width:180px;height:180px;object-fit:contain;" loading="lazy" /></div>}
        <div class="absolute top-5 left-5 bg-white/95 rounded-full px-3 py-1.5 cag-tag text-forest">CONGO GREY · 11 MO</div>
      </div>
      <div class="p-10 md:p-12 flex flex-col justify-center">
        <span class="cag-tag text-clay">{eyebrow}</span>
        <h1 class="font-display font-bold text-4xl mt-3 leading-[1.1]" set:html={title} />
        <p class="text-mid mt-5 leading-relaxed text-[15px]">{body}</p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <a href={primaryCta.href} class="bg-clay hover:bg-clay-dk transition text-white rounded-full px-6 py-3 font-semibold text-[14px] cag-glow">{primaryCta.label}</a>
          <a href={secondaryCta.href} class="border-2 border-clay text-clay hover:bg-clay hover:text-white transition rounded-full px-6 py-3 font-semibold text-[14px]">{secondaryCta.label}</a>
        </div>
      </div>
    </div>
    <div class="border-t border-line grid grid-cols-2 md:grid-cols-4 divide-x divide-line bg-warm">
      {trust.map(t => (
        <div class="p-5 text-center">
          <div class="text-[20px]">{t.icon}</div>
          <div class="cag-tag text-mid mt-1">{t.label}</div>
        </div>
      ))}
    </div>
  </div>
)}

{variant === 'editorial' && (
  <div class="cag-hero-grad rounded-3xl border border-line overflow-hidden relative">
    <div class="grid md:grid-cols-[1.1fr_1fr] gap-8 items-center p-12">
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 bg-white/70 backdrop-blur rounded-full px-3 py-1.5 cag-tag text-forest">
          <span class="w-1.5 h-1.5 bg-clay rounded-full animate-pulse"></span> {eyebrow}
        </div>
        <h1 class="font-display font-bold text-5xl mt-5 leading-[1.05] tracking-tight" set:html={title} />
        <p class="text-mid mt-6 max-w-[480px] leading-relaxed">{body}</p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <a href={primaryCta.href} class="bg-clay hover:bg-clay-dk transition text-white rounded-full px-7 py-3.5 font-semibold text-[15px] cag-glow">{primaryCta.label} →</a>
          <a href={secondaryCta.href} class="text-clay underline decoration-2 underline-offset-4 hover:text-clay-dk py-3.5 font-semibold text-[15px]">{secondaryCta.label}</a>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-square cag-bird-ph rounded-3xl cag-warm-shadow-lg flex items-center justify-center opacity-70 rotate-2"><img src="/emoji/cag-congo.png" alt="" style="width:200px;height:200px;object-fit:contain;" loading="lazy" /></div>
      </div>
    </div>
    <div class="border-t border-line/60 bg-white/40 backdrop-blur grid grid-cols-2 md:grid-cols-4 divide-x divide-line/60">
      {trust.map(t => (
        <div class="p-5 text-center"><div class="text-[20px]">{t.icon}</div><div class="cag-tag text-forest mt-1">{t.label}</div></div>
      ))}
    </div>
  </div>
)}

{variant === 'dark' && (
  <div class="bg-panel rounded-3xl text-white overflow-hidden">
    <div class="grid md:grid-cols-2">
      <div class="p-12 flex flex-col justify-center">
        <div class="cag-tag text-clay">{eyebrow}</div>
        <h1 class="font-display font-bold text-5xl mt-4 leading-[1.05]" set:html={title} />
        <p class="text-white/70 mt-5 leading-relaxed max-w-[460px]">{body}</p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <a href={primaryCta.href} class="bg-clay hover:bg-clay-dk transition rounded-full px-7 py-3.5 font-semibold text-[15px] cag-glow">{primaryCta.label}</a>
          <a href={secondaryCta.href} class="border border-white/30 hover:bg-white/10 transition rounded-full px-7 py-3.5 font-semibold text-[15px]">{secondaryCta.label}</a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-1">
        <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70"><img src="/emoji/cag-congo.png" alt="" style="width:120px;height:120px;object-fit:contain;" loading="lazy" /></div>
        <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70 saturate-50"><img src="/emoji/cag-congo.png" alt="" style="width:120px;height:120px;object-fit:contain;" loading="lazy" /></div>
        <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70 saturate-150"><img src="/emoji/cag-congo.png" alt="" style="width:120px;height:120px;object-fit:contain;" loading="lazy" /></div>
        <div class="cag-bird-ph aspect-square flex items-center justify-center opacity-70"><img src="/emoji/cag-congo.png" alt="" style="width:120px;height:120px;object-fit:contain;" loading="lazy" /></div>
      </div>
    </div>
  </div>
)}
