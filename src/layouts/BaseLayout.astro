---
import '../styles/global.css';
import '../styles/direction-d.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileTabBar from '../components/MobileTabBar.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  schemaJson?: string;
  extraHeadHtml?: string;
  /** Robots directive. Defaults to index,follow; pass "noindex, follow" on thank-you / utility pages. */
  robots?: string;
  /** Pages that render their own <CTA /> set this to suppress the global pre-footer band (avoids a double CTA). */
  hideGlobalCta?: boolean;
}
const { title, description, canonical, ogType = 'website', schemaJson, extraHeadHtml, robots = 'index, follow', hideGlobalCta = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en-US">
<head>
  <!-- Google tag (gtag.js) — deferred off the critical path (Lighthouse: reduce unused JavaScript).
       gtag.js (~155 KiB) only fetches after first user interaction OR a short idle fallback,
       so it no longer blocks/loads with the initial page. dataLayer calls are queued and replayed. -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MEWJ9GVC4T');
    (function () {
      var loaded = false;
      function loadGA() {
        if (loaded) return; loaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-MEWJ9GVC4T';
        document.head.appendChild(s);
      }
      var evts = ['scroll', 'mousemove', 'touchstart', 'keydown', 'pointerdown'];
      evts.forEach(function (e) {
        window.addEventListener(e, loadGA, { once: true, passive: true });
      });
      // Fallback so no-interaction sessions are still measured. Plain 12s timer, NOT
      // requestIdleCallback — idle fires ~1-2s after load, which pulls gtag.js back into
      // the Lighthouse trace ("reduce unused JavaScript", ~156 KiB). Real users interact
      // (scroll/touch) within the first seconds, so this only delays truly idle sessions.
      setTimeout(loadGA, 12000);
    })();
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content="https://congoafricangreys.com/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Congo African Greys" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://congoafricangreys.com/og-twitter.png" />

  <!-- Fonts — preconnect + non-render-blocking load (media=print swap). Direction D
       (Newsreader + IBM Plex) and the Lora/Sora token fallback share one combined
       request. display=swap means fallback text paints immediately, then swaps. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Sora:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Sora:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    />
  </noscript>

  <!-- Structured data -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}
  {extraHeadHtml && <Fragment set:html={extraHeadHtml} />}
</head>
<body class="theme-d bg-warm-white font-sora text-stone-800 antialiased pb-16 md:pb-0">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-lg focus:bg-clay focus:px-4 focus:py-2 focus:font-semibold focus:text-white">Skip to main content</a>
  <Header />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  {!hideGlobalCta && (
    <section class="bg-logo-dark text-cream py-20 px-4 text-center">
      <h2 class="font-lora font-bold text-4xl text-clay mb-4 leading-tight">Reserve a Hand-Raised, CITES-Documented<br class="hidden md:block" /> African Grey From C.A.Gs</h2>
      <p class="text-cream/80 text-lg max-w-xl mx-auto mb-10">
        Congo and Timneh African Greys, captive-bred in Midland, TX. Every Grey comes with CITES Appendix I paperwork, DNA sexing certificate, avian-vet health cert, and a written health guarantee.
      </p>
      <a
        href="/contact-us/"
        class="inline-block bg-clay text-white font-semibold px-10 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
      >
        Start Your Inquiry &rarr;
      </a>
    </section>
  )}
  <Footer />
  <MobileTabBar />
</body>
</html>
