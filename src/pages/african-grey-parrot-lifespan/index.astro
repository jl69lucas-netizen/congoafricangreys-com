                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover object-top" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "40–60", label: "Yrs In Your Home" },
      { num: "70+", label: "Yrs Top Records" },
      { num: "20–30", label: "Yrs Wild Average" },
      { num: "2014", label: "Breeding Since" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="How Long Do African Grey Parrots Live?"
      badge="8 facts · 90-sec read"
      items={[
        { stat: "50–60+", label: "Years (Congo)", body: "A captive Congo African Grey commonly lives 50 to 60 years or more on a good diet, with documented birds reaching 70-plus." },
        { stat: "50+", label: "Years (Timneh)", body: "Timneh Greys live just as long as Congos — lifespan is essentially identical between the two subspecies." },
        { stat: "20–30", label: "Years (Wild)", body: "Wild African Greys average far less than captive birds, cut short by predation, disease, and habitat loss." },
        { stat: "70+", label: "Record Ages", body: "The longevity literature credibly records African Greys past 70 years — these are real records, not folklore." },
        { stat: "Diet", label: "#1 Lever", body: "A pellet-and-vegetable diet with calcium and UV-B is the single biggest factor in whether a Grey reaches its full lifespan." },
        { stat: "Annual", label: "Avian Vet", body: "Yearly bird-vet exams catch hidden illness early — prey animals mask disease until it is advanced." },
