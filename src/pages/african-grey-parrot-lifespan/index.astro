    color:#b04228; text-decoration:none; display:inline-block; padding:10px 0 10px 12px; margin:-10px 0; }
  .life-d .section-next-link:hover { text-decoration:underline; }

  /* Infographic — lifespan timeline (760px wrapper, 400px desktop fixed) */
  .ig-life{ max-width:760px; margin:2.5rem auto 0; padding:26px 28px; background:#fff; border:1px solid var(--line, rgba(32,52,43,.12)); border-radius:20px; box-shadow:0 4px 24px rgba(60,30,10,.06); display:flex; flex-direction:column; gap:14px; }
  @media (min-width:641px){ .ig-life{ height:400px; justify-content:space-between; } }
  .ig-life-eyebrow{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#b04228; }
