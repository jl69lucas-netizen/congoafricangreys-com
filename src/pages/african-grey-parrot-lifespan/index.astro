  <script is:inline>
    // FAQ accordion (smooth open/close) — mirrors homepage/care-hub/diet pattern
    (function () {
      const qs = document.querySelectorAll('.cag-faq-q');
      if (!qs.length) return;
      qs.forEach(btn => btn.addEventListener('click', () => {
        const item = btn.closest('.cag-faq-item');
        const open = item.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['how-long','records','congo-vs-timneh','what-affects','maximize','commitment','senior','available-birds','faq','contact'];
      var labels = {
        'records':         'Record-Setting Ages',
        'congo-vs-timneh': 'Congo vs Timneh Lifespan',
        'what-affects':    'What Affects Lifespan',
        'maximize':        'How to Add Years',
        'commitment':      'The 40–60 Year Commitment',
        'senior':          'Caring for a Senior Grey',
        'available-birds': 'Available Greys',
        'faq':             'Lifespan FAQ',
        'contact':         'Ask C.A.Gs',
      };
      for (var i = 0; i < ids.length - 1; i++) {
        var cur = document.getElementById(ids[i]);
        if (!cur) continue;
        var nav = document.createElement('div');
        nav.className = 'section-next-nav';
        nav.innerHTML = '<a href="#' + ids[i + 1] + '" class="section-next-link">&#8595; Continue: ' + (labels[ids[i + 1]] || ids[i + 1]) + '</a>';
        cur.appendChild(nav);
      }
    })();
  </script>
