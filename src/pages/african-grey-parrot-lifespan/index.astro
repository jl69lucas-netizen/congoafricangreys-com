---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';

const title = "African Grey Parrot Lifespan | How Long Do African Greys Live, Captive vs Wild & What Affects It? | Congo 50–60+ Yrs, Timneh 50+ Yrs — The 40–60 Year Commitment | C.A.Gs – Midland, TX";
const description = "Our African Grey parrot lifespan guide: Congos live 50–60+ years in captivity, Timnehs 50+, records past 70. What shortens or extends a Grey's life — diet, avian vet care, hypocalcemia, exercise, air quality — and why a captive-bred Congo or Timneh is a 40–60 year commitment | USDA breeders.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-lifespan/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Lifespan", url: "/african-grey-parrot-lifespan/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + diet/care pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'how-long',        label: 'How Long',      part: 1 },
  { id: 'records',         label: 'Record Ages',   part: 1 },
  { id: 'congo-vs-timneh', label: 'Congo v Timneh', part: 1 },
  { id: 'what-affects',    label: 'What Affects',  part: 2 },
  { id: 'maximize',        label: 'Add Years',     part: 2 },
  { id: 'commitment',      label: 'Commitment',    part: 2 },
  { id: 'senior',          label: 'Senior Greys',  part: 2 },
  { id: 'available-birds', label: 'Available',     part: 3 },
  { id: 'faq',             label: 'FAQ',           part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',    part: 3 },
];
const jumpPartNames = {
  1: 'How Long They Live',
  2: 'Living Longer',
  3: 'Choose & Reserve',
};

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + price-matrix.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'A whole life ahead of him.',
    notes: 'Hand-raised Congo male, 4 months old — a healthy start on what should be a 50-to-60-year companionship.' },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Decades of conversation in the making.',
    notes: 'Premium hand-raised Congo female, 3 months old, weaned onto the calcium-rich diet that protects long-term health.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, settled, and barely out of the nest.',
    notes: 'Soft-tempered Congo female, 1 year old — a yearling at the very beginning of a long life.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'A 50-year talker, ready early.',
    notes: 'Hand-raised Timneh male, 5 months old — Timnehs match the Congo for longevity and tend to talk sooner.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm companion for the long haul.',
    notes: 'Hand-raised Timneh female, 6 months old, fully weaned and ready to begin decades at home.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two long lives, one family.',
    notes: 'Unrelated Congo pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo), both weaned and thriving.' },
];

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
const faqs = [
  { q: "How long do African Grey parrots live?",
    a: "In captivity, with proper diet, avian veterinary care, and enrichment, African Grey parrots commonly live 50 to 60 years or more, and well-documented individuals have reached 70 to 80. Wild African Greys average far less — often 20 to 30 years — because predation, disease, and habitat loss cut life short. Congo and Timneh Greys share the same long lifespan, so the species you choose should not be decided on longevity." },
  { q: "What is the oldest African Grey on record?",
    a: "The longevity literature records captive African Greys living past 70 years, with the longevity database AnAge listing a maximum of roughly 60+ years and individual reports reaching the high 70s. The famous research Grey 'Alex' lived to about 31, while pet and aviary birds kept on excellent diets have outlived that by decades. These are credible records, not folklore — which is exactly why we tell every buyer to treat a Grey as a multi-decade commitment." },
  { q: "Do Congo and Timneh African Greys live the same length of time?",
    a: "Yes — lifespan is essentially identical between the two. Both our Congo African Greys and Timneh African Greys live 50 to 60-plus years in captivity when fed and cared for well; the Congo is simply larger and the Timneh smaller. Body size, tail color, and how early a bird talks differ between them, but neither subspecies is meaningfully longer-lived than the other." },
  { q: "What shortens an African Grey's lifespan?",
    a: "The biggest lifespan-shorteners in captivity are an all-seed diet (causing vitamin-A deficiency, chronic infection, and fatty liver), untreated hypocalcemia (Greys are uniquely prone to low blood calcium), PTFE/Teflon and smoke fumes that can kill in minutes, delayed veterinary care because birds hide illness, and chronic stress or feather-destructive behavior from boredom. Most of these are preventable, which is why husbandry — not luck — decides how long a Grey lives." },
  { q: "How can I help my African Grey live longer?",
    a: "Feed a pellet-and-vegetable diet with calcium and UV-B support, see an avian-certified vet every year for proactive bloodwork, keep the air free of PTFE fumes and smoke, provide daily out-of-cage exercise and foraging for mental health, and weigh your bird weekly to catch illness early. A Grey that is well fed, well exercised, mentally engaged, and seen by a bird vet annually is the one that reaches the top of its 50-to-60-year range." },
  { q: "How old is an African Grey in human years?",
    a: "African Greys mature sexually around 3 to 5 years, reach behavioral maturity at 10 to 12, and are middle-aged at roughly 25 to 30 given their long lifespan. A 40-year-old Grey is well into its senior years but can still be vocal and engaged, while a 50-plus-year bird is genuinely elderly. There is no exact conversion, but a useful rule of thumb is that a Grey's first year packs in a great deal of development, then it ages slowly across many decades." },
  { q: "What should I do if my African Grey outlives me?",
    a: "Plan for it before you need to. Name a guardian for the bird in your will, leave them the complete medical history, diet notes, weight log, and the CITES Appendix I documentation that must travel with the bird for life, and consider a modest pet trust to cover care. Reputable parrot organizations and breeders — including us — maintain rehoming networks for Greys that outlive their owners, so connect with one early rather than in a crisis." },
  { q: "Why does an African Grey's long lifespan matter before I buy one?",
    a: "Because a Congo or Timneh African Grey is a 40-to-60-year commitment — often the longest of any companion animal you will own. That means decades of daily attention, diet, vet bills, and social interaction, plus a real chance the bird outlives you. Here at C.A.Gs we would rather a buyer think hard about that timeline now than rehome a grieving, bonded bird later, so we walk every family through the full lifetime reality before placing a Grey." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Lifespan — How Long Do African Greys Live, Captive vs Wild & How to Maximize It",
  description: "A complete African Grey parrot lifespan guide from USDA-licensed breeders C.A.Gs: Congo Greys live 50–60+ years and Timneh Greys 50+ in captivity, with records past 70; what shortens and extends a Grey's life, how to maximize longevity, and why a captive-bred Congo or Timneh is a 40–60 year commitment.",
  image: "https://congoafricangreys.com/african-grey-parrot-free-exploration.webp",
  inLanguage: "en-US",
  datePublished: "2024-09-01",
  dateModified: "2026-06-07",
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// Longevity practices (custom numbered grid — phone-free, diet-page idiom)
const longevityPractices = [
  { t: "Feed for the long haul", b: "A pellet base with fresh vegetables, plus calcium and UV-B support, is the single biggest lever on lifespan. Seed-only diets shave years off a Grey through vitamin-A deficiency and fatty liver." },
  { t: "Annual avian vet care", b: "See a bird-certified vet every year for a proactive exam and bloodwork. Greys hide illness as prey animals, so a yearly panel catches kidney, liver, and calcium problems before they turn fatal." },
  { t: "Guard the air", b: "Retire non-stick (PTFE) cookware and keep the home smoke-free. Overheated Teflon and cigarette smoke are airborne killers that end an otherwise healthy Grey's life in minutes or erode it over years." },
  { t: "Daily exercise & flight", b: "Out-of-cage time, climbing, and supervised flapping keep heart, muscles, and weight healthy. A sedentary, cage-bound Grey is prone to obesity and the disease that follows it." },
  { t: "Protect mental health", b: "Foraging, training, novelty, and real social time prevent the chronic stress and feather-plucking that quietly shorten a Grey's life. A bored Grey is rarely a long-lived one." },
  { t: "Weigh weekly, act early", b: "A gram scale is your earliest warning system: a 10–15 gram drop can flag illness in a bird that still looks normal. Catching trouble a week sooner is often the difference that adds years." },
];
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
  extraHeadHtml={'<link rel="preload" as="image" href="/african-grey-parrot-free-exploration.webp" fetchpriority="high" type="image/webp" />'}>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="life-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green · data-forward) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
