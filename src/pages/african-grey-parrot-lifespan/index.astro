     scope so the global theme applies and the seam-logo divider renders.
     body.theme-d already supplies Newsreader/IBM Plex, lead paragraphs,
     eyebrow ticks, card + button motion — NOT re-done here.
     ============================================================ */
  .life-d { --rule: rgba(45,106,79,.16); }

  /* AA: clay as small readable text on this page's LIGHT sections → #b04228 (4.5:1).
     Mirrors the homepage .home-d rule. Clay on the green hero stays bright. */
  .life-d a.text-clay, .life-d .text-clay { color:#b04228; }
  /* Hero clay accent stays bright; clay FILLS keep white text (global .bg-clay =
     --clay-ink #bd4129, 5.3:1 — the old color:inherit leaked dark stone = FAIL). */
  .life-d .hero-v3-b .text-clay { color:inherit; }
  .life-d .bg-clay { color:#fff; }

  /* Woven in-content links: clay, underlined, AA-safe — applies to all the
