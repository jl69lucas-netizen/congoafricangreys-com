  .life-d p a:not(.rounded-full):not(.bg-clay),
  .life-d li a:not(.rounded-full):not(.bg-clay) {
    color:#b04228; font-weight:500; text-decoration:underline;
    text-decoration-color:rgba(176,66,40,.35); text-underline-offset:2px;
    transition:text-decoration-color .2s ease;
  }
  .life-d p a:not(.rounded-full):not(.bg-clay):hover,
  .life-d li a:not(.rounded-full):not(.bg-clay):hover { text-decoration-color:#b04228; }

  /* Section seam — centered wordmark divider (verbatim scope from index.astro) */
  .life-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
