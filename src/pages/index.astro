---

<BaseLayout {title} {description} {canonical}>

<!-- Direction D display + body typefaces -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" />

<style is:global>
/* ============================================================
   HOMEPAGE THEME — "Modern Editorial" (Direction D, approved 2026-06-01)
   Newsreader literary serif headings (lower-contrast, calmer) + IBM
   Plex Sans body. CIRCULAR hero kept. Clear hairline dividers + compact
   rhythm. SOFT WARM cards (radius + warm shadow). Lead-line paragraphs
   (Layout B). Locked palette (Forest / Clay / Cream); clay pill CTA.
   ============================================================ */
.home-d { --ink:#20342b; --line:rgba(32,52,43,.12); --rule:rgba(45,106,79,.16); }

/* --- BODY type -> IBM Plex Sans (base + the font-sora utility).
   Headings + their child spans inherit the serif below, so the hero's
   "Trust" accent is unaffected. --- */
.home-d { font-family:'IBM Plex Sans', system-ui, sans-serif; }
.home-d .font-sora { font-family:'IBM Plex Sans', system-ui, sans-serif !important; }

/* --- HEADINGS -> Newsreader, optical size pinned, calm weight --- */
.home-d h1, .home-d h2, .home-d h3, .home-d h4, .home-d h5, .home-d h6 {
  font-family:'Newsreader', Georgia, 'Times New Roman', serif !important;
  font-weight:600 !important;
  font-optical-sizing:none;
  font-variation-settings:'opsz' 18;
  letter-spacing:-.003em;
}
.home-d .hero-v3-b h1 { font-size:clamp(1.8rem, 1.2rem + 2.6vw, 2.4rem) !important; line-height:1.12 !important; font-weight:500 !important; }
.home-d .hero-v3-b .text-clay { font-style:italic; font-weight:500; }

/* --- HERO PORTRAIT: CIRCLE KEPT (no radius override) --- */

/* --- DIVIDERS + COMPACT RHYTHM: clear lines, no big gaps --- */
.home-d > * + * { border-top:1px solid var(--rule); }
.home-d > section.hero-v3-b { border-top:0 !important; }
.home-d > section:not(.hero-v3-b), .home-d > nav, .home-d > div { padding-top:2.25rem; padding-bottom:2.25rem; }
@media (min-width:768px){ .home-d > section:not(.hero-v3-b), .home-d > nav, .home-d > div { padding-top:2.9rem; padding-bottom:2.9rem; } }
.home-d .py-16, .home-d .py-14, .home-d .py-12 { padding-top:2.25rem !important; padding-bottom:2.25rem !important; }
@media (min-width:768px){ .home-d .py-16, .home-d .py-14, .home-d .py-12 { padding-top:2.9rem !important; padding-bottom:2.9rem !important; } }

/* --- PARAGRAPH LAYOUT B — lead line: first paragraph after a heading reads larger/ink --- */
.home-d p { max-width:64ch !important; }
.home-d .text-center p { margin-left:auto; margin-right:auto; }
.home-d h1 + p, .home-d h2 + p { font-size:1.08em !important; line-height:1.7 !important; color:var(--ink) !important; }

/* --- EYEBROWS: calm uppercase label with a clay underline tick --- */
.home-d .border-l-4 { border-left:0 !important; padding-left:0 !important; }
.home-d p.uppercase, .home-d span.uppercase { letter-spacing:.18em !important; font-weight:600; }
.home-d .text-center > p.uppercase::after,
.home-d .mb-8 > p.uppercase::after, .home-d .mb-7 > p.uppercase::after, .home-d .mb-6 > p.uppercase::after, .home-d .mb-2 > p.uppercase::after {
  content:""; display:block; width:44px; height:2px; background:var(--color-clay,#e8604c); margin:10px 0 0; border-radius:2px;
}
.home-d .text-center > p.uppercase::after { margin-left:auto; margin-right:auto; }

/* --- History SplitFeature (classic): keep the origin photo crisp (component dims to 70%)
   and scale the feature title so it stays subordinate to the section H2 on every device --- */
.home-d #history .split-image.cag-bird-ph { opacity:1 !important; }
.home-d #history .split-grid h3 { font-size:clamp(1.15rem, 2.2vw, 1.5rem) !important; line-height:1.2 !important; }

/* --- CARDS: SOFT WARM frame — larger radius + warm shadow --- */
.home-d .rounded-2xl { border-radius:20px !important; }
.home-d article {
  border-radius:18px !important; border:1px solid var(--line) !important;
  box-shadow:0 6px 26px rgba(60,30,10,0.08) !important;
  transition:transform .18s cubic-bezier(.22,1,.36,1), box-shadow .18s ease !important;
}
.home-d article:hover { transform:translateY(-4px) !important; box-shadow:0 14px 38px rgba(60,30,10,0.14) !important; }

/* --- BUTTONS: keep clay pill (brand signature); calm rise on hover --- */
.home-d a[class*="rounded-full"], .home-d button[class*="rounded-full"] {
  transition:transform .18s cubic-bezier(.22,1,.36,1), background-color .18s ease, border-color .18s ease !important;
}
.home-d a[class*="rounded-full"]:hover, .home-d button[class*="rounded-full"]:hover { transform:translateY(-2px); }
</style>

<div class="home-d">

  <!-- Jump Rail — fixed right-side progress nav (desktop 1024px+) -->
  <JumpRail />

  <!-- 1. Hero — cag-hero-v3:b "Authority Green" (REBUILD v2) -->
  <HeroV3 availableCount={birds.filter(b => b.status === 'available').length} />

  <!-- 2. Counter Snippet — cag-counter-snippet (Rule 31: 4 stats after H1) -->
  <CounterSnippet />

  <!-- 3. Key Takeaway — cag-key-takeaway-v2:02 (stat-forward answer box) -->
  <KeyTakeawayV2 />

  <!-- 4. TOC — cag-toc-v3:02 (grouped by part) -->
  <TocV3 />

  <!-- 5. About the Breeders — cag-owner-card (H-S-S, Mark & Teri) -->
  <OwnerCard />

  <!-- 6. Review block #1 — verified buyer social proof (Review-top image) -->
  <section id="reviews-top" class="scroll-mt-20 bg-cream py-14 px-4 md:py-16">
    <div class="container mx-auto max-w-[1100px]">
      <div class="mb-8 text-center">
        <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Verified Buyer Review</p>
        <h2 class="font-lora mt-2 font-bold text-logo-dark">What Do African Grey Families Say About C.A.Gs?</h2>
      </div>
      <Testimonials variant="feature" testimonials={[{ ...reviews[0], avatarSrc: '/african-grey-review-top.webp' }]} />
    </div>
  </section>

  <!-- 7. All Products — cag-available-grid (filterable Pill-Tabs) -->
  <section id="available-birds" class="py-16 px-4 bg-warm-white scroll-mt-20">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div class="border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">This Week's Aviary</p>
          <h2 class="font-lora font-bold text-logo-dark">Which Hand-Fed African Greys Are Available Right Now?</h2>
          <p class="text-stone-500 mt-2 max-w-md text-sm leading-relaxed">Real birds. Real availability. Every one is hand-fed, DNA-sexed, CITES-documented, and vet-certified — no waitlist tricks, no bait listings.</p>
        </div>
        <a href="/african-grey-parrot-for-sale/" class="inline-block bg-clay hover:bg-clay-dk text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors whitespace-nowrap cag-glow">View All Birds →</a>
      </div>

      <!-- Filter bar -->
      <div id="bird-filters" class="flex flex-wrap gap-2 mb-8 font-sora text-sm">
        <button data-filter="all" class="bird-filter is-active px-4 py-2 rounded-full border border-green/30 transition-colors">All</button>
        <button data-filter="Congo African Grey" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Congo</button>
        <button data-filter="Timneh African Grey" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Timneh</button>
        <button data-filter="chick" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Chicks</button>
        <button data-filter="adult" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Adults</button>
        <button data-filter="pair" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Pairs</button>
        <button data-filter="under2000" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Under $2,000</button>
      </div>

      <div id="bird-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {birds.map(bird => (
          <div class="bird-item" data-variant={bird.variant} data-kind={bird.kind} data-price={bird.priceVal} data-status={bird.status}>
            <BirdCard {...bird} />
          </div>
        ))}
      </div>
      <p id="bird-empty" class="hidden text-center text-stone-500 py-10 font-sora">No birds match that filter right now — <a href="/contact-us/" class="text-clay font-semibold">ask about upcoming clutches →</a></p>

      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {['CITES Captive-Bred Cert', 'DNA Sex Certificate', 'Avian Vet Health Cert', 'Hatch Certificate'].map(badge => (
          <span class="text-xs font-sora text-green bg-green/8 border border-green/20 px-3 py-1 rounded-full">✓ {badge}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. Eggs & Breeding Pairs — horizontal compact list-style (links to category pages) -->
  <section id="eggs-pairs" class="scroll-mt-20 bg-cream py-14 px-4 md:py-16">
