---
import BaseLayout from '../layouts/BaseLayout.astro';
import Schema from '../components/Schema.astro';
import BirdCard from '../components/BirdCard.astro';

// cag-library components (the new component library)
import HeroV3      from '../components/cag-library/HeroV3.astro';
import CounterSnippet from '../components/cag-library/CounterSnippet.astro';
