---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import CTA from '../components/CTA.astro';
import Schema from '../components/Schema.astro';
import FadeIn from '../components/FadeIn';
import BirdCard from '../components/BirdCard.astro';

const title = "African Grey Parrot Breeder | Congo African Greys | Midland, TX";
const description = "Captive-bred Congo and Timneh African Grey parrots from Mark & Teri Benjamin's USDA AWA licensed family aviary in Midland, Texas. CITES documented, DNA sexed, health guaranteed. Ships nationwide.";
const canonical = "https://congoafricangreys.com/";

const birds = [
  {
    id: 'amie',  name: 'Amie',  sex: 'Female', age: '11 mo',  price: '$2,700',
    tag: 'New Arrival',   tagType: 'new'    as const,
    hook: 'She mimics your laugh before you finish it.',
    notes: 'Premium hand-raised female, advanced training. Responds to her name and several household words already.',
  },
  {
    id: 'joys',  name: 'Joys',  sex: 'Female', age: '2 yr',   price: '$2,200',
    tag: 'Top Talker',    tagType: 'talker' as const,
    hook: 'Every morning she says "good morning" before you do.',
    notes: "Vocal female actively learning new phrases. Exceptional recall — she won't let you forget her.",
  },
  {
    id: 'roys',  name: 'Roys',  sex: 'Male',   age: '3 yr',   price: '$2,000',
    tag: 'Family Bird',   tagType: 'family' as const,
    hook: 'Energetic, curious, and impossible to ignore.',
    notes: "Great with kids and activity. Thrives in a lively home where there's always something to watch.",
  },
  {
    id: 'carl',  name: 'Carl',  sex: 'Male',   age: '1 yr',   price: '$2,500',
    tag: 'Talking Now',   tagType: 'talker' as const,
    hook: 'His vocabulary is growing faster than we can count.',
    notes: 'Highly interactive male at the peak of language acquisition. Bond now and shape how he talks.',
  },
  {
    id: 'loti',  name: 'Loti',  sex: 'Male',   age: '5 yr',   price: '$1,800',
    tag: 'Calm & Social', tagType: 'family' as const,
    hook: 'Apartment-ready. The bird your neighbours will want to meet.',
    notes: 'Mature, deeply bonded male. Low-drama, high-affection. Adjusts quickly to new homes.',
  },
  {
    id: 'bery',  name: 'Bery',  sex: 'Female', age: '4 yr',   price: '$1,600',
    tag: 'Best Value',    tagType: 'value'  as const,
    hook: 'Gentle, easy, and the bird first-time owners dream of.',
    notes: 'Soft temperament, easy to handle. The best first African Grey — and a steal at this price.',
  },
];

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are your African Grey parrots CITES documented?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All our African Grey parrots are CITES Appendix II captive-bred with full documentation including hatch certificate, band number, DNA sexing certificate, and avian vet health certificate."
      }
    },
    {
      "@type": "Question",
      "name": "How much does an African Grey parrot cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our Congo African Grey parrots range from $1,500 to $3,000 depending on age and training. Timneh African Greys range from $1,200 to $2,500. A $200 deposit reserves your bird."
      }
    },
    {
      "@type": "Question",
      "name": "Do you ship African Grey parrots nationwide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We ship IATA-compliant to all 50 states. Birds travel in approved carriers with a health certificate and arrive safely to your nearest airport."
      }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero: Immersive Full-Bleed -->
  <section class="relative text-white overflow-hidden md:h-[480px] md:flex md:items-end md:justify-start">

    <!-- Background image: responsive crops per breakpoint, focal-point optimised -->
    <picture>
      <source
        media="(max-width: 767px)"
        srcset="/hero-mobile.webp"
        type="image/webp"
        width="400"
        height="563"
      />
      <source
        media="(min-width: 768px)"
        srcset="/hero-desktop.webp"
        type="image/webp"
        width="800"
        height="334"
      />
      <img
        src="/hero-desktop.webp"
        alt="Hand-reared Congo African Grey parrots being socialized by a certified breeder"
        class="block w-full object-cover object-[65%_45%] h-[50vh] md:absolute md:inset-0 md:h-full md:w-full"
        loading="eager"
        fetchpriority="high"
        width="800"
        height="334"
      />
    </picture>

    <!-- Desktop-only gradient overlay: darkens left (text area) fades right (birds visible) -->
    <div class="hidden md:block absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/5 pointer-events-none"></div>
    <div class="hidden md:block absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent pointer-events-none"></div>

    <!-- Content: green rounded card on mobile, left-side overlay on desktop -->
    <div class="relative z-10 w-full text-center
      bg-green -mt-8 rounded-t-3xl px-6 pt-10 pb-10
      md:bg-transparent md:rounded-none md:mt-0 md:w-auto
      md:pb-10 md:pl-14 md:pr-6 md:text-left">
      <div class="md:max-w-lg">

        <!-- Eyebrow -->
        <p class="font-sora text-[11px] font-semibold uppercase tracking-widest text-white/60 mb-5">
          Midland, Texas &middot; Family Aviary Since 2014
        </p>

        <!-- H1: two lines for visual impact -->
        <h1 class="font-lora font-bold leading-none mb-2 text-3xl sm:text-4xl md:text-4xl">
          African Grey
        </h1>
        <p class="font-lora font-bold leading-none mb-5 text-2xl sm:text-3xl md:text-3xl">
          Parrots For Sale
        </p>

        <!-- Tagline -->
        <p class="font-sora font-semibold text-base md:text-xl mb-4 text-white">
          Raised with Family. <span class="text-clay">Proven with Trust.</span>
        </p>

        <!-- Description -->
        <p class="font-sora text-white/70 text-sm max-w-2xl mx-auto mb-6 leading-relaxed">
          Congo and Timneh African Greys from Mark &amp; Teri Benjamin's USDA AWA
          licensed, CITES-documented home aviary. Hand-raised, DNA sexed, vet-certified.
          Every bird ships nationwide.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
          <a
            href="/african-grey-parrot-for-sale/"
            class="bg-clay text-white font-sora font-semibold px-8 py-3.5 rounded-full hover:bg-clay-dk transition-colors text-sm"
          >
            See Available Birds
          </a>
          <a
            href="/contact-us/"
            class="border-2 border-white/50 text-white font-sora font-semibold px-8 py-3.5 rounded-full hover:bg-white/10 hover:border-white transition-all text-sm"
          >
            Inquire Now
          </a>
        </div>

        <!-- Trust badges: scrollable row on mobile, wrapped on desktop -->
        <div class="flex gap-2 justify-start sm:justify-center overflow-x-auto pb-1 md:flex-wrap md:overflow-visible"
          style="-ms-overflow-style: none; scrollbar-width: none;">
          {[
            { icon: '🏛️', line1: 'USDA AWA', line2: 'Licensed' },
            { icon: '📋', line1: 'CITES', line2: 'Documented' },
            { icon: '🔬', line1: 'DNA', line2: 'Sexed' },
            { icon: '🩺', line1: 'Health', line2: 'Cert' },
            { icon: '✅', line1: 'Approved', line2: 'Breeder' },
          ].map(b => (
            <div class="flex-shrink-0 border border-white/30 rounded-xl px-3 py-2.5 backdrop-blur-sm bg-white/5 text-center min-w-[72px]">
              <span class="text-xl block mb-1">{b.icon}</span>
              <span class="font-sora text-[10px] leading-tight text-white/80 block">{b.line1}</span>
              <span class="font-sora text-[10px] leading-tight text-white/80 block">{b.line2}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Available Birds -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-10 gap-4 flex-wrap">
        <div class="border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">This Week's Aviary</p>
          <h2 class="font-lora font-bold text-3xl text-logo-dark">Birds Available Right Now</h2>
          <p class="text-stone-500 mt-2 max-w-md text-sm leading-relaxed">Real birds. Real availability. Every one is hand-fed, DNA-sexed, CITES-documented, and vet-certified — no waitlist tricks, no bait listings.</p>
        </div>
        <a href="/african-grey-parrot-for-sale/" class="text-sm font-semibold text-clay hover:text-clay-dk border border-clay/40 hover:border-clay px-4 py-2 rounded-full transition-colors whitespace-nowrap">
          View all birds →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {birds.map(bird => (
          <BirdCard {...bird} />
        ))}
      </div>
      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {['CITES Captive-Bred Cert', 'DNA Sex Certificate', 'Avian Vet Health Cert', 'Hatch Certificate'].map(badge => (
          <span class="text-xs font-sora text-green bg-green/8 border border-green/20 px-3 py-1 rounded-full">
            ✓ {badge}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Variants -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <FadeIn client:visible>
        <h2 class="font-lora font-bold text-3xl text-center text-logo-dark mb-4">Two Variants. One Standard of Care.</h2>
        <p class="text-center text-stone-500 mb-12 max-w-xl mx-auto">Both variants are Psittacus erithacus — the world's most intelligent parrot. The difference is size, temperament, and price.</p>
      </FadeIn>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Congo -->
        <FadeIn client:visible delay={0.1}>
        <div class="border border-gold/30 rounded-2xl p-8 bg-white shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl">🦜</span>
            <h3 class="font-lora font-bold text-2xl text-logo-dark">Congo African Grey</h3>
          </div>
          <p class="text-stone-600 mb-6 leading-relaxed">The classic African Grey. Larger body (400–600g), brilliant red tail, exceptional vocabulary. Most emotionally sensitive — bonds deeply with one family.</p>
          <ul class="text-sm text-stone-600 space-y-2 mb-6">
            <li>&#10003; $1,500–$3,000 &middot; babies from $3,000</li>
            <li>&#10003; 40–60 year lifespan</li>
            <li>&#10003; 1,000+ word vocabulary potential</li>
            <li>&#10003; CITES Appendix II &middot; full documentation</li>
          </ul>
          <a href="/congo-african-grey-for-sale/" class="inline-block bg-green text-white font-semibold px-6 py-3 rounded-full text-sm hover:bg-clay transition-colors">
            View Congo Greys &rarr;
          </a>
        </div>
        </FadeIn>
        <!-- Timneh -->
        <FadeIn client:visible delay={0.2}>
        <div class="border border-gold/30 rounded-2xl p-8 bg-white shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl">🦜</span>
            <h3 class="font-lora font-bold text-2xl text-logo-dark">Timneh African Grey</h3>
          </div>
          <p class="text-stone-600 mb-6 leading-relaxed">Smaller (275–375g), maroon tail, calmer temperament. Matures faster — often starts talking earlier. Adapts more readily to new environments.</p>
          <ul class="text-sm text-stone-600 space-y-2 mb-6">
            <li>&#10003; $1,200–$2,500</li>
            <li>&#10003; 40–60 year lifespan</li>
            <li>&#10003; Earlier talker, more adaptable</li>
            <li>&#10003; CITES Appendix II &middot; full documentation</li>
          </ul>
          <a href="/african-grey-parrot-for-sale/" class="inline-block bg-green text-white font-semibold px-6 py-3 rounded-full text-sm hover:bg-clay transition-colors">
            View Timneh Greys &rarr;
          </a>
        </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Why CAG -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <FadeIn client:visible>
        <h2 class="font-lora font-bold text-3xl text-center text-logo-dark mb-12">Why Choose Congo African Greys?</h2>
      </FadeIn>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { icon: '🏡', title: 'Home Aviary', body: "Not a commercial facility. Mark and Teri's birds are raised inside their Midland, TX home — socialized with family from hatch." },
          { icon: '📋', title: 'Full Documentation', body: 'Every bird ships with CITES captive-bred cert, hatch certificate, band number, DNA sexing cert, and avian vet health certificate.' },
          { icon: '🎓', title: '12 Years of Breeding', body: 'Founded in 2014. Hundreds of healthy placements. USDA AWA licensed. We know these birds — and we stand behind every one.' },
          { icon: '✈️', title: 'Nationwide Shipping', body: 'IATA-compliant transport to all 50 states. Birds arrive at your nearest airport — we coordinate everything.' },
          { icon: '💊', title: '3-Day Health Guarantee', body: 'Every bird comes with a 3-day health guarantee and avian vet health certificate dated within 10 days of shipment.' },
          { icon: '📞', title: 'Lifetime Support', body: "You're never alone. Mark and Teri answer questions about diet, behavior, and enrichment long after your bird comes home." },
        ].map((card, i) => (
          <FadeIn client:visible delay={i * 0.08}>
            <div class="bg-white rounded-xl p-6 shadow-sm border border-stone-100 h-full">
              <div class="text-3xl mb-3">{card.icon}</div>
              <h3 class="font-lora font-semibold text-logo-dark text-lg mb-2">{card.title}</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{card.body}</p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-center text-logo-dark mb-10">Common Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.name}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">
              {faq.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Schema type="faq" data={faqSchema} />
  <Schema type="organization" />

  <CTA />
</BaseLayout>
