---
import BaseLayout from '../layouts/BaseLayout.astro';
import Schema from '../components/Schema.astro';
import FadeIn from '../components/FadeIn';
import BirdCard from '../components/BirdCard.astro';

// cag-library components (the new component library)
import HeroV3      from '../components/cag-library/HeroV3.astro';
import CounterSnippet from '../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../components/cag-library/KeyTakeawayV2.astro';
import TocV3        from '../components/cag-library/TocV3.astro';
import OwnerCard    from '../components/cag-library/OwnerCard.astro';
import SplitFeature from '../components/cag-library/SplitFeature.astro';
import TrustStats   from '../components/cag-library/TrustStats.astro';
import ScamAwareness from '../components/cag-library/ScamAwareness.astro';
import CareGrid     from '../components/cag-library/CareGrid.astro';
import PricingTable from '../components/cag-library/PricingTable.astro';
import Testimonials from '../components/cag-library/Testimonials.astro';
import VideoSection from '../components/cag-library/VideoSection.astro';
import NewsletterV2 from '../components/cag-library/NewsletterV2.astro';
import CompareTableE from '../components/cag-library/CompareTableE.astro';
import FaqAccordion from '../components/cag-library/FaqAccordion.astro';
import ContactForm  from '../components/cag-library/ContactForm.astro';

const title = "African Grey Parrot Breeder | USDA-Licensed Congo & Timneh";
const description = "USDA-licensed African Grey parrot breeder. Mark & Teri Benjamin hand-raise captive-bred Congo & Timneh Greys in Midland, TX since 2014 — DNA-sexed, vet-checked, documented, nationwide shipping.";
const canonical = "https://congoafricangreys.com/";

// ─── Available birds (filterable) — prices from data/price-matrix.json ───
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    kind: 'chick', status: 'available', priceVal: 2300,
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Energetic, curious, and impossible to ignore.',
    notes: "Hand-raised male, 4 months old. Thrives in a lively home where there's always something to watch." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    kind: 'chick', status: 'available', priceVal: 2500,
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'She mimics your laugh before you finish it.',
    notes: 'Premium hand-raised female, 3 months old. Full social training. Responds to her name already.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    kind: 'adult', status: 'available', priceVal: 1700,
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, easy, and the bird first-time owners dream of.',
    notes: 'Soft temperament, easy to handle. 1-year-old female — personality fully developed, ready to bond.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    kind: 'pair', status: 'available', priceVal: 3500,
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two birds, one bond. They go together — and so do you.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised with full social training.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    kind: 'chick', status: 'available', priceVal: 1600,
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird. Bigger personality than you expected.',
    notes: 'Hand-raised male Timneh African Grey, 5 months old. Full social training. Ready to go home.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    kind: 'chick', status: 'available', priceVal: 1500,
    image: '/evie-timneh-african-grey-female-6-months.webp',
    hook: 'Calm, clever, and ready to come home.',
    notes: 'Hand-raised female Timneh African Grey, 6 months old. Full social training. Gentle and sociable.' },
];

// ─── Real reviews (verified buyers) ───
const reviews = [
  { headline: 'Affectionate, intelligent, already picking up words.',
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee.",
    name: 'Alice Tengan', location: 'Cheektowaga, NY', meta: 'Congo African Grey' },
  { headline: 'They made buying a bird online stress-free.',
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family, talking and entertaining us daily.",
    name: 'Elsie Creech', location: 'Jacksonville, FL', meta: 'Congo African Grey' },
  { headline: 'Healthy, friendly, and well-trained.',
    quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained. Watching it grow and bond with my family has been an absolute joy. I recommend C.A.Gs to anyone looking for a quality African Grey.",
    name: 'Henry Acadia', location: 'San Jose, CA', meta: 'Congo African Grey' },
];

// ─── Master FAQ (CITES Appendix I corrected; prices from price-matrix) ───
const faqItems = [
  { q: 'Are your African Grey parrots CITES documented?',
    a: 'Yes. African Greys are protected under CITES Appendix I — the highest level of protection, applied in 2017 to restrict commercial trade and protect wild populations from poaching and habitat loss. Every one of our parrots is captive-bred in the USA, never wild-caught, and comes with full documentation: hatch certificate, band number, DNA sexing certificate, and avian-vet health certificate.' },
  { q: 'How much does an African Grey parrot cost?',
    a: 'Our Congo African Greys range from $1,700 to $2,500 for individual birds, with the bonded Jins + Jeni pair at $3,500. Timneh African Greys are $1,500–$1,600. Proven breeding pairs are $3,000, and candled fertile eggs are $95 each (buy 5, free US shipping). A $200 deposit reserves your bird.' },
  { q: 'Do you ship African Grey parrots nationwide?',
    a: 'Yes. We ship IATA-compliant to all 50 states. Your bird travels in an approved live-animal carrier with an avian-vet health certificate dated within 10 days of travel, and you collect it at your nearest airport — calm, hydrated, and ready to meet you.' },
  { q: 'Are the birds DNA-sexed and vet-checked?',
    a: 'Every bird is DNA-sexed and examined by an avian veterinarian before placement. You receive the DNA certificate and the health certificate with your bird.' },
  { q: 'What is the difference between a Congo and a Timneh African Grey?',
    a: 'Both are African Greys. The Congo (Psittacus erithacus) is larger (400–600g) with a bright red tail and a famous talking vocabulary. The Timneh (Psittacus timneh) is smaller (275–375g) with a maroon tail, a calmer temperament, and often starts talking earlier — a great fit for first-time owners.' },
  { q: 'Is the deposit refundable?',
    a: 'The $200 deposit holds your bird and is applied to the final price. It is refundable any time before the bird ships.' },
  { q: 'How long do African Grey parrots live?',
    a: 'African Greys live 40 to 60 years in captivity, and well-cared-for birds frequently reach the upper end of that range. Bringing one home is a multi-decade commitment — many owners name their Grey in their estate plans. We talk every buyer through that reality before placement, because a bird this intelligent thrives only in a home prepared for the long haul.' },
  { q: 'Do African Grey parrots really talk?',
    a: 'Yes — the African Grey is widely regarded as the best talking parrot in the world. Congo Greys commonly build vocabularies of several hundred words, and the famous Grey named Alex, studied for three decades by Dr. Irene Pepperberg, demonstrated that Greys can use words in context, count, identify colors and shapes, and grasp the concept of zero. Every bird is an individual, but with daily interaction most of our Greys begin mimicking sounds and words within their first few months home.' },
  { q: 'What do African Grey parrots eat?',
    a: 'A healthy African Grey eats a formulated pellet diet as its base, supplemented with fresh vegetables, leafy greens, and limited fruit. Greys are prone to calcium deficiency (hypocalcemia), so calcium support and natural sunlight or full-spectrum light matter. Never feed avocado, chocolate, caffeine, or alcohol — all are toxic to parrots. We send every buyer home with the exact diet their bird is already eating to avoid digestive stress during the transition.' },
  { q: 'Do African Greys need a companion bird?',
    a: 'No — a single African Grey bonds deeply with its human family and does not require another bird. What it does require is daily interaction, mental enrichment, and out-of-cage time. A Grey left alone and under-stimulated can develop feather-plucking and other stress behaviors, which is why we match birds to homes that can give them attention, not just space.' },
  { q: 'Is an African Grey a good choice for a first-time bird owner?',
    a: 'It can be, with preparation. Of the two subspecies, the Timneh African Grey tends to be calmer and less prone to nervousness, which makes it a gentler introduction for first-time Grey owners. Either way, we provide lifetime support — Teri stays on the phone with new owners through the settling-in period and well beyond.' },
  // ── PAA-sourced "People Also Ask" questions (Google + GSC) ──
  { q: 'Are African Grey parrots good pets?',
    a: 'For the right owner, the African Grey is one of the most rewarding companion birds in the world — affectionate, endlessly intelligent, and capable of genuine conversation. They are not, however, a low-maintenance pet. A Grey needs daily interaction, mental enrichment, and an owner prepared for a 40–60 year relationship. Families who understand that commitment rarely regret it.' },
  { q: 'Are African Greys loud?',
    a: 'Compared with macaws and cockatoos, African Greys are relatively quiet. They are mimics and whistlers far more than screamers, so the sound of a Grey is usually words, doorbells, and microwave beeps rather than ear-splitting calls. Most families find their noise level very manageable in a normal home.' },
  { q: 'Can an African Grey be left alone during the day?',
    a: 'A Grey can be alone for a normal work day if it has a large cage, foraging toys, and rotated enrichment — but it should not be isolated for long stretches every day. These are highly social birds; chronic loneliness and boredom are the leading causes of feather-plucking. Plan for real daily interaction, not just food and water.' },
  { q: 'Why are African Grey parrots so expensive?',
    a: 'The price reflects ethical captive breeding: months of daily hand-feeding, DNA sexing, an avian-vet exam, CITES Appendix I documentation, and a closed band — plus the fact that wild trade is now banned, so every legitimate bird is captive-bred. A listing far below our $1,500 floor is the clearest sign of a scam or a sick, undocumented bird.' },
  { q: 'Do African Greys bond with only one person?',
    a: 'Congo African Greys in particular tend to choose a favorite person, but early, consistent handling by the whole household builds a bird that is comfortable with several people. We socialize every chick with multiple handlers from day one specifically to encourage that broader confidence.' },
  { q: 'Are African Grey parrots legal to own in the United States?',
    a: 'Yes. While the species is listed on CITES Appendix I — which bans commercial trade in wild-caught birds — captive-bred African Greys are legal to own and transfer domestically in the U.S. with proper documentation. Every bird we place is U.S. captive-bred and fully documented, so your ownership is on solid legal ground.' },
  { q: 'How big do African Grey parrots get?',
    a: 'A Congo African Grey reaches about 12–14 inches long and 400–600 grams. A Timneh is smaller — roughly 9–11 inches and 275–375 grams. Both need a cage with room to fully spread their wings and climb, plus daily out-of-cage time.' },
  { q: 'What age should I buy an African Grey?',
    a: 'Buy a fully weaned bird — never an unweaned chick. African Greys typically wean between 12 and 16 weeks, and hand-feeding a baby is risky for inexperienced owners. Every bird we sell is fully weaned, eating on its own, and ready to bond safely with its new family.' },
  { q: 'Male or female African Grey — which is better?',
    a: 'Behaviorally, male and female African Greys are very similar; personality is shaped far more by individual temperament and upbringing than by sex. Every bird we sell is DNA-sexed so you know exactly what you are bringing home. If you have a preference, just tell us in your inquiry.' },
  { q: 'How do I know an African Grey breeder is legitimate?',
    a: 'A real breeder can show a verifiable USDA Animal Welfare Act license, provides CITES Appendix I captive-bred paperwork, will video-call to show your specific bird on demand, accepts reversible payment (card, PayPal Goods, bank wire), and has a findable physical location. We meet every one of those tests — and we hand you the paperwork before any money moves.' },
];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "PetStore"],
  "name": "C.A.Gs – Midland, TX",
  "alternateName": "Congo African Greys",
  "url": "https://congoafricangreys.com/",
  "description": "USDA-licensed captive-bred African Grey parrot breeder — Congo & Timneh — in Midland, Texas.",
  "founder": ["Mark Benjamin", "Teri Benjamin"],
  "foundingDate": "2014",
  "telephone": "+1-402-696-0317",
  "address": { "@type": "PostalAddress", "addressLocality": "Midland", "addressRegion": "TX", "addressCountry": "US" },
  "areaServed": "United States",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "127" }
};

const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "Talking Congo & Timneh African Greys — Congo African Greys",
  "description": "Hand-raised Congo and Timneh African Greys learning words at our Midland, TX home aviary.",
  "thumbnailUrl": "https://congoafricangreys.com/congo-african-grey-variant.webp",
  "uploadDate": "2026-05-01",
  "contentUrl": "https://congoafricangreys.com/talking-african-grey-parrot-video.mp4"
};
---

<BaseLayout {title} {description} {canonical}>

  <!-- 1. Hero — cag-hero-v3:b "Authority Green" (REBUILD v2) -->
  <HeroV3 availableCount={birds.filter(b => b.status === 'available').length} />

  <!-- 2. Counter Snippet — cag-counter-snippet (Rule 31: 4 stats after H1) -->
  <CounterSnippet />

  <!-- 3. Key Takeaway — cag-key-takeaway-v2:02 (stat-forward answer box) -->
  <KeyTakeawayV2 />

  <!-- 4. TOC — cag-toc-v3:02 (grouped by part) -->
  <TocV3 />

  <!-- 5. About the Breeders — cag-owner-card (H-S-S, Mark & Teri) -->
  <OwnerCard />

  <!-- 6. Review block #1 — verified buyer social proof (Review-top image) -->
  <section id="reviews-top" class="scroll-mt-20 bg-cream py-14 px-4 md:py-16">
    <div class="container mx-auto max-w-[1100px]">
      <div class="mb-8 text-center">
        <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Verified Buyer Review</p>
        <h2 class="font-lora mt-2 text-3xl font-bold text-logo-dark md:text-4xl">What Do African Grey Families Say About C.A.Gs?</h2>
      </div>
      <Testimonials variant="feature" testimonials={[{ ...reviews[0], avatarSrc: '/african-grey-review-top.webp' }]} />
    </div>
  </section>

  <!-- 7. All Products — cag-available-grid (filterable Pill-Tabs) -->
  <section id="available-birds" class="py-16 px-4 bg-warm-white scroll-mt-20">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div class="border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">This Week's Aviary</p>
          <h2 class="font-lora font-bold text-3xl text-logo-dark">Which Hand-Fed African Greys Are Available Right Now?</h2>
          <p class="text-stone-500 mt-2 max-w-md text-sm leading-relaxed">Real birds. Real availability. Every one is hand-fed, DNA-sexed, CITES-documented, and vet-certified — no waitlist tricks, no bait listings.</p>
        </div>
        <a href="/african-grey-parrot-for-sale/" class="text-sm font-semibold text-clay hover:text-clay-dk border border-clay/40 hover:border-clay px-4 py-2 rounded-full transition-colors whitespace-nowrap">View all birds →</a>
      </div>

      <!-- Filter bar -->
      <div id="bird-filters" class="flex flex-wrap gap-2 mb-8 font-sora text-sm">
        <button data-filter="all" class="bird-filter is-active px-4 py-2 rounded-full border border-green/30 transition-colors">All</button>
        <button data-filter="Congo African Grey" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Congo</button>
        <button data-filter="Timneh African Grey" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Timneh</button>
        <button data-filter="chick" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Chicks</button>
        <button data-filter="adult" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Adults</button>
        <button data-filter="pair" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Pairs</button>
        <button data-filter="under2000" class="bird-filter px-4 py-2 rounded-full border border-green/30 transition-colors">Under $2,000</button>
      </div>

      <div id="bird-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {birds.map(bird => (
          <div class="bird-item" data-variant={bird.variant} data-kind={bird.kind} data-price={bird.priceVal} data-status={bird.status}>
            <BirdCard {...bird} />
          </div>
        ))}
      </div>
      <p id="bird-empty" class="hidden text-center text-stone-500 py-10 font-sora">No birds match that filter right now — <a href="/contact-us/" class="text-clay font-semibold">ask about upcoming clutches →</a></p>

      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {['CITES Captive-Bred Cert', 'DNA Sex Certificate', 'Avian Vet Health Cert', 'Hatch Certificate'].map(badge => (
          <span class="text-xs font-sora text-green bg-green/8 border border-green/20 px-3 py-1 rounded-full">✓ {badge}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. Eggs & Breeding Pairs — horizontal compact list-style (links to category pages) -->
  <section id="eggs-pairs" class="scroll-mt-20 bg-cream py-14 px-4 md:py-16">
    <div class="container mx-auto max-w-[1100px]">
      <div class="mb-7 border-l-4 border-green pl-4">
        <p class="font-sora text-xs font-semibold uppercase tracking-widest text-clay mb-2">Beyond Single Birds</p>
        <h2 class="font-lora font-bold text-3xl text-logo-dark">Looking for Fertile Eggs or a Bonded Breeding Pair?</h2>
        <p class="font-sora text-stone-500 mt-2 max-w-2xl text-sm leading-relaxed">Whether you incubate your own clutch or want a proven, DNA-sexed pair for your own aviary, C.A.Gs places both — with the same CITES Appendix I documentation as every hand-fed baby.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {[
          { img: '/african-grey-candled-eggs.webp',
            tag: 'Fertile Eggs',
            title: 'African Grey Fertile Eggs',
            desc: 'Candled, fertility-checked Congo & Timneh eggs — $95 each, free US shipping on 5+.',
            href: '/african-grey-parrot-bird-eggs-for-sale-usa/',
            cta: 'View fertile eggs' },
          { img: '/congo-african-grey-breeding-pair-aviary.webp',
            tag: 'Breeding Pairs',
            title: 'Proven Breeding Pairs',
            desc: 'Bonded, DNA-sexed African Grey pairs ($3,000) — proven producers for serious aviculturists.',
            href: '/african-grey-breeding-pair-for-sale/',
            cta: 'View breeding pairs' },
        ].map(item => (
          <a href={item.href} class="group flex items-stretch gap-4 rounded-2xl border border-black/[0.07] bg-white p-3 transition-shadow hover:shadow-lg" style="box-shadow:0 4px 18px rgba(60,30,10,0.05);">
            <img src={item.img} alt={`${item.title} for sale at C.A.Gs — captive-bred, CITES Appendix I documented`} width="160" height="160" loading="lazy" decoding="async" class="h-28 w-28 flex-shrink-0 rounded-xl object-cover sm:h-32 sm:w-32" />
            <div class="flex flex-col justify-center py-1 pr-2">
              <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">{item.tag}</span>
              <h3 class="font-lora mt-1 text-xl font-bold text-logo-dark">{item.title}</h3>
              <p class="font-sora mt-1.5 text-[13.5px] leading-relaxed text-stone-600">{item.desc}</p>
              <span class="font-sora mt-2 inline-flex items-center gap-1 text-sm font-semibold text-clay group-hover:gap-2 transition-all">{item.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. Congo African Grey -->
  <section id="congo" class="py-16 px-4 scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8 border-l-4 border-green pl-4">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Congo African Grey · Psittacus erithacus</p>
        <h2 class="font-lora font-bold text-3xl text-logo-dark md:text-4xl">What Is a Congo African Grey — the Classic Red-Tailed Talker?</h2>
        <p class="text-stone-600 leading-relaxed mt-3 text-[15px]" style="max-width:70ch;">Decades of <a href="https://alexfoundation.org/" rel="noopener noreferrer" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">documented cognition research</a> made the Congo African Grey the bird people picture when they hear "the smartest parrot in the world." At C.A.Gs in Midland, TX, every <a href="/congo-african-grey-for-sale/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">Congo African Grey we place</a> is hand-fed from the nest box, DNA-sexed, and CITES Appendix I documented — the proof behind the reputation.</p>
      </div>
      <SplitFeature variant="editorial"
        eyebrow="THE LARGER SUBSPECIES"
        title="Why Is the Congo Considered the World's Best Talking Parrot?"
        body="The Congo African Grey (Psittacus erithacus) is the larger of the two subspecies — 400–600 grams, a brilliant scarlet tail, and a silver-scalloped grey body. Congos are extraordinary mimics with documented vocabularies of hundreds of words, and they bond deeply with their family. Ours are hand-raised in our Midland, Texas home, DNA-sexed, and CITES Appendix I documented."
        bullets={[
          { label: '<b class="text-ink">Price:</b> $1,700 (adult) – $2,500 (hand-raised baby)' },
          { label: '<b class="text-ink">Size:</b> 400–600g · 12–14 in · bright red tail' },
          { label: '<b class="text-ink">Lifespan:</b> 40–60 years' },
          { label: '<b class="text-ink">Best for:</b> owners who want a deeply bonded, talkative companion' },
        ]}
        quote="A Congo Grey doesn't just mimic words — it learns when to use them."
        ctaLabel="See Congo African Greys for sale"
        ctaHref="/congo-african-grey-for-sale/"
        imageSrc="/congo-african-grey-variant.webp"
      />
      <div class="max-w-3xl mx-auto pb-2 mt-10">
        <h3 class="font-lora font-bold text-2xl text-logo-dark mb-3">How Big Does a Congo African Grey Get, and Why the Red Tail?</h3>
        <div class="space-y-4 text-stone-600 leading-relaxed" style="max-width:70ch;">
          <p>Field guides like the <a href="https://www.parrots.org/encyclopedia/grey-parrot" rel="noopener noreferrer" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">World Parrot Trust species profile</a> describe the Congo exactly as buyers first see it: a dove-grey body with delicate white scalloping, an all-black beak, and the striking scarlet tail that sets it apart from every other parrot. Adults weigh roughly 400–600 grams and measure about 12–14 inches — the larger of the two subspecies, and the one with the clearest, most human-sounding voice in the parrot world.</p>
          <p>Temperament is where the Congo earns its reputation as a sensitive bird. Because Congos read household mood closely and often bond hardest with one or two people, they thrive in calmer, attentive homes — the same routine and patience covered in our <a href="/african-grey-parrot-care-guide/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">African Grey care guide</a> is what turns that sensitivity into a decades-long conversation. Pricing reflects that ethical, hand-raised start, and our full <a href="/african-grey-parrot-price/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">African Grey price breakdown</a> shows exactly what each documented bird includes.</p>
        </div>
        <h5 class="font-sora font-bold text-sm uppercase tracking-wide text-green mt-6 mb-1.5">What Is the Congo's Scientific Name — Psittacus erithacus?</h5>
        <p class="text-stone-600 leading-relaxed text-[15px]" style="max-width:70ch;"><em>Psittacus erithacus</em> is the formal binomial for the Congo African Grey, native to the rainforests of West and Central Africa and listed on <a href="https://en.wikipedia.org/wiki/Grey_parrot" rel="noopener noreferrer" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">CITES Appendix I as a protected species</a>. Every Congo we place is U.S. captive-bred and never wild-caught.</p>
        <div class="mt-6 space-y-3">
