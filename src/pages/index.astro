<script is:inline>
  // Bird filter
  (function () {
    const grid = document.getElementById('bird-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.bird-item'));
    const empty = document.getElementById('bird-empty');
    document.querySelectorAll('.bird-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.bird-filter').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const f = btn.getAttribute('data-filter');
        let shown = 0;
        items.forEach(it => {
          let show = true;
          if (f === 'all') show = true;
          else if (f === 'under2000') show = Number(it.getAttribute('data-price')) < 2000;
          else show = it.getAttribute('data-variant') === f || it.getAttribute('data-kind') === f;
          it.style.display = show ? '' : 'none';
          if (show) shown++;
        });
        if (empty) empty.classList.toggle('hidden', shown > 0);
      });
    });
  })();

  // First-year cost calculator
  (function () {
    const bird = document.getElementById('calc-bird');
    const total = document.getElementById('calc-total');
    if (!bird || !total) return;
    const ship = document.getElementById('calc-ship');
    const cage = document.getElementById('calc-cage');
    const vet = document.getElementById('calc-vet');
    const fmt = n => '$' + n.toLocaleString('en-US');
    function recalc() {
      let t = Number(bird.value);
      if (ship.checked) t += 400;
      if (cage.checked) t += 450;
      if (vet.checked) t += 700;
      total.textContent = fmt(t);
    }
    [bird, ship, cage, vet].forEach(el => el.addEventListener('change', recalc));
    recalc();
  })();

  // Documentation checklist score
  (function () {
    const checks = Array.from(document.querySelectorAll('.doc-check'));
    const score = document.getElementById('doc-score');
    if (!checks.length || !score) return;
    function upd() {
      const n = checks.filter(c => c.checked).length;
      score.textContent = n + ' / ' + checks.length + ' verified';
      score.style.color = n === checks.length ? '#2D6A4F' : '#5a5248';
    }
    checks.forEach(c => c.addEventListener('change', upd));
  })();
</script>

<style>
  .bird-filter.is-active { background: var(--color-green, #2D6A4F); color: #fff; border-color: var(--color-green, #2D6A4F); }
  /* Shipping process-flow infographic: stack vertically on mobile */
  @media (max-width: 767px) {
