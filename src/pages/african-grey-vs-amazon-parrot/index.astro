.cvt-main p{line-height:1.68;margin:0 0 15px;max-width:70ch}
.cvt-main a{color:var(--clay-t);text-decoration:underline;text-underline-offset:2px}
.cvt-main a.btn-clay{color:#fff;text-decoration:none}
.cvt-main a.btn-ghost{color:var(--f);text-decoration:none}
.cvt-main a.btn-ghost:hover{color:#fff}
.cvt-main .bird-photo,.cvt-main .blog-c,.cvt-main .ship-places a{text-decoration:none}
.sec-img{display:block;width:100%;max-width:760px;aspect-ratio:760/400;object-fit:cover;height:auto;border-radius:18px;margin:4px 0 18px;box-shadow:0 6px 20px rgba(60,30,10,.1)}
.sec-img.inf-img{aspect-ratio:1408/768;box-shadow:0 4px 16px rgba(60,30,10,.08)}
/* PORTRAIT — square OG photos (e.g. the Congo close-up) show whole, centered, not cover-cropped to the 1.9:1 band */
.sec-img.portrait{max-width:420px;aspect-ratio:1/1;object-position:center;margin-left:auto;margin-right:auto}
/* PORTRAIT-TALL — 3:4 source shown whole at a medium size (Moluccan/Citron contrast) */
.sec-img.portrait-tall{max-width:340px;aspect-ratio:3/4;object-position:center;margin-left:auto;margin-right:auto}
/* PHOTO 4:3 — landscape OG photo shown whole at a medium size (breeder-with-birds) */
.sec-img.photo43{max-width:480px;aspect-ratio:4/3;object-position:center 42%;margin-left:auto;margin-right:auto}
/* NL-INFLOW — newsletters that sit inside the article flow read as rounded section bands */
.nl-inflow{margin:24px 0;border-radius:18px;overflow:hidden;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.nl-inflow>*{max-width:none}
.qa-box{background:#eaf4ef;border:1px solid #cfe4da;border-radius:16px;padding:20px 22px;margin:0 0 15px}
.qa-box p{margin:0;max-width:none}
.qa-box strong{color:var(--f)}
/* QUICK ANSWER 4B — clay-recolored snippet (pin accent, no side-stripe) + Choose-if cards */
.qa-snip{position:relative;background:linear-gradient(180deg,#fdf2ef,#fbeae4);border:1px solid #f0c4b7;border-radius:16px;padding:18px 20px 18px 50px;margin:0 0 14px}
.qa-snip .qa-pin{position:absolute;left:17px;top:17px;display:flex;color:var(--clay-ink);font-size:1.35rem}
.qa-snip p{margin:0;max-width:none;line-height:1.62}
.qa-snip strong{color:var(--clay-ink)}
.choose-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:0 0 16px}
.choose-c{background:#fff;border:1px solid var(--bd);border-radius:14px;padding:15px 17px}
.choose-c.grey{border-top:3px solid var(--f)}
.choose-c.too{border-top:3px solid var(--clay-ink)}
.choose-h{display:block;font-family:'Newsreader',serif;font-weight:700;font-size:1.02rem;margin-bottom:9px}
.choose-c.grey .choose-h{color:var(--f)}
.choose-c.too .choose-h{color:var(--clay-ink)}
.choose-c ul{margin:0;padding-left:18px}
.choose-c li{font-size:.86rem;line-height:1.5;margin-bottom:6px;color:#4c443c}
.choose-c li:last-child{margin-bottom:0}
@media(max-width:640px){.choose-grid{grid-template-columns:1fr}}
/* SEAM — logo medallion on hairlines (2026-07-05: chip treatment, no more flat strip) */
.seam{display:flex;align-items:center;gap:14px;margin:28px 0}
.seam::before{content:"";flex:1;height:2px;border-radius:1px;background:linear-gradient(90deg,transparent,rgba(240,128,112,.6))}
.seam::after{content:"";flex:1;height:2px;border-radius:1px;background:linear-gradient(90deg,rgba(240,128,112,.6),transparent)}
.seam img{width:54px;height:54px;object-fit:cover;background:#fff;border:2px solid rgba(232,96,76,.35);border-radius:50%;padding:2px;box-shadow:0 4px 14px rgba(60,30,10,.14)}
/* KEY TAKEAWAYS — refined stat cards: clay tick, ink stat, hairline, quieter sub */
.kt-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:0 0 18px}
.kt-c{background:#fff;border:1px solid var(--bd);border-radius:14px;padding:16px 16px 14px}
.kt-tick{display:block;width:22px;height:4px;border-radius:2px;background:var(--clay-ink);margin-bottom:10px}
.kt-c b{font-family:'Newsreader',serif;color:#2a2622;font-size:1.4rem;display:block;line-height:1.15;letter-spacing:-.01em;padding-bottom:8px;border-bottom:1px solid var(--bd);margin-bottom:8px}
.kt-sub{font-size:.86rem;color:#57534e;line-height:1.5;display:block}
/* SIDE-BY-SIDE — CompareTableE idiom: branded gradient headers + Edge, mobile tabs */
.cmpe-tabs{display:none;gap:8px;margin:0 0 10px}
.cmpe-tab{display:inline-flex;align-items:center;gap:7px;border-radius:50px;padding:9px 18px;font:inherit;font-size:.88rem;font-weight:700;cursor:pointer;background:#fff;color:var(--f);border:2px solid var(--f)}
.cmpe-tab img{width:20px;height:20px;object-fit:contain}
.cmpe-tab.active{background:var(--f);color:#fff}
.cmpe-tab[data-v="t"]{border-color:var(--clay-ink);color:var(--clay-ink)}
.cmpe-tab[data-v="t"].active{background:var(--clay-ink);color:#fff}
.tbl-wrap{overflow-x:auto;border-radius:16px;border:1px solid var(--bd);box-shadow:0 4px 20px rgba(60,30,10,.07)}
.tbl-wrap.plain{box-shadow:none;border-radius:12px;max-width:640px}
.cmp-tbl{width:100%;border-collapse:collapse;font-size:.9rem;background:#fff}
.cmp-tbl th{padding:12px;text-align:left;font-weight:600;vertical-align:middle}
.cmp-tbl .th-f,.cmp-tbl .th-e{background:#fff;color:#57534e;font-size:.7rem;letter-spacing:.09em;text-transform:uppercase;border-bottom:1px solid var(--bd)}
.cmp-tbl .th-c{background:linear-gradient(135deg,#2D6A4F,#1f4d39);color:#fff}
.cmp-tbl .th-t2{background:linear-gradient(135deg,#e8604c,#c8472f);color:#fff}
.th-flex{display:flex;align-items:center;gap:10px}
.th-flex img{width:30px;height:30px;object-fit:contain;flex:none}
.th-title{display:block;font-family:'Newsreader',serif;font-weight:700;font-size:1.02rem;line-height:1.2}
.th-sub{display:block;font-size:.72rem;font-weight:400;opacity:.9;margin-top:2px}
.cmp-tbl td{padding:10px 12px;border-bottom:1px solid var(--bd)}
.cmp-tbl tr:nth-child(even) td{background:var(--cream)}
.cmp-tbl .td-f{font-weight:600}
.cmp-tbl .edge{color:var(--f);font-weight:700}
/* scorecard data table (real DOM data behind the infographic) */
.score-tbl{width:100%;border-collapse:collapse;font-size:.86rem;background:#fff}
.score-tbl th{background:var(--f);color:#fff;padding:9px 12px;text-align:left;font-weight:600}
.score-tbl td{padding:8px 12px;border-bottom:1px solid var(--bd)}
.score-tbl tr:last-child td{border-bottom:none}
.score-tbl tr:nth-child(even) td{background:var(--cream)}
.score-tbl .sc{font-weight:700;color:var(--f)}
/* SCORECARD — stack into cards on phones so the 4 columns never cramp */
@media(max-width:640px){
  .tbl-wrap.plain{border:none;box-shadow:none;border-radius:0;max-width:none;overflow:visible}
  .score-tbl,.score-tbl tbody,.score-tbl tr,.score-tbl td{display:block;width:auto}
  .score-tbl thead{position:absolute;left:-9999px}
  .score-tbl tr{background:#fff!important;border:1px solid var(--bd);border-radius:14px;padding:12px 15px;margin-bottom:11px;box-shadow:0 3px 12px rgba(60,30,10,.06)}
  .score-tbl tr:nth-child(even) td{background:transparent}
  .score-tbl td{border:none;padding:6px 0;display:flex;justify-content:space-between;align-items:baseline;gap:14px}
  .score-tbl td::before{content:attr(data-label);font-weight:600;color:#57534e;font-size:.78rem;letter-spacing:.02em}
  .score-tbl .sc-trait{font-family:'Newsreader',serif;font-size:1.1rem;color:#2a2622;border-bottom:1px solid var(--bd);padding-bottom:9px;margin-bottom:3px}
  .score-tbl .sc-trait::before{display:none}
  .score-tbl .sc{color:var(--f);font-weight:700;font-size:1.02rem}
  .score-tbl .sc-note{flex-direction:column;align-items:flex-start;gap:3px;color:#57534e;font-size:.88rem}
}
.cap{font-size:.85rem;color:#7a6f64;font-style:italic}
.author-card{background:#fff;border:1px solid var(--bd);border-radius:20px;overflow:hidden;margin:0 0 18px;box-shadow:0 4px 16px rgba(60,30,10,.07)}
.ac-banner{display:block;width:100%;height:240px;object-fit:cover}
.ac-row{display:flex;gap:16px;align-items:center;padding:18px 20px}
.ac-avatar{width:72px;height:54px;border-radius:12px;object-fit:cover;object-position:50% 32%;flex:none}
.ac-name{font-family:'Newsreader',serif;font-size:1.2rem;margin:0}
.ac-sub{font-size:.85rem;color:#7a6f64;margin:2px 0 8px}
.ac-badges{margin:0;display:flex;gap:6px;flex-wrap:wrap}
