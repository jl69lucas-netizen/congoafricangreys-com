.blog-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.blog-c{background:#fff;border:1px solid var(--bd);border-radius:16px;overflow:hidden;text-decoration:none!important;color:#2a2622;transition:transform .15s,box-shadow .2s}
