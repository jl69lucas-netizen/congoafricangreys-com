.blog-c img{width:100%;height:140px;object-fit:cover}
.blog-body{padding:12px 14px 14px}
.blog-tag{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 11px;font-size:.68rem;font-weight:600}
