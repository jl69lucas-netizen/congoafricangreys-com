.bird-cta{text-align:center;margin-top:auto}
.ship-mini{font-size:.68rem;color:#7a6f64;display:block;margin-top:10px;border-top:1px dashed var(--bd);padding-top:6px}
.pair-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:0 0 16px}
.pair-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
