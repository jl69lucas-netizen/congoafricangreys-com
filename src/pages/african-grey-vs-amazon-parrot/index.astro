---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "African Grey vs Amazon Parrot: Talking, Singing, Noise, Temperament & Cost Compared by Breeders | C.A.Gs – The Honest Talker-vs-Singer Guide";
const description = "African Grey vs Amazon parrot, compared honestly by breeders who raise Greys: talking versus singing, noise, powder-down dust, biting, hormonal maturity, health and first-year cost — plus which of six Amazon species you're really weighing, and the CITES captive-bred answer no other page gives.";
const canonical = "https://congoafricangreys.com/african-grey-vs-amazon-parrot/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey vs Amazon Parrot", url: "/african-grey-vs-amazon-parrot/" },
];

// 6 Amazon species subsections (S7a–f) — richest-image-first order, each with its OG photo
const species = [
  { id: "red-lored", name: "Red-Lored Amazon", sci: "Amazona autumnalis", img: "/red-lored-amazon-parrot.webp",
    alt: "Red-Lored Amazon with its red forehead and yellow cheek patch, one of the gentler Amazon species weighed against a talking African Grey",
    size: "13 in · 310–480 g", noise: "Moderate for an Amazon", talk: "Modest talker", trait: "One of the calmer Amazons",
    body: "The Red-Lored — green with a red forehead and a butter-yellow cheek — is among the more even-tempered Amazons, which is exactly why it leads this list. It talks in a smaller vocabulary than a Grey and with less of the context a Grey brings, but it hormones less ferociously than the big yellow-headed Amazons below. Beside our Greys the trade is the recurring one on this page: the Amazon gives up vocabulary and clarity, the Grey gives up the Amazon's easy, extroverted confidence with strangers." },
  { id: "white-fronted", name: "White-Fronted Amazon", sci: "Amazona albifrons", img: "/white-fronted-amazon-parrot.webp",
    alt: "White-Fronted Amazon showing the white forehead and red eye-ring of the smallest Amazon species, compared with an African Grey",
    size: "10 in · 200–250 g", noise: "Moderate", talk: "Limited talker", trait: "The smallest Amazon",
    body: "The White-Fronted is the smallest Amazon — roughly a third the weight of a Congo Grey — with a white forehead, red eye-ring, and (in males) red wing coverts you can actually sex by eye, which almost no other Amazon offers. It's feisty for its size and a modest talker at best. If apartment footprint is driving the decision, this is the Amazon that competes with a Grey on space; on talking and contextual smarts, the Grey still wins comfortably." },
  { id: "yellow-shouldered", name: "Yellow-Shouldered Amazon", sci: "Amazona barbadensis", img: "/yellow-shouldered-amazon-parrot.webp",
    alt: "Yellow-Shouldered Amazon with yellow crown and yellow bend-of-wing, a rarer Amazon species shown beside the African Grey",
    size: "13 in · 470–550 g", noise: "Moderate to loud", talk: "Modest talker", trait: "Rare, endangered in the wild",
    body: "The Yellow-Shouldered wears a yellow crown and a yellow bend-of-wing, and it is genuinely uncommon as a pet — endangered in its arid island range, which makes captive-bred provenance and paperwork more important here, not less. Temperament sits in the Amazon middle: sociable, seasonally spicy, a fair but unremarkable talker. Against a Grey it underscores the point of this whole section — 'Amazon' is a genus of very different birds, and this one behaves nothing like the opera-singing yellow-heads that follow." },
  { id: "blue-fronted", name: "Blue-Fronted Amazon", sci: "Amazona aestiva", img: "/blue-fronted-amazon-parrot.webp",
    alt: "Blue-Fronted Amazon with its blue forehead and yellow face, a classic pet Amazon and strong talker compared to an African Grey",
    size: "15 in · 350–500 g", noise: "Loud", talk: "Strong talker & singer", trait: "A classic pet Amazon",
    body: "The Blue-Fronted — blue brow over a variable yellow face — is one of the classic companion Amazons and a genuinely strong talker and singer, the point where the Amazon starts to close the talking gap on volume and melody even if not on vocabulary or context. It is also where hormones start to bite: mature Blue-Fronts can turn seasonally aggressive. This is the first of the three Amazons owners on Reddit specifically warn new keepers about — worth reading the hormonal-maturity section below before you fall for the face." },
  { id: "yellow-naped", name: "Yellow-Naped Amazon", sci: "Amazona auropalliata", img: "/yellow-naped-amazon-parrot.webp",
    alt: "Yellow-Naped Amazon with the yellow band across its nape, among the best-talking Amazons, shown alongside an African Grey",
    size: "14 in · 480–680 g", noise: "Very loud", talk: "Elite talker & singer", trait: "Best-talking Amazon — and very hormonal",
    body: "The Yellow-Naped, marked by a yellow band across the back of the neck, is the Amazon that actually rivals a Grey for talking — many keepers rate it the best-talking Amazon, and it sings with a prosody no Grey matches. The catch is temperament: it is highly intelligent, very loud, and among the most hormonally intense parrots kept, capable of real aggression in breeding season. It is also endangered. A Grey gives you the clearer, more contextual talker with far steadier behaviour; the Yellow-Nape gives you a showman you must manage." },
  { id: "double-yellow-headed", name: "Double-Yellow-Headed Amazon", sci: "Amazona oratrix", img: "/double-yellow-headed-amazon-parrot.webp",
    alt: "Double-Yellow-Headed Amazon whose entire head turns yellow with maturity, a top-talking but hormonal Amazon compared with an African Grey",
    size: "15 in · 380–550 g", noise: "Very loud", talk: "Elite talker & singer", trait: "Operatic talker — notoriously hormonal",
    body: "The Double-Yellow-Headed grows a fully yellow head at maturity and is the Amazon of legend — an operatic singer and top-tier talker that owners adore. It is also the Amazon most associated with hormonal aggression as it matures, the bird behind the forum warnings about a sweet baby becoming a challenging adult. Endangered in the wild and demanding in the home, it belongs with experienced keepers. Beside a Grey it is the sharpest version of this page's whole argument: dazzling performance for serious behavioural commitment, versus the Grey's quieter, steadier brilliance." },
];

// S19 — available birds, read live from clutch-inventory (never hardcoded status)
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === 'available')
  .sort((a, b) => (a.variant === 'congo_african_grey' ? -1 : 1));

const faqs = [
  { q: "What is the difference between an African Grey and an Amazon parrot?", a: "The African Grey is a silver-grey, red-tailed parrot prized as the best-talking bird on earth — a quiet, contextual, one-person thinker. An Amazon is a green, extroverted parrot that sings and projects, bonds more readily with a whole household, and comes in many species with sharply different temperaments. In short: the Grey out-talks and out-thinks with words; the Amazon out-sings and out-socialises. The Grey is dustier and more sensitive; the Amazon is louder and more prone to hormonal swings." },
  { q: "What are the cons of the Amazon parrot?", a: "The main drawbacks are volume, hormones and obesity. Amazons are loud all day, not just at dawn and dusk, and the yellow-headed species can turn seasonally aggressive as they mature — the single most common reason Amazon ownerships end. They are also prone to obesity and fatty liver disease on the wrong diet. On the plus side they are hardy, confident, sociable birds and superb singers; the cons are manageable for prepared owners but real." },
  { q: "What are the disadvantages of the African Grey parrot?", a: "Greys are sensitive, dusty and easily bored. They produce fine powder-down dander that bothers allergy households, they are prone to feather-plucking if under-stimulated, and they bond so specifically that they can be reserved with strangers. They also need calcium, Vitamin A and UV-B attention to avoid hypocalcemia. None of this makes them bad companions — it makes them a bird for owners who will enrich, bathe and vet them properly for decades." },
  { q: "What is the friendliest parrot to own — a Grey or an Amazon?", a: "For an outgoing, whole-family bird, an Amazon usually reads as friendlier: extroverted, confident with visitors, quick to perform. A Grey is deeply devoted but often to one person, and warms to strangers slowly. Neither is objectively friendlier — they're social in different ways. If you want a bird that greets guests, lean Amazon; if you want a profound one-person bond, lean Grey. Both need daily interaction to stay friendly at all." },
  { q: "Which parrot has the highest IQ, the African Grey or the Amazon?", a: "The African Grey is the benchmark for parrot intelligence. Decades of research by Dr. Irene Pepperberg with Alex the Grey demonstrated counting, categorisation and contextual language use that reset expectations for bird cognition. Amazons are bright, trainable and socially shrewd, but the Grey is the species science reaches for when it studies parrot reasoning. If cognitive depth and contextual talking are the draw, the Grey leads." },
  { q: "How much does an African Grey cost compared to an Amazon?", a: "Our documented Congo African Greys run $1,700 to $3,500 and Timnehs $1,500 to $1,600, every bird DNA-sexed, disease-screened and CITES-documented. Amazon market prices vary widely by species and are set by other sellers, not us — we raise Greys only. On either side, the number that matters is documentation, not the sticker: a cheap, undocumented parrot is a different and riskier purchase. Our full breakdown lives on the African Grey price page." },
  { q: "How long will an Amazon parrot live, and how does that compare to a Grey?", a: "Both are multi-decade commitments. Amazons commonly live 40 to 70 years with good care, and African Greys 40 to 60 — either bird can outlive the person who buys it. So a written succession plan — spelling out who takes over the bird's care — is simply part of owning either species responsibly. Lifespan is not a tiebreaker here; the honest question is whether your next several decades have room for a demanding parrot." },
  { q: "Can an African Grey and an Amazon parrot live together?", a: "Only in separate cages, with supervised out-time and never left alone together. Both are strong-beaked, opinionated birds, and Amazons can be pushy — a bad interaction can injure a Grey fast. Experienced multi-bird keepers manage it with slow introductions and constant supervision, but for most homes a single demanding parrot is already a full-time commitment. Two at once is a serious step up in noise, dust, cost and conflict management." },
  { q: "Do Greys talk better while Amazons sing better?", a: "Broadly, yes — and it's the most useful way to frame the choice. Greys win on vocabulary, clarity and contextual use of words; owners of both consistently say the Grey is the more articulate mimic. Amazons win on volume, melody and prosody — the yellow-headed species are famous 'opera singers.' Neither guarantees anything for an individual bird, but if you dream of conversation, choose the Grey; if you love a bird that belts songs, choose an Amazon." },
  { q: "Is an African Grey a good first bird compared to an Amazon?", a: "Neither is a true beginner's parrot — both are intelligent, loud enough, long-lived and demanding. A well-researched first-timer can succeed with a Grey, which is steadier in behaviour, provided they commit to enrichment and dust management. A big yellow-headed Amazon, with its hormonal swings and volume, is better left to experienced keepers. If this is your first parrot, the honest advice on both sides is: start smaller, or go in with your eyes fully open." },
  { q: "Are African Greys and Amazon parrots wild-caught?", a: "Reputable ones are not. Both African Greys and Amazons are CITES-listed — the Grey on Appendix I since 2017 — and every bird we place is captive-bred in the USA with full paperwork, never wild-caught. Captive-bred, CITES-documented birds are legal to own and transfer domestically. Any listing that is vague about origin, or that hints at imported or wild-sourced birds, is a listing to walk away from for either species." },
  { q: "Which is quieter for an apartment, an African Grey or an Amazon?", a: "The African Grey, clearly. Greys are among the least screamy parrots, with fairly predictable dawn-and-dusk vocal sessions, while Amazons are loud across the day and the big species can carry through shared walls. Neither is silent, and both need daily out-of-cage time, but for thin walls and close neighbours the Grey is the far safer apartment bird. The main Grey trade-off in a small space is dust, not noise." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey vs Amazon Parrot: Talking, Singing, Noise, Temperament & Cost Compared",
  description: description,
  author: { "@type": "Organization", name: "C.A.Gs – Congo African Greys, Midland TX" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com" },
  mainEntityOfPage: canonical,
  datePublished: "2026-06-04",
  dateModified: "2026-07-12",
};

// NOTE: no page-level BreadcrumbList schema — the <Breadcrumb> component already
// emits it; a second copy trips the breadcrumb_one gate (found 2026-07-04).

// verdict table (S6) — Length + Body shade rows added 2026-07-05 (competitor sweep:
// the top-ranked info pages all lead with the charcoal shade / inches figures we lacked)
// congo key = African Grey column, timneh key = Cockatoo column (keeps the CompareTableE markup unchanged)
const rows = [
  { attr: "Talking (vocabulary & context)", congo: "Exceptional — 200–1,000+ words, in context", timneh: "Good in top species; smaller, less contextual", edge: "African Grey" },
  { attr: "Singing (melody & volume)", congo: "Modest — whistles & mimicry", timneh: "Superb — yellow-heads are 'opera singers'", edge: "Amazon" },
  { attr: "Temperament", congo: "Reserved, one-person, sensitive", timneh: "Extroverted, confident, 'spicy'", edge: "Depends on you" },
  { attr: "Noise level", congo: "Moderate — least screamy parrots", timneh: "Loud, all day", edge: "African Grey" },
  { attr: "Body size", congo: "12–14 in · 400–600 g", timneh: "10–15 in · 200–680 g by species", edge: "Comparable" },
  { attr: "Powder-down dust", congo: "High — allergy-relevant", timneh: "Low", edge: "Amazon (less dust)" },
  { attr: "Hormonal aggression", congo: "Mild, plucking-prone if bored", timneh: "High in yellow-headed species", edge: "African Grey" },
  { attr: "Obesity / fatty liver", congo: "Lower risk", timneh: "High risk on wrong diet", edge: "African Grey" },
  { attr: "Beginner suitability", congo: "Demanding but steadier", timneh: "Demanding; big yellow-heads harder", edge: "Grey, marginally" },
  { attr: "Apartment fit", congo: "Plausible with daily time", timneh: "Louder; small species workable", edge: "African Grey" },
  { attr: "Lifespan", congo: "40–60 years", timneh: "40–70 years", edge: "Both lifelong" },
  { attr: "Typical price", congo: "$1,700–$3,500 (our Greys)", timneh: "Varies by species (external market)", edge: "Depends" },
  { attr: "CITES documentation", congo: "Appendix I — included", timneh: "CITES-listed — we don't sell them", edge: "Grey (we document)" },
];

const takeaways = [
  { big: "Talk vs sing", sub: "Greys win vocabulary & context; Amazons win melody & volume" },
  { big: "2 vs 30+", sub: "you're weighing two Grey species against a genus of very different Amazons" },
  { big: "Louder all day", sub: "Amazons project across the day; Greys are the least screamy parrots" },
  { big: "Dust vs hormones", sub: "the Grey's trade-off is powder-down; the Amazon's is hormonal maturity" },
  { big: "40–70 yrs", sub: "either bird can outlive its owner; a caretaker plan matters" },
  { big: "6 species", sub: "we name the Red-Lored, White-Fronted, Yellow-Shouldered, Blue-Fronted, Yellow-Naped & Double-Yellow-Head" },
  { big: "100%", sub: "documented — CITES papers, DNA sexing certificate and PBFD/APV PCR results on every Grey" },
  { big: "$185 / $350", sub: "nationwide airport pickup or door-to-door delivery" },
];

// c = African Grey, t = Amazon (keeps the score-table markup unchanged)
const scores = [
  { trait: "Talking (vocabulary & context)", c: 10, t: 7, note: "the Grey's signature; top Amazons come close" },
  { trait: "Singing (melody & volume)", c: 5, t: 10, note: "the Amazon's signature" },
  { trait: "Quietness", c: 7, t: 3, note: "Amazons are loud all day" },
  { trait: "Low dust / dander", c: 4, t: 8, note: "the Grey is the dusty one here" },
  { trait: "Steady (low-hormonal) temperament", c: 8, t: 4, note: "yellow-head Amazons swing hard" },
  { trait: "Beginner-friendliness", c: 5, t: 4, note: "neither is truly easy" },
  { trait: "Apartment fit", c: 7, t: 4, note: "the Grey is quieter for shared walls" },
];

// S19 — real photo per bird card (never a photo-less card); crops refreshed 2026-07-05
const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a cuddly tamed female Congo African Grey resting on her keeper's lap" },
  "amie": { src: "/amie-congo-african-grey-handfed-baby-card.webp", alt: "Amie, a hand-fed baby female Congo African Grey snuggled against her keeper's shoulder" },
  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey standing next to his toy ball" },
  "jins-jeni": { src: "/congo-african-grey-companion-pair-card.webp", alt: "Jins and Jeni, Congo African Grey companion pair raised together" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a young male Timneh African Grey stretching his wings on a perch" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a female Timneh African Grey perched calmly, showing her horn-colored beak" },
};

// S19 — the documentation every bird leaves with (Verified-Claim Ledger)
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// S24 — top-7 delivery metros, fresh anchors not used on other shipping sections
// This page owns 7 metros (Houston/Austin/San Diego/Bay Area/Orlando/Tampa/Columbus) — distinct from the CvT, macaw, cockatoo and male-vs-female pill sets
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-houston/", label: "Houston airport pickup" },
  { href: "/african-grey-parrot-for-sale-austin/", label: "Austin door arrivals" },
  { href: "/african-grey-parrot-for-sale-san-diego/", label: "San Diego home delivery" },
  { href: "/african-grey-parrot-for-sale-bay-area/", label: "Bay Area courier runs" },
  { href: "/african-grey-parrot-for-sale-orlando/", label: "Orlando cargo route" },
  { href: "/african-grey-parrot-for-sale-tampa/", label: "Tampa weekend drop-offs" },
  { href: "/african-grey-parrot-for-sale-columbus/", label: "Columbus front-door delivery" },
];

// S3 — single numbered section list drives BOTH the desktop TOC and the mobile
// jump rail (sequential 01–20, no skips, every section present — fixed 2026-07-05)
const tocItems = [
  { id: "quick-answer", label: "Quick Answer" },
  { id: "takeaways", label: "Fast Facts" },
  { id: "side-by-side", label: "At a Glance" },
  { id: "trust", label: "Why It's Not Symmetric" },
  { id: "grey", label: "The African Grey" },
  { id: "amazon", label: "The Amazon Parrot" },
  { id: "species", label: "Which Amazon?" },
  { id: "talking", label: "Talk vs Sing" },
  { id: "noise", label: "Noise & Apartment" },
  { id: "dust", label: "Dust & Allergies" },
  { id: "bite", label: "Reading a Bite" },
  { id: "health", label: "Health by Species" },
  { id: "scorecard", label: "Scorecard" },
  { id: "household", label: "Which Fits You" },
  { id: "cost", label: "First-Year Cost" },
  { id: "hormonal", label: "Hormonal Timeline" },
  { id: "myths", label: "Myths" },
  { id: "buy-either", label: "Buy Either At All?" },
  { id: "cites", label: "Wild-Caught? CITES" },
  { id: "shipping", label: "Shipping" },
  { id: "available", label: "Available Greys" },
  { id: "stories", label: "Owner Story" },
  { id: "faq", label: "FAQ" },
  { id: "learn", label: "Keep Learning" },
  { id: "reserve", label: "Reserve" },
];
const num = (i: number) => String(i + 1).padStart(2, "0");

// S20 — real reviews only, from the verified homepage bottomReviews set (the
// second quote was previously misattributed to "Clifford Hutter"; it belongs
// to Archie Obrien — corrected 2026-07-05, avatars added)
// One featured pull-quote (17B). Only 3 verified review texts exist site-wide;
// Catherine Kempf's is NOT used on congo-vs-timneh, minimizing the tolerated review-dup.
const story = { name: "Catherine Kempf", loc: "Schaumburg, IL", meta: "Congo African Grey",
  avatar: "/catherine-kempf-schaumburg-il-review.webp",
  quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained. Watching it grow and bond with my family has been an absolute joy. I recommend C.A.Gs to anyone looking for a quality African Grey." };
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta
  heroPreload="/african-grey-vs-amazon-parrot-hero.webp"
  heroPreloadSrcset="/african-grey-vs-amazon-parrot-hero-760.webp 760w, /african-grey-vs-amazon-parrot-hero.webp 900w"
  heroPreloadSizes="(max-width: 900px) 50vw, 280px">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <div class="cvt">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- S1 HERO — full-bleed band, portraits show the whole bird (2026-07-05: Roys + Elad, face/beak/tail contrast) -->
  <section class="cvt-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The talker and the singer, weighed honestly</p>
        <h1 class="cag-h1">African Grey vs Amazon Parrot: Which Talker Truly Fits Your Home?</h1>
        <p class="lead">We hand-raise African Greys here in Midland, and the first thing Amazon-curious buyers want settled is almost always the same: do they want a talker or a singer? What follows is the straight comparison we give them — Grey versus Amazon, then Grey against each of the six Amazon species they're really deciding among.</p>
        <p class="hero-cta"><a class="btn-clay" href="#side-by-side">Compare Now</a> <a class="btn-ghost" href="/available/">See Available Greys</a></p>
      </div>
      <div class="hero-imgs">
        <figure class="hero-left">
          <img src="/african-grey-vs-amazon-parrot-hero.webp"
            srcset="/african-grey-vs-amazon-parrot-hero-760.webp 760w, /african-grey-vs-amazon-parrot-hero.webp 900w"
            sizes="(max-width: 900px) 50vw, 280px"
            width="900" height="1001" alt="African Grey vs Amazon parrot: a Congo African Grey with silver plumage and a bright red tail, the world's best-talking parrot" fetchpriority="high">
          <figcaption class="chip">Grey · talker</figcaption>
        </figure>
        <span class="vs" aria-hidden="true">vs</span>
        <figure class="hero-right">
          <img src="/red-lored-amazon-hero-portrait.webp"
            srcset="/red-lored-amazon-hero-portrait-760.webp 760w, /red-lored-amazon-hero-portrait.webp 1024w"
            sizes="(max-width: 900px) 50vw, 280px"
            width="1024" height="926" alt="A green Red-Lored Amazon with a red forehead, the extroverted singing parrot buyers weigh against a talking African Grey" loading="lazy">
          <figcaption class="chip">Amazon · singer</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- S2 COUNTER SNIPPET — modernized 2026-07-05: icon chips, serif numerals, hairline separators -->
  <section class="cvt-counter"><div class="container counter-row">
    <div class="cs">
      <b>2</b><span class="cs-l">Grey species we raise</span>
    </div>
    <div class="cs">
      <b>30+</b><span class="cs-l">Amazon species we don't</span>
    </div>
    <div class="cs">
      <b>100%</b><span class="cs-l">CITES documented</span>
    </div>
    <div class="cs">
      <b>24h</b><span class="cs-l">Reply to inquiries</span>
    </div>
  </div></section>

  <!-- S3 mobile jump rail — all 24 sections, sequential numbering, clear divider band -->
  <nav class="cvt-rail" aria-label="Jump to section"><div class="container rail-row">
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </div></nav>

  <div class="container cvt-body">

  <!-- S3 desktop TOC — card treatment + ink title so it reads apart from the green counter band -->
  <aside class="cvt-toc" aria-label="On this page">
    <p class="toc-title"><span class="toc-tick" aria-hidden="true"></span>On this page</p>
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </aside>

  <div class="cvt-main">

  <!-- S4 QUICK ANSWER (4B clay-recolored — snippet + Choose-if cards, per approved matrix) -->
  <section id="quick-answer">
    <h2 class="cag-h2">The 60-Second Grey-or-Amazon Answer</h2>
    <div class="qa-snip">
      <span class="qa-pin" aria-hidden="true"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-6.3-7-11a7 7 0 0 1 14 0c0 4.7-7 11-7 11z"/><circle cx="12" cy="10" r="2.4"/></svg></span>
      <p><strong>Quick answer:</strong> The African Grey is the planet's premier talking parrot — 200 to 1,000-plus words, deployed in context — packaged in a quieter, dustier, more one-person bird. An Amazon is a green, extroverted singer: louder, more confident with strangers, and, in the yellow-headed species, far more hormonal. Greys talk better; Amazons sing better. The catch buyers miss is that "Amazon" isn't one bird — it's a genus of thirty-plus species that behave very differently, while "African Grey" is essentially two.</p>
    </div>
    <div class="choose-grid">
      <div class="choose-c grey">
        <span class="choose-h">Choose an African Grey if…</span>
        <ul>
          <li>conversation matters more than song, and you want words used in context</li>
          <li>you share walls and need the calmer, more predictable voice</li>
          <li>you can manage feather dust in exchange for steadier, less hormonal moods</li>
        </ul>
      </div>
      <div class="choose-c too">
        <span class="choose-h">Choose an Amazon if…</span>
        <ul>
          <li>you love a confident singer that performs and greets visitors</li>
          <li>your home can absorb all-day volume and seasonal hormonal swings</li>
          <li>you want a low-dust bird and don't mind smaller, less contextual talking</li>
        </ul>
      </div>
    </div>
    <img class="sec-img inf-img" src="/african-grey-vs-amazon-parrot-comparison-chart.webp" srcset="/african-grey-vs-amazon-parrot-comparison-chart-760.webp 760w, /african-grey-vs-amazon-parrot-comparison-chart.webp 1376w" sizes="(max-width:900px) 92vw, 760px" width="1376" height="768" alt="African grey vs amazon parrot comparison chart weighing talking, singing, noise, dust, temperament and price side by side" loading="lazy">
    <p>Search phrasing varies — Amazon parrot vs African Grey, "African gray" with an <em>a</em>, even the merged "Amazon grey parrot" — but the conclusion doesn't: this isn't a better-or-worse contest, it's a wiring match between a contextual talker and an extroverted singer. Since we raise only Greys, we'll flag our bias plainly and still give the Amazon full credit for what it does better. And the rest of the page opens with the question the other results skip — <a href="#species">which Amazon are you actually comparing?</a></p>
  </section>

