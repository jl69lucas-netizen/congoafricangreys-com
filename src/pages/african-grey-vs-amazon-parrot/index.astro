/* the 5th "busy professional / hold off" answer spans full width as a footer card */
.match-c:nth-child(5){grid-column:1/-1}
.match-c:nth-child(5)::before{background:var(--f)}
/* S15 timeline */
.timeline{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:6px 0 8px}
.tl-c{background:#fff;border:1px solid var(--bd);border-radius:14px;padding:14px;position:relative}
.tl-n{position:absolute;top:-10px;left:14px;width:24px;height:24px;border-radius:50%;background:var(--clay-ink);color:#fff;font-size:.75rem;font-weight:600;display:flex;align-items:center;justify-content:center}
.tl-c b{font-family:'Newsreader',serif;display:block;margin:6px 0 6px;color:var(--f);font-size:.98rem}
.tl-c p{font-size:.82rem;margin:0!important;max-width:none}
/* S16 myths */
.myth-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 8px}
.myth-c{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:18px}
.myth-x{display:inline-block;background:var(--clay-ink);color:#fff;border-radius:50px;padding:3px 13px;font-size:.72rem;font-weight:600;margin-bottom:10px}
.myth-c p{margin:0;font-size:.9rem}
/* S18 shipping + health */
.ship-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.ship-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.ship-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.ship-c>img{display:block;width:100%;height:200px;object-fit:cover}
.ship-body{padding:16px 18px}
.ship-tier{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 12px;font-size:.7rem;font-weight:600}
.ship-tier.clay{background:var(--clay-ink)}
.ship-c b{font-family:'Newsreader',serif;display:block;margin:8px 0 2px;font-size:1.15rem}
.ship-price{color:var(--clay-t);font-weight:700;font-size:1.15rem}
.ship-c p{font-size:.82rem;color:#5b524a;margin:6px 0 0!important;max-width:none}
.ship-places{list-style:none;margin:0 0 14px;padding:0;display:flex;flex-wrap:wrap;gap:10px}
.ship-places a{display:inline-flex;align-items:center;gap:8px;background:#f4efe9;border:1px solid var(--bd);border-radius:50px;padding:9px 15px;font-size:.84rem;line-height:1.15;color:var(--f);text-decoration:none;transition:border-color .2s,color .2s,background-color .2s}
.ship-places a:hover{border-color:var(--clay-t);color:var(--clay-t);background:#fff}
.ship-places .pin{color:var(--clay-t);flex:none;width:15px;height:15px}
.ship-places a:hover .pin{color:var(--clay-t)}
.health-card{background:#fff;border:1px solid var(--bd);border-radius:14px;overflow:hidden;margin:6px 0 14px;max-width:420px}
.hc-head{background:var(--f);color:#fff;padding:8px 14px;font-family:'Newsreader',serif}
.hc-list{list-style:none;margin:0;padding:12px 14px}
.hc-list li{font-size:.85rem;padding:4px 0 4px 22px;position:relative}
.hc-list li::before{content:"✔";position:absolute;left:0;color:var(--f);font-weight:700}
.ship-line{font-size:.78rem;color:#7a6f64;font-weight:600;border-top:1px dashed var(--bd);padding-top:8px}
/* S19 bird cards — photo-first + doc badges + per-bird CTA */
.bird-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:6px 0 18px}
.bird-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;color:#2a2622;display:flex;flex-direction:column;transition:transform .15s,box-shadow .2s}
.bird-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.12)}
.bird-photo{position:relative;display:block}
