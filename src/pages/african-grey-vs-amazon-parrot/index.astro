/* S13 lifestyle */
.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 14px}
.match-c{position:relative;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:15px 16px;transition:transform .15s,box-shadow .2s}
.match-c::before{content:"";display:block;width:24px;height:3px;border-radius:2px;background:var(--clay-ink);margin-bottom:10px}
.match-c:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(60,30,10,.09)}
.match-c h4{margin:0 0 6px!important;color:var(--f)}
