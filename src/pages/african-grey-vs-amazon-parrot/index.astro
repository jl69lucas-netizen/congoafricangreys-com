---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey vs Amazon Parrot | Talking, Temperament & Care Compared";
const description = "African Grey vs Amazon parrot compared: talking precision, hormonal aggression, lifespan, price, CITES status, and care demands. Which talker fits your life?";
const canonical = "https://congoafricangreys.com/african-grey-vs-amazon-parrot/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey vs Amazon Parrot", url: "/african-grey-vs-amazon-parrot/" },
];

const comparisonRows = [
  { attr: "Body size", ag: "12–14 inches (Congo)", amz: "10–18 inches depending on species" },
  { attr: "Weight", ag: "400–550 grams (Congo)", amz: "250–700 grams" },
  { attr: "Noise level", ag: "Moderate — occasional screaming", amz: "Loud — Amazons vocalize frequently and at high volume" },
  { attr: "Talking ability", ag: "Exceptional — best-talking parrot species, 200–1,000+ words", amz: "Good — animated and entertaining, but lower vocabulary ceiling" },
  { attr: "Talking clarity", ag: "Near-human voice accuracy", amz: "Clear but typically less precise than African Greys" },
  { attr: "Affection level", ag: "Bonded but independent — on their own terms", amz: "Playful and social — more overtly affectionate" },
  { attr: "Hormonal aggression", ag: "Rare if properly socialized", amz: "Common — intense seasonal hormonal phases (spring/fall)" },
  { attr: "Price range", ag: "$1,700 – $3,500", amz: "$1,000 – $3,000 depending on species" },
  { attr: "Lifespan", ag: "40–60 years", amz: "40–70 years depending on species" },
  { attr: "Diet sensitivity", ag: "High — calcium deficiency is a documented health risk", amz: "Moderate — prone to obesity on seed-heavy diets" },
  { attr: "CITES status", ag: "Appendix I (all African Greys)", amz: "Varies: Appendix I (yellow-naped) or Appendix II" },
  { attr: "Best for", ag: "Experienced owners wanting the smartest talker", amz: "Social households wanting an entertaining, outgoing bird" },
];

const faqs = [
  {
    q: "Do African Greys or Amazon parrots talk better?",
    a: "African Greys are widely regarded as the superior talkers — they develop larger vocabularies (200–1,000+ words) and speak with near-human voice accuracy. Amazon parrots talk well and are often more animated and contextually funny, but their vocabulary ceiling is typically lower and their pronunciation less precise than a well-trained African Grey.",
  },
  {
    q: "Are Amazon parrots more aggressive than African Greys?",
    a: "Amazons — particularly yellow-naped, double yellow-headed, and blue-fronted species — go through intense hormonal phases each spring and fall that can trigger biting, charging, and territorial aggression. African Greys can be nippy when stressed or under-socialized, but full-blown hormonal aggression is far less common. If you have children in the home, this difference matters significantly.",
  },
  {
    q: "Which parrot lives longer — African Grey or Amazon?",
    a: "Both species are 40–70 year commitments in captivity. African Greys average 40–60 years; Amazon parrots average 40–70 years depending on species. Neither should be acquired without planning for the bird's full lifetime care, including estate planning.",
  },
  {
    q: "Can you own both an African Grey and an Amazon parrot together?",
    a: "With caution. African Greys are sensitive birds that can be stressed by the louder, more assertive behavior of Amazon parrots. They should not be housed in the same cage. If kept in the same household, separate rooms and individual socialization time are recommended. Never leave them unsupervised together.",
  },
  {
    q: "What CITES documentation is required for Amazon parrots?",
    a: "It depends on the species. Yellow-naped Amazon parrots (Amazona auropalliata) are CITES Appendix I, meaning they face the most restrictive trade controls and require additional permits beyond standard Appendix II documentation. Most common Amazon parrot species kept as pets are Appendix II. Always demand species-specific CITES documentation from any breeder before purchasing.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section style="background:#1b4332;padding:4rem 1rem">
    <div style="max-width:900px;margin:0 auto;text-align:center">
      <p style="color:#f0c674;font-family:var(--font-sora,sans-serif);font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:1rem">Species Comparison · USDA AWA Licensed Breeders</p>
      <h1 style="font-family:var(--font-lora,serif);font-weight:700;font-size:clamp(2rem,5vw,3rem);color:#faf7f4;margin-bottom:1rem">African Grey vs Amazon Parrot: Which Talker Is Right for You?</h1>
      <p style="color:rgba(250,247,244,.8);font-size:1.1rem;max-width:680px;margin:0 auto">Both are elite-talking parrots. But African Greys speak with precision while Amazons bring personality and volume. One suits your home — the other will frustrate you.</p>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section style="padding:4rem 1rem;background:#faf7f4">
    <div style="max-width:960px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;margin-bottom:1.5rem;text-align:center">Side-by-Side Comparison</h2>
      <div style="overflow-x:auto;border-radius:12px;box-shadow:0 1px 4px rgba(60,30,10,.1)">
        <table style="width:100%;border-collapse:collapse;font-family:var(--font-sora,sans-serif);font-size:.9rem">
          <thead>
            <tr style="background:#2D6A4F;color:white">
              <th style="padding:.75rem 1rem;text-align:left;font-weight:600">Attribute</th>
              <th style="padding:.75rem 1rem;text-align:left;font-weight:600">African Grey</th>
              <th style="padding:.75rem 1rem;text-align:left;font-weight:600">Amazon Parrot</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr style={i % 2 === 0 ? "background:white" : "background:#f5f0eb"}>
                <td style="padding:.75rem 1rem;font-weight:600;color:#2D6A4F">{row.attr}</td>
                <td style="padding:.75rem 1rem;color:#374151">{row.ag}</td>
                <td style="padding:.75rem 1rem;color:#374151">{row.amz}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- VERDICT -->
  <section style="padding:3.5rem 1rem;background:white">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.5rem;color:#2D6A4F;margin-bottom:1rem">The Honest Verdict</h2>
      <p style="color:#374151;line-height:1.7;max-width:70ch;margin-bottom:1rem">African Greys are the choice if you want the most intelligent, precise-talking parrot available. They form deep one-person bonds, learn context, and can hold real conversations after 2–3 years of consistent training.</p>
      <p style="color:#374151;line-height:1.7;max-width:70ch;margin-bottom:1rem">Amazon parrots are louder, more overtly social, and better suited to households that want an entertainer over a scholar. They do talk — but the precision gap between a trained African Grey and an Amazon is significant.</p>
      <p style="color:#374151;line-height:1.7;max-width:70ch">The Amazon's hormonal aggression is the biggest practical difference. If your household includes children under 12, Amazon hormonal seasons can be genuinely dangerous. African Greys are more predictable in that regard.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:4rem 1rem;background:#faf7f4">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;margin-bottom:2rem">Frequently Asked Questions</h2>
      <div style="display:flex;flex-direction:column;gap:1rem">
        {faqs.map((faq) => (
          <details style="background:white;border:1px solid #e7e2db;border-radius:12px;padding:1.25rem">
            <summary style="font-family:var(--font-sora,sans-serif);font-weight:600;cursor:pointer;color:#1f2937;list-style:none">{faq.q}</summary>
            <p style="margin-top:.75rem;color:#4b5563;line-height:1.7;max-width:70ch">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
