.bird-body{padding:13px 15px 15px;display:flex;flex-direction:column;flex:1}
.bird-top{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:8px}
.bird-name{font-family:'Newsreader',serif;font-size:1.08rem;margin:0}
.bird-name a{color:#2a2622;text-decoration:none}
.bird-name a:hover{color:var(--clay-t)}
.bird-price{color:var(--clay-t);font-weight:700;font-size:1rem;white-space:nowrap}
.bird-docs{list-style:none;margin:0 0 12px;padding:0;display:flex;flex-wrap:wrap;gap:5px}
