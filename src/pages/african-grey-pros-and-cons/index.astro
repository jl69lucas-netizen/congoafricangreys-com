.kt-sub{font-size:.86rem;color:#57534e;line-height:1.5;display:block}
.cmpe-tabs{display:none;gap:8px;margin:0 0 10px}
.cmpe-tab{display:inline-flex;align-items:center;gap:7px;border-radius:50px;padding:9px 18px;font:inherit;font-size:.88rem;font-weight:700;cursor:pointer;background:#fff;color:var(--f);border:2px solid var(--f)}
.cmpe-tab img{width:20px;height:20px;object-fit:contain}
.cmpe-tab.active{background:var(--f);color:#fff}
.cmpe-tab[data-v="t"]{border-color:var(--clay-ink);color:var(--clay-ink)}
.cmpe-tab[data-v="t"].active{background:var(--clay-ink);color:#fff}
.tbl-wrap{overflow-x:auto;border-radius:16px;border:1px solid var(--bd);box-shadow:0 4px 20px rgba(60,30,10,.07)}
.tbl-wrap.plain{box-shadow:none;border-radius:12px;max-width:640px}
.cmp-tbl{width:100%;border-collapse:collapse;font-size:.9rem;background:#fff}
.cmp-tbl th{padding:12px;text-align:left;font-weight:600;vertical-align:middle}
.cmp-tbl .th-f,.cmp-tbl .th-e{background:#fff;color:#57534e;font-size:.7rem;letter-spacing:.09em;text-transform:uppercase;border-bottom:1px solid var(--bd)}
.cmp-tbl .th-c{background:linear-gradient(135deg,#2D6A4F,#1f4d39);color:#fff}
.cmp-tbl .th-t2{background:linear-gradient(135deg,#e8604c,#c8472f);color:#fff}
.th-flex{display:flex;align-items:center;gap:10px}
.th-flex img{width:30px;height:30px;object-fit:contain;flex:none}
.th-title{display:block;font-family:'Newsreader',serif;font-weight:700;font-size:1.02rem;line-height:1.2}
.th-sub{display:block;font-size:.72rem;font-weight:400;opacity:.9;margin-top:2px}
.cmp-tbl td{padding:10px 12px;border-bottom:1px solid var(--bd)}
.cmp-tbl tr:nth-child(even) td{background:var(--cream)}
.cmp-tbl .td-f{font-weight:600}
.cmp-tbl .edge{color:var(--f);font-weight:700}
.score-tbl{width:100%;border-collapse:collapse;font-size:.86rem;background:#fff}
.score-tbl th{background:var(--f);color:#fff;padding:9px 12px;text-align:left;font-weight:600}
.score-tbl td{padding:8px 12px;border-bottom:1px solid var(--bd)}
.score-tbl tr:last-child td{border-bottom:none}
.score-tbl tr:nth-child(even) td{background:var(--cream)}
.score-tbl .sc{font-weight:700;color:var(--f)}
@media(max-width:640px){
  .tbl-wrap.plain{border:none;box-shadow:none;border-radius:0;max-width:none;overflow:visible}
  .score-tbl,.score-tbl tbody,.score-tbl tr,.score-tbl td{display:block;width:auto}
  .score-tbl thead{position:absolute;left:-9999px}
  .score-tbl tr{background:#fff!important;border:1px solid var(--bd);border-radius:14px;padding:12px 15px;margin-bottom:11px;box-shadow:0 3px 12px rgba(60,30,10,.06)}
  .score-tbl tr:nth-child(even) td{background:transparent}
  .score-tbl td{border:none;padding:6px 0;display:flex;justify-content:space-between;align-items:baseline;gap:14px}
  .score-tbl td::before{content:attr(data-label);font-weight:600;color:#57534e;font-size:.78rem;letter-spacing:.02em}
  .score-tbl .sc-trait{font-family:'Newsreader',serif;font-size:1.1rem;color:#2a2622;border-bottom:1px solid var(--bd);padding-bottom:9px;margin-bottom:3px}
  .score-tbl .sc-trait::before{display:none}
  .score-tbl .sc{color:var(--f);font-weight:700;font-size:1.02rem}
  .score-tbl .sc-note{flex-direction:column;align-items:flex-start;gap:3px;color:#57534e;font-size:.88rem}
}
.cap{font-size:.85rem;color:#7a6f64;font-style:italic}
.author-card{background:#fff;border:1px solid var(--bd);border-radius:20px;overflow:hidden;margin:0 0 18px;box-shadow:0 4px 16px rgba(60,30,10,.07)}
.ac-banner{display:block;width:100%;height:240px;object-fit:cover}
.ac-row{display:flex;gap:16px;align-items:center;padding:18px 20px}
.ac-avatar{width:72px;height:54px;border-radius:12px;object-fit:cover;object-position:50% 32%;flex:none}
.ac-name{font-family:'Newsreader',serif;font-size:1.2rem;margin:0}
.ac-sub{font-size:.85rem;color:#7a6f64;margin:2px 0 8px}
.ac-badges{margin:0;display:flex;gap:6px;flex-wrap:wrap}
.ac-badges span{background:var(--f);color:#fff;border-radius:50px;padding:4px 12px;font-size:.72rem;font-weight:600}
@media(max-width:900px){
  .cvt-body{grid-template-columns:1fr;gap:0;padding-top:24px}
  .cvt-toc{display:none}
  .cvt-rail{display:block}
  .hero-imgs img{height:280px}
  .cvt-counter{padding:9px 0}
  .counter-row{display:grid;grid-template-columns:1fr 1fr;gap:2px 0}
  .cs{padding:7px 14px;gap:8px}
  .counter-row b{font-size:1.2rem}
  .cs-l{font-size:.74rem}
  .cs+.cs{border-left:none}
  .cs:nth-child(even){border-left:1px solid rgba(255,255,255,.16)}
  .kt-grid{grid-template-columns:1fr 1fr}
  .cmpe-tabs{display:flex}
  .cmp-tbl{font-size:.84rem}
  .cmp-tbl th,.cmp-tbl td{padding:9px 10px}
  .show-c .th-t2,.show-c .td-t{display:none}
  .show-t .th-c,.show-t .td-c{display:none}
}
@media(max-width:520px){.kt-grid{grid-template-columns:1fr}}
.hero-imgs .hero-left img{object-position:38% center}
.hero-imgs .hero-right img{object-position:62% center}
/* macaw species cards — masonry columns, not a grid: a CSS grid stretched
   every card to its tallest row sibling, leaving the dead white space the
   breeder flagged. Columns let each card end exactly where its text ends. */
.macaw-species-grid{columns:2;column-gap:16px;margin:6px 0 16px}
.msp-card{break-inside:avoid;-webkit-column-break-inside:avoid;page-break-inside:avoid;display:inline-block;width:100%;background:#fff;border:1px solid var(--bd);border-radius:16px;overflow:hidden;box-shadow:0 3px 14px rgba(60,30,10,.055);margin:0 0 16px;scroll-margin-top:calc(var(--hdr) + 18px);transition:transform .22s cubic-bezier(.22,1,.36,1),box-shadow .22s}
.msp-card:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(60,30,10,.1)}
.msp-media{position:relative;aspect-ratio:3/2;background:#f4efe9;overflow:hidden}
.msp-media img{display:block;width:100%;height:100%;object-fit:cover}
.msp-num{position:absolute;top:10px;left:10px;min-width:26px;height:26px;padding:0 7px;border-radius:50px;background:rgba(31,77,57,.92);color:#fff;font-size:.68rem;font-weight:700;font-variant-numeric:tabular-nums;display:flex;align-items:center;justify-content:center;letter-spacing:.02em}
.msp-body{padding:14px 16px 16px}
.msp-body h3{margin:0 0 3px!important;font-size:1.08rem!important;line-height:1.25}
.sp-sci{font-size:.76rem;color:#7a6f64;margin:0 0 7px!important;max-width:none}
.sp-trait{font-size:.8rem;color:var(--clay-t);font-weight:600;line-height:1.4;margin:0 0 11px!important;padding-bottom:11px;border-bottom:1px solid var(--bd);max-width:none}
.sp-stats{list-style:none;display:flex;flex-wrap:wrap;gap:6px;margin:0 0 11px;padding:0}
.sp-stats li{background:#eaf4ef;border:1px solid #cfe4da;border-radius:8px;padding:5px 9px;font-size:.68rem;display:flex;flex-direction:column;gap:1px;line-height:1.25}
.sp-stats li span{color:#57534e;font-size:.62rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600}
.sp-stats li b{color:var(--f);font-size:.74rem}
.msp-body p:last-child{font-size:.85rem;margin-bottom:0!important;line-height:1.62;color:#4c443c;max-width:none}
@media(max-width:760px){.macaw-species-grid{columns:1}}

/* bite force — the shared table lives on 3 other pages, so this one gets its
   own treatment: proportional force bars behind the measured-newton column */
.force-scale{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:4px 0 0;margin:10px 0 18px;max-width:600px;box-shadow:0 4px 16px rgba(60,30,10,.06);overflow:hidden}
.bite-tbl{width:100%;border-collapse:collapse;font-size:.87rem;background:transparent;table-layout:fixed}
/* a ::before on a <tr> becomes an anonymous table-cell and shifts every
   column across — the proportional bar hangs off a <td> instead */
.fs-cap{caption-side:top;text-align:left;padding:14px 18px 13px;font-size:.68rem;letter-spacing:.09em;text-transform:uppercase;color:#7a6f64;font-weight:600;line-height:1.4}
.fs-tick{display:inline-block;vertical-align:middle;width:18px;height:3px;border-radius:2px;background:var(--clay-ink);margin-right:9px}
.bite-tbl th{padding:0 18px 9px;text-align:left;font-size:.64rem;letter-spacing:.09em;text-transform:uppercase;color:#7a6f64;font-weight:600;border-bottom:1px solid var(--bd);white-space:nowrap}
.bite-tbl th:first-child{width:40%}
.bite-tbl th:last-child,.bite-tbl td:last-child{text-align:right}
.bite-tbl tbody tr{position:relative}
.bite-tbl td{padding:16px 18px 20px;border-bottom:1px solid var(--bd);vertical-align:baseline}
.bite-tbl td:first-child::after{content:"";position:absolute;left:18px;right:18px;bottom:8px;height:4px;border-radius:2px;background:linear-gradient(90deg,currentColor 0,currentColor var(--w-pct,0%),transparent var(--w-pct,0%));opacity:.32}
.bite-tbl tbody tr:last-child td{border-bottom:none}
.bite-tbl td:first-child{font-family:'Newsreader',serif;font-size:1.05rem;color:#2a2622;line-height:1.3}
.bite-tbl td:nth-child(2){font-weight:700;font-variant-numeric:tabular-nums;white-space:nowrap}
.bite-tbl td:last-child{color:#7a6f64;font-size:.8rem;font-variant-numeric:tabular-nums;white-space:nowrap}
.fs-grey{color:var(--f);--w-pct:18%}
.fs-grey td:nth-child(2){color:var(--f)}
.fs-human{color:#b3a58e;--w-pct:93%}
.fs-human td:nth-child(2){color:#7a6f64}
.fs-macaw{color:var(--clay-ink);background:#fdf6f3;--w-pct:100%}
.fs-macaw td:nth-child(2){color:var(--clay-ink)}
.fs-macaw td:first-child{font-weight:600;color:var(--clay-ink)}
@media(max-width:560px){
  .force-scale{max-width:none}
  .bite-tbl,.bite-tbl tbody,.bite-tbl tr,.bite-tbl td{display:block;width:auto}
  .bite-tbl thead{position:absolute;left:-9999px}
  .fs-cap{padding:14px 16px 10px}
  .bite-tbl tbody tr{padding:14px 16px 18px;border-bottom:1px solid var(--bd)}
  .bite-tbl tbody tr:last-child{border-bottom:none}
  .bite-tbl td{display:flex;justify-content:space-between;align-items:baseline;gap:12px;border:none;padding:4px 0;text-align:left!important}
  .bite-tbl td::before{content:attr(data-label);font-size:.68rem;letter-spacing:.06em;text-transform:uppercase;color:#7a6f64;font-weight:600}
  .bite-tbl td:first-child{display:block;font-size:1.08rem;padding:0 0 9px}
  .bite-tbl td:first-child::before{display:none}
  .bite-tbl td:first-child::after{left:16px;right:16px;bottom:8px}
}
/* interactive tools — size comparator, budget estimator, quiz.
   These are instruments, not forms: a labelled header band, generous
   internal rhythm, tabular figures, and one clay result surface each. */
.size-tool,.budget-tool,.quiz-tool{position:relative;background:linear-gradient(180deg,#fff 0%,#fffdfc 100%);border:1px solid var(--bd);border-radius:20px;padding:46px 22px 22px;margin:14px 0 18px;box-shadow:0 6px 24px rgba(60,30,10,.07)}
.size-tool::before,.budget-tool::before,.quiz-tool::before{content:attr(data-label);position:absolute;top:0;left:0;right:0;height:34px;display:flex;align-items:center;padding:0 20px;background:linear-gradient(135deg,#2D6A4F,#1f4d39);color:#fff;border-radius:19px 19px 0 0;font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700}
.size-tool{--tool-accent:var(--f)}
.size-tool>label{display:block;font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;font-weight:700;color:#7a6f64;margin-bottom:9px}
.tool-select{position:relative;max-width:380px;margin-bottom:22px}
.tool-select::after{content:"";position:absolute;right:16px;top:50%;width:8px;height:8px;border-right:2px solid var(--f);border-bottom:2px solid var(--f);transform:translateY(-70%) rotate(45deg);pointer-events:none}
.size-tool select{width:100%;appearance:none;-webkit-appearance:none;border:1.5px solid var(--bd);border-radius:14px;padding:13px 42px 13px 15px;font:inherit;font-weight:600;color:#2a2622;background:#fff;cursor:pointer;transition:border-color .2s,box-shadow .2s}
.size-tool select:hover{border-color:var(--f)}
.size-tool select:focus-visible{outline:none;border-color:var(--f);box-shadow:0 0 0 3px rgba(45,106,79,.14)}
.size-bars{display:flex;flex-direction:column;gap:18px;margin-bottom:18px}
.size-row{display:grid;grid-template-columns:1fr;gap:7px}
.size-label{font-size:.78rem;color:#3a332c;font-weight:700;letter-spacing:.01em}
.size-track{position:relative;background:#f4efe9;border-radius:50px;height:16px;overflow:hidden;border:1px solid var(--bd)}
.size-fill{height:100%;border-radius:50px;transition:width .55s cubic-bezier(.22,1,.36,1)}
.grey-fill{background:linear-gradient(90deg,#2D6A4F,#3d8462)}
.macaw-fill{background:linear-gradient(90deg,#c8472f,#e8604c)}
.size-val{font-size:.78rem;font-weight:700;color:#57534e;font-variant-numeric:tabular-nums}
.size-row .size-label,.size-row .size-val{grid-column:1}
.size-head{display:flex;justify-content:space-between;align-items:baseline;gap:12px}
.size-out{background:linear-gradient(180deg,#fdf2ef,#fbeae4);border:1px solid #f0c4b7;border-radius:14px;padding:14px 16px;font-size:.88rem;margin:0!important;max-width:none;color:#3a332c}
.size-out :global(strong){color:var(--clay-ink);font-variant-numeric:tabular-nums}
.budget-row{display:flex;align-items:center;gap:12px;font-weight:400;font-size:.87rem;color:#3a332c;cursor:pointer;padding:11px 13px;margin-bottom:6px;border:1px solid transparent;border-radius:12px;transition:background-color .18s,border-color .18s}
.budget-row:hover{background:#fffaf8;border-color:var(--bd)}
.budget-row:has(input:checked){background:#f7fbf9;border-color:#cfe4da}
.budget-row input{width:19px;height:19px;flex:none;accent-color:var(--f);cursor:pointer}
.budget-total{display:flex;justify-content:space-between;align-items:center;gap:14px;background:linear-gradient(135deg,#2D6A4F,#1f4d39);color:#fff;border-radius:14px;padding:16px 18px;margin-top:16px}
.budget-total span{font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;font-weight:700;opacity:.85;color:#fff}
.budget-total b{font-family:'Newsreader',serif;font-size:1.55rem;color:#fff;font-variant-numeric:tabular-nums;letter-spacing:-.01em}
.quiz-q{margin-bottom:20px}
.quiz-q:last-of-type{margin-bottom:22px}
.quiz-question{font-weight:700;font-size:.9rem;color:#2a2622;margin:0 0 10px!important;max-width:none}
.quiz-q label{display:flex;align-items:flex-start;gap:11px;font-size:.86rem;font-weight:400;color:#4c443c;padding:10px 13px;margin-bottom:6px;border:1px solid var(--bd);border-radius:12px;cursor:pointer;transition:background-color .18s,border-color .18s}
.quiz-q label:hover{background:#fffaf8;border-color:#e0cfc0}
.quiz-q label:has(input:checked){background:#f7fbf9;border-color:#cfe4da}
.quiz-q input{margin:2px 0 0;accent-color:var(--f);flex:none;width:17px;height:17px}
.quiz-btn{margin-top:2px;width:100%;max-width:260px}
.quiz-result{margin-top:20px;background:linear-gradient(180deg,#fdf2ef,#fbeae4);border:1px solid #f0c4b7;border-radius:16px;padding:18px 20px;font-size:.9rem;line-height:1.65;color:#3a332c}
.quiz-result :global(strong){color:var(--clay-ink);display:block;margin-bottom:5px;font-size:.98rem}
.quiz-result :global(a){color:var(--clay-t);font-weight:600;text-decoration:underline;text-underline-offset:2px}
@media(prefers-reduced-motion:no-preference){.quiz-result[data-in]{animation:toolIn .4s cubic-bezier(.22,1,.36,1)}}
@keyframes toolIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 14px}
.match-c{position:relative;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:15px 16px;transition:transform .15s,box-shadow .2s}
.match-c::before{content:"";display:block;width:24px;height:3px;border-radius:2px;background:var(--clay-ink);margin-bottom:10px}
.match-c:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(60,30,10,.09)}
.match-c h4{margin:0 0 6px!important;color:var(--f)}
.match-c p{margin-bottom:0;font-size:.9rem}
.match-c:nth-child(5){grid-column:1/-1}
.match-c:nth-child(5)::before{background:var(--f)}
.timeline{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:6px 0 8px}
.tl-c{background:#fff;border:1px solid var(--bd);border-radius:14px;padding:14px;position:relative}
.tl-n{position:absolute;top:-10px;left:14px;width:24px;height:24px;border-radius:50%;background:var(--clay-ink);color:#fff;font-size:.75rem;font-weight:600;display:flex;align-items:center;justify-content:center}
.tl-c b{font-family:'Newsreader',serif;display:block;margin:6px 0 6px;color:var(--f);font-size:.98rem}
.tl-c p{font-size:.82rem;margin:0!important;max-width:none}
.myth-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 8px}
.myth-c{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:18px}
.myth-x{display:inline-block;background:var(--clay-ink);color:#fff;border-radius:50px;padding:3px 13px;font-size:.72rem;font-weight:600;margin-bottom:10px}
.myth-c p{margin:0;font-size:.9rem}
.ship-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.ship-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.ship-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.ship-c>img{display:block;width:100%;height:250px;object-fit:cover;object-position:center 40%;background:#f4efe9}
.ship-body{padding:16px 18px}
.ship-tier{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 12px;font-size:.7rem;font-weight:600}
.ship-tier.clay{background:var(--clay-ink)}
.ship-c b{font-family:'Newsreader',serif;display:block;margin:8px 0 2px;font-size:1.15rem}
.ship-price{color:var(--clay-t);font-weight:700;font-size:1.15rem}
.ship-c p{font-size:.82rem;color:#5b524a;margin:6px 0 0!important;max-width:none}
.ship-places{list-style:none;margin:0 0 14px;padding:0;display:flex;flex-wrap:wrap;gap:10px}
.ship-places a{display:inline-flex;align-items:center;gap:8px;background:#f4efe9;border:1px solid var(--bd);border-radius:50px;padding:9px 15px;font-size:.84rem;line-height:1.15;color:var(--f);text-decoration:none;transition:border-color .2s,color .2s,background-color .2s}
.ship-places a:hover{border-color:var(--clay-t);color:var(--clay-t);background:#fff}
.ship-places .pin{color:var(--clay-t);flex:none;width:15px;height:15px}
.health-card{background:#fff;border:1px solid var(--bd);border-radius:14px;overflow:hidden;margin:6px 0 14px;max-width:420px}
.hc-head{background:var(--f);color:#fff;padding:8px 14px;font-family:'Newsreader',serif}
.hc-list{list-style:none;margin:0;padding:12px 14px}
.hc-list li{font-size:.85rem;padding:4px 0 4px 22px;position:relative}
.hc-list li::before{content:"✔";position:absolute;left:0;color:var(--f);font-weight:700}
.ship-line{font-size:.78rem;color:#7a6f64;font-weight:600;border-top:1px dashed var(--bd);padding-top:8px}
.bird-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:6px 0 18px}
.bird-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;color:#2a2622;display:flex;flex-direction:column;transition:transform .15s,box-shadow .2s}
.bird-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.12)}
.bird-photo{position:relative;display:block}
.bird-photo img{display:block;width:100%;height:250px;object-fit:cover;object-position:center 26%;background:#f4efe9}
.bird-badge{position:absolute;top:10px;left:10px;background:rgba(45,106,79,.94);color:#fff;font-size:.68rem;font-weight:600;padding:4px 11px;border-radius:50px}
.bird-body{padding:13px 15px 15px;display:flex;flex-direction:column;flex:1}
.bird-top{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:8px}
.bird-name{font-family:'Newsreader',serif;font-size:1.08rem;margin:0}
.bird-name a{color:#2a2622;text-decoration:none}
.bird-name a:hover{color:var(--clay-t)}
