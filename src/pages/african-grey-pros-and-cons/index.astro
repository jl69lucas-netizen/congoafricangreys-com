  <script is:inline>
    (function () {
      var navLinks = document.querySelectorAll('.cvt-toc a, .rail-row a');
      var sections = [].slice.call(document.querySelectorAll('.cvt-main section[id]'));
      if (navLinks.length && sections.length && 'IntersectionObserver' in window) {
        var current = '';
        var spy = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) current = e.target.id; });
          navLinks.forEach(function (a) { a.classList.toggle('on', a.getAttribute('href') === '#' + current); });
        }, { rootMargin: '-25% 0px -65% 0px' });
        sections.forEach(function (sec) { spy.observe(sec); });
      }
      var btn = document.getElementById('fit-btn');
      if (btn) {
        btn.addEventListener('click', function () {
          var n = document.querySelectorAll('.fit-ck:checked').length;
          var out = document.getElementById('fit-result');
          var msg;
          if (n >= 5) msg = '<strong>Grey-ready (' + n + '/6).</strong> On this honest read, an African Grey is a realistic and rewarding fit for your home. Meet the documented birds below, or line up the last details first.';
          else if (n >= 3) msg = '<strong>A strong maybe (' + n + '/6).</strong> You are close. Close the gaps — usually daily time at home or the long-term plan — before you commit, and a Grey can absolutely work.';
          else msg = '<strong>Not yet (' + n + '/6).</strong> On the four questions that sink most placements, the honest move is to wait or choose a lower-need companion. That is a kindness to you and the bird, not a failure.';
          out.innerHTML = msg;
          out.hidden = false;
          out.setAttribute('data-in', '');
        });
      }
    })();
  </script>
