---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import clutch from '../../../data/clutch-inventory.json';

// Meta — extended 3-part, transactional-compact (distinct LSI from the Congo page), ≤280
const title = "Timneh African Grey for Sale — Hand-Raised & DNA-Tested | Where Can I Buy a Calmer African Grey? | 2 Documented Babies Ready | C.A.Gs, Midland TX — Psittacus timneh, Verify in 60 Seconds, From $1,500";
// Desc — Primary benefit | secondary benefit | trust signal + CTA, ≤300
const description = "Timneh African Grey parrots for sale from a USDA-licensed Texas breeder — Elad and Evie, hand-raised, DNA-sexed and CITES-documented from $1,500. Smaller, calmer, earlier-talking greys. Verify us in 60 seconds, video-call your bird before any deposit, US-only shipping $185 airport / $350 home. We reply within 24 hours.";
const canonical = "https://congoafricangreys.com/timneh-african-grey-for-sale/";

const IMG = "/images/timneh-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "Timneh African Grey for Sale", url: "/timneh-african-grey-for-sale/" },
];

// Real inventory — Timneh only; never hardcode status; males first (Elad), then hens (Evie)
const available = ((clutch as any).birds as any[])
  .filter((b) => b.variant === "timneh_african_grey" && b.status === "available")
  .sort((a, b) => (a.sex === "male" ? -1 : 1));

const birdImg: Record<string, { src: string; alt: string; pos: string }> = {
  "elad": { src: IMG + "elad-timneh-african-grey-male-card.webp", pos: "center 34%", alt: "Elad, a hand-raised male Timneh African Grey for sale, leaning into a gentle head scratch" },
  "evie": { src: IMG + "evie-timneh-african-grey-female-card.webp", pos: "center 38%", alt: "Evie, a young female Timneh African Grey with charcoal plumage perched calmly on a rope" },
};
const birdBlurb: Record<string, string> = {
  "elad": "Confident, even-tempered young male — an early talker who bonds fast in an interactive home.",
  "evie": "Gentle, tractable hen who loves quiet interaction and handles new things calmly.",
};
const catFor = (b: any) => (b.sex === "male" ? "male" : "female");

// Geo shipping cards — DISTINCT state/city set vs the Congo page (cannibalization guard), real slugs
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-new-york/", label: "Timneh African Greys for sale New York", note: "JFK live-animal cargo" },
  { href: "/african-grey-parrot-for-sale-houston/", label: "Hand-raised Timneh greys Houston", note: "Short in-state transit" },
  { href: "/african-grey-parrot-for-sale-georgia/", label: "Timneh African Grey parrots Georgia", note: "Atlanta cargo hub" },
  { href: "/african-grey-parrot-for-sale-colorado/", label: "DNA-tested Timneh greys Colorado", note: "Denver Intl cargo" },
  { href: "/african-grey-parrot-for-sale-pennsylvania/", label: "Timneh African Grey breeder Pennsylvania", note: "Philadelphia route" },
  { href: "/african-grey-parrot-for-sale-massachusetts/", label: "Timneh African Grey for sale Massachusetts", note: "Boston Logan desk" },
  { href: "/african-grey-parrot-for-sale-oregon/", label: "Buy a Timneh African Grey Oregon", note: "Portland cargo desk" },
  { href: "/african-grey-parrot-for-sale-ohio/", label: "Timneh African Greys for sale Ohio", note: "Columbus pickup route" },
];

// Real reviews only (verified C.A.Gs buyers of our African Greys)
const stories = [
  { name: "Richard Woodard", loc: "Winter Haven, FL", meta: "Verified C.A.Gs buyer",
    avatar: "/richard-woodard-winter-haven-fl-review-112.webp",
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My African Grey is now the star of our family, talking and entertaining us daily." },
  { name: "Archie Obrien", loc: "Farmingdale, NY", meta: "Verified C.A.Gs buyer",
    avatar: "/archie-obrien-farmingdale-ny-review.webp",
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee." },
];

// Further reading — real pages, matching Timneh thumbnails
const readMore = [
  { href: "/how-to-avoid-african-grey-parrot-scams/", img: IMG + "real-vs-fake-timneh-breeder-comparison-760.webp", kicker: "Scam guide", title: "How to avoid African Grey parrot scams", sub: "How to read a fake Timneh listing — and why the cheapest ones fall apart fastest." },
  { href: "/congo-vs-timneh-african-grey/", img: IMG + "timneh-vs-congo-fast-facts-760.webp", kicker: "Which grey", title: "Congo vs Timneh African Grey", sub: "Which grey suits your home — the calmer Timneh or the bigger Congo, weighed point by point." },
  { href: "/cites-african-grey-documentation/", img: IMG + "own-a-timneh-legally-usa-cites-appendix-i-infographic-760.webp", kicker: "Legality", title: "CITES documentation, explained", sub: "What Appendix I paperwork looks like when a legal, captive-bred grey travels home." },
  { href: "/african-grey-parrot-price/", img: IMG + "timneh-african-grey-eating-peanut-760.webp", kicker: "Pricing", title: "African Grey price — what you actually pay for", sub: "Where the $1,500 floor comes from, and why a sub-$1,000 grey should scare you off." },
];

const faqs = [
  { q: "How much does a Timneh African Grey cost?", a: "Our hand-raised Timneh African Greys are $1,500 for Evie and $1,600 for Elad, held with a $200 refundable deposit. Nothing here is priced under $1,500 — a healthy, DNA-sexed, captive-bred Timneh costs real money to raise, test and document, so a $750 'limited-time' Timneh is about as loud a warning sign as this market produces." },
  { q: "Is it legal to buy a Timneh African Grey in the USA?", a: "Yes. The Timneh carries a CITES Appendix I listing, but captive-bred birds are legal to own and rehome within the United States as long as the paperwork is in order. Ours all hatched in Texas from captive parents — never wild-caught — and travel with CITES captive-bred records plus a USDA-licensed breeder's paper trail. We keep shipping domestic, because a legitimate seller doesn't offer to send an Appendix-I bird overseas." },
  { q: "Do Timneh African Greys talk as well as Congos?", a: "Yes — Timnehs are every bit as intelligent as Congos and often start mimicking a little earlier, with a clearer, softer little voice. They tend to build a slightly smaller vocabulary than a Congo's headline hundred-plus words, but they use it in context, and because we hand-raise and socialize ours daily, they associate words with people and objects from the start." },
  { q: "Are Timneh African Greys calmer, and good for first-time owners?", a: "Many owners describe Timnehs as more stable and less prone to the nervousness and feather-plucking that can affect Congos, which is why they're a common first-grey pick. We'll be honest, though — the community is split, and some Timnehs are shy little things. Either way a Timneh is still a 40–50 year commitment that needs daily interaction, so we match the bird to the home rather than sell a stereotype." },
  { q: "How long do Timneh African Greys live?", a: "In good care a Timneh African Grey usually lives 40–50 years, occasionally longer, which makes buying one a multi-decade commitment far closer to raising a child than picking up a pet. That long horizon is exactly why we put the work into healthy, well-socialized birds — they'll be family for decades." },
  { q: "Can a Timneh African Grey be shipped safely?", a: "Yes — a reserved Timneh travels US-only on IATA live-animal cargo via Delta, United or American, $185 to your nearest airport or $350 delivered climate-controlled to your door. Within a 2–3 hour drive of Midland, Texas, an in-person pickup is the kindest route, and either way the bird carries its full document folder and health certificate." },
  { q: "What's included when I reserve a Timneh African Grey?", a: "Each Timneh arrives with a DNA-sexing certificate, a closed leg band, an avian-vet health record, PBFD and Avian Polyomavirus PCR results, a care guide, a welcome kit, and our lifetime support line — precisely the stack of documentation a fraudulent listing could never pull together." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: "Timneh African Grey Parrot for Sale (Psittacus timneh)",
  image: [ site + IMG + "timneh-african-grey-parrot-for-sale-hero.webp", site + IMG + "elad-timneh-african-grey-male-card.webp" ],
  description: "A hand-raised, DNA-sexed Timneh African Grey parrot from C.A.Gs, a USDA-licensed family aviary in Midland, Texas. Captive-bred, CITES Appendix I documented, PBFD & Avian Polyomavirus PCR-screened, and placed with lifetime breeder support.",
  category: "Companion parrot",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52" },
  review: stories.map((s) => ({ "@type": "Review", author: { "@type": "Person", name: s.name },
    reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" }, reviewBody: s.quote })),
  offers: { "@type": "AggregateOffer", lowPrice: "1500", highPrice: "1600", priceCurrency: "USD", offerCount: String(available.length),
    availability: "https://schema.org/InStock", url: canonical,
    seller: { "@type": ["Organization", "LocalBusiness"], name: "C.A.Gs – Midland, TX", alternateName: "Congo African Greys" } },
};
const itemListSchema = { "@context": "https://schema.org", "@type": "ItemList",
  itemListElement: available.map((b, i) => ({ "@type": "ListItem", position: i + 1,
    item: { "@type": "Product", name: b.name + " — Timneh African Grey", category: "Companion parrot",
      offers: { "@type": "Offer", price: String(b.price), priceCurrency: "USD",
        availability: "https://schema.org/InStock", url: site + b.slug } } })) };

const sections = [
  { n: "01", id: "available", label: "Available Timnehs now", tag: "2 birds" },
  { n: "02", id: "short", label: "The short version", tag: "$1,500+" },
  { n: "03", id: "why", label: "Why a Timneh grey", tag: "Calmer" },
  { n: "04", id: "identify", label: "Spot a true Timneh", tag: "Maroon" },
  { n: "05", id: "legit", label: "Is this breeder legit?", tag: "Verify" },
  { n: "06", id: "price", label: "Why prices vary", tag: "$1–6.5k" },
  { n: "07", id: "included", label: "What's included", tag: "Docs" },
  { n: "08", id: "health", label: "Health & testing", tag: "PCR" },
  { n: "09", id: "legal", label: "Legal to own?", tag: "CITES I" },
  { n: "10", id: "shipping", label: "Shipping & cost", tag: "$185/$350" },
  { n: "11", id: "carecost", label: "Monthly care cost", tag: "Diet" },
  { n: "12", id: "lifestyle", label: "Living with one", tag: "Daily" },
  { n: "13", id: "eggs", label: "Timneh eggs?", tag: "Read first" },
  { n: "14", id: "congo", label: "Prefer a Congo?", tag: "Compare" },
  { n: "15", id: "families", label: "Buyer families", tag: "" },
  { n: "16", id: "resources", label: "Keep reading", tag: "" },
  { n: "17", id: "faq", label: "Timneh FAQs", tag: "" },
  { n: "18", id: "reserve", label: "Reserve yours", tag: "24h" },
];
const N = sections.length;

// In-body TOC — T1 Numbered Ledger Rail (curated 6 anchors)
const ledger = [
  { href: "#available", n: "01", h: "See who's available" },
  { href: "#why", n: "02", h: "Why a Timneh grey" },
  { href: "#legit", n: "03", h: "Verify we're real" },
  { href: "#price", n: "04", h: "Understand the price" },
  { href: "#legal", n: "05", h: "Legality & shipping" },
  { href: "#reserve", n: "06", h: "Reserve & bring home" },
];
const seam = "/cag-fs-seam-emblem.webp";
---

<BaseLayout {title} {description} {canonical} ogType="product" hideGlobalCta
  heroPreload={IMG + "timneh-african-grey-parrot-for-sale-hero.webp"}
  heroPreloadSrcset={IMG + "timneh-african-grey-parrot-for-sale-hero-560.webp 560w, " + IMG + "timneh-african-grey-parrot-for-sale-hero-760.webp 760w, " + IMG + "timneh-african-grey-parrot-for-sale-hero.webp 1280w"}
  heroPreloadSizes="(max-width:900px) 92vw, 520px">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="timneh">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- HERO — Split-Hero B · Full-bleed warm gradient (Timneh head-scratch) -->
  <header class="chero">
    <div class="container chero-grid">
      <div class="chero-copy">
        <p class="eyebrow">2 Timneh babies · Levi × Rily clutch · Midland, TX</p>
        <h1 class="cag-h1">Timneh African Grey <em>Parrots</em> for Sale — Smaller, Calmer, Hand-Raised &amp; CITES-Documented Greys</h1>
        <p class="lead">Here at C.A.Gs we hand-raise Timneh African Grey parrots (<i>Psittacus timneh</i>) — the smaller, often calmer, earlier-talking grey — and place them from $1,500. Elad and Evie are DNA-sexed, health-screened babies from our own pair, Levi &amp; Rily. No anonymous listing, no wild-caught birds: a USDA-licensed Texas breeder you can verify in about a minute and video-call before you pay a cent.</p>
        <div class="chero-cta">
          <a class="btn-clay" href="#available">See available Timnehs &rarr;</a>
          <a class="btn-ghost" href="#legit">Is this seller legit?</a>
        </div>
        <p class="chero-rate"><span class="stars" aria-hidden="true">★★★★★</span> <b>4.9</b> · 52 verified C.A.Gs buyers</p>
        <ul class="chero-ribbon">
          <li>USDA Class A</li><li>CITES Appendix I</li><li>PCR DNA-sexed</li><li>US-only shipping</li>
        </ul>
      </div>
      <div class="chero-media">
        <img src={IMG + "timneh-african-grey-parrot-for-sale-hero.webp"}
          srcset={IMG + "timneh-african-grey-parrot-for-sale-hero-560.webp 560w, " + IMG + "timneh-african-grey-parrot-for-sale-hero-760.webp 760w, " + IMG + "timneh-african-grey-parrot-for-sale-hero.webp 1280w"}
          sizes="(max-width:900px) 92vw, 520px" width="1280" height="960"
          fetchpriority="high" loading="eager" decoding="async"
          alt="Hand-raised Timneh African Grey for sale leaning into a gentle head scratch, showing its charcoal plumage and maroon tail" />
        <span class="chero-tag">Hand-raised in Midland, TX</span>
      </div>
    </div>
  </header>

  <!-- COUNTER — for-sale outlined stat cards (Ledger-verified only) -->
  <div class="chero-counter">
    <div class="container counter-row">
      <div class="cs"><b>$1,500</b><span class="cs-l">Timneh floor price</span></div>
      <div class="cs"><b>2</b><span class="cs-l">Timnehs reservable</span></div>
      <div class="cs"><b>60s</b><span class="cs-l">Verify our license</span></div>
      <div class="cs"><b>App. I</b><span class="cs-l">CITES documented</span></div>
      <div class="cs"><b>0</b><span class="cs-l">Wild-caught, ever</span></div>
      <div class="cs"><b>40–50</b><span class="cs-l">Year companion</span></div>
      <div class="cs"><b>24h</b><span class="cs-l">Inquiry reply</span></div>
    </div>
  </div>

  <!-- MOBILE JUMP RAIL — Rail B green ticker -->
  <nav class="chero-rail" aria-label="On this page">
    <div class="container railB">
      {sections.map((s, i) => (<a href={`#${s.id}`} class={i === 0 ? "on" : ""}><span class="p">{s.n}</span> {s.label}</a>))}
    </div>
  </nav>

  <div class="container">

    <!-- IN-BODY TOC — T1 Numbered Ledger Rail -->
    <nav class="tledger" aria-label="Your path to reserving a Timneh African Grey">
      <p class="tledger-h">Your Path to Reserving a Timneh — About 6 Minutes to Read</p>
      <ol class="tledger-row">
        {ledger.map((s) => (
          <li><a href={s.href}><span class="tl-n">{s.n}</span><span class="tl-h">{s.h}</span></a></li>
        ))}
      </ol>
    </nav>

    <div class="timneh-body">

    <!-- DESKTOP DIAL TOC — Dial 1 · Clay Progress (sticky left, light card) -->
    <nav class="tdial desk-only" aria-label="Contents" id="timnehDial" style="--p:6">
      <div class="tdial-ring"><div><b id="dialNum">1</b><span>of {N}</span></div></div>
      <div class="tdial-list">
        {sections.map((s, i) => (<a href={`#${s.id}`} data-i={i} class={i === 0 ? "on" : ""}><span class="num">{s.n}</span>{s.label}{s.tag && <span class="tag">{s.tag}</span>}</a>))}
      </div>
    </nav>

    <main class="timneh-main">

      <!-- 1 · AVAILABLE -->
      <section id="available">
        <h2 class="cag-h2">Which Timneh African Greys Do We Have for Sale Right Now?</h2>
        <p>Two hand-raised Timneh African Greys are reservable at C.A.Gs today — Elad, a young male, and Evie, a young hen — both babies from our own breeding pair, Levi &amp; Rily, here in our Midland, Texas home. Each card below opens that Timneh's own page with its photos, parentage and full paperwork, and every bird is DNA-sexed and health-screened before it travels.</p>

        <div class="availC">
          {available.map((b) => {
            const cat = catFor(b);
            const badge = cat === "male" ? "Male" : "Female";
            return (
              <a class="ac-tile" href={b.slug} data-cat={cat}>
                <span class="ac-photo">
                  {birdImg[b.id] && <img src={birdImg[b.id].src}
                    srcset={birdImg[b.id].src.replace(".webp", "-440.webp") + " 440w, " + birdImg[b.id].src + " 800w"}
                    sizes="(max-width:980px) 46vw, 210px"
                    width="800" height="800" loading="lazy" decoding="async" style={`object-position:${birdImg[b.id].pos}`} alt={birdImg[b.id].alt} />}
                  <span class="ac-badge">{badge}</span>
                </span>
                <span class="ac-info">
                  <span class="ac-top">
                    <span class="ac-name">{b.name}</span>
                    <span class="ac-price">{b.price_display}</span>
                  </span>
                  {birdBlurb[b.id] && <span class="ac-blurb">{birdBlurb[b.id]}</span>}
                  <span class="ac-go" aria-hidden="true">View {b.name} &rarr;</span>
                </span>
              </a>
            );
          })}
        </div>
        <p class="side-note">Every Timneh above is a real, reservable bird in our home &middot; US-only shipping &middot; $185 airport &middot; $350 home &middot; Local pickup in Midland, TX (within 2&ndash;3 hours)</p>

        <h3 class="cag-h3">Meet Elad &amp; Evie, Our Available Timneh Greys</h3>
        <p>Elad is a hand-raised male Timneh we can already read like a book — confident, even-tempered and quick to step up — and Evie is a gentle, tractable hen who takes new things in stride. Because we've raised both by hand from the nursery, we can tell you their temperament rather than guess it, and we match each to the right home instead of selling a "type."</p>
        <img class="sec-img og-photo og-tall" src={IMG + "elad-evie-timneh-siblings.webp"} srcset={IMG + "elad-evie-timneh-siblings-760.webp 760w, " + IMG + "elad-evie-timneh-siblings.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Elad and Evie, two young Timneh African Greys raised together in the C.A.Gs home aviary" />

        <h4 class="cag-h4">What's on Each Timneh's Listing Card?</h4>
        <p>Read a card left to right and you get sex, age, price and status at a glance, plus the US-only delivery cost sitting right there rather than sprung on you at checkout. The status word is literal, too: "available" means a bird genuinely still with us, and the moment Elad or Evie is spoken for, the card updates instead of lingering as bait.</p>

        <h5 class="cag-h5">Both Elad and Evie Come With a DNA-Sexing Certificate and Vet Health Record</h5>
        <p>You never have to take our word that Elad is a cock or Evie a hen — a DNA lab settles it, and that certificate rides home in the folder beside the avian-vet health record. Timneh cocks and hens look identical to the eye, so a lab result is the line between a seller who actually knows their birds and one who is merely hoping.</p>

        <h6 class="cag-h6">Elad (Male, $1,600) · Evie (Female, $1,500) — Real Levi × Rily Babies, Reservable Now</h6>
        <p>Elad at $1,600 and Evie at $1,500 are the actual figures off our inventory sheet, each tied to one real bird with its own profile page, both out of the same clutch from Levi &amp; Rily. <a href="/african-grey-parrot-price/">Our African Grey pricing guide</a> is the source of truth if a number ever reads differently somewhere on the site — flag it and we'll fix the stray card.</p>
        <div class="sec-cta">
          <a class="btn-clay" href="#reserve">Reserve a Timneh — from $1,500 &rarr;</a>
          <a class="btn-ghost" href="#legit">First, check we're legit</a>
        </div>
      </section>

      <div class="seam"><img src={seam} width="150" height="50" alt="" loading="lazy" decoding="async"></div>

      <!-- 2 · SHORT VERSION (K2 price-tag) -->
      <section id="short">
        <h2 class="cag-h2">The Two-Minute Summary Before You Buy a Timneh African Grey</h2>
        <p>Short on time? Here it is in one breath: our hand-raised Timnehs run $1,500 to $1,600, leave with DNA sexing, disease screening and CITES captive-bred papers, travel US-only for $185 to $350, and can be checked out in roughly a minute before a dollar moves. Every section that follows is just the evidence behind those five claims.</p>

        <div class="k2" role="note" aria-label="Timneh African Grey quick-facts">
          <div class="k2-tag">
            <span class="k2-eyebrow">Timneh — quick facts</span>
            <span class="k2-price">$1,500<small>–$1,600</small></span>
            <span class="k2-sub">Elad $1,600 · Evie $1,500 · $200 deposit</span>
          </div>
          <ul class="k2-list">
            <li><span>Testing</span><b>DNA + PBFD/APV PCR</b></li>
            <li><span>Paperwork</span><b>CITES App. I · USDA</b></li>
            <li><span>Shipping</span><b>$185 / $350 · US-only</b></li>
            <li><span>Reply time</span><b>Within 24 hours</b></li>
          </ul>
        </div>

        <h3 class="cag-h3">The Four Numbers That Decide a Timneh's Honesty</h3>
        <p>Whether a Timneh listing deserves your trust comes down to four figures — what it costs at the floor, what testing backs it, what documents follow it, and what shipping runs — and an honest breeder rattles them off without a pause. We've already laid all four out on the card and in the recap above, so none of them are buried in fine print.</p>

        <h4 class="cag-h4">Floor Price, PCR Testing, CITES Papers and US-Only Shipping at a Glance</h4>
        <p>Concretely: $1,500 is as low as a Timneh goes with us; each one carries DNA sexing plus PBFD and Avian Polyomavirus PCR results; the papers are CITES Appendix I captive-bred alongside our USDA license; and delivery is a flat $185 to the airport or $350 to the door, inside the US only. There's no mystery add-on waiting at the end — invented last-minute fees are precisely the trick our scam guide tells buyers to watch for.</p>

        <h5 class="cag-h5">Our Timnehs Never Drop Below $1,500 — A $750 Bird Is the Scam Tell</h5>
        <p>The arithmetic simply doesn't close under $1,500 — hand-feeding, lab work, a vet exam and paperwork all cost what they cost — so a "$750 Timneh with free shipping" is an invitation, not a deal. On a companion that may share your home for four or five decades, a price that looks too kind is usually attached to a bird that was never there.</p>

        <!-- K5 · capsule strip -->
        <div class="k5" role="note" aria-label="Timneh trust capsules">
          <span class="cap"><b>Levi × Rily</b>our own pair</span>
          <span class="cap"><b>US-only</b>no export</span>
          <span class="cap"><b>Video call</b>before deposit</span>
          <span class="cap"><b>Refundable</b>$200 deposit</span>
        </div>
      </section>

      <div class="seam"><img src={seam} width="150" height="50" alt="" loading="lazy" decoding="async"></div>

      <!-- 3 · WHY A TIMNEH (INTEREST) -->
      <section id="why">
        <h2 class="cag-h2">What Makes the Timneh African Grey Such a Rewarding Companion Parrot?</h2>
        <p>A Timneh hands you the whole African Grey intellect — the problem-solving, the mimicry, the emotional depth — in a lighter, more apartment-sized body with a name for keeping its cool. We raise ours by hand toward exactly that promise, so the bird arriving at your door is already socialized to talk, forage and lean into people, rather than a spooked youngster you'll spend a year coaxing out of its shell.</p>
        <img class="sec-img inf-img" src={IMG + "elad-timneh-personality-profile.webp"} srcset={IMG + "elad-timneh-personality-profile-760.webp 760w, " + IMG + "elad-timneh-personality-profile.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Elad's Timneh African Grey personality profile — energy, talking, beginner-friendly, social and noise ratings" />

        <h3 class="cag-h3">Is a Timneh Really Calmer and Less Nervous Than a Congo?</h3>
        <p>Often, yes — many Timneh owners describe a bird that is more stable, more relaxed, and less prone to feather-plucking than a Congo, which is a big part of why the subspecies keeps gaining fans. We'll stay honest, though, because a good breeder should: the community is genuinely split, and a Timneh can still be a shy, sensitive little thing, so temperament is something we talk through per bird rather than promise.</p>

        <h4 class="cag-h4">What Do Timneh Owners Actually Say About Temperament?</h4>
        <p>Owner forums land on the same theme again and again — Timnehs handle change more gracefully and tend to bond warmly once they trust you. Elad, our male, is squarely in that even-tempered camp; Evie, our hen, is gentle but a touch more cautious, and we'd rather tell you that than oversell her.</p>

        <h5 class="cag-h5">Owners Often Report Timnehs Are More Stable and Less Prone to Feather-Plucking</h5>
        <p>Feather-plucking in African Greys is usually a stress and boredom response, and the common owner read is that Timnehs weather that stress a little better than Congos. That is a tendency, not a guarantee — any grey needs daily interaction and enrichment to stay whole-feathered and happy.</p>

        <h6 class="cag-h6">The Community Is Split — Some Call Them "Nervous Little Things," So We Stay Honest</h6>
        <p>For balance: right alongside the "calmer than a Congo" praise, you'll find keepers who call Timnehs "nervous little things" who are brilliant mimics but easily startled. Both experiences are real, which is exactly why we won't flatten your expectations into a slogan.</p>

        <h3 class="cag-h3">How Well and How Early Do Timneh African Greys Talk?</h3>
        <p>Timnehs are outstanding talkers who frequently start mimicking earlier than Congos, with a clearer, softer little voice that many owners find charming. Our daily handling and name-training front-load the word-to-meaning associations a Timneh needs, which is why buyers so often report first words within weeks of homecoming.</p>
        <img class="sec-img inf-img" src={IMG + "evie-timneh-personality-profile.webp"} srcset={IMG + "evie-timneh-personality-profile-760.webp 760w, " + IMG + "evie-timneh-personality-profile.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Evie's Timneh African Grey personality profile — tractability, curiosity, calmness and vocality ratings" />

        <h4 class="cag-h4">How Old Is a Timneh When It Starts Talking?</h4>
        <p>First sounds and words usually surface somewhere between six months and a year, with real fluency following over the next year or two — but no two Timnehs keep the same calendar. Speech rides on trust, so a chick talked to and handled daily from the nursery tends to open up faster than one that spent its early weeks stressed or barely touched.</p>
      </section>

      <div class="seam"><img src={seam} width="150" height="50" alt="" loading="lazy" decoding="async"></div>

      <!-- 4 · IDENTIFY -->
      <section id="identify">
        <h2 class="cag-h2">How Do You Identify a True Timneh — Charcoal Body, Maroon Tail, Horn Beak?</h2>
        <p>A true Timneh African Grey gives itself away the moment you know the tells: a deeper charcoal-grey body, a maroon or dark-burgundy tail where a Congo flashes bright red, a horn-colored upper beak, and a compact 9–11 inch, 275–375 gram build. Our photos on this page show every one of those marks, and holding them up against a seller's pictures is the fastest sanity check you can run.</p>
        <img class="sec-img inf-img" src={IMG + "true-timneh-identification-infographic.webp"} srcset={IMG + "true-timneh-identification-infographic-760.webp 760w, " + IMG + "true-timneh-identification-infographic.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Timneh African Grey identification infographic marking the charcoal body, maroon tail and horn-colored beak" />

        <h3 class="cag-h3">Is a Timneh a Better First African Grey?</h3>
        <p>For many first-time grey owners, yes — the smaller size and calmer reputation make a Timneh a gentler introduction to grey ownership than a Congo. It's still a serious, decades-long commitment, so "better first bird" means better-suited, not easy; our <a href="/congo-vs-timneh-african-grey/">Congo vs Timneh comparison</a> weighs the trade-offs in full, and our <a href="/congo-african-grey-for-sale/">Congo African Greys for sale</a> are listed separately.</p>

        <h4 class="cag-h4">Why Do People Choose a Timneh Over a Congo?</h4>
        <p>Buyers pick a Timneh for its smaller footprint, its calmer-leaning temperament, its early, clear talking, and a lower price — all the reasons the subspecies is quietly gaining ground. None of that makes it "the lesser grey"; it makes it the right grey for a particular home, which is the only comparison that matters.</p>

        <h5 class="cag-h5">Smaller Size and a Calmer Reputation Make Timnehs a Common First-Grey Pick</h5>
        <p>At roughly two-thirds the weight of a Congo, a Timneh fits smaller spaces and feels less intimidating in the hand, which reassures first-time owners. Pair that with the calmer reputation and you have the practical case behind the Timneh's rising popularity.</p>
      </section>

