.chero-counter{background:var(--cream);padding:6px 0 18px}
.counter-row{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:10px}
.cs{display:flex;flex-direction:column;gap:2px;align-items:flex-start;justify-content:center;min-height:66px;background:#fff;border:1px solid var(--bd);border-radius:12px;padding:10px 13px;box-shadow:0 2px 10px rgba(60,30,10,.04)}
@media(max-width:1050px){.counter-row{grid-template-columns:repeat(4,1fr)}}
@media(max-width:640px){.counter-row{grid-template-columns:repeat(2,1fr)}}
.counter-row b{font-family:'Newsreader',serif;font-size:1.32rem;line-height:1;color:var(--clay-ink);font-variant-numeric:tabular-nums}
.cs-l{font-size:.71rem;font-weight:600;color:var(--mid);line-height:1.25}
/* MOBILE RAIL B — green ticker */
.chero-rail{position:sticky;top:var(--hdr);z-index:40;background:rgba(250,247,244,.985);border-bottom:1px solid var(--bd);box-shadow:0 6px 14px rgba(60,30,10,.07);display:none}
.railB{display:flex;gap:8px;overflow-x:auto;padding:12px 0;scrollbar-width:none}
.railB::-webkit-scrollbar{display:none}
.railB a{flex:0 0 auto;font-size:.78rem;font-weight:600;color:#fff;border:1.5px solid var(--f);border-radius:50px;padding:7px 14px;text-decoration:none;background:var(--f);white-space:nowrap;transition:box-shadow .15s,background-color .15s}
.railB a.on{background:#25543d;box-shadow:0 2px 8px rgba(45,106,79,.35)}
.railB a .p{font-weight:700;color:#c9f2db}
/* IN-BODY TOC — T1 Numbered Ledger Rail */
.tledger{background:#fff;border:1px solid var(--bd);border-radius:18px;padding:16px 20px 8px;margin:16px 0 4px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.tledger-h{font-family:'Newsreader',serif;font-size:1.05rem;color:#2a2622;margin:0 0 12px}
.tledger-row{list-style:none;display:grid;grid-template-columns:repeat(6,1fr);gap:0;margin:0;padding:0}
.tledger-row li{border-left:1px solid var(--bd)}
.tledger-row li:first-child{border-left:none}
.tledger-row a{display:flex;flex-direction:column;gap:6px;text-decoration:none;padding:6px 14px 12px;transition:color .15s}
.tledger-row a:hover .tl-h{color:var(--clay-t)}
.tl-n{font-family:'Newsreader',serif;font-weight:700;font-size:1.15rem;color:var(--clay-ink);line-height:1}
.tl-h{font-size:.82rem;font-weight:600;color:#3a332c;line-height:1.25}
/* BODY GRID — sticky dial + main */
.timneh-body{display:grid;grid-template-columns:196px minmax(0,1fr);gap:28px;align-items:start;margin-top:14px}
/* DIAL 1 · CLAY PROGRESS (light card, clay ring) */
.tdial{display:flex;flex-direction:column;gap:10px;align-items:stretch;background:#fff;border:1px solid var(--bd);border-radius:16px;padding:12px 10px;box-shadow:0 3px 12px rgba(60,30,10,.05);position:sticky;top:calc(var(--hdr) + 16px);max-height:calc(100vh - var(--hdr) - 32px);overflow-y:auto;scrollbar-width:thin;scrollbar-color:#e0b6a8 transparent}
.tdial-ring{margin:2px auto 0;flex:none;width:64px;height:64px;border-radius:50%;background:conic-gradient(var(--clay) calc(var(--p,6) * 1%),#f0e2d9 0);display:grid;place-items:center}
.tdial-ring>div{width:50px;height:50px;border-radius:50%;background:#fff;display:grid;place-items:center;text-align:center;font-family:'Newsreader',serif}
.tdial-ring b{font-size:15px;color:var(--clay-t);display:block;line-height:1}
.tdial-ring span{font-size:7px;color:#6b625a;letter-spacing:.08em;text-transform:uppercase}
.tdial-list{display:grid;grid-template-columns:1fr;gap:1px;border-top:1px dashed var(--bd);padding-top:8px}
.tdial-list a{display:flex;gap:7px;align-items:baseline;color:#4a423b;text-decoration:none;font-size:.74rem;line-height:1.25;padding:5px 7px;border-radius:8px;transition:background-color .15s,color .15s}
.tdial-list a:hover{background:#fdf0ea;color:#2a2622}
.tdial-list a.on{background:#fdf0ea;color:#2a2622;font-weight:600}
.tdial-list a.on .num{color:var(--clay-t)}
.tdial-list .num{font-family:'Newsreader',serif;font-weight:700;color:#6b625a;width:16px;flex:none;font-size:.7rem;font-variant-numeric:tabular-nums}
.tdial-list .tag{margin-left:auto;font-size:.56rem;font-weight:600;letter-spacing:.02em;color:#fff;background:var(--clay-ink);border-radius:50px;padding:1px 6px;white-space:nowrap}
/* SECTION CTA row */
.sec-cta{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin:4px 0 20px}
.sec-cta .btn-clay,.sec-cta .btn-ghost{padding:11px 22px;font-size:.86rem}
.sec-cta .btn-ghost{border:2px solid var(--f);color:var(--f);background:none}
.sec-cta .btn-ghost:hover{background:var(--f);color:#fff}
/* K2 · price-tag takeaway */
.k2{display:grid;grid-template-columns:minmax(0,220px) 1fr;gap:0;border:1px solid var(--bd);border-radius:16px;overflow:hidden;margin:4px 0 16px;max-width:600px;box-shadow:0 6px 20px rgba(60,30,10,.08)}
.k2-tag{background:linear-gradient(135deg,#bd4129,#9c3a23);color:#fff;padding:20px 22px;display:flex;flex-direction:column;justify-content:center;gap:4px}
.k2-eyebrow{font-size:.66rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#f6d3c6}
.k2-price{font-family:'Newsreader',serif;font-size:2.1rem;line-height:1;font-weight:600}
.k2-price small{font-size:1rem;opacity:.85}
.k2-sub{font-size:.72rem;color:#f6d3c6}
.k2-list{list-style:none;margin:0;padding:12px 20px;display:flex;flex-direction:column;justify-content:center;background:#fff}
.k2-list li{display:flex;justify-content:space-between;gap:14px;font-size:.86rem;padding:7px 0;border-bottom:1px dotted #e6dad0}
.k2-list li:last-child{border-bottom:none}
.k2-list b{color:var(--clay-t);white-space:nowrap}
/* K5 · capsule strip */
.k5{display:flex;flex-wrap:wrap;gap:10px;margin:2px 0 4px}
.k5 .cap{display:flex;flex-direction:column;gap:1px;background:#eaf4ef;border:1px solid #cfe6da;border-radius:12px;padding:8px 14px;font-size:.72rem;color:#3d5b4d}
.k5 .cap b{font-family:'Newsreader',serif;font-size:.95rem;color:var(--f)}
/* MAIN type scale */
.timneh-main{max-width:880px;min-width:0}
.timneh-main section{margin-bottom:14px;scroll-margin-top:calc(var(--hdr) + 18px);padding-top:20px}
.timneh .cag-h2{font-family:'Newsreader',serif;font-size:clamp(1.375rem,3.5vw,2rem);color:#2a2622;margin:8px 0 16px;line-height:1.18}
.timneh .cag-h3{font-family:'Newsreader',serif;font-size:clamp(1.125rem,2.2vw,1.5rem);color:var(--f);margin:24px 0 10px;line-height:1.25}
.timneh .cag-h4{font-family:'Newsreader',serif;font-size:clamp(1rem,1.8vw,1.25rem);margin:20px 0 8px;line-height:1.3;color:#2a2622}
.timneh .cag-h5{font-family:'Newsreader',serif;font-size:clamp(.95rem,1.25vw,1.05rem);margin:16px 0 6px;color:#3a332c}
.timneh .cag-h6{font-family:'IBM Plex Sans',sans-serif;font-size:clamp(.75rem,.95vw,.82rem);letter-spacing:.04em;text-transform:uppercase;color:var(--clay-t);margin:16px 0 4px}
.timneh-main p{line-height:1.68;margin:0 0 15px;max-width:70ch}
.timneh-main a{color:var(--clay-t);text-decoration:underline;text-underline-offset:2px}
.timneh-main a.btn-clay,.timneh-main a.btn-ghost{text-decoration:none}
.timneh-main a.btn-clay{color:#fff}
/* External link ↗ arrow indicator */
.timneh-main p a[target="_blank"]::after{content:"\2197";font-size:.78em;font-weight:700;margin-left:2px;text-decoration:none;display:inline-block;vertical-align:baseline}
.sec-img{display:block;width:100%;max-width:760px;aspect-ratio:1408/768;object-fit:cover;height:auto;border-radius:18px;margin:4px 0 18px;box-shadow:0 6px 20px rgba(60,30,10,.1)}
.sec-img.inf-img{box-shadow:0 4px 16px rgba(60,30,10,.08)}
.sec-img.fit-contain{object-fit:contain;background:#f6efe8;border:1px solid var(--bd)}
/* SEAM */
.seam{display:flex;align-items:center;justify-content:center;gap:14px;margin:22px 0}
.seam::before,.seam::after{content:"";flex:1;max-width:220px;height:2px;border-radius:1px}
.seam::before{background:linear-gradient(90deg,transparent,rgba(200,71,47,.5))}
.seam::after{background:linear-gradient(90deg,rgba(200,71,47,.5),transparent)}
.seam img{width:auto;height:30px;object-fit:contain;opacity:.95}
/* PRICE BAND (HTML) */
.priceband{background:#fff;border:1px solid var(--bd);border-radius:18px;padding:18px 20px;margin:6px 0 16px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.pb-scale{display:flex;justify-content:space-between;font-size:.72rem;font-weight:600;color:var(--mid);margin-bottom:6px;font-variant-numeric:tabular-nums}
.pb-bar{display:flex;gap:4px}
.pb-zone{display:flex;flex-direction:column;justify-content:center;gap:2px;border-radius:8px;padding:12px 10px;color:#fff;font-size:.72rem;line-height:1.2}
.pb-zone em{font-style:normal;font-weight:700;font-size:.82rem}
.pb-zone.red{background:#bd4129}
.pb-zone.green{background:var(--f)}
.pb-zone.amber{background:#c99a4e}
.pb-note{font-size:.82rem;color:#4a423b;margin:10px 0 0!important;max-width:none}
.pb-note b{color:var(--clay-t)}
/* CARE CARDS (HTML) */
.carecards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:6px 0 16px}
.cc{background:#fff;border:1px solid var(--bd);border-radius:14px;padding:14px 15px;box-shadow:0 3px 12px rgba(60,30,10,.05);display:flex;flex-direction:column;gap:3px}
.cc-k{font-size:.66rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#9c3a23}
.cc b{font-family:'Newsreader',serif;font-size:1.12rem;color:#2a2622;line-height:1.1}
.cc-s{font-size:.74rem;color:#6b625a;line-height:1.35}
/* TABLE A */
.otA{border-radius:18px;overflow:hidden;box-shadow:0 4px 16px rgba(60,30,10,.08);border:1px solid var(--bd);margin:6px 0 18px}
.otA table{border-collapse:collapse;width:100%}
.otA th{background:var(--clay-ink);color:#fff;padding:12px 14px;text-align:left;font-size:.8rem;font-weight:600}
.otA td{background:#fff;padding:12px 14px;border-bottom:1px solid #f3e6de;font-size:.86rem}
.otA tr:nth-child(even) td{background:#fdf4ef}
.otA td:first-child b{font-family:'Newsreader',serif;font-size:.98rem}
.otA .sub{display:block;font-size:.72rem;color:var(--clay-t)}
/* TABLE B · clay-spine species cards (Congo-vs teaser) */
.otB{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.otB-card{background:#fff;border:1px solid var(--bd);border-left:4px solid #b8a294;border-radius:14px;padding:16px 18px}
.otB-card.feat{border-left-color:var(--clay-ink)}
.otB-name{display:flex;align-items:center;gap:8px;font-family:'Newsreader',serif;font-size:1.15rem;color:#2a2622;margin-bottom:8px}
.otB-card ul{list-style:none;margin:0;padding:0}
.otB-card li{font-size:.84rem;color:#4a423b;padding:5px 0;border-bottom:1px dashed var(--bd)}
.otB-card li:last-child{border-bottom:none;color:var(--clay-t);font-weight:600}
/* SHIP CARDS */
.ship-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.ship-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.ship-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.ship-c>img{display:block;width:100%;height:200px;object-fit:cover}
.ship-body{padding:16px 18px}
.ship-tier{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 12px;font-size:.7rem;font-weight:600}
.ship-tier.clay{background:var(--clay-ink)}
.ship-c b{font-family:'Newsreader',serif;display:block;margin:8px 0 2px;font-size:1.15rem}
.ship-price{color:var(--clay-t);font-weight:700;font-size:1.15rem}
.ship-c p{font-size:.82rem;color:#5b524a;margin:6px 0 0!important;max-width:none}
.ship-line{font-size:.78rem;color:#7a6f64;font-weight:600;border-top:1px dashed var(--bd);padding-top:8px}
/* GEO ROUTE CARDS */
.geo-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:6px 0 16px}
.geo-c{display:flex;align-items:center;gap:12px;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:12px 14px;text-decoration:none!important;transition:transform .15s,box-shadow .2s,border-color .2s}
.geo-c:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(60,30,10,.1);border-color:var(--clay)}
.geo-pin{flex:none;width:34px;height:34px;border-radius:10px;background:#fdf0eb;color:#9c3a23;display:grid;place-items:center}
.geo-pin svg{width:17px;height:17px}
.geo-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.geo-kw{font-size:.87rem;font-weight:600;color:#2a2622;line-height:1.3}
.geo-note{font-size:.72rem;color:#7a6f64}
.geo-arrow{flex:none;color:#9c3a23;font-weight:700}
/* DOC STACK */
.doc-stack{background:linear-gradient(135deg,#fff,#fdf4ef);border:1px solid var(--bd);border-radius:18px;padding:20px 22px;margin:6px 0 16px;max-width:560px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.ds-title{font-family:'Newsreader',serif;font-size:1.15rem;margin:0 0 12px;color:#2a2622;padding-bottom:10px;border-bottom:2px solid var(--f)}
.ds-list{list-style:none;margin:0;padding:0;counter-reset:ds}
.ds-list li{counter-increment:ds;display:flex;flex-direction:column;gap:1px;padding:9px 0 9px 40px;position:relative;border-bottom:1px dashed var(--bd)}
.ds-list li:last-child{border-bottom:none}
.ds-list li::before{content:counter(ds,decimal-leading-zero);position:absolute;left:0;top:10px;font-family:'Newsreader',serif;font-weight:700;font-size:.85rem;color:#fff;background:var(--f);width:28px;height:28px;border-radius:9px;display:grid;place-items:center}
.ds-list b{font-size:.9rem;color:#2a2622}
.ds-list span{font-size:.76rem;color:#6b625a}
/* VERIFY CHECKLIST (light) */
.chkT{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;margin:6px 0 18px;box-shadow:0 4px 16px rgba(60,30,10,.07)}
.chkT-head{background:linear-gradient(135deg,#faf5f1,#fdf0ea);padding:16px 22px;border-bottom:1px solid var(--bd)}
.chkT-eyebrow{color:var(--clay-t);font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin:0 0 3px}
.chkT-title{font-family:'Newsreader',serif;font-size:1.15rem;color:#2a2622;margin:0;line-height:1.25;max-width:none}
.chkT-grid{list-style:none;margin:0;padding:14px 22px 18px;display:grid;grid-template-columns:1fr 1fr;gap:2px 26px;counter-reset:chk}
.chkT-grid li{counter-increment:chk;display:flex;flex-direction:column;gap:1px;padding:10px 0 10px 36px;position:relative;border-bottom:1px dashed var(--bd)}
.chkT-grid li::before{content:counter(chk);position:absolute;left:0;top:11px;width:24px;height:24px;border-radius:8px;background:#e7f1ec;color:var(--f);font-weight:700;font-size:.78rem;display:grid;place-items:center;font-family:'Newsreader',serif}
.chkT-grid b{font-size:.88rem;color:#2a2622}
.chkT-grid span{font-size:.76rem;color:#6b625a;line-height:1.45}
/* K3 green ledger band */
.k3{background:linear-gradient(135deg,#1e5038,#2d6a4f);color:#fff;border-radius:16px;padding:20px 24px;margin:6px 0 18px;max-width:560px;box-shadow:0 8px 24px rgba(30,80,56,.22)}
.k3-title{font-family:'Newsreader',serif;font-size:1.18rem;margin:0 0 10px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,.22);color:#fff}
.k3-row{display:flex;justify-content:space-between;gap:14px;font-size:.9rem;padding:9px 0;border-bottom:1px dashed rgba(255,255,255,.16)}
.k3-row.last{border-bottom:none;padding-bottom:0}
.k3-row span{color:rgba(255,255,255,.86)}
.k3-row b{color:#a7e0c2;white-space:nowrap}
/* QUOTES */
.quote-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 4px}
.quote-c{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:16px;margin:0}
.q-head{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.q-av{width:48px;height:48px;border-radius:50%;object-fit:cover;flex:none;border:2px solid #eaf4ef}
.q-id{flex:1;min-width:0}
.q-name{display:block;font-family:'Newsreader',serif;font-size:1rem;color:#2a2622;line-height:1.2}
.q-loc{display:block;font-size:.75rem;color:#7a6f64;margin-top:1px}
.stars{color:#c9a227;letter-spacing:2px;font-size:.85rem;flex:none}
.quote-c p{font-size:.9rem;font-style:italic;margin:0;max-width:none}
/* FORM */
.final-cta{background:var(--cream);border:1px solid var(--bd);border-radius:20px;padding:clamp(22px,4vw,36px);margin-bottom:20px}
.cta-form{display:grid;gap:12px;max-width:640px;margin:10px 0 0}
.cta-form label{display:grid;gap:5px;font-size:.85rem;font-weight:600;color:#3a332c}
.cta-form .opt{font-weight:400;color:#7a6f64}
.cta-form input,.cta-form textarea,.cta-form select{border:1.5px solid var(--bd);border-radius:12px;padding:11px 13px;font:inherit;font-weight:400;background:#fff9f6;width:100%}
.cta-form input:focus,.cta-form textarea:focus,.cta-form select:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.12)}
.form-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px}
.cta-form button{border:none;cursor:pointer}
.cta-form .btn-ghost{border:2px solid var(--f);color:var(--f);padding:11px 22px}
.cta-form .btn-ghost:hover{background:var(--f);color:#fff}
.form-note{font-size:.8rem;color:#7a6f64;margin:2px 0 0!important}
.hp{position:absolute;left:-9999px}
/* NEWSLETTER — for-sale split */
.fs-nl{margin:24px 0;border-radius:20px;overflow:hidden;box-shadow:0 6px 22px rgba(60,30,10,.08)}
.fs-nl.split{display:grid;grid-template-columns:minmax(0,320px) 1fr;background:#fff;border:1px solid var(--bd)}
.fs-nl-media{position:relative}
.fs-nl-media img{display:block;width:100%;height:100%;object-fit:cover;aspect-ratio:1408/768}
.fs-nl-cap{position:absolute;left:12px;bottom:12px;background:rgba(34,31,29,.8);color:#fff;font-size:.68rem;font-weight:600;padding:4px 11px;border-radius:50px}
.fs-nl-body{padding:clamp(20px,3vw,30px)}
.fs-nl-eyebrow{color:var(--clay-t);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px}
.fs-nl-h{font-family:'Newsreader',serif;font-size:clamp(1.15rem,2.2vw,1.45rem);line-height:1.2;margin:0 0 6px;color:#2a2622}
.fs-nl-sub{font-size:.86rem;line-height:1.55;margin:0 0 14px!important;max-width:62ch;color:#5b524a}
.fs-nl-form{display:flex;gap:10px;flex-wrap:wrap}
.fs-nl-form input{flex:1;min-width:200px;border:1.5px solid var(--bd);border-radius:50px;padding:12px 18px;font:inherit;background:#fff;color:#2a2622}
.fs-nl-form input:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.15)}
.fs-nl-form button{border:none;cursor:pointer}
.fs-nl-note{font-size:.74rem;color:var(--mid);margin:10px 0 0!important}
/* AVAIL-C · clean card */
.availC{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin:12px 0 4px;max-width:560px}
.ac-tile{display:flex;flex-direction:column;border-radius:16px;overflow:hidden;background:#fff;border:1px solid var(--bd);text-decoration:none!important;box-shadow:0 4px 14px rgba(60,30,10,.07);transition:transform .2s,box-shadow .2s}
.ac-tile:hover{transform:translateY(-3px);box-shadow:0 14px 30px rgba(60,30,10,.14)}
.ac-tile:focus-visible{outline:3px solid var(--clay-ink);outline-offset:2px}
.ac-photo{position:relative;display:block;aspect-ratio:1/1;overflow:hidden;background:#e7ddd4}
.ac-photo img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .35s cubic-bezier(.22,1,.36,1)}
.ac-tile:hover .ac-photo img{transform:scale(1.04)}
.ac-badge{position:absolute;top:10px;left:10px;font-size:.6rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#fff;background:rgba(28,58,46,.92);padding:4px 10px;border-radius:50px}
/* Evie's FEMALE badge sits at middle-left so it never covers her face */
.ac-tile[data-cat="female"] .ac-badge{top:50%;transform:translateY(-50%)}
.ac-info{display:flex;flex-direction:column;gap:6px;padding:12px 13px 13px;flex:1}
.ac-top{display:flex;align-items:baseline;justify-content:space-between;gap:8px}
.ac-name{font-family:'Newsreader',serif;font-size:1.12rem;font-weight:600;color:#2a2622;line-height:1.1}
.ac-price{font-family:'Newsreader',serif;font-weight:700;font-size:1rem;color:var(--clay-t);white-space:nowrap}
.ac-blurb{font-size:.73rem;line-height:1.4;color:#6b625a;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.ac-go{margin-top:auto;display:block;text-align:center;background:var(--clay-ink);color:#fff;font-size:.76rem;font-weight:700;border-radius:50px;padding:8px 10px;white-space:nowrap;transition:background-color .2s}
.ac-tile:hover .ac-go{background:#9c3a23}
.side-note{font-size:.78rem;color:#7a6f64;font-weight:600;margin:8px 0 14px}
/* FAQ-B · two-column compact accordion */
.faqB{margin:8px 0 6px;display:grid;grid-template-columns:1fr 1fr;gap:10px;align-items:start}
.faqB-item{background:#fff;border:1px solid var(--bd);border-radius:12px;overflow:hidden;box-shadow:0 2px 10px rgba(60,30,10,.04)}
.faqB-item summary{list-style:none;cursor:pointer;display:flex;align-items:center;gap:12px;padding:13px 16px;color:#2a2622}
.faqB-item summary::-webkit-details-marker{display:none}
.faqB-q{font-family:'Newsreader',serif;font-size:.98rem;font-weight:600;flex:1;line-height:1.3}
.faqB-x{position:relative;width:15px;height:15px;flex:none}
.faqB-x:before,.faqB-x:after{content:"";position:absolute;background:var(--clay-ink);border-radius:2px;transition:transform .2s}
.faqB-x:before{top:6.5px;left:0;width:15px;height:2px}
.faqB-x:after{left:6.5px;top:0;width:2px;height:15px}
.faqB-item[open] .faqB-x:after{transform:scaleY(0)}
.faqB-item[open] summary{border-bottom:1px solid var(--bd)}
.faqB-item p{color:#4a423b;font-size:.86rem;margin:0;padding:12px 16px 14px;max-width:none;line-height:1.55}
/* READ / BLOG cards */
.read-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:8px 0 6px}
.read-c{display:flex;gap:0;background:#fff;border:1px solid var(--bd);border-radius:16px;overflow:hidden;text-decoration:none;transition:transform .15s,box-shadow .2s}
.read-c:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(60,30,10,.12)}
.read-img{flex:0 0 148px;display:block;position:relative;overflow:hidden}
.read-img img{display:block;width:148px;height:100%;min-height:140px;object-fit:cover;transition:transform .2s}
.read-c:hover .read-img img{transform:scale(1.04)}
.read-body{display:flex;flex-direction:column;padding:14px 16px;min-width:0}
.read-kicker{font-size:.62rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#9c3a23}
.read-title{font-family:'Newsreader',serif;font-size:1.08rem;color:#2a2622;margin:4px 0 4px;line-height:1.25}
.read-c:hover .read-title{color:#9c3a23}
.read-sub{font-size:.8rem;color:#6b625a;line-height:1.45}
.read-more{font-size:.76rem;font-weight:700;color:var(--f);margin-top:auto;padding-top:10px}
/* CONTACT FORM two-column */
.form-head{max-width:640px}
.form-eyebrow{color:var(--clay-t);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px}
.form-wrap{display:grid;grid-template-columns:250px 1fr;gap:20px;margin-top:16px;align-items:start}
.form-side{background:#1c3a2e;color:#fff;border-radius:16px;padding:20px}
.fs-title{font-family:'Newsreader',serif;font-size:1.05rem;margin:0 0 12px;color:#fff}
.fs-list{list-style:none;margin:0;padding:0}
.fs-list li{display:flex;justify-content:space-between;gap:12px;font-size:.84rem;padding:8px 0;border-bottom:1px dashed rgba(255,255,255,.14);color:rgba(255,255,255,.85)}
.fs-list li b{color:#8fd3ac;white-space:nowrap}
.fs-ship{font-size:.72rem;color:rgba(255,255,255,.6);margin:12px 0 0!important}
/* ===== TABLET / MOBILE ===== */
@media(max-width:980px){
  .tledger-row{grid-template-columns:repeat(3,1fr)}
  .tledger-row li:nth-child(4){border-left:none}
}
@media(max-width:900px){
  .chero-grid{grid-template-columns:1fr;gap:14px}
  .chero-media{order:-1;aspect-ratio:16/10}
  .chero-ribbon{display:grid;grid-template-columns:1fr 1fr;gap:8px 14px}
  .desk-only{display:none}
  .chero-rail{display:block}
  .timneh-body{grid-template-columns:1fr;gap:0}
  .k2{grid-template-columns:1fr;max-width:440px}
  .fs-nl.split{grid-template-columns:1fr}
  .fs-nl-media img{aspect-ratio:16/9;max-height:200px}
  .fs-nl-body{padding:18px 16px}
  .form-wrap{grid-template-columns:1fr}
  .form-side{order:2}
  .read-cards,.faqB,.otB{grid-template-columns:1fr}
  .read-img{flex-basis:120px}
  .read-img img{width:120px}
  .ship-cards,.quote-grid{grid-template-columns:1fr}
  .geo-cards{grid-template-columns:1fr}
  .chkT-grid{grid-template-columns:1fr;padding:10px 16px 14px}
  .form-2col{grid-template-columns:1fr}
  .timneh-main .sec-img{width:100%;max-width:100%;margin-left:0;border-radius:14px}
  .timneh-main .sec-img.og-photo{aspect-ratio:5/4}
  /* Bird-portrait OG photos: distinct taller full-bleed 4:5 frame on mobile (blur-fill keeps the full bird) */
  .timneh-main .sec-img.og-tall{width:100vw;max-width:100vw;margin-left:calc(50% - 50vw);aspect-ratio:4/5;border-radius:0}
  /* TABLE A stacking */
  .otA table,.otA thead,.otA tbody,.otA tr,.otA th,.otA td{display:block}
  .otA thead{display:none}
  .otA tr{border-bottom:6px solid var(--cream)}
  .otA td{display:flex;justify-content:space-between;gap:14px;border-bottom:1px solid #f3e6de}
  .otA td:before{content:attr(data-label);font-weight:600;color:var(--mid);font-size:.72rem;letter-spacing:.02em}
  .otA td:first-child{display:block}
  .otA td:first-child:before{display:none}
}
@media(max-width:640px){
  .tledger-row{grid-template-columns:1fr 1fr}
  .tledger-row li{border-left:none;border-top:1px solid var(--bd)}
  .tledger-row li:nth-child(-n+2){border-top:none}
  .carecards{grid-template-columns:1fr 1fr}
  .availC{gap:10px}
  .ac-blurb{display:none}
  .ac-info{padding:9px 10px 10px;gap:5px}
  .ac-top{flex-direction:column;align-items:flex-start;gap:1px}
  .ac-name{font-size:1rem}
  .ac-price{font-size:.9rem}
  .ac-go{font-size:.7rem;padding:7px 8px}
  .ac-badge{font-size:.55rem;padding:3px 8px;top:8px;left:8px}
  .pb-zone{font-size:.6rem;padding:10px 5px}
  .pb-zone em{font-size:.66rem}
}
@media(max-width:520px){.carecards{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){.timneh *{transition:none!important}}
</style>

<script>
  const dial = document.getElementById('timnehDial');
  const num = document.getElementById('dialNum');
  const secs = Array.from(document.querySelectorAll('.timneh-main section[id]'));
  const dialLinks = dial ? Array.from(dial.querySelectorAll('a[data-i]')) : [];
  const railLinks = Array.from(document.querySelectorAll('.chero-rail .railB a'));
  const total = secs.length || 1;
  function setActive(i) {
    if (dial) dial.style.setProperty('--p', String(Math.round(((i + 1) / total) * 100)));
    if (num) num.textContent = String(i + 1);
    dialLinks.forEach((a, k) => a.classList.toggle('on', k === i));
    railLinks.forEach((a, k) => a.classList.toggle('on', k === i));
  }
  if (secs.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const i = secs.indexOf(e.target);
          if (i > -1) setActive(i);
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
    secs.forEach((s) => io.observe(s));
    setActive(0);
  }

  // FAQ: first item stays closed on desktop, opens on mobile for scan-ability
  if (window.matchMedia('(max-width:900px)').matches) {
    const firstFaq = document.querySelector('.faqB .faqB-item');
    if (firstFaq) firstFaq.open = true;
  }
</script>
