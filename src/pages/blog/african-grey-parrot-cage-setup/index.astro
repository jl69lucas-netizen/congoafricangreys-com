const howToSteps = [
  { name: "Choose the right cage", text: "Pick a 304-stainless or verified lead/zinc-free cage — Congo 36\"×24\"×48\" minimum (48\"+ wide ideal), correct bar spacing." },
  { name: "Add perches by zone", text: "Mount 4–7 perches of varied diameter and material — a sleeping perch up high, activity perches in the middle, a foraging-friendly low perch." },
  { name: "Add toys and a rotation bin", text: "Hang 6–8 toys across foraging, shreddable, puzzle and foot categories; keep spares in a bin and swap 2–3 weekly." },
  { name: "Set food and water stations", text: "Place stainless bowls in the middle zone, never directly beneath a perch, with a separate foraging station lower down." },
  { name: "Place the cage", text: "Against a wall at eye level in a busy family room, away from the kitchen, drafts and direct sun." },
];

const faqs = [
  {
    q: "What size cage does an African Grey parrot need?",
    a: "A Congo African Grey needs at least 36\" wide × 24\" deep × 48\" tall, and a Timneh at least 30\" × 20\" × 40\" — but wider is genuinely better, and 48\"–60\" of width is the sweet spot. Bar spacing should be 3/4\"–1\" for Congos and 5/8\"–3/4\" for Timnehs. Skip round cages; parrots need corners to feel secure.",
  },
  {
    q: "Where should an African Grey's cage be placed?",
    a: "Against a wall, at eye level, in a room the family actually uses — Greys are intensely social and need to watch daily life. Keep the cage well away from the kitchen (PTFE/Teflon fumes are lethal), away from drafts and vents, and out of more than a few hours of direct sun.",
  },
  {
    q: "How many toys does an African Grey need in its cage?",
    a: "Hang 4–7 toys at a time across four categories — foraging, shreddable, puzzle, and foot toys — and keep a bin of 6–8 so you can rotate. Swap 2–3 toys every 5–7 days while leaving 2 familiar ones in place, so the cage stays interesting without triggering neophobia.",
  },
  {
    q: "Do African Greys need UV light?",
    a: "They benefit from it. African Greys are prone to calcium and vitamin-D issues, and a bird-safe UVB lamp (run on a timer for a few hours daily, never through window glass) helps them synthesise vitamin D3 and use calcium properly. It supplements — it does not replace — a good pellet-based diet and vet care.",
  },
  {
    q: "Can an African Grey stay in its cage all day?",
    a: "No. A cage is a secure base, not a full-time home. Greys need at least 4 hours of supervised out-of-cage time daily plus 10–12 hours of quiet, covered sleep. Confining a Grey to its cage around the clock is one of the fastest routes to feather plucking and screaming.",
  },
  {
    q: "What is the safest bar spacing for an African Grey?",
    a: "3/4\"–1\" for adult Congos and 5/8\"–3/4\" for Timnehs. For just-weaned fledglings we run 7/8\"–1\": at 3/4\" a clumsy young bird can wedge a wing or head. The rule is simple — your Grey should never be able to push its head through the gap.",
  },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Cage Setup: The Breeder's Blueprint",
  description,
  image: "https://congoafricangreys.com/african-grey-cage-setup-blueprint-infographic.webp",
  author: { "@type": "Person", name: "Mark & Teri Benjamin" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com", url: "https://congoafricangreys.com" },
  datePublished: "2026-05-22",
  dateModified: "2026-06-28",
  mainEntityOfPage: canonical,
  url: canonical,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

