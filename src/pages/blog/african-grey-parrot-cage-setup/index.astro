  { label: "Enrichment", href: "#enrichment" },
  { label: "Checklist", href: "#checklist" },
  { label: "FAQ", href: "#faq" },
];

const quickRows = [
  { label: "Congo minimum cage", value: '36" W × 24" D × 48" H' },
  { label: "Timneh minimum cage", value: '30" W × 20" D × 40" H' },
  { label: "Bar spacing", value: '3/4"–1" (7/8"–1" for fledglings)' },
  { label: "Safest material", value: "304 stainless steel" },
  { label: "Perches", value: "3+ of varying diameter & texture" },
  { label: "Toy rotation", value: "swap 2–3 every 5–7 days" },
];

const sizeColumns = ["Subspecies", "Minimum size", "Bar spacing", "Ideal size"];
const sizeRows = [
  { item: "Congo African Grey", values: ['36" × 24" × 48"', '3/4" – 1"', '40" × 30" × 60"'] },
  { item: "Timneh African Grey", values: ['30" × 20" × 40"', '5/8" – 3/4"', '36" × 24" × 48"'] },
];

const cageBranches = [
  { answer: "Congo + room to spare", result: 'Go 40"×30"×60" with 7/8"–1" bar spacing — the build we recommend for every Congo we place.' },
  { answer: "Congo + tight budget/space", result: 'A 36"×24"×48" play-top cage at 3/4"–1" spacing is the safe floor — never smaller.' },
  { answer: "Timneh African Grey", result: 'Drop to 30"×20"×40" minimum at 5/8"–3/4" spacing — Timnehs have smaller heads and slip through wider bars.' },
