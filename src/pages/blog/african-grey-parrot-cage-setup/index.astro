const title = "African Grey Parrot Cage Setup: Size, Bar Spacing & Enrichment | C.A.Gs";
const description = "African Grey cage setup from USDA-licensed breeders: minimum 36\"×24\"×48\" cage, safe 3/4\"–1\" bar spacing, stainless-steel materials, perch variety, placement rules, and the enrichment-rotation system we use in our aviary.";
const canonical = "https://congoafricangreys.com/blog/african-grey-parrot-cage-setup/";

const breadcrumbs = [
