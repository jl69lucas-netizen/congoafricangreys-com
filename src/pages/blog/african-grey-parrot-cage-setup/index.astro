];

const faqs = [
  {
    q: "What size cage does an African Grey parrot need?",
    a: "The minimum cage for a Congo African Grey is 36\" wide × 24\" deep × 48\" tall; for a Timneh, 30\" × 20\" × 40\". Bigger is always better — we house ours in 40\"×30\"×60\" flights. Bar spacing should be 3/4\"–1\" for Congos and 5/8\"–3/4\" for Timnehs. Skip round cages — parrots need corners to feel secure.",
  },
  {
    q: "What is the safest bar spacing for an African Grey?",
    a: "3/4\" to 1\" is safe for adult Congos and 5/8\" to 3/4\" for Timnehs. For just-weaned fledglings we run 7/8\"–1\": at 3/4\" a clumsy young bird can wedge a wing or head between the bars. The rule is simple — your Grey should never be able to push its head through the gap.",
  },
  {
    q: "What material should an African Grey cage be made from?",
    a: "304-grade stainless steel is the only safe long-term choice — it never rusts and won't shed anything toxic when chewed. Powder-coated steel is acceptable only if the manufacturer confirms it's lead-free and zinc-free. Never use galvanized metal (zinc poisoning is fatal) or chrome plating (it flakes and causes heavy-metal toxicity).",
  },
  {
    q: "How many perches does an African Grey need, and what kind?",
    a: "At least three, in different diameters (3/4\"–1.5\") and textures: one natural-wood perch (manzanita or java wood), one rope perch for sleeping, and one pumice or concrete conditioning perch for nails and beak. Avoid smooth wooden dowels — uniform diameter causes pressure sores within months.",
  },
  {
    q: "Where should I place an African Grey's cage in my home?",
    a: "Against a wall (not marooned in the centre of a room) at eye level or slightly above, in a room the family actually uses. Keep it well away from the kitchen — PTFE/Teflon fumes from non-stick cookware kill birds — and away from drafts, vents, and more than a few hours of direct sun.",
  },
  {
    q: "How often should I rotate my African Grey's toys?",
    a: "Swap 2–3 toys every 5–7 days while leaving 2 familiar toys in place. African Greys are neophobic at first but bored within a week, so this rotation balances novelty against security. Cycle through four categories: foraging, shreddable, puzzle, and foot toys.",
  },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Cage Setup: Size, Bar Spacing, Materials & Enrichment",
  description,
  author: { "@type": "Person", name: "Mark & Teri Benjamin" },
  publisher: {
    "@type": "Organization",
    name: "CongoAfricanGreys.com",
    url: "https://congoafricangreys.com",
  },
  datePublished: "2026-05-22",
  dateModified: "2026-06-27",
  mainEntityOfPage: canonical,
  url: canonical,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const h2 = "font-lora font-bold text-3xl mt-12 mb-5 scroll-mt-24";
const h3 = "font-lora font-bold text-2xl mt-8 mb-3";
const h4 = "font-lora font-semibold text-xl mt-6 mb-2";
const h5 = "font-sora font-semibold text-base mt-5 mb-1";
