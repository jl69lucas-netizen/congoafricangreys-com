    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp', objectPos: 'object-center',
    hook: 'Gentle, established — our value Congo.',
    notes: 'Soft temperament, 1-year-old female at the $1,700 honest floor — tame, documented and ready for the right home.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Bonded Duo', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair-talking-birds.webp', objectPos: 'object-center',
    hook: 'Two hand-raised birds, adopted together.',
    notes: 'Unrelated companion pair sold together. Jins (male, 6mo) + Jeni (female, 4mo), both fully documented and hand-raised.' },
];

const faqs = [
  { q: "Can I buy an African Grey online safely?",
    a: "Yes — but only when you verify the seller the same way every time. Buying online is safe with a reputable, USDA-licensed breeder who will do a live video call with the bird in hand, provide CITES Appendix I papers, a PCR DNA-sexing certificate and an avian-vet health certificate, and accept a reversible deposit. It becomes dangerous the moment a seller refuses any of those. The internet isn't the risk; skipping the checks is." },
  { q: "Are Facebook or Instagram bird sellers legit?",
    a: "Some are, but social platforms are where most African Grey scams start, so treat every listing as unverified until it passes the seller check. A genuine breeder on Facebook or Instagram will happily move to a live video call, show full paperwork and a USDA licence, and take a payment you can dispute. A scammer will push you toward urgency, wire transfers or gift cards, and will always have a reason they can't video-call the bird right now. If you can't verify a physical location and licence, don't send money." },
  { q: "How much should an African Grey deposit be?",
    a: "A reasonable deposit to hold a specific bird is a few hundred dollars — we take $200 — paid by a reversible method, with the balance settled before the bird travels. Be wary of a seller who wants the full amount up front by wire or crypto, or a 'deposit' that's suspiciously large. A real breeder reserves the bird, keeps you updated while it finishes weaning, and never needs an irreversible payment to hold it." },
  { q: "Is a breeder or a rescue better for a first-time owner?",
    a: "For most first-time owners, a reputable breeder is the more predictable path, because a hand-raised, health-tested baby arrives socialised, documented and without a hidden behavioural history. A rescue African Grey can be a wonderful choice too, but rescued Greys often carry trust issues, feather-plucking or bonded-to-one-person behaviour that suit an experienced home better. Either way, insist on health records and never on wild-caught origin." },
  { q: "What paperwork should a reputable breeder provide?",
    a: "Every legitimate African Grey should come with CITES Appendix I captive-bred documentation, a PCR DNA-sexing certificate, an avian-vet health certificate, a hatch certificate and a closed band number — plus a written health guarantee and a USDA licence you can verify. If a seller can't produce that full set before you pay, that isn't a paperwork delay; it's a warning. Missing papers is the single most common thread in undocumented and scam birds." },
  { q: "How do I find an African Grey breeder near me?",
    a: "Start with breeders who publish a real address, a USDA licence and original photos and video of their own birds, then verify them the same way you'd verify any online seller. 'Near me' matters less than 'verifiable' — a reputable breeder a few states away who ships on IATA-compliant flights is safer than an anonymous local listing. We ship nationwide, $185 to your nearest airport or $350 home delivery, so distance rarely needs to decide it." },
  { q: "What's the safest way to pay for a parrot?",
    a: "Use a payment method you can dispute and reverse if something goes wrong. Never wire money, buy gift cards or send cryptocurrency for a bird you haven't verified, because those payments are gone the instant you send them — which is exactly why scammers demand them. A reversible deposit, paid only after you've seen the bird live and the paperwork in full, is the safest route every time." },
];

const img = (path: string, w: number, h: number, name: string, caption: string, description: string) => ({
  "@type": "ImageObject",
  "contentUrl": "https://congoafricangreys.com" + path,
  "url": "https://congoafricangreys.com" + path,
  name, caption, width: w, height: h, description,
});

const imageObjects = [
  img(hero, 1600, 900,
    "A trustworthy home aviary where a healthy hand-raised Congo African Grey is verified before purchase",
    "The safest place to buy an African Grey is a real, verifiable breeder.",
    "A warm, natural-light photograph of a healthy hand-raised Congo African Grey perched calmly on a natural manzanita perch in a clean home aviary, with a breeder's hands loosely offering a foraging toy. The image illustrates this guide's central point: the safest place to buy an African Grey is from a reputable, USDA-licensed breeder you can verify by live video and full documentation, not from an anonymous marketplace listing."),
  img(igRank.src, 1200, 700,
    "The five safest places to buy an African Grey ranked from lowest to highest risk",
    "The 5 places to buy an African Grey, ranked by risk.",
    "A flat-design vertical ranking infographic titled 'The 5 Safest Places to Buy an African Grey — Ranked by Risk', listing licensed breeder and rescue as lowest risk in green, bird expo and pet store as medium risk in amber, and online marketplace as highest risk in clay red with a warning icon. It visualises the guide's core ranking so buyers can see at a glance which sources protect them and which expose them to scams."),
  img(igSource.src, 1200, 700,
    "Breeder versus marketplace versus rescue versus pet store compared on price, risk, health and trust",
    "Where to buy compared: price, scam risk, health record and trust.",
    "A flat-design four-column comparison graphic titled 'Where to Buy an African Grey — Source Comparison', comparing a licensed breeder, an online marketplace, a rescue and a pet store across price, scam risk, health record and overall trust, using green, amber and clay markers. The graphic gives buyers a scannable, snippet-ready summary of how the buying sources stack up."),
  img(igVerify.src, 1200, 700,
    "A checklist for spotting a reputable African Grey breeder",
    "How to spot a reputable breeder — the five-point checklist.",
    "A flat-design checklist infographic titled 'How to Spot a Reputable African Grey Breeder' with five checked items: does a live video call, provides CITES, DNA and avian-vet paperwork, shows a verifiable USDA licence, quotes one fair fixed price, and takes a reversible deposit. It doubles as a printable buyer-safety checklist and link-magnet asset."),
  img(igFlags.src, 1200, 700,
    "The red flags that mean walk away from an African Grey seller",
    "Red flags that mean walk away — before you pay anyone.",
    "A flat-design warning infographic titled 'Red Flags: Walk Away' showing the danger signs of an African Grey scam — a price far below fifteen hundred dollars, no CITES, DNA or vet paperwork, a seller who won't video-call, demands for wire, gift-card or crypto payment, and high-pressure urgency — each with a clay warning accent. It helps buyers recognise a scam before sending money."),
  img(igTrust.src, 1200, 900,
    "Mark and Teri Benjamin with a hand-raised Congo African Grey at C.A.Gs in Midland, Texas",
    "Why buyers choose C.A.Gs — a verifiable, USDA-licensed breeder.",
    "An authentic photograph of a hand-raised Congo African Grey with its breeders at C.A.Gs in Midland, Texas, conveying original media and first-hand E-E-A-T. The image supports the section on why buyers choose a verifiable, USDA-licensed breeder who provides health testing, documentation and lifetime support."),
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Best Place to Buy an African Grey Parrot: 5 Sources Ranked by Risk",
  description,
  image: imageObjects,
  author: { "@type": "Person", name: "Mark & Teri Benjamin" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com", url: "https://congoafricangreys.com" },
  datePublished: "2026-07-02",
  dateModified: "2026-07-02",
  mainEntityOfPage: canonical,
  url: canonical,
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to verify a reputable African Grey breeder in five minutes",
  description: "A breeder's quick screen for confirming an African Grey seller is legitimate before you pay a deposit.",
  step: [
    { "@type": "HowToStep", name: "Ask for a live video call", text: "Ask the seller to video-call you with the actual bird in hand. A refusal is the clearest red flag." },
    { "@type": "HowToStep", name: "Demand the documents", text: "Insist on CITES Appendix I papers, a PCR DNA-sexing certificate and an avian-vet health certificate before paying." },
    { "@type": "HowToStep", name: "Verify the licence and address", text: "Confirm a real USDA licence and a physical location you can check." },
    { "@type": "HowToStep", name: "Check the price is honest", text: "Be wary of a price far below the $1,700 floor — a bargain listing is usually a scam or an undocumented bird." },
    { "@type": "HowToStep", name: "Use a reversible payment", text: "Take a reversible deposit and never wire money, buy gift cards or send crypto." },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

const h2 = "font-lora font-bold text-logo-dark leading-tight mb-4 mt-2 scroll-mt-24";
const h3 = "font-lora font-semibold text-xl text-logo-dark mb-3 mt-6";
const h4 = "font-lora font-semibold text-lg text-logo-dark mb-2 mt-5";
const h5 = "font-lora font-semibold text-base text-logo-dark mt-5 mb-1";
const h6 = "font-sora font-semibold text-xs uppercase tracking-wide mt-4 mb-1";
const p = "text-stone-700 leading-relaxed mb-4";
const lnk = "underline font-medium";
const figc = "block text-center text-sm text-stone-600 mt-2";
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta heroPreload={hero} heroPreloadSrcset={heroSrcset} heroPreloadSizes={heroSizes}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    .bp-d .cag-seam { display:flex; align-items:center; gap:26px; max-width:1100px; margin:2.25rem auto 1.5rem; padding:0 24px; }
    .bp-d .cag-seam__line { flex:1; height:1px; background:rgba(45,106,79,.16); }
    .bp-d .cag-seam img { height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
    @media (max-width:600px){ .bp-d .cag-seam { gap:16px; } .bp-d .cag-seam img { height:24px; } }
    .bp-d .bp-hero h1 { font-size:clamp(1.7rem, 1.1rem + 2.6vw, 2.4rem) !important; line-height:1.14 !important; }
    .bp-d figure img { box-shadow:0 10px 30px rgba(60,30,10,.08); }
    .bp-jump { max-width:900px; margin:1.25rem auto 0; }
    .bp-jump .jump-eyebrow { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.16em; color:#b04228; margin:0 0 6px 4px; }
    @media (max-width:767px){
      .bp-jump { position:sticky; top:94px; z-index:40; background:#faf7f4; padding-top:8px; padding-bottom:8px; margin-top:.5rem; box-shadow:0 8px 14px -10px rgba(60,30,10,.28); }
      .bp-jump .jump-eyebrow { display:none; }
    }
  </style>

  <div class="bp-d">
    <div style="max-width:1200px;margin:0 auto;">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 1. Hero -->
    <section class="bp-hero text-white px-4 pt-12 pb-10" style="background:#2D6A4F">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1">
            <p class="font-sora text-xs font-medium tracking-wide mb-3" style="color:#ffd6c9">Buyer's Guide · Ranked by Risk · Midland, TX</p>
            <h1 class="font-lora font-bold mb-4" style="color:#faf7f4">Best Place to Buy an African Grey Parrot: 5 Sources Ranked by Risk</h1>
            <p class="text-lg mb-6" style="color:rgba(250,247,244,0.85)">Where should you actually spend $1,700–$3,500 — and who's most likely to take it and run? A working breeder ranks every source by risk, and shows you how to verify any seller in five minutes.</p>
            <a href="#places" class="inline-block bg-clay text-white font-sora font-semibold px-7 py-3" style="border-radius:50px">See the 5 places ranked</a>
            <p class="font-sora text-xs mt-4 mb-0" style="color:rgba(250,247,244,0.85)">Written by <strong style="color:#faf7f4">Mark &amp; Teri Benjamin</strong> · C.A.Gs African Grey breeders, Midland TX · USDA-licensed since 2014</p>
          </div>
          <figure class="m-0 order-1 md:order-2">
            <img src={hero} srcset={heroSrcset} sizes={heroSizes} width="1408" height="768" alt="A healthy hand-raised Congo African Grey being verified by its breeder in a clean home aviary — the safest place to buy an African Grey" title="The safest place to buy an African Grey | C.A.Gs" class="w-full rounded-2xl" fetchpriority="high" decoding="async" />
            <span class="block text-center text-sm mt-2" style="color:rgba(250,247,244,0.85)">The safest place to buy — a real breeder you can verify.</span>
          </figure>
        </div>
      </div>
    </section>

    <!-- 2. Counter snippet -->
    <CounterSnippet stats={counterStats} />

    <!-- 3. Top lead-capture strip -->
    <div style="max-width:1100px;margin:0 auto;" class="px-4 mt-6 relative z-10">
      <InquiryCompact heading="Want to buy from a breeder you can actually verify?" subtext="Tell us what you're looking for and we'll send live video, full paperwork and the birds available now — no pressure, no games." subject="African Grey buying enquiry" page="blog/best-place" idPrefix="top" />
    </div>

    <!-- 4. Jump nav -->
    <div class="bp-jump px-4">
      <p class="jump-eyebrow font-sora">On This Page</p>
      <JumpNav links={jumpLinks} sticky={false} />
    </div>

    <section class="px-4 pt-8 pb-4" style="background:#faf7f4">
      <div style="max-width:760px;margin:0 auto;">

        <!-- 5. Quick-Answer box -->
        <div id="quick" class="scroll-mt-24 mb-6">
          <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">
            <div class="px-6 py-5 sm:px-8" style="background:#2D6A4F">
              <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.18em] mb-1.5" style="color:#ffd6c9">The short answer</p>
              <h2 class="font-lora font-bold text-xl sm:text-2xl leading-snug" style="color:#faf7f4">Where Is the Best Place to Buy an African Grey?</h2>
            </div>
            <div class="p-6 sm:p-8">
              <p class="font-sora text-stone-700 leading-relaxed mb-6">The safest place to buy an African Grey is from a <strong>reputable, USDA-licensed breeder</strong> who will do a <strong>live video call</strong> with the bird, provide <strong>CITES, PCR DNA and avian-vet paperwork</strong>, and take a <strong>reversible deposit</strong>. Online marketplaces and anonymous social sellers carry the highest scam risk. If a seller refuses the video call or the papers, that's your answer — walk away.</p>
              <div class="grid grid-cols-2 gap-3">
                {quickFacts.map((r) => (
                  <div class="rounded-xl border border-stone-200 bg-cream/60 px-4 py-3">
                    <span class="block font-sora text-[11px] uppercase tracking-wide text-stone-600">{r.label}</span>
                    <span class="block font-sora text-sm font-semibold text-logo-dark mt-1 leading-snug">{r.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- 6. H2-1 Where to buy -->
        <h2 id="where" class={h2}>Where Is the Best Place to Buy an African Grey in 2026?</h2>
        <p class={p}>Type "best place to buy an African Grey" into Google and the top result isn't a shop — it's people in a forum asking each other for a seller they can trust, because the scams are that bad. That tells you everything about this purchase: you're not really shopping for a bird, you're shopping for someone to trust with $1,700–$3,500 and a 40–60 year commitment. The best place to buy, in one line, is wherever you can <strong>verify</strong> the seller — and the honest ranking below is really a ranking of how easy each source makes that verification.</p>

        <figure class="m-0 my-6">
          <img src="/male-and-female-congo-african-grey-parrots.webp" srcset="/male-and-female-congo-african-grey-parrots-500.webp 500w, /male-and-female-congo-african-grey-parrots-680.webp 680w, /male-and-female-congo-african-grey-parrots.webp 735w" sizes="(min-width: 768px) 712px, 92vw" width="735" height="529" loading="lazy" decoding="async" class="w-full rounded-2xl border border-stone-200" alt="A male and female Congo African Grey — hand-raised, DNA-sexed and documented — the kind of verifiable bird a reputable breeder can show you on a live call" title="Male and female Congo African Grey parrots | C.A.Gs" />
          <figcaption class={figc}>Real, documented Congo African Greys — the bird a trustworthy source can prove is theirs.</figcaption>
        </figure>

        <h3 class={h3}>Why Does It Matter So Much Where You Buy?</h3>
        <p class={p}>Because the African Grey is one of the most trafficked and most faked birds in the pet trade, and the damage from buying badly isn't only financial. A bird from the wrong source can arrive sick, undocumented, unweaned — or not arrive at all. As <a href="https://www.worldwildlife.org/species/african-grey-parrot" class={lnk} style="color:#b04228" target="_blank" rel="noopener noreferrer">the World Wildlife Fund notes about heavy trapping of the species ↗</a>, captive-bred documentation is exactly what separates a legal, ethical bird from a laundered one. Where you buy decides whether you get papers, a health guarantee and a breeder who still answers the phone in year three — or a dead end.</p>
        <h4 class={h4}>The real cost of choosing the wrong source</h4>
        <p class={p}>A saved few hundred dollars up front routinely turns into thousands at the avian vet, or the total loss of a deposit to a seller who vanishes. The buyers who reach us most upset aren't the ones who paid a fair price — they're the ones who chased a cheap one and are now trying to rescue the situation. Where you buy is the decision every other outcome hangs on.</p>

        <figure class="m-0 my-6 mx-auto max-w-sm">
          <img src="/african-grey-parrot-buyers-shield.webp" srcset="/african-grey-parrot-buyers-shield-560w.webp 560w, /african-grey-parrot-buyers-shield.webp 900w" sizes="(min-width: 768px) 384px, 92vw" width="900" height="1612" loading="lazy" decoding="async" class="w-full rounded-2xl border border-stone-200" alt="African Grey Parrot Buyer's Shield — the documents and checks that protect you from scams when buying an African Grey: live video call, CITES and DNA paperwork, USDA licence, fair price and a reversible deposit" title="African Grey buyer's shield | C.A.Gs" />
          <figcaption class={figc}>The buyer's shield — the checks and papers that keep your money, and your bird, safe.</figcaption>
        </figure>

        <h3 class={h3}>What's the One Question That Filters 90% of Sellers?</h3>
        <p class={p}>Ask any seller a single question and most of the risk sorts itself out: <em>"Will you get on a live video call with the bird in your hands right now?"</em> A real breeder says yes without hesitation — we do it every week. A scammer suddenly has a reason they can't: the bird's asleep, the camera's broken, another buyer is deciding. The question costs nothing and it's the fastest trust test in birds.</p>
        <h4 class={h4}>"Will you do a live video call with the bird in hand?"</h4>
        <p class={p}>It works because it's almost impossible to fake in the moment. Photos can be stolen, paperwork can be promised, prices can be adjusted — but a live, unedited video of a specific bird, on demand, is exactly what a person who doesn't have the bird cannot produce. Lead with this question, and the sources at the bottom of our ranking eliminate themselves before you've risked a cent.</p>

        <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-seam-logo.webp" alt="" width="160" height="53" loading="lazy" /><span class="cag-seam__line"></span></div>

        <!-- 7. H2-2 Five places ranked -->
        <h2 id="places" class={h2}>The 5 Places You Can Buy an African Grey, Ranked by Risk</h2>
        <p class={p}>Here's the honest ranking, from safest to most dangerous. We put ourselves at the top, but with the receipts to back it up — the point isn't "buy from us," it's "buy from whoever passes the same checks we happily pass." Every source below can, in theory, sell you a wonderful bird; what changes from top to bottom is how likely you are to end up documented and protected instead of scammed.</p>

        <figure class="m-0 my-6">
          <img src={igRank.src} srcset={igRank.srcset} sizes={igRank.sizes} width="1200" height="655" loading="lazy" decoding="async" class="w-full rounded-2xl border border-stone-200" alt="The five safest places to buy an African Grey ranked from lowest to highest risk: licensed breeder and rescue lowest, bird expo and pet store medium, online marketplace highest" title="5 places to buy an African Grey, ranked by risk | C.A.Gs" />
