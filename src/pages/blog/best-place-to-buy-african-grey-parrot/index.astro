const title = "Best Place to Buy an African Grey Parrot | 5 Safest Sources Ranked by Risk | Where Can I Buy a Healthy African Grey Without Getting Scammed? | C.A.Gs – Midland, TX";
const description = "Wondering where the best place to buy an African Grey parrot is? A breeder ranks the 5 safest sources by risk and shows how to buy a healthy African Grey without getting scammed.";
const canonical = "https://congoafricangreys.com/blog/best-place-to-buy-african-grey-parrot/";

// Hero + in-content visuals are PLACEHOLDERS — drop generated WebP files at these paths.
const hero = "/best-place-buy-african-grey-hero.webp";
const heroSrcset = "/best-place-buy-african-grey-hero-480w.webp 480w, /best-place-buy-african-grey-hero-800w.webp 800w, /best-place-buy-african-grey-hero.webp 1408w";
const heroSizes = "(min-width: 768px) 480px, 92vw";

const ig = (base: string) => ({
  src: `/${base}.webp`,
  srcset: `/${base}-760w.webp 760w, /${base}.webp 1200w`,
  sizes: "(min-width: 768px) 712px, 92vw",
});
const igRank   = ig("african-grey-5-safest-places-to-buy-ranked-by-risk-infographic");
const igSource = ig("where-to-buy-african-grey-breeder-vs-marketplace-vs-rescue-comparison");
const igVerify = ig("how-to-spot-a-reputable-african-grey-breeder-checklist");
const igFlags  = ig("african-grey-buyer-red-flags-walk-away-infographic");
const igTrust  = ig("why-buyers-choose-cags-trusted-african-grey-breeder");

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: "Best Place to Buy", url: "/blog/best-place-to-buy-african-grey-parrot/" },
];

const jumpLinks = [
  { label: "Short Answer", href: "#quick" },
  { label: "Where to Buy", href: "#where" },
  { label: "5 Places Ranked", href: "#places" },
  { label: "Compare Sources", href: "#compare" },
  { label: "Spot a Breeder", href: "#reputable" },
  { label: "Red Flags", href: "#redflags" },
  { label: "Why C.A.Gs", href: "#why" },
  { label: "Available", href: "#available" },
  { label: "FAQ", href: "#faq" },
];

const counterStats = [
  { num: "USDA",   label: "Licensed since 2014" },
  { num: "CITES",  label: "Appendix I docs" },
  { num: "PCR",    label: "DNA-sexed birds" },
  { num: "$185",   label: "Ships nationwide" },
];

const quickFacts = [
  { label: "Safest source", value: "Licensed breeder" },
  { label: "Highest risk", value: "Online marketplace" },
  { label: "Honest price", value: "$1,700–$3,500" },
  { label: "Never pay by", value: "Wire · gift card · crypto" },
];

const sourceCols = ["Where you buy", "Typical price", "Scam risk", "Health record", "Overall trust"];
const sourceRows = [
  { item: "Licensed breeder", values: ["$1,700–$3,500", "Low", "Full & verifiable", "Highest"] },
  { item: "Rescue / adoption", values: ["$200–$800 fee", "Low", "Usually documented", "High"] },
  { item: "Bird expo", values: ["Varies", "Medium", "Ask on the day", "Mixed"] },
  { item: "Pet store", values: ["$3,000–$5,000+", "Medium", "Often thin", "Medium"] },
  { item: "Online marketplace", values: ["Suspiciously low", "Very high", "Rarely any", "Lowest"] },
];

const reputableCols = ["A reputable breeder will…", "A risky seller will…"];
const reputableRows = [
  { item: "Do a live video call with the bird in hand", values: ["Refuse, stall, or send old photos"] },
  { item: "Provide CITES, PCR DNA & an avian-vet certificate", values: ["Have 'papers coming later'"] },
  { item: "Show a verifiable USDA licence & address", values: ["Give no licence or a fake one"] },
  { item: "Quote one fair, fixed price", values: ["Dangle a low price, then add 'fees'"] },
  { item: "Take a reversible deposit", values: ["Demand wire, gift cards or crypto"] },
];

const flagRows = [
  { item: "Price far below $1,500", values: ["No papers, unweaned, or a pure scam"] },
  { item: "No CITES / DNA / vet certificate", values: ["Untested, undocumented or wild-caught risk"] },
  { item: "Won't do a live video call", values: ["The bird may not exist at all"] },
  { item: "Wants wire, gift card or crypto", values: ["Irreversible — classic advance-fee scam"] },
  { item: "Pressure and urgency", values: ["'Another buyer is waiting' is a sales trap"] },
  { item: "No verifiable licence or address", values: ["Nobody to hold accountable"] },
];

const sellerBranches = [
  { answer: "They'll video-call you live with the bird, and show CITES, DNA and vet papers", result: "Green light on the two checks that matter most. Confirm the USDA licence and a verifiable address, use a reversible deposit, and you're buying from a real breeder — proceed." },
  { answer: "They have the bird on video but the paperwork is 'coming later'", result: "Pause. Real documentation exists before a sale, not after payment. Ask to see the CITES, PCR DNA and avian-vet certificate now — if they can't produce them, treat it as a red flag." },
  { answer: "They refuse a live video call or only send photos", result: "Walk away. A refusal to show the actual bird, live, is the single most reliable sign the bird doesn't exist. No paperwork or price makes that safe." },
  { answer: "The price is well under $1,500 and they want wire, gift cards or crypto", result: "Stop and keep your money. That combination — bargain price plus irreversible payment — is an advance-fee scam in progress. Run the seller check on our scam guide before you send a cent." },
];

const birds = [
  { id: 'amie', name: 'Amie', sex: 'Female', age: '3 mo', price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Hand-raised, fully documented, ready to reserve.',
    notes: 'Premium hand-raised female, 3 months old. PCR DNA-sexed, vet-checked, CITES-documented — captive-bred in the USA with the full paper trail.' },
  { id: 'roys', name: 'Roys', sex: 'Male', age: '4 mo', price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
