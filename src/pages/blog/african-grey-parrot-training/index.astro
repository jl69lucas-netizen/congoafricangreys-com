const title = "African Grey Parrot Training: A Breeder's Step-by-Step Guide | Step-Up, Recall, Talking & Fixing Biting/Screaming the Right Way | C.A.Gs – Midland, TX";
const description = "How to train an African Grey the breeder's way — train the mind before the behaviour. Trust first, then step-up, recall and target training, talking, and how to fix biting, screaming and fear with positive reinforcement. Short sessions, real body-language reading, no punishment.";
const canonical = "https://congoafricangreys.com/blog/african-grey-parrot-training/";

const hero = "/african-grey-step-up-target-training.webp";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: "African Grey Training", url: "/blog/african-grey-parrot-training/" },
];

const jumpLinks = [
  { label: "Quick Answer", href: "#quick" },
  { label: "Principles", href: "#principles" },
  { label: "Trust First", href: "#trust" },
  { label: "Commands", href: "#commands" },
  { label: "Talking", href: "#talking" },
  { label: "Behaviour", href: "#behaviour" },
  { label: "Mistakes", href: "#mistakes" },
  { label: "FAQ", href: "#faq" },
];

const counterStats = [
  { num: "5–15 min", label: "Ideal Session" },
  { num: "Trust",    label: "Comes First" },
  { num: "Reward",   label: "Never Punish" },
  { num: "Any age",  label: "Still Trainable" },
];

const quickFacts = [
  { label: "Method", value: "Positive reinforcement" },
  { label: "Session length", value: "5–15 minutes, daily" },
  { label: "First skill", value: "Step-up" },
  { label: "Golden rule", value: "Trust before tricks" },
];

const goalCols = ["Training goal", "Difficulty", "Typical time"];
const goalRows = [
  { item: "Step-up", values: ["Easy", "1–7 days"] },
  { item: "Step-down", values: ["Easy", "1–5 days"] },
  { item: "Recall (come when called)", values: ["Medium", "2–4 weeks"] },
  { item: "Target training", values: ["Medium", "1–3 weeks"] },
  { item: "Talking on cue", values: ["Medium–Hard", "Weeks–months"] },
];

const signalCols = ["Body-language signal", "What it usually means", "What to do"];
const signalRows = [
  { item: "Pinned / flashing eyes", values: ["Excited or over-aroused", "Pause — don't reach in yet"] },
  { item: "Fanned tail, raised wings", values: ["Agitated or territorial", "Lower the energy, give space"] },
  { item: "Sleeked feathers, leaning away", values: ["Fear — 'back off'", "Slow down, rebuild trust"] },
  { item: "Relaxed fluff + beak grinding", values: ["Content, winding down", "Bond — don't drill"] },
  { item: "Open beak, lunging", values: ["A bite warning", "Respect it — never punish"] },
];

const planBranches = [
  { answer: "Your Grey just arrived / is brand new", result: "Don't train yet. Spend one to two weeks simply being present — sit nearby, talk softly, drop treats through the bars. Trust is the prerequisite, not the reward." },
  { answer: "Your Grey steps up but bites sometimes", result: "Go back to body language. Almost every 'sudden' bite is a missed warning, not aggression — read the eyes and posture and you'll see it coming." },
  { answer: "Your Grey is confident and bonded", result: "Build the ladder: step-up → step-down → recall → target, 5–15 minutes a day, and always end on a win while the bird still wants more." },
  { answer: "Your Grey screams when you leave the room", result: "That's contact-calling, not misbehaviour. Answer once, reward the quiet that follows, and never come running for the scream — that only trains it louder." },
];

// Available birds — hand-raised and socialised for trainability (mirrors clutch-inventory + homepage grid).
const birds = [
  { id: 'amie', name: 'Amie', sex: 'Female', age: '3 mo', price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Already steps up and responds to her name.',
    notes: 'Premium hand-raised female, 3 months old. Full social training from weaning — calm with hands, easy to start training.' },
  { id: 'roys', name: 'Roys', sex: 'Male', age: '4 mo', price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Curious, food-motivated — a trainer’s dream.',
    notes: "Hand-raised male, 4 months old. Bold and treat-driven, which makes positive-reinforcement training quick to take." },
  { id: 'bery', name: 'Bery', sex: 'Female', age: '1 yr', price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp', objectPos: 'object-center',
    hook: 'Gentle and trusting — ideal for first-time trainers.',
    notes: 'Soft temperament, easy to handle. 1-year-old female already comfortable with step-up and gentle handling.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Bonded Duo', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair-talking-birds.webp', objectPos: 'object-center',
    hook: 'Two birds, trained together since weaning.',
    notes: 'Unrelated pair, adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised with daily handling and social training.' },
];

const faqs = [
  { q: "Are African Greys easy to train?",
    a: "African Greys are among the most trainable parrots because they're so intelligent — but that intelligence cuts both ways. They learn good habits fast and bad ones just as fast, and they bore quickly. The bird isn't hard to train; it's easy to train wrongly. Keep sessions short, reward generously, never punish, and an African Grey will out-learn almost any other companion bird." },
  { q: "How do I stop my African Grey from biting?",
    a: "Stop reading the bite as the start of the problem — it's the end of one. A Grey almost always warns first with pinned eyes, a fanned tail or a leaning-away posture, and the bite only comes when those signals were missed or pushed past. Learn the body language, back off when you see a warning, and never grab, flick or shout — punishment makes a bird bite harder and trust you less." },
  { q: "How long does it take to train an African Grey?",
    a: "Simple skills come fast: most Greys learn a reliable step-up in a few days to a week. Recall and target training take a few weeks, and talking on cue can take weeks to months. But the real timeline is the trust that comes first — rush that and everything after it stalls, so we tell owners to think in terms of months of relationship, not days of drilling." },
  { q: "Can you train an older or rehomed African Grey?",
    a: "Yes. The 'you can't teach an old Grey new tricks' idea is a myth — these birds learn for life. A rehomed or older African Grey may carry baggage (fear, distrust, learned screaming) so progress is slower at first, but with patience, routine and positive reinforcement they absolutely retrain. Many of the most bonded Greys we hear about were second-chance birds." },
  { q: "Can African Greys learn commands like a dog?",
    a: "They can learn cued behaviours — step-up, step-down, recall, turn around, target — using the same positive-reinforcement science (operant conditioning) used for dogs. The difference is motivation: a Grey works for trust and reward on its own terms, not to please you. Frame it as cooperation, not obedience, and you'll get far more out of the bird." },
  { q: "Why is my African Grey suddenly aggressive?",
    a: "'Sudden' aggression almost always has a cause: hormones, fear, a change in the home, a cage it's guarding, or — most often — a string of ignored body-language warnings that finally escalated. Greys are sensitive and territorial, so look for the trigger rather than labelling the bird 'mean'. Fix the cause and lower the pressure, and the aggression usually fades." },
  { q: "How long should an African Grey training session be?",
    a: "Short. Five to fifteen minutes is the sweet spot, once or twice a day. African Greys fatigue mentally, and a tired, over-faced bird stops learning and starts resenting the sessions. Always finish while the bird is still keen and on a success — leaving it wanting more is what keeps it coming back tomorrow." },
  { q: "What's the best reward for training an African Grey?",
    a: "Whatever your individual bird will work hardest for — usually a small, special food treat it doesn't get any other time (a sliver of nut, a single seed, a piece of fruit), paired with warm praise. Keep treats tiny so the bird doesn't fill up, and reserve the 'jackpot' favourite strictly for training so it stays valuable." },
];

const imageObjects = [
  {
    "@type": "ImageObject",
    "contentUrl": "https://congoafricangreys.com" + hero,
    "url": "https://congoafricangreys.com" + hero,
    "name": "A hand-raised African Grey learning the step-up command from a C.A.Gs breeder",
    "caption": "Step-up training with a hand-raised Congo African Grey — trust first, reward always.",
    "width": 1000,
    "height": 560,
    "description": "A hand-raised Congo African Grey practising the step-up command onto a human hand in a calm home setting, used to illustrate the core method of this guide: African Grey training is built on trust and positive reinforcement, taught in short daily sessions, never forced. Every chick we raise at C.A.Gs in Midland, Texas is handled and gentled from weaning so it arrives already comfortable with hands and ready to learn."
  }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Training: A Breeder's Step-by-Step Guide",
  description,
  image: imageObjects,
  author: { "@type": "Person", name: "Mark & Teri Benjamin" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com", url: "https://congoafricangreys.com" },
  datePublished: "2026-05-22",
  dateModified: "2026-06-28",
  mainEntityOfPage: canonical,
  url: canonical,
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to train an African Grey parrot",
  description: "A breeder's step-by-step method for training an African Grey using trust and positive reinforcement.",
  step: [
    { "@type": "HowToStep", name: "Build trust first", text: "Before any training, spend one to two weeks earning trust — be present, talk softly, and offer treats through the cage bars with no pressure." },
    { "@type": "HowToStep", name: "Teach the step-up", text: "Present a steady hand or perch just above the feet, cue 'step up', and reward the instant the bird steps on. Keep sessions to 5–15 minutes." },
    { "@type": "HowToStep", name: "Reinforce and add skills", text: "Once step-up is reliable, build step-down, recall and target training, rewarding every success and always ending on a win." },
    { "@type": "HowToStep", name: "Expand vocabulary", text: "Pair short words with the moment they belong to, repeat them in context daily, and reward every attempt rather than drilling." },
