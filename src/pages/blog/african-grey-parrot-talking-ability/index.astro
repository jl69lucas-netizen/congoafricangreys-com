// for the Average-Parrot column (never the banned generic-parrot 🦜).
const featherIcon = '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#ffffff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>';
const greyVsParrotRows: [string, string, string][] = [
  ['Vocabulary', '100–1,000+ words', '20–100 words'],
  ['Mimicry clarity', 'Exceptional — near-human', 'Good'],
  ['Contextual use', 'Very high — words tied to meaning', 'Low–medium'],
  ['Trainability', 'Very high', 'Medium'],
  ['Cognition', '~4–6-year-old child (Alex studies)', 'Basic mimicry'],
];

const title = "African Grey Parrot Talking Ability: How Well Do They Really Talk? | Word Counts, Timeline, Congo vs Timneh & the Truth About Mimicry vs Understanding | C.A.Gs – Midland, TX";
