  { label: "Vocabulary", value: "200–1,000+ words possible" },
  { label: "First words", value: "usually 12–18 months" },
  { label: "Understanding", value: "contextual, not just mimicry" },
];

const timeline = [
  { age: "0–6 months", head: "Experimental sounds", text: "Clicks, whistles, beeps and soft babble — the bird is tuning its syrinx. No real words yet, and none expected. A quiet chick now is not a quiet adult later." },
  { age: "6–12 months", head: "First word attempts", text: "The first recognisable word usually appears here — almost always a phrase tied to a moment ('hello' at the door, its own name, a morning greeting). Timnehs often beat Congos to this milestone." },
  { age: "1–2 years", head: "10–50 words", text: "In a well-socialised bird the vocabulary builds quickly and pronunciation sharpens. Phrases start linking to context — 'want up?', 'night night', the microwave beep it stole from your kitchen." },
  { age: "2–5 years", head: "Phrases & sentences", text: "The big expansion. Words become phrases, phrases become little sentences, and genuine contextual use settles in. This is when owners stop saying 'it mimics' and start saying 'it talks'." },
  { age: "5+ years", head: "200–1,000+ words", text: "Full range. Some birds plateau at a few dozen favourites; the keenest reach several hundred and a documented few pass a thousand. Development never fully stops — Greys add words for life." },
];

const talkerCols = ["Trait", "Congo African Grey", "Timneh African Grey"];
const talkerRows = [
  { item: "Starts talking", values: ["12–18 months", "9–14 months (earlier)"] },
  { item: "Voice quality", values: ["Clearer, more human", "Slightly raspier / softer"] },
  { item: "Ultimate vocabulary", values: ["Often larger", "Strong, modestly smaller"] },
