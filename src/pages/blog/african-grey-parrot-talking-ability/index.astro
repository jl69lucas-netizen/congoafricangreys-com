const poster = "/african-grey-breeder-with-bird-midland-tx.webp";
const videoUrl = "/talking-african-grey-parrot-video.mp4";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: "African Grey Talking Ability", url: "/blog/african-grey-parrot-talking-ability/" },
];

const jumpLinks = [
  { label: "Quick Answer", href: "#quick" },
  { label: "How They Talk", href: "#how" },
