---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';
import JumpNav from '../../components/cag-jump-nav.astro';

const title = "African Grey Parrot Blog | Care, Training & Buyer Guides";
const description = "African Grey parrot articles from USDA-licensed breeders. Diet, training, lifespan, health, CITES documentation, and species guides written from 10+ years of hands-on experience.";
const canonical = "https://congoafricangreys.com/blog/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
];

const posts = [
  {
    title: "African Grey for Sale: What $1,700–$3,500 Gets You",
    slug: "/blog/african-grey-parrot-price-what-you-get/",
    excerpt: "A price tag tells you nothing on its own. Exactly what every documented C.A.Gs Grey includes — PCR DNA sexing, avian-vet certificate, CITES papers, and lifetime support.",
    category: "Buying",
  },
  {
    title: "Best Place to Buy an African Grey in 2026",
    slug: "/blog/best-place-to-buy-african-grey-parrot/",
    excerpt: "Breeder, online marketplace, or rescue? An honest three-way comparison on price, CITES documentation, health risk, and scam exposure — plus a 5-minute seller check.",
    category: "Buyer's Guide",
  },
  {
    title: "African Grey vs Eclectus",
    slug: "/blog/african-grey-vs-eclectus/",
    excerpt: "Two smart, manageable companions compared: talking ability, temperament, the Eclectus' specialised diet, sexing, and which one actually fits your home.",
    category: "Comparisons",
  },
  {
    title: "African Grey Parrot Facts",
    slug: "/blog/african-grey-parrot-facts/",
    excerpt: "20 verified facts: lifespan 40–60 years, CITES Appendix I status, 200–1,000 word vocabulary, and the Congo vs Timneh distinction every buyer needs to know.",
    category: "Facts",
  },
  {
    title: "African Grey Parrot Cage Setup",
    slug: "/blog/african-grey-parrot-cage-setup/",
    excerpt: "Minimum 36\"×24\"×48\" cage, stainless steel bars at 3/4\"–1\" spacing, 3-perch variety setup, and the enrichment rotation system we use in our breeding facility.",
    category: "Care",
  },
  {
    title: "African Grey Health Problems",
    slug: "/blog/african-grey-health-problems/",
    excerpt: "Feather plucking, calcium deficiency seizures, psittacosis, aspergillosis — the 7 most common African Grey health problems and how to prevent every one.",
    category: "Health",
  },
  {
    title: "African Grey Parrot Training",
    slug: "/blog/african-grey-parrot-training/",
    excerpt: "Target training, step-up, recall, and talking development — the step-by-step methods we use with every bird before it leaves our facility.",
    category: "Training",
  },
  {
    title: "African Grey Parrot Talking Ability",
    slug: "/blog/african-grey-parrot-talking-ability/",
    excerpt: "African Greys can learn 200–1,000+ words — but not all of them will, and the timeline is slower than most buyers expect. Here's what the research and 10 years of experience says.",
    category: "Intelligence",
  },
  {
    title: "Is an African Grey Good for Beginners?",
    slug: "/blog/is-african-grey-good-for-beginners/",
    excerpt: "The honest answer from breeders: African Greys are rarely beginner-friendly — but some first-time owners succeed. Here's the distinction.",
    category: "Buyer's Guide",
  },
  {
    title: "African Grey vs Amazon Parrot",
    slug: "/african-grey-vs-amazon-parrot/",
    excerpt: "Two elite talkers compared: African Grey precision vs. Amazon charisma, plus hormonal aggression differences most buyers don't expect.",
    category: "Comparisons",
  },
  {
    title: "African Grey Parrot Care Guide",
    slug: "/african-grey-parrot-care-guide/",
    excerpt: "Complete care guide covering diet, housing, enrichment, health, and CITES documentation requirements.",
    category: "Care",
  },
  {
    title: "African Grey Parrot Diet",
    slug: "/african-grey-parrot-diet/",
    excerpt: "What to feed, what to avoid, and how to build a diet that keeps an African Grey healthy for 40–60 years.",
    category: "Nutrition",
  },
  {
    title: "African Grey Parrot Lifespan",
    slug: "/african-grey-parrot-lifespan/",
    excerpt: "African Greys live 40–60 years. What affects lifespan, life stages, and how to plan for a lifelong companion.",
    category: "Health",
  },
  {
    title: "African Grey Pros and Cons",
    slug: "/african-grey-pros-and-cons/",
    excerpt: "An honest look at what makes African Greys exceptional — and what makes them the wrong bird for many households.",
    category: "Buyer's Guide",
  },
  {
    title: "Baby African Grey for Sale",
    slug: "/baby-african-grey-parrot-for-sale/",
    excerpt: "Hand-raised, fully weaned baby African Greys with CITES documentation. What to expect and what questions to ask.",
    category: "Buying",
  },
  {
    title: "Congo vs Timneh African Grey",
    slug: "/congo-vs-timneh-african-grey/",
    excerpt: "Size, color, price, temperament and talking ability compared side by side.",
    category: "Comparisons",
  },
  {
    title: "African Grey vs Macaw",
    slug: "/african-grey-vs-macaw/",
    excerpt: "Which parrot fits your home, schedule, and budget? Full side-by-side comparison.",
    category: "Comparisons",
  },
  {
    title: "African Grey vs Cockatoo",
    slug: "/african-grey-vs-cockatoo/",
    excerpt: "Talking ability, affection level, noise, and care demands compared.",
    category: "Comparisons",
  },
  {
    title: "How to Avoid African Grey Parrot Scams",
    slug: "/how-to-avoid-african-grey-parrot-scams/",
    excerpt: "CITES documentation red flags, deposit scam patterns, and how to verify a legitimate breeder.",
    category: "Safety",
  },
  {
    title: "CITES African Grey Documentation",
    slug: "/cites-african-grey-documentation/",
    excerpt: "What documentation every captive-bred African Grey must ship with — and what to demand before any deposit.",
    category: "Legal",
  },
  {
    title: "African Grey Parrot Price Guide",
    slug: "/african-grey-parrot-price/",
    excerpt: "Congo and Timneh pricing, first-year setup costs, annual expenses, and 40–60 year lifetime estimates.",
    category: "Costs",
  },
  {
    title: "African Grey Parrot Species Guide",
    slug: "/african-grey-parrot-guide/",
    excerpt: "Complete species guide: subspecies, intelligence, talking ability, wild range, CITES status, and captive care.",
    category: "Species",
  },
];

// Category-to-section mapping
const buyingCategories   = new Set(["Buying", "Buyer's Guide", "Costs", "Safety", "Legal"]);
const careCategories     = new Set(["Care", "Nutrition", "Species"]);
const trainingCategories = new Set(["Training", "Intelligence"]);
const fitCategories      = new Set(["Facts", "Health", "Comparisons"]);

const buyingPosts   = posts.filter(p => buyingCategories.has(p.category));
const carePosts     = posts.filter(p => careCategories.has(p.category));
const trainingPosts = posts.filter(p => trainingCategories.has(p.category));
const fitPosts      = posts.filter(p => fitCategories.has(p.category));

// Only the first 9 /blog/ posts for schema hasPart
const blogPosts = posts.filter(p => p.slug.startsWith("/blog/"));

const jumpLinks = [
  { label: "Start Here",       href: "#start-here" },
  { label: "Buying & Costs",   href: "#buying-costs" },
  { label: "Daily Care",       href: "#daily-care" },
  { label: "Talking & Training", href: "#training" },
  { label: "Right Fit?",       href: "#right-fit" },
  { label: "About These Guides", href: "#about-guides" },
  { label: "FAQ",              href: "#faq" },
];

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": "https://congoafricangreys.com/blog/",
      "url": "https://congoafricangreys.com/blog/",
      "name": "African Grey Parrot Blog | Care, Training & Buyer Guides",
      "description": "African Grey parrot articles from USDA-licensed breeders in Midland, TX — diet, training, lifespan, health, CITES documentation, and species guides.",
      "publisher": {
        "@type": "Organization",
        "name": "C.A.Gs – Midland, TX",
        "url": "https://congoafricangreys.com/"
      },
      "hasPart": blogPosts.map(p => ({
        "@type": "BlogPosting",
        "name": p.title,
        "url": `https://congoafricangreys.com${p.slug}`
      }))
    },
    {
      "@type": "FAQPage",
      "@id": "https://congoafricangreys.com/blog/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How often do you publish new African Grey guides?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We add new guides whenever a real buyer question comes up in our aviary that we haven't answered in writing yet. Care, buying, and comparison topics come first because those are the questions we hear most. When a buyer's question leads us to realize a gap in our library, that question becomes our next post."
          }
        },
        {
          "@type": "Question",
          "name": "Can I talk to a breeder before I buy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes — we encourage it. Reach us through the contact form on our site or call us directly. When it's time to ship, airport pickup costs $185 and home delivery costs $350. We use IATA-compliant carriers (Delta, United, and American) for all domestic shipments."
          }
        },
        {
          "@type": "Question",
          "name": "Do these guides cover both Congo and Timneh Greys?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We raise both subspecies here at C.A.Gs and flag Congo vs Timneh differences wherever they matter — price, temperament, and talking timeline all vary between the two. The subspecies difference affects both what you pay and what daily life with the bird looks like."
          }
        }
      ]
    }
  ]
});
---

<BaseLayout {title} {description} {canonical} hideGlobalCta schemaJson={schemaJson}>

  <!-- Breadcrumb -->
  <div style="max-width:1200px;margin:0 auto;padding:0 1rem;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section style="background:#2D6A4F;" class="text-white py-16 px-4">
    <div style="max-width:760px;margin:0 auto;text-align:center;">
      <p class="font-sora" style="color:#f0c674;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:1rem;">
        Written by USDA-Licensed Breeders · Midland, TX
      </p>
      <h1 class="font-lora" style="color:#faf7f4;font-weight:700;margin-bottom:1rem;">
        African Grey Parrot Blog: Real Breeder Guides to Care, Talking &amp; Buying
      </h1>
      <p class="font-sora" style="color:rgba(250,247,244,0.85);font-size:1.0625rem;line-height:1.65;max-width:60ch;margin:0 auto;">
        Here at C.A.Gs, Mark &amp; Teri Benjamin have raised captive-bred Congo and Timneh African Greys for over a decade — and every guide in this library comes straight from our aviary in Midland, Texas, not a content farm.
      </p>
    </div>
  </section>

  <!-- Jump Nav -->
  <div style="max-width:1200px;margin:0 auto;padding:1.5rem 1rem 0;">
    <JumpNav links={jumpLinks} sticky={false} />
  </div>

  <!-- ══════════════════════════════════════════
       START HERE
  ══════════════════════════════════════════ -->
  <section id="start-here" style="background:#faf7f4;padding:3rem 1rem 2rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:1rem;">
        New to African Greys? Start With These Guides
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;">
        If you've never owned an African Grey before, the sections below are organised in the order that matters most — what you'll pay and where to buy, what daily care actually looks like, whether your home fits the bird, and whether you can really expect yours to talk. Work through them in order and you'll have a clearer picture than most buyers who've spent weeks Googling.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       BUYING & COSTS
  ══════════════════════════════════════════ -->
  <section id="buying-costs" style="background:#faf7f4;padding:2rem 1rem 3rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        How Much Is an African Grey — and Where Should You Buy One?
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:2rem;">
        Our buying and cost guides answer the two questions we get first from every new inquiry: what the price tag actually covers, and how to tell a legitimate captive-bred breeder from a scam. Each post below is grounded in the documentation every CITES Appendix I bird must ship with.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {buyingPosts.map(post => (
          <a href={post.slug}
             style="background:#fff;border-radius:1rem;border:1px solid #ede5dc;box-shadow:0 2px 12px rgba(60,30,10,0.06);padding:1.5rem;text-decoration:none;display:block;transition:border-color 0.15s;"
             class="blog-card">
            <span class="font-sora"
                  style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#b04228;">
              {post.category}
            </span>
            <h3 class="font-lora"
                style="color:#2D6A4F;font-size:1.0625rem;font-weight:600;margin:0.5rem 0 0.75rem;line-height:1.3;">
              {post.title}
            </h3>
            <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.6;margin:0 0 1rem;">
              {post.excerpt}
            </p>
            <span class="font-sora"
                  style="font-size:0.875rem;font-weight:600;color:#e8604c;">
              Read more
              <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true"
                   style="display:inline;vertical-align:middle;margin-left:0.2em;">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       DAILY CARE
  ══════════════════════════════════════════ -->
  <section id="daily-care" style="background:#fff;padding:3rem 1rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        What Does Daily African Grey Care Actually Involve?
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:2rem;">
        We write these care guides the way we'd explain things to a new owner picking up their bird from our aviary — not as a checklist, but as the real reasoning behind each practice. A 40–60 year commitment deserves that level of honesty about what the day-to-day looks like.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {carePosts.map(post => (
          <a href={post.slug}
             style="background:#fff;border-radius:1rem;border:1px solid #ede5dc;box-shadow:0 2px 12px rgba(60,30,10,0.06);padding:1.5rem;text-decoration:none;display:block;transition:border-color 0.15s;"
             class="blog-card">
            <span class="font-sora"
                  style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#b04228;">
              {post.category}
            </span>
            <h3 class="font-lora"
                style="color:#2D6A4F;font-size:1.0625rem;font-weight:600;margin:0.5rem 0 0.75rem;line-height:1.3;">
              {post.title}
            </h3>
            <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.6;margin:0 0 1rem;">
              {post.excerpt}
            </p>
            <span class="font-sora"
                  style="font-size:0.875rem;font-weight:600;color:#e8604c;">
              Read more
              <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true"
                   style="display:inline;vertical-align:middle;margin-left:0.2em;">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TALKING & TRAINING
  ══════════════════════════════════════════ -->
  <section id="training" style="background:#faf7f4;padding:3rem 1rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        Can You Really Teach an African Grey to Talk?
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:2rem;">
        The short answer is: most will — but not on the buyer's timeline. Our training and intelligence guides pull from the methods we use in our facility before every bird leaves, and from watching hundreds of birds develop over the years. We're honest about what takes months and what can't be rushed.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {trainingPosts.map(post => (
          <a href={post.slug}
             style="background:#fff;border-radius:1rem;border:1px solid #ede5dc;box-shadow:0 2px 12px rgba(60,30,10,0.06);padding:1.5rem;text-decoration:none;display:block;transition:border-color 0.15s;"
             class="blog-card">
            <span class="font-sora"
                  style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#b04228;">
              {post.category}
            </span>
            <h3 class="font-lora"
                style="color:#2D6A4F;font-size:1.0625rem;font-weight:600;margin:0.5rem 0 0.75rem;line-height:1.3;">
              {post.title}
            </h3>
            <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.6;margin:0 0 1rem;">
              {post.excerpt}
            </p>
            <span class="font-sora"
                  style="font-size:0.875rem;font-weight:600;color:#e8604c;">
              Read more
              <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true"
                   style="display:inline;vertical-align:middle;margin-left:0.2em;">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       RIGHT FIT
  ══════════════════════════════════════════ -->
  <section id="right-fit" style="background:#fff;padding:3rem 1rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        Is an African Grey the Right Parrot for Your Home?
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:2rem;">
        We'd rather talk someone out of the wrong bird than sell a bird into the wrong home — that's how we've operated since 2014. The guides here cover the honest facts about African Grey temperament, health, and how they compare to other parrots, so you can make the call with real information.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {fitPosts.map(post => (
          <a href={post.slug}
             style="background:#fff;border-radius:1rem;border:1px solid #ede5dc;box-shadow:0 2px 12px rgba(60,30,10,0.06);padding:1.5rem;text-decoration:none;display:block;transition:border-color 0.15s;"
             class="blog-card">
            <span class="font-sora"
                  style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#b04228;">
              {post.category}
            </span>
            <h3 class="font-lora"
                style="color:#2D6A4F;font-size:1.0625rem;font-weight:600;margin:0.5rem 0 0.75rem;line-height:1.3;">
              {post.title}
            </h3>
            <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.6;margin:0 0 1rem;">
              {post.excerpt}
            </p>
            <span class="font-sora"
                  style="font-size:0.875rem;font-weight:600;color:#e8604c;">
              Read more
              <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true"
                   style="display:inline;vertical-align:middle;margin-left:0.2em;">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       ABOUT THESE GUIDES (E-E-A-T)
  ══════════════════════════════════════════ -->
  <section id="about-guides" style="background:#eaf4ef;padding:3rem 1rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h2 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        Who Writes These Guides — and Why Trust Them?
      </h2>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:2rem;">
        Every article in this library is written or reviewed by Mark and Teri Benjamin — USDA-licensed breeders who have raised captive-bred African Greys since 2014, here in Midland, Texas. We don't outsource our content to writers who've never handled a Grey, and we don't publish facts we can't trace back to our own aviary or a cited source.
      </p>

      <h3 class="font-lora" style="color:#2D6A4F;margin-bottom:0.75rem;">
        Why Real Breeders, Not Content Mills, Write Every Word
      </h3>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:1.5rem;">
        The difference shows up in the details — the feeding rotation we actually use, the health warning signs we've personally observed over hundreds of clutches, the CITES paperwork questions that trip up first-time buyers. Those specifics can't come from a content brief; they come from doing this work every day.
      </p>

      <h4 class="font-lora" style="color:#2D6A4F;margin-bottom:0.5rem;">
        Where Do Our Facts Come From?
      </h4>
      <p class="font-sora" style="color:#5a5248;line-height:1.65;max-width:70ch;margin-bottom:1.25rem;">
        We cross-check every factual claim against our own aviary records or a cited external source before it goes on the page.
      </p>

      <h5 class="font-sora" style="color:#1c1a18;font-weight:700;margin-bottom:0.4rem;">
        Every claim ties back to our own aviary or a cited source
      </h5>
      <p class="font-sora" style="color:#5a5248;font-size:0.9375rem;line-height:1.65;max-width:70ch;margin-bottom:1.25rem;">
        If a claim about lifespan, diet, or health doesn't appear in our own records or in peer-reviewed avian literature, we don't publish it. That's the standard we hold ourselves to, and it's why our guides read differently from most of what you'll find on Google.
      </p>

      <h5 class="font-sora" style="color:#1c1a18;font-weight:700;margin-bottom:0.4rem;">
        We frame every bird as CITES Appendix I and captive-bred in the USA
      </h5>
      <p class="font-sora" style="color:#5a5248;font-size:0.9375rem;line-height:1.65;max-width:70ch;margin-bottom:0.75rem;">
        African Greys were uplisted to CITES Appendix I at CoP17, effective January 2017. Every bird we raise is captive-bred in our Texas aviary with full documentation — PCR DNA sexing certificate, avian-vet health certificate, and CITES papers included with each bird.
      </p>

      <h6 class="font-sora" style="color:#5a5248;font-weight:700;font-size:0.875rem;margin-bottom:0.4rem;">
        Why we never reference wild-caught trade
      </h6>
      <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.65;max-width:70ch;margin-bottom:1.25rem;">
        Wild-caught African Greys cannot be legally imported into or sold within the United States under current CITES Appendix I protections. Our guides reflect that reality — we don't treat it as a footnote.
      </p>

      <h5 class="font-sora" style="color:#1c1a18;font-weight:700;margin-bottom:0.4rem;">
        How we keep these guides current
      </h5>
      <p class="font-sora" style="color:#5a5248;font-size:0.9375rem;line-height:1.65;max-width:70ch;margin-bottom:0.75rem;">
        We review our articles whenever our own practices change or a buyer raises a question our existing guide doesn't answer well enough.
      </p>

      <h6 class="font-sora" style="color:#5a5248;font-weight:700;font-size:0.875rem;margin-bottom:0.4rem;">
        Our freshness signals live in schema, never as a visible date
      </h6>
      <p class="font-sora" style="color:#5a5248;font-size:0.875rem;line-height:1.65;max-width:70ch;margin-bottom:0;">
        Search engines see our <code>dateModified</code> metadata in structured data. We don't slap a visible "last updated" timestamp on articles because a date without context tells you nothing about whether the advice still holds — and our advice does.
      </p>
