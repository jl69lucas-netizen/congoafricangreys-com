---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrot Blog | Care, Training & Buyer Guides";
const description = "African Grey parrot articles from USDA-licensed breeders. Diet, training, lifespan, health, CITES documentation, and species guides written from 10+ years of hands-on experience.";
const canonical = "https://congoafricangreys.com/blog/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
];

const posts = [
  {
    title: "African Grey for Sale: What $1,700–$3,500 Gets You",
    slug: "/blog/african-grey-parrot-price-what-you-get/",
    excerpt: "A price tag tells you nothing on its own. Exactly what every documented C.A.Gs Grey includes — PCR DNA sexing, avian-vet certificate, CITES papers, and lifetime support.",
    category: "Buying",
  },
  {
    title: "Best Place to Buy an African Grey in 2026",
    slug: "/blog/best-place-to-buy-african-grey-parrot/",
    excerpt: "Breeder, online marketplace, or rescue? An honest three-way comparison on price, CITES documentation, health risk, and scam exposure — plus a 5-minute seller check.",
    category: "Buyer's Guide",
  },
  {
    title: "African Grey vs Eclectus",
    slug: "/blog/african-grey-vs-eclectus/",
    excerpt: "Two smart, manageable companions compared: talking ability, temperament, the Eclectus' specialised diet, sexing, and which one actually fits your home.",
    category: "Comparisons",
  },
  {
    title: "African Grey Parrot Facts",
    slug: "/blog/african-grey-parrot-facts/",
    excerpt: "20 verified facts: lifespan 40–60 years, CITES Appendix I status, 200–1,000 word vocabulary, and the Congo vs Timneh distinction every buyer needs to know.",
    category: "Facts",
  },
  {
    title: "African Grey Parrot Cage Setup",
    slug: "/blog/african-grey-parrot-cage-setup/",
    excerpt: "Minimum 36\"×24\"×48\" cage, stainless steel bars at 3/4\"–1\" spacing, 3-perch variety setup, and the enrichment rotation system we use in our breeding facility.",
    category: "Care",
  },
  {
    title: "African Grey Health Problems",
    slug: "/blog/african-grey-health-problems/",
    excerpt: "Feather plucking, calcium deficiency seizures, psittacosis, aspergillosis — the 7 most common African Grey health problems and how to prevent every one.",
    category: "Health",
  },
  {
    title: "African Grey Parrot Training",
    slug: "/blog/african-grey-parrot-training/",
    excerpt: "Target training, step-up, recall, and talking development — the step-by-step methods we use with every bird before it leaves our facility.",
    category: "Training",
  },
  {
    title: "African Grey Parrot Talking Ability",
    slug: "/blog/african-grey-parrot-talking-ability/",
    excerpt: "African Greys can learn 200–1,000+ words — but not all of them will, and the timeline is slower than most buyers expect. Here's what the research and 10 years of experience says.",
    category: "Intelligence",
  },
  {
    title: "Is an African Grey Good for Beginners?",
    slug: "/blog/is-african-grey-good-for-beginners/",
    excerpt: "The honest answer from breeders: African Greys are rarely beginner-friendly — but some first-time owners succeed. Here's the distinction.",
    category: "Buyer's Guide",
  },
  {
    title: "African Grey vs Amazon Parrot",
    slug: "/african-grey-vs-amazon-parrot/",
    excerpt: "Two elite talkers compared: African Grey precision vs. Amazon charisma, plus hormonal aggression differences most buyers don't expect.",
    category: "Comparisons",
  },
  {
    title: "African Grey Parrot Care Guide",
    slug: "/african-grey-parrot-care-guide/",
    excerpt: "Complete care guide covering diet, housing, enrichment, health, and CITES documentation requirements.",
    category: "Care",
  },
  {
    title: "African Grey Parrot Diet",
    slug: "/african-grey-parrot-diet/",
    excerpt: "What to feed, what to avoid, and how to build a diet that keeps an African Grey healthy for 40–60 years.",
    category: "Nutrition",
  },
  {
    title: "African Grey Parrot Lifespan",
    slug: "/african-grey-parrot-lifespan/",
    excerpt: "African Greys live 40–60 years. What affects lifespan, life stages, and how to plan for a lifelong companion.",
    category: "Health",
  },
  {
    title: "African Grey Pros and Cons",
    slug: "/african-grey-pros-and-cons/",
    excerpt: "An honest look at what makes African Greys exceptional — and what makes them the wrong bird for many households.",
    category: "Buyer's Guide",
  },
  {
    title: "Baby African Grey for Sale",
    slug: "/baby-african-grey-parrot-for-sale/",
    excerpt: "Hand-raised, fully weaned baby African Greys with CITES documentation. What to expect and what questions to ask.",
    category: "Buying",
  },
  {
    title: "Congo vs Timneh African Grey",
    slug: "/congo-vs-timneh-african-grey/",
    excerpt: "Size, color, price, temperament and talking ability compared side by side.",
    category: "Comparisons",
  },
  {
    title: "African Grey vs Macaw",
    slug: "/african-grey-vs-macaw/",
    excerpt: "Which parrot fits your home, schedule, and budget? Full side-by-side comparison.",
    category: "Comparisons",
  },
  {
    title: "African Grey vs Cockatoo",
    slug: "/african-grey-vs-cockatoo/",
    excerpt: "Talking ability, affection level, noise, and care demands compared.",
    category: "Comparisons",
  },
  {
    title: "How to Avoid African Grey Parrot Scams",
    slug: "/how-to-avoid-african-grey-parrot-scams/",
    excerpt: "CITES documentation red flags, deposit scam patterns, and how to verify a legitimate breeder.",
    category: "Safety",
  },
  {
    title: "CITES African Grey Documentation",
    slug: "/cites-african-grey-documentation/",
    excerpt: "What documentation every captive-bred African Grey must ship with — and what to demand before any deposit.",
    category: "Legal",
  },
  {
    title: "African Grey Parrot Price Guide",
    slug: "/african-grey-parrot-price/",
    excerpt: "Congo and Timneh pricing, first-year setup costs, annual expenses, and 40–60 year lifetime estimates.",
    category: "Costs",
  },
  {
    title: "African Grey Parrot Species Guide",
    slug: "/african-grey-parrot-guide/",
    excerpt: "Complete species guide: subspecies, intelligence, talking ability, wild range, CITES status, and captive care.",
    category: "Species",
  },
];
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <!-- Hero -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section style="background:#2D6A4F" class="text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p style="color:#f0c674" class="font-sora text-sm font-semibold uppercase tracking-widest mb-4">Written by USDA-Licensed Breeders · Midland, TX</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4" style="color:#faf7f4">African Grey Parrot Blog</h1>
      <p style="color:rgba(250,247,244,0.8)" class="text-lg max-w-2xl mx-auto">Care guides, species comparisons, diet, health, and buyer resources — written by Mark &amp; Teri Benjamin after 10+ years raising captive-bred African Greys.</p>
    </div>
  </section>

  <!-- Article Grid -->
  <section class="py-16 px-4" style="background:#faf7f4">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={post.slug} class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 hover:border-clay transition-colors block" style="text-decoration:none">
            <span class="text-xs font-sora font-semibold uppercase tracking-wide" style="color:#e8604c">{post.category}</span>
            <h2 class="font-lora font-bold text-lg mt-2 mb-3" style="color:#2D6A4F">{post.title}</h2>
            <p class="text-stone-600 text-sm leading-relaxed">{post.excerpt}</p>
            <span class="text-sm font-sora font-semibold mt-4 inline-block" style="color:#e8604c">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
