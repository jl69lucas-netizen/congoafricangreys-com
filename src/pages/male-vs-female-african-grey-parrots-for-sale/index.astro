---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "Male & Female African Grey Parrots for Sale — DNA-Sexed Cocks & Hens, Same Price $1,500–$3,500, Ships Nationwide | Reserve at C.A.Gs Congo & Timneh Greys";
const description = "Male & female African Grey parrots for sale, DNA-sexed — no guesswork: every Congo & Timneh leaves with a PCR sexing certificate, health guarantee and CITES papers. Cocks and hens cost the same; you pick the bird, not the sex. $200 reserves, ships nationwide. C.A.Gs DNA-sexed African Greys.";
const canonical = "https://congoafricangreys.com/male-vs-female-african-grey-parrots-for-sale/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "Male vs Female African Grey", url: "/male-vs-female-african-grey-parrots-for-sale/" },
];

// S19 — available birds, read live from clutch-inventory (never hardcoded status)
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === 'available')
  .sort((a, b) => (a.variant === 'timneh_african_grey' ? -1 : 1));

const faqs = [
  { q: "Is a male or female African Grey better as a pet?", a: "Neither, and we say that as the people who raise both. Male and female African Greys are so close in temperament, talking and bonding that the individual bird outweighs its sex every time. What actually predicts a great companion is hand-rearing, early socialization and the time you put in — not whether it's a cock or a hen. Choose the bird whose personality clicks with your household; let DNA tell you the sex afterward." },
  { q: "Do male or female African Greys talk better?", a: "There's no reliable talking difference between the sexes. Both males and females can become brilliant, precise talkers, and both can stay quiet — it comes down to the individual bird, how much you talk to it, and how hand-tame it is. Folklore that 'males talk more' isn't supported by how our clutches actually turn out. If a big vocabulary matters, pick the chatty individual in front of you, not a sex." },
  { q: "How can you tell if an African Grey is male or female?", a: "You can't tell by looking — African Greys are a monomorphic species, meaning males and females are visually near-identical in size, color and markings. The head-shape, body-shape and eye 'tells' you'll read online are folklore and are wrong often enough to be useless. The only accurate method is a DNA test (a PCR test on a feather or a drop of blood). Every C.A.Gs bird leaves with a DNA-sexing certificate, so the guesswork is already done." },
  { q: "Do male and female African Greys look different?", a: "No. Both sexes have the same light silver-grey body, red tail and pale face mask (Congo) or charcoal body, maroon tail and horn-colored beak (Timneh). There is no visible feature — not the head, not the 'squared-off' skull, not the wing tips — that reliably separates a male from a female. That visual sameness is exactly why DNA sexing exists." },
  { q: "Are female African Greys calmer or quieter than males?", a: "On average, no more than the individual bird's own temperament dictates. We've raised placid males and spirited females and vice-versa. 'Hens are calmer, cocks are louder' is a generalization that falls apart across a real clutch. Both sexes have the same vocal range and the same capacity for calm — enrichment, routine and handling shape the noise far more than sex does." },
  { q: "Do female African Greys lay eggs without a mate?", a: "A lone female can lay infertile eggs if she becomes hormonally stimulated, even with no male present. It's manageable — the risk to watch is chronic egg-laying, which draws down calcium and can cause hypocalcemia or egg-binding. A correct diet, calcium and UV-B/D3 exposure, and limiting nest-like spaces keep it in check. It's a real consideration if you specifically want a hen, not a dealbreaker." },
  { q: "Is a male or female African Grey better for a first-time owner?", a: "Either. Sex isn't the variable a first-timer should optimize; temperament and hand-taming are. A calm, well-socialized bird of either sex is the right first grey. We match first-time buyers to the individual chick that suits their home, then hand them the DNA certificate — the sex is information, not the decision." },
  { q: "Do African Greys bond better with a male or female owner?", a: "Hand-reared African Greys bond to their primary caregiver's time and calm handling, not to the owner's gender. The idea that Greys 'prefer women' or 'prefer men' is folklore — the bird bonds to whoever shows up consistently, reads its body language and doesn't rush it. Men and women both raise deeply bonded Greys here." },
  { q: "Are male African Greys more aggressive or hormonal?", a: "Both sexes go through seasonal hormonal phases, and both can nip or get territorial during them — it's not a male-only trait. The folklore runs both ways (some call males 'aggressive,' others call females 'moody'), which is a good sign it's individual, not sex-linked. Consistent routine and reading your bird's signals matter far more than which sex you picked." },
  { q: "What is DNA sexing and do your birds come sexed?", a: "DNA sexing is a lab PCR test — on a feather or a small blood sample — that reads the bird's chromosomes to confirm male or female with high accuracy. It's the only reliable method for a monomorphic species. Yes: every C.A.Gs African Grey is DNA-sexed and leaves with the certificate, so you know exactly what you're getting. You can read more on our DNA-tested African Greys page." },
  { q: "Is it better to get two males or a male and female pair?", a: "For a talking companion bird, a single hand-reared grey bonds hardest to you regardless of sex — two birds often bond to each other and to you less. If you want a pair, a compatible male–female or same-sex pairing can both work; sex matters less than whether the two birds actually get along. A male–female pair can still learn to talk, though a bonded pair typically talks to each other more than to you." },
  { q: "Do male and female African Greys cost the same?", a: "Yes. At C.A.Gs the price is set by variant and age, never by sex — a male and a female Congo of the same age cost the same, and so do our Timnehs. Any seller charging a premium for one sex is pricing on folklore, not on what the bird is worth." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Male vs Female African Grey Parrots for Sale: Do the Sexes Really Differ?",
  description: description,
  author: { "@type": "Organization", name: "C.A.Gs – Congo African Greys, Midland TX" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com" },
  mainEntityOfPage: canonical,
  datePublished: "2026-06-13",
  dateModified: "2026-07-07",
};

// LocalBusiness + Person(founders) + Review/AggregateRating — real facts only
// (NAP per credentials master; rating 4.9 / 52 real reviews per Verified-Claim Ledger).
// Product schema is intentionally omitted: this is a comparison page, not a single
// product/offer page — Product/Offer lives on the /available/<bird>/ pages.
const bizSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://congoafricangreys.com/#business",
  name: "C.A.Gs – Congo African Greys",
  url: "https://congoafricangreys.com/",
  telephone: "+1-281-545-3169",
  address: { "@type": "PostalAddress", addressLocality: "Midland", addressRegion: "TX", addressCountry: "US" },
  areaServed: "US",
  founder: [
    { "@type": "Person", name: "Mark Benjamin" },
    { "@type": "Person", name: "Teri Benjamin" },
  ],
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52" },
  review: [
    { "@type": "Review", author: { "@type": "Person", name: "Catherine Kempf" }, reviewRating: { "@type": "Rating", ratingValue: "5" }, reviewBody: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained." },
    { "@type": "Review", author: { "@type": "Person", name: "Ida Brim" }, reviewRating: { "@type": "Rating", ratingValue: "5" }, reviewBody: "From the first email to home delivery, everything was exactly as promised. My grey arrived hand-raised, weaned, and confident — with his health certificate and CITES documents in hand." },
  ],
};

// NOTE: no page-level BreadcrumbList schema — the <Breadcrumb> component already
// emits it; a second copy trips the breadcrumb_one gate (found 2026-07-04).

// verdict table (S6) — Length + Body shade rows added 2026-07-05 (competitor sweep:
// the top-ranked info pages all lead with the charcoal shade / inches figures we lacked)
const rows = [
  { attr: "Appearance", male: "Monomorphic — identical", female: "Monomorphic — identical", edge: "Can't sex by sight" },
  { attr: "Size & weight", male: "Same for the variant", female: "Same for the variant", edge: "No sex difference" },
  { attr: "Talking ability", male: "Individual; can excel", female: "Individual; can excel", edge: "The bird, not the sex" },
  { attr: "Temperament", male: "Full individual range", female: "Full individual range", edge: "The bird, not the sex" },
  { attr: "Bonding", male: "Bonds to time & handling", female: "Bonds to time & handling", edge: "Not sex-linked" },
  { attr: "Hormonal phase", male: "Seasonal display", female: "Seasonal; may lay infertile eggs", edge: "Both seasonal" },
  { attr: "Egg-laying", male: "Not applicable", female: "Possible without a mate — manage calcium", edge: "Female-specific" },
  { attr: "How you sex it", male: "DNA (PCR) only", female: "DNA (PCR) only", edge: "DNA, never looks" },
  { attr: "Price at C.A.Gs", male: "Set by variant & age", female: "Same — set by variant & age", edge: "Identical" },
  { attr: "Lifespan", male: "40–60 years", female: "40–60 years", edge: "Equal" },
  { attr: "DNA certificate", male: "Included", female: "Included", edge: "Equal" },
  { attr: "CITES documentation", male: "Appendix I — included", female: "Appendix I — included", edge: "Equal" },
];

const takeaways = [
  { big: "Identical", sub: "males & females are monomorphic — no reliable visible sex difference" },
  { big: "DNA only", sub: "a PCR test is the one accurate way to sex an African Grey" },
  { big: "Same price", sub: "sex never changes our price — variant and age do" },
  { big: "No talk gap", sub: "both sexes talk equally well; the individual bird decides" },
  { big: "40–60 yrs", sub: "either sex is a retirement-length commitment" },
  { big: "Bonds to you", sub: "to your time and handling, not to your gender" },
  { big: "100%", sub: "every chick leaves DNA-sexed with its certificate + CITES docs" },
  { big: "$185 / $350", sub: "airport pickup vs home delivery, nationwide" },
];

const scores = [
  { trait: "Talking ability", m: 8, f: 8, note: "no reliable sex gap — it's the bird" },
  { trait: "Temperament steadiness", m: 8, f: 8, note: "individual range, not sex-linked" },
  { trait: "Noise level", m: 7, f: 7, note: "same vocal range" },
  { trait: "Depth of bond to you", m: 9, f: 9, note: "driven by handling, not sex" },
  { trait: "Beginner suitability", m: 8, f: 8, note: "pick temperament, not sex" },
  { trait: "Hormonal ease", m: 8, f: 7, note: "hens can egg-lay; both go seasonal" },
];

// S19 — real photo per bird card (never a photo-less card); crops refreshed 2026-07-05
const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a cuddly tamed female Congo African Grey resting on her keeper's lap" },
  "amie": { src: "/amie-congo-african-grey-handfed-baby-card.webp", alt: "Amie, a hand-fed baby female Congo African Grey snuggled against her keeper's shoulder" },
  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey standing next to his toy ball" },
  "jins-jeni": { src: "/congo-african-grey-companion-pair-card.webp", alt: "Jins and Jeni, Congo African Grey companion pair raised together" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a young male Timneh African Grey stretching his wings on a perch" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a female Timneh African Grey perched calmly, showing her horn-colored beak" },
};

// S19 — the documentation every bird leaves with (Verified-Claim Ledger)
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// S18 — this page's OWN 7 delivery destinations. The congo-vs-timneh page owns
// TX/FL/NY/LA/Chicago/GA/NC — never reuse a set across pages (each page targets
// a distinct local-entity cluster; see the location-link distribution note).
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-arizona/", label: "Arizona hens & cocks, flown to PHX" },
  { href: "/african-grey-parrot-for-sale-pennsylvania/", label: "Pennsylvania doorstep courier" },
  { href: "/african-grey-parrot-for-sale-ohio/", label: "Ohio next-clutch reservations" },
  { href: "/african-grey-parrot-for-sale-miami/", label: "Miami same-week cargo slot" },
  { href: "/african-grey-parrot-for-sale-dallas/", label: "Dallas–Fort Worth short hop" },
  { href: "/african-grey-parrot-for-sale-washington/", label: "Washington state Sea-Tac route" },
  { href: "/african-grey-parrot-for-sale-new-jersey/", label: "New Jersey Newark arrivals" },
];

// S3 — single numbered section list drives BOTH the desktop TOC and the mobile
// jump rail (sequential 01–20, no skips, every section present — fixed 2026-07-05)
const tocItems = [
  { id: "quick-answer", label: "Quick Answer" },
  { id: "takeaways", label: "Key Takeaways" },
  { id: "side-by-side", label: "Side-by-Side" },
  { id: "trust", label: "Why Trust Us" },
  { id: "behavior", label: "Does Sex Predict Behavior?" },
  { id: "male", label: "The Male African Grey" },
  { id: "female", label: "The Female African Grey" },
  { id: "sexing", label: "How to Tell Them Apart" },
  { id: "scorecard", label: "Decision Scorecard" },
  { id: "household", label: "Which Fits Your Home" },
  { id: "cost", label: "Cost" },
  { id: "first30", label: "First 30 Days" },
  { id: "myths", label: "Myths" },
  { id: "pairs", label: "One, Pair or Same-Sex" },
  { id: "cites", label: "CITES & Docs" },
  { id: "shipping", label: "Shipping" },
  { id: "available", label: "Available Now" },
  { id: "stories", label: "Owner Stories" },
  { id: "safe", label: "Buy Safely" },
  { id: "faq", label: "FAQ" },
  { id: "learn", label: "Keep Learning" },
  { id: "reserve", label: "Reserve" },
];
const num = (i: number) => String(i + 1).padStart(2, "0");

// S20 — real reviews only, from the verified homepage bottomReviews set (the
// second slot swapped Archie Obrien → Ida Brim 2026-07-11 (dup-content gate:
// Archie's quote also runs verbatim on congo-vs-timneh, the flagship keeps it;
// sibling pages must feature DIFFERENT real reviewers. Ida's quote is her real
// verbatim review, avatar already in public/)
const stories = [
  { name: "Catherine Kempf", loc: "Schaumburg, IL", meta: "Congo African Grey",
    avatar: "/catherine-kempf-schaumburg-il-review.webp",
    quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained. Watching it grow and bond with my family has been an absolute joy. I recommend C.A.Gs to anyone looking for a quality African Grey." },
  { name: "Ida Brim", loc: "Nashville, TN", meta: "African Grey",
    avatar: "/ida-brim-nashville-tn-review.webp",
    quote: "From the first email to home delivery, everything was exactly as promised. My grey arrived hand-raised, weaned, and confident — with his health certificate and CITES documents in hand." },
];
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta
  heroPreload="/Kent-playful-male-congo-african-grey.webp"
  heroPreloadSrcset="/Kent-playful-male-congo-african-grey-450.webp 450w, /Kent-playful-male-congo-african-grey.webp 900w"
  heroPreloadSizes="(max-width: 900px) 60vw, 300px">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(bizSchema)} />

  <div class="cvt">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- S1 HERO — full-bleed band; Kent (male, portrait) L / Evie (female, landscape) R -->
  <section class="cvt-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Hand-raised · DNA-sexed · Ships nationwide</p>
        <h1 class="cag-h1">Male vs. Female African Grey Parrots for Sale</h1>
        <p class="lead">Buyers ask us this almost daily: should I get a male or a female African Grey? Here's the honest answer from the breeders who DNA-sex every chick — the sexes barely differ, the individual bird is what matters, and we hand you the certificate so you never have to guess.</p>
        <p class="hero-cta"><a class="btn-clay" href="#quick-answer">See the Honest Answer</a> <a class="btn-ghost" href="/available/">See Available Greys</a></p>
      </div>
      <div class="hero-imgs">
        <figure>
          <img src="/Kent-playful-male-congo-african-grey.webp"
            srcset="/Kent-playful-male-congo-african-grey-450.webp 450w, /Kent-playful-male-congo-african-grey.webp 900w"
            sizes="(max-width: 900px) 50vw, 280px" style="object-position:center 26%"
            width="375" height="500" alt="Kent, a hand-raised male Congo African Grey at C.A.Gs, perched on a hand showing his light silver-grey plumage and dark beak" fetchpriority="high">
          <figcaption class="chip">Male · Kent</figcaption>
        </figure>
        <span class="vs" aria-hidden="true">vs</span>
        <figure>
          <img src="/Evie-female-timneh-african-grey.webp"
            width="640" height="427" alt="Evie, a hand-raised female Timneh African Grey at C.A.Gs, exploring a foraging toy, showing her darker charcoal plumage" loading="lazy">
          <figcaption class="chip">Female · Evie</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- S2 COUNTER SNIPPET — modernized 2026-07-05: icon chips, serif numerals, hairline separators -->
  <section class="cvt-counter"><div class="container counter-row">
    <div class="cs">
      <span class="cs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 12 15 2 8.5 12 2"/><polyline points="2 15.5 12 22 22 15.5"/></svg></span>
      <b>100%</b><span class="cs-l">DNA-sexed &amp; certified</span>
    </div>
    <div class="cs">
      <span class="cs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 13 17 22l-5-3-5 3L8.5 13"/></svg></span>
      <b>PCR</b><span class="cs-l">Sexing done for you</span>
    </div>
    <div class="cs">
      <span class="cs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 11.5 11.5 14 15.5 9.5"/></svg></span>
      <b>100%</b><span class="cs-l">CITES documented</span>
    </div>
    <div class="cs">
      <span class="cs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
      <b>24h</b><span class="cs-l">Reply to inquiries</span>
    </div>
  </div></section>

  <!-- S3 mobile jump rail — all 20 sections, sequential numbering, clear divider band (2026-07-05) -->
  <nav class="cvt-rail" aria-label="Jump to section"><div class="container rail-row">
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </div></nav>

  <div class="container cvt-body">

  <!-- S3 desktop TOC — card treatment + ink title so it reads apart from the green counter band -->
  <aside class="cvt-toc" aria-label="On this page">
    <p class="toc-title"><span class="toc-tick" aria-hidden="true"></span>On this page</p>
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </aside>

  <div class="cvt-main">

  <!-- S4 QUICK ANSWER (4A clay-edge) -->
  <section id="quick-answer">
    <h2 class="cag-h2">Is a Male or Female African Grey Better as a Pet?</h2>
    <div class="qa-box">
      <p><strong>Quick Answer:</strong> Neither — and we say that as the breeders who raise and DNA-sex both. Male and female African Greys are a <em>monomorphic</em> species: they look identical and behave within the same range, so the individual bird's temperament and how it was hand-raised matter far more than its sex. Pick a male African Grey if the cock in front of you is the one you connect with; pick a female if the hen is. The sex is confirmed by a DNA test, not by which bird talks or cuddles more.</p>
    </div>
    <img class="sec-img inf-img" src="/male-vs-female-african-grey-monomorphic-identical-infographic.webp" srcset="/male-vs-female-african-grey-monomorphic-identical-infographic-760.webp 760w, /male-vs-female-african-grey-monomorphic-identical-infographic.webp 1376w" sizes="(max-width:900px) 92vw, 760px" width="1376" height="768" alt="Infographic showing a male and female African Grey in mirror symmetry with an equals sign, illustrating that the sexes are monomorphic and visually identical" loading="lazy">
    <p>Buyers reach this page searching every phrasing of it — male or female African Grey, which is better male or female, even "African gray" with an <em>a</em> — and the answer holds across all of them. Whether you're after the best talker, the calmer companion, or simply the bird that bonds to you, the deciding factor is the individual grey and the hours you give it, not the chromosome. The rest of this page shows you exactly why, and hands you the <a href="/dna-tested-african-grey-for-sale/">DNA-sexed documentation</a> that settles the sex for certain.</p>
    <h3 class="cag-h3">What Actually Differs Between a Male and Female African Grey?</h3>
    <img class="sec-img" src="/male-vs-female-african-grey-chicks.webp" srcset="/male-vs-female-african-grey-chicks-480.webp 480w, /male-vs-female-african-grey-chicks.webp 640w" sizes="(max-width:900px) 92vw, 640px" width="640" height="480" alt="Two young hand-raised African Grey chicks side by side at the C.A.Gs nursery in Midland, TX, visually identical regardless of sex" loading="lazy">
    <p>What genuinely differs is narrower than most listings imply. The one reliable, real difference is reproductive — only a hen lays eggs, which brings a calcium consideration we cover further down. Everything else buyers ask about, from "do males talk more" to "are females calmer," sits inside a wide band of individual variation that swamps any sex average. We've weaned quiet cocks and motor-mouth hens out of the very same clutch. When a seller tells you a sex guarantees a personality, that's folklore doing the selling.</p>
  </section>

  <div class="seam"><img src="/cag-footer-logo-80.webp" width="40" height="40" alt="" loading="lazy"></div>

  <Newsletter variant="top" action="https://formspree.io/f/xrejpnvn" heading="Still Deciding Male or Female? Get New-Clutch Alerts" sub="Join the list for first word when a DNA-sexed Congo or Timneh chick — cock or hen — is ready to reserve." cta="Join the list" />

  <div class="seam"><img src="/cag-footer-logo-80.webp" width="40" height="40" alt="" loading="lazy"></div>

  <!-- S5 KEY TAKEAWAYS — refined stat cards (2026-07-05 redesign: ink stats, clay tick, hairline) -->
  <section id="takeaways">
    <h2 class="cag-h2">Which Eight Facts Do Buyers Screenshot From This Page?</h2>
    <p>Short on time? These are the facts about male and female African Greys that buyers screenshot and text to their spouse — why the sexes look identical, how they're actually sexed, why price never depends on sex, and where the individual bird outweighs every generalization. Every number below comes from our own aviary records and the DNA certificates we hand out, not a rewritten listicle.</p>
    <div class="kt-grid">
      {takeaways.map((k) => (<div class="kt-c"><span class="kt-tick" aria-hidden="true"></span><b>{k.big}</b><span class="kt-sub">{k.sub}</span></div>))}
    </div>
    <img class="sec-img" src="/playful-african-grey-chicks.webp" width="320" height="311" alt="Playful hand-raised African Grey chicks at the C.A.Gs nursery in Midland, TX, males and females indistinguishable by sight" loading="lazy">
  </section>

  <!-- S6 SIDE-BY-SIDE — CompareTableE idiom (branded gradient headers + Edge column) with a mobile Male/Female tab toggle -->
  <section id="side-by-side">
    <h2 class="cag-h2">Cock vs Hen on Paper: Which of 12 Traits Actually Split by Sex?</h2>
