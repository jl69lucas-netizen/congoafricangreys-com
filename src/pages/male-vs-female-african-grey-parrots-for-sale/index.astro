        <table class="w-full text-sm">
          <thead class="bg-green text-cream">
            <tr>
              <th class="px-4 py-3 text-left font-sora">Behavior</th>
              <th class="px-4 py-3 text-left font-sora">Male African Grey</th>
              <th class="px-4 py-3 text-left font-sora">Female African Grey</th>
            </tr>
          </thead>
