---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "Congo vs Timneh African Grey: Key Differences | CongoAfricanGreys.com";
const description = "Congo vs Timneh African Grey compared: size, color, price, temperament and talking ability. Find which captive-bred, CITES-documented African Grey fits your home.";
const canonical = "https://congoafricangreys.com/congo-vs-timneh-african-grey/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "Congo vs Timneh", url: "/congo-vs-timneh-african-grey/" },
];

const faqs = [
  {
    q: "What is the main difference between a Congo and Timneh African Grey?",
    a: "The Congo African Grey is larger (12–14 inches, 400–550 g) with a bright red tail and an all-black beak. The Timneh African Grey is smaller (9–11 inches, 275–375 g) with a darker maroon tail and a horn-colored upper mandible. Both are intelligent talking parrots and both are CITES Appendix I species supplied with full captive-bred documentation.",
  },
  {
    q: "Which talks better, a Congo or a Timneh African Grey?",
    a: "Both subspecies are among the best talking parrots in the world. Congo African Greys are famous for crisp, near-human speech clarity. Timneh African Greys often begin talking earlier and are typically calmer and less prone to nervousness, which can make them easier for first-time owners.",
  },
  {
    q: "How much does a Congo vs a Timneh African Grey cost?",
    a: "At CongoAfricanGreys.com a captive-bred Congo African Grey ranges from $1,700 to $3,500, and a Timneh African Grey ranges from $1,500 to $1,600. Price reflects age, training progress and documentation. See our African Grey parrot price guide for a full breakdown.",
  },
  {
    q: "Is a Congo or Timneh African Grey better for apartments?",
    a: "The Timneh African Grey is generally the better apartment choice. It is smaller, often calmer and tends to vocalize at a slightly lower volume. Congos are also suitable for apartments but their louder contact calls can carry further through shared walls.",
  },
  {
    q: "Are Congo and Timneh African Greys both legal to own?",
    a: "Yes. Both the Congo and Timneh African Grey are CITES Appendix I species. Every bird we place is captive-bred in the United States and ships with CITES captive-bred documentation, a hatch certificate with band number, DNA sexing results and an avian veterinary health certificate.",
  },
  {
    q: "Which African Grey is better for a first-time owner?",
    a: "Many first-time owners do well with a Timneh African Grey because of its typically steadier, more easygoing temperament. That said, a well-socialized, hand-raised Congo from a reputable breeder also adjusts smoothly. The bigger factor is choosing a fully weaned, hand-raised bird with complete documentation.",
  },
  {
    q: "Do Congo and Timneh African Greys have the same lifespan?",
    a: "Yes. Both subspecies commonly live 40 to 60 years with proper nutrition, veterinary care and enrichment. Choosing either bird is a multi-decade commitment that should be planned for as a lifelong companion.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};

const comparisonRows = [
  { attr: "Body size", congo: "12–14 inches (33–36 cm)", timneh: "9–11 inches (28–33 cm)" },
  { attr: "Weight", congo: "400–550 grams", timneh: "275–375 grams" },
  { attr: "Tail color", congo: "Bright cherry-red", timneh: "Dark maroon / charcoal" },
  { attr: "Upper mandible (beak)", congo: "Solid black", timneh: "Horn / bone-colored tip" },
  { attr: "Plumage", congo: "Light silver-grey", timneh: "Darker charcoal-grey" },
  { attr: "Price range", congo: "$1,700 – $3,500", timneh: "$1,500 – $1,600" },
  { attr: "Temperament", congo: "Affectionate, sensitive, can be reserved", timneh: "Calm, confident, easygoing" },
  { attr: "Talking ability", congo: "Exceptional clarity, large vocabulary", timneh: "Talks early, slightly softer voice" },
  { attr: "Apartment suitability", congo: "Good — louder contact calls", timneh: "Excellent — quieter, smaller" },
  { attr: "Lifespan", congo: "40–60 years", timneh: "40–60 years" },
  { attr: "CITES status", congo: "Appendix I — fully documented", timneh: "Appendix I — fully documented" },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="cvt-hero">
    <div class="container">
      <h1 class="cag-h1">Congo vs Timneh African Grey: Key Differences</h1>
      <p class="cvt-sub">
        Two subspecies, one remarkable parrot. Compare size, color, price,
        temperament and talking ability so you can choose the right
        captive-bred, CITES-documented African Grey for your family.
      </p>
      <div class="cvt-hero-cta">
        <a class="btn-primary" href="/congo-african-grey-for-sale/">View Congo African Greys</a>
        <a class="btn-secondary" href="/timneh-african-grey-for-sale/">View Timneh African Greys</a>
      </div>
    </div>
  </section>

  <!-- QUICK ANSWER -->
  <section class="cvt-section">
    <div class="container container-text">
      <h2 class="cag-h2">The Quick Answer</h2>
      <div class="cvt-quick">
        <div class="cvt-quick-card">
          <h3>Choose a Congo if&hellip;</h3>
          <p>
            You want the larger, classic silver-grey African Grey with a
            striking red tail and want the crispest, most human-like speech.
          </p>
        </div>
        <div class="cvt-quick-card">
          <h3>Choose a Timneh if&hellip;</h3>
          <p>
            You want a smaller, typically calmer bird that often talks earlier,
            settles quickly and suits apartments and first-time owners.
          </p>
        </div>
        <div class="cvt-quick-card">
          <h3>They are equal on&hellip;</h3>
          <p>
            Intelligence, 40–60 year lifespan, CITES Appendix I status and the
            full captive-bred documentation included with every bird we place.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 KEY FACTS -->
  <section class="cvt-section cvt-alt">
    <div class="container container-text">
      <h2 class="cag-h2">5 Facts That Actually Matter</h2>
      <ul class="cvt-facts">
        <li><strong>They are the same species.</strong> Congo (<em>Psittacus erithacus erithacus</em>) and Timneh (<em>Psittacus erithacus timneh</em>) are two subspecies of the same African Grey parrot.</li>
        <li><strong>Beak color is the fastest tell.</strong> A solid black upper beak means Congo; a horn-colored tip means Timneh.</li>
        <li><strong>Smaller does not mean less smart.</strong> Timnehs match Congos in cognitive ability and often begin talking sooner.</li>
        <li><strong>Both are legal and documented.</strong> Captive-bred status and CITES Appendix I paperwork apply equally to both.</li>
        <li><strong>Temperament beats subspecies.</strong> A hand-raised, fully weaned bird from a reputable breeder is the single biggest predictor of a smooth transition home.</li>
      </ul>
    </div>
  </section>

  <!-- MAIN COMPARISON TABLE -->
  <section class="cvt-section">
    <div class="container">
      <h2 class="cag-h2">Congo vs Timneh African Grey: Side-by-Side</h2>
      <div class="cvt-table-wrap">
        <table class="cvt-table">
          <thead>
            <tr>
              <th>Attribute</th>
              <th>Congo African Grey</th>
              <th>Timneh African Grey</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <th scope="row">{row.attr}</th>
                <td>{row.congo}</td>
                <td>{row.timneh}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="cvt-note">
        Pricing reflects age, training progress and documentation. For a full
        breakdown see our <a href="/african-grey-parrot-price/">African Grey parrot price guide</a>.
      </p>
    </div>
  </section>

  <!-- DEEP DIVE: CONGO -->
  <section class="cvt-section cvt-alt">
    <div class="container container-text">
      <h2 class="cag-h2">The Congo African Grey in Depth</h2>
      <p>
        The Congo African Grey is the bird most people picture when they hear
        "African Grey" — a light silver-grey parrot, 12 to 14 inches long, with
        a brilliant cherry-red tail and a solid black beak. Adults weigh between
        400 and 550 grams, giving them a confident, substantial presence on the
        hand.
      </p>
      <p>
        Congos are renowned for speech clarity. Many develop large vocabularies
        and reproduce human inflection so precisely that visitors mistake them
        for a person in the next room. They are sensitive, observant birds that
        bond deeply and thrive on routine, mental enrichment and a calm
        household.
      </p>
      <p>
        A captive-bred Congo from CongoAfricanGreys.com ranges from
        <strong>$1,700 to $3,500</strong>, fully weaned and hand-raised. Browse
        current availability on our
        <a href="/congo-african-grey-for-sale/">Congo African Grey for sale</a> page.
      </p>
    </div>
  </section>

  <!-- DEEP DIVE: TIMNEH -->
  <section class="cvt-section">
    <div class="container container-text">
      <h2 class="cag-h2">The Timneh African Grey in Depth</h2>
      <p>
        The Timneh African Grey is the smaller subspecies — 9 to 11 inches long
        and 275 to 375 grams — with darker charcoal plumage, a maroon tail and a
        distinctive horn-colored upper mandible. It is every bit as intelligent
        as the Congo, simply packaged in a more compact bird.
      </p>
      <p>
        Timnehs are widely regarded as calmer and more confident. They tend to
        be less prone to the nervousness some Congos show, often start talking
        at a younger age and settle into new homes quickly. That steadiness
        makes them a popular choice for apartments and for first-time African
        Grey owners.
      </p>
      <p>
        A captive-bred Timneh from CongoAfricanGreys.com ranges from
        <strong>$1,500 to $1,600</strong>, fully weaned and hand-raised. Browse
        current availability on our
        <a href="/timneh-african-grey-for-sale/">Timneh African Grey for sale</a> page.
      </p>
    </div>
  </section>

  <!-- MID-PAGE CTA -->
  <section class="cvt-cta">
    <div class="container">
      <h2 class="cag-h2">Still Deciding Between Congo and Timneh?</h2>
      <p>
        Tell our breeder team about your home and experience level — we will
        recommend the right African Grey and walk you through every document.
      </p>
      <a class="btn-primary" href="/african-grey-parrot-for-sale-near-me/">Talk to Our Breeder Team</a>
    </div>
  </section>

  <!-- CITES SECTION -->
  <section class="cvt-section cvt-alt">
    <div class="container container-text">
      <h2 class="cag-h2">CITES Status &amp; Documentation</h2>
      <p>
        Both the Congo and Timneh African Grey are listed under
        <strong>CITES Appendix I</strong>. This protects wild populations and
        regulates international trade — it does not restrict responsible
        ownership of captive-bred birds within the United States.
      </p>
      <p>Every African Grey we place — Congo or Timneh — ships with:</p>
      <ul class="cvt-doc-list">
        <li>CITES captive-bred documentation</li>
        <li>Hatch certificate with leg-band number</li>
        <li>DNA sexing certificate</li>
        <li>Avian veterinary health certificate</li>
        <li>USDA Animal Welfare Act compliance under our licensed facility</li>
      </ul>
      <p>
        We never sell wild-caught birds. Every parrot is bred and hand-raised in
        our care, fully weaned before it goes home.
      </p>
    </div>
  </section>

  <!-- WHICH IS RIGHT FOR YOU -->
  <section class="cvt-section">
    <div class="container">
      <h2 class="cag-h2">Which One Is Right for You?</h2>
      <div class="cvt-match">
        <div class="cvt-match-col">
          <h3>A Congo African Grey suits you if&hellip;</h3>
          <ul>
            <li>You want the larger, iconic red-tailed African Grey</li>
            <li>Crisp, human-like speech clarity is a priority</li>
            <li>Your household is calm and keeps a steady routine</li>
            <li>You can offer daily one-on-one interaction and enrichment</li>
            <li>You have a home or unit where louder contact calls are fine</li>
          </ul>
        </div>
        <div class="cvt-match-col">
          <h3>A Timneh African Grey suits you if&hellip;</h3>
          <ul>
            <li>You prefer a smaller, lighter parrot</li>
            <li>You are a first-time African Grey owner</li>
            <li>You live in an apartment or noise-sensitive setting</li>
            <li>You want a typically calmer, more confident temperament</li>
            <li>You would like a bird that often starts talking earlier</li>
          </ul>
        </div>
      </div>
      <p class="cvt-note">
        Not sure which side you fall on? A well-socialized, hand-raised bird
        from a reputable breeder adjusts beautifully either way — temperament
        and proper rearing matter more than subspecies.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cvt-section cvt-alt">
    <div class="container container-text">
      <h2 class="cag-h2">Congo vs Timneh African Grey: FAQ</h2>
      <div class="cvt-faq">
        {faqs.map((f) => (
          <details class="cvt-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cvt-cta">
    <div class="container">
      <h2 class="cag-h2">Ready to Bring Home an African Grey?</h2>
      <p>
        Whether you choose a Congo or a Timneh, every bird is captive-bred,
        hand-raised and placed with complete documentation.
      </p>
      <div class="cvt-hero-cta">
        <a class="btn-primary" href="/congo-african-grey-for-sale/">See Congo African Greys</a>
        <a class="btn-secondary" href="/timneh-african-grey-for-sale/">See Timneh African Greys</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .container-text {
    max-width: 760px;
  }
  .cag-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .cag-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .cvt-hero {
    background: #faf7f4;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .cvt-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: #44403c;
    max-width: 70ch;
    margin: 0 auto 1.75rem;
  }
  .cvt-hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary,
  .btn-secondary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.9rem;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: #e8604c;
    color: #fff;
  }
  .btn-primary:hover {
    background: #d44e3b;
  }
  .btn-secondary {
    background: #fff;
    color: #2D6A4F;
    border: 2px solid #2D6A4F;
  }
  .btn-secondary:hover {
    background: #2D6A4F;
    color: #fff;
  }
  .cvt-section {
    padding: 3rem 0;
  }
  .cvt-alt {
    background: #faf7f4;
  }
  .cvt-section p,
  .cvt-facts li,
  .cvt-doc-list li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
  }
  .cvt-quick {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .cvt-quick-card {
    background: #fff;
    border: 1px solid #e7e0d8;
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 4px 14px rgba(60, 30, 10, 0.06);
  }
  .cvt-quick-card h3 {
    font-family: 'Lora', Georgia, serif;
    color: #2D6A4F;
    font-size: 1.2rem;
    margin: 0 0 0.6rem;
  }
  .cvt-quick-card p {
    font-size: 0.98rem;
    margin: 0;
  }
  .cvt-facts {
    padding-left: 1.25rem;
  }
  .cvt-facts li {
    margin-bottom: 0.85rem;
  }
  .cvt-table-wrap {
    overflow-x: auto;
    border-radius: 20px;
    border: 1px solid #e7e0d8;
    box-shadow: 0 4px 14px rgba(60, 30, 10, 0.06);
  }
  .cvt-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Sora', system-ui, sans-serif;
    background: #fff;
  }
  .cvt-table thead th {
    background: #2D6A4F;
    color: #fff;
    font-weight: 600;
    padding: 1rem;
    text-align: left;
    font-size: 1rem;
  }
  .cvt-table tbody th,
  .cvt-table tbody td {
    padding: 0.9rem 1rem;
    border-top: 1px solid #e7e0d8;
    font-size: 0.97rem;
    color: #44403c;
    text-align: left;
    vertical-align: top;
  }
  .cvt-table tbody th {
    font-weight: 600;
    color: #2D6A4F;
    width: 22%;
  }
  .cvt-table tbody tr:nth-child(even) {
    background: #faf7f4;
  }
  .cvt-note {
    font-size: 0.95rem !important;
    color: #57534e !important;
    margin-top: 1rem;
  }
  .cvt-cta {
    background: #2D6A4F;
    padding: 3rem 0;
    text-align: center;
  }
  .cvt-cta .cag-h2 {
    color: #fff;
  }
  .cvt-cta p {
    color: #e7f0ec !important;
    margin: 0 auto 1.5rem;
    text-align: center;
  }
  .cvt-doc-list {
    padding-left: 1.25rem;
  }
  .cvt-doc-list li {
    margin-bottom: 0.5rem;
  }
  .cvt-match {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .cvt-match-col {
    background: #fff;
    border: 1px solid #e7e0d8;
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 4px 14px rgba(60, 30, 10, 0.06);
  }
  .cvt-match-col h3 {
    font-family: 'Lora', Georgia, serif;
    color: #2D6A4F;
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }
  .cvt-match-col ul {
    padding-left: 1.2rem;
    margin: 0;
  }
  .cvt-match-col li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.6;
    color: #44403c;
    margin-bottom: 0.55rem;
  }
  .cvt-faq-item {
    background: #fff;
    border: 1px solid #e7e0d8;
    border-radius: 12px;
    padding: 0.25rem 1.25rem;
    margin-bottom: 0.75rem;
  }
  .cvt-faq-item summary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    color: #2D6A4F;
    cursor: pointer;
    padding: 0.9rem 0;
    list-style: none;
  }
  .cvt-faq-item summary::-webkit-details-marker {
    display: none;
  }
  .cvt-faq-item summary::after {
    content: '+';
    float: right;
    color: #e8604c;
    font-size: 1.3rem;
    line-height: 1;
  }
  .cvt-faq-item[open] summary::after {
    content: '\2212';
  }
  .cvt-faq-item p {
    margin: 0 0 1rem;
    font-size: 0.98rem;
  }
  @media (max-width: 1024px) {
    .container {
      padding: 0 32px;
    }
  }
  @media (max-width: 767px) {
    .container {
      padding: 0 16px;
    }
    .cvt-quick {
      grid-template-columns: 1fr;
    }
    .cvt-match {
      grid-template-columns: 1fr;
    }
  }
</style>
