              <img src={item.img} alt={`${item.title} — captive-bred at C.A.Gs in Midland, TX, CITES Appendix I documented`} width="160" height="160" loading="lazy" decoding="async" class="h-28 w-28 flex-shrink-0 rounded-xl object-cover sm:h-32 sm:w-32" />
              <div class="flex flex-col justify-center py-1 pr-2">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">{item.tag}</span>
                <h3 class="font-lora mt-1 text-xl font-bold text-logo-dark">{item.title}</h3>
                <p class="font-sora mt-1.5 text-[13.5px] leading-relaxed text-stone-600">{item.desc}</p>
                <span class="font-sora mt-2 inline-flex items-center gap-1 text-sm font-semibold text-clay group-hover:gap-2 transition-all">{item.cta} →</span>
              </div>
            </a>
          ))}
        </div>
        <p class="font-sora text-stone-500 text-sm leading-relaxed mt-6" style="max-width:70ch;">Want to see the documentation for an egg order or a pair before you commit? <a href="#contact" class="text-green underline decoration-1 underline-offset-2">Ask us below</a> and we'll walk you through every certificate.</p>
      </div>
    </section>

    <!-- 7. FINAL CTA + CONTACT -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.webp" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section class="pt-14 px-4 md:pt-16 text-center">
      <div class="max-w-3xl mx-auto">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Documented &amp; Legal</p>
        <h2 class="font-lora font-bold text-logo-dark mb-4">Every Grey We Place Is Fully CITES Documented — Ready to Ask Us About Yours?</h2>
        <p class="text-stone-600 leading-relaxed text-[15px] mx-auto" style="max-width:70ch;">Every African Grey from C.A.Gs is U.S. captive-bred, closed-banded, PCR DNA-sexed, avian-vet certified, and placed with a complete CITES Appendix I documentation packet — never wild-caught, paperwork in your hands before any deposit.</p>
        <p class="text-stone-600 leading-relaxed text-[15px] mx-auto mt-2.5" style="max-width:70ch;">Tell us about your home in the form below and Mark or Teri will reply within 24 hours. Still deciding? Compare our <a href="/congo-african-grey-for-sale/">Congo</a> and <a href="/timneh-african-grey-for-sale/">Timneh</a> Greys — both carry the exact same documentation standard.</p>
      </div>
    </section>

    <div id="contact" class="scroll-mt-20">
      <InquiryForm />
    </div>

  </div>

  <script is:inline>
    // FAQ accordion (smooth open/close) — mirrors homepage / captive-bred pattern
    (function () {
      const qs = document.querySelectorAll('.cag-faq-q');
      if (!qs.length) return;
      qs.forEach(btn => btn.addEventListener('click', () => {
        const item = btn.closest('.cag-faq-item');
        const open = item.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['what-is-cites', 'appendix-i', 'is-it-legal', 'documents', 'domestic-vs-international', 'verify', 'faq', 'contact'];
      var labels = {
        'appendix-i': 'The 2017 Appendix I Uplisting',
        'is-it-legal': 'Is It Legal to Own One?',
        'documents': 'The 4-Document Packet',
        'domestic-vs-international': 'Domestic vs International',
        'verify': 'Verify the Breeder',
        'faq': 'CITES Questions',
        'contact': 'Ask About Documentation'
      };
      for (var i = 0; i < ids.length - 1; i++) {
        var cur = document.getElementById(ids[i]);
        if (!cur) continue;
        var nav = document.createElement('div');
        nav.className = 'section-next-nav';
        nav.innerHTML = '<a href="#' + ids[i + 1] + '" class="section-next-link">&#8595; Continue: ' + (labels[ids[i + 1]] || ids[i + 1]) + '</a>';
        cur.appendChild(nav);
      }
    })();
  </script>
</BaseLayout>

<style is:global>
  /* ============================================================
     CITES DOCUMENTATION PAGE — Direction-D-aware interior wrapper (.cites-d)
     body.theme-d already supplies Newsreader/IBM Plex, lead paragraphs,
     eyebrow ticks, card + button motion. This only scopes seam + links + table.
     ============================================================ */
  .cites-d { --rule: rgba(45,106,79,.16); }

  /* Smooth in-page jumps (JumpRail + TOC + next-nav) with reduced-motion guard. */
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

  /* Sticky header is ~96px tall — keep jumped-to headings visible below it. */
  .cites-d [id] { scroll-margin-top: 110px; }

  /* Hero eyebrow — homepage HeroV3 pattern: no pill, no uppercase. */
  .cites-d .hero-eyebrow { font-size:10px; font-weight:500; letter-spacing:.12em; color:rgba(255,255,255,.75); text-transform:none; }
  @media (min-width:768px) { .cites-d .hero-eyebrow { font-size:11px; } }

  /* AA: clay as small readable text on LIGHT sections → #b04228 (4.5:1). */
  .cites-d a.text-clay, .cites-d .text-clay { color:#b04228; }
  .cites-d .hero-v3-b .text-clay { color:inherit; }
  /* Clay FILLS keep white text (global .bg-clay renders --clay-ink #bd4129, 4.78:1).
     (Was color:inherit — leaked dark stone text onto clay buttons/tags.) */
  .cites-d .bg-clay { color:#fff; }

  /* Section jump-nav ("↓ Continue:") — JS-injected, so rules MUST be global. */
  .cites-d .section-next-nav { text-align:right; padding-top:18px; margin-top:14px; border-top:1px solid #ede5dc; max-width:1100px; margin-left:auto; margin-right:auto; }
  .cites-d .section-next-link { font-family:'IBM Plex Sans','Sora',sans-serif; font-size:.85rem; font-weight:600; color:#b04228; text-decoration:none; display:inline-block; padding:10px 0 10px 12px; margin:-10px 0; }
  .cites-d .section-next-link:hover { text-decoration:underline; }

  /* Woven in-content links: clay, underlined, AA-safe. */
  .cites-d p a:not(.rounded-full):not(.bg-clay),
  .cites-d li a:not(.rounded-full):not(.bg-clay) {
    color:#b04228; font-weight:500; text-decoration:underline;
    text-decoration-color:rgba(176,66,40,.35); text-underline-offset:2px;
    transition:text-decoration-color .2s ease;
  }
  .cites-d p a:not(.rounded-full):not(.bg-clay):hover,
  .cites-d li a:not(.rounded-full):not(.bg-clay):hover { text-decoration-color:#b04228; }

  /* External links open in a new tab — subtle outward arrow affordance. */
  .cites-d p a[target="_blank"]::after { content:"\2197"; font-size:.7em; line-height:0; vertical-align:super; opacity:.5; margin-left:.12em; }

  /* Domestic vs international comparison table */
  .cites-table { font-family:'IBM Plex Sans',sans-serif; font-size:.92rem; }
  .cites-table thead th { padding:13px 16px; text-align:left; font-weight:600; color:#fff; font-size:.85rem; }
  .cites-table thead th:first-child { background:#2D6A4F; }
  .cites-table thead .cites-good-h { background:#1e5238; }
  .cites-table thead .cites-cross-h { background:#5a5248; }
  .cites-table tbody tr:nth-child(even) { background:#faf7f4; }
  .cites-table tbody td { padding:12px 16px; border-bottom:1px solid #ede5dc; line-height:1.5; vertical-align:top; }
  .cites-table tbody tr:last-child td { border-bottom:none; }
  .cites-feat { font-weight:600; color:#6b6560; width:24%; }
  .cites-good { color:#1c5c40; font-weight:500; }
  .cites-cross { color:#5a5248; }

  /* Section seam — centered wordmark divider (verbatim scope). */
  .cites-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
  .cites-d .cag-seam img{ height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
  @media (max-width:600px){ .cites-d > .cag-seam{ gap:16px; } .cites-d .cag-seam img{ height:24px; } }

  /* Infographic — 4-document pack grid (760px wrapper, 400px desktop fixed) */
  .ig-cites{ max-width:760px; margin:0 auto 2.25rem; padding:26px 28px; background:#fff; border:1px solid rgba(32,52,43,.12); border-radius:20px; box-shadow:0 4px 24px rgba(60,30,10,.06); display:flex; flex-direction:column; gap:18px; }
  @media (min-width:641px){ .ig-cites{ height:400px; justify-content:space-between; } }
  .ig-cites-eyebrow{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#b04228; }
  .ig-cites-title{ font-family:'Newsreader',Georgia,serif; font-size:1.35rem; font-weight:700; color:#1f3a2d; margin:.3rem 0 0; }
  .ig-cites-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .ig-cites-card{ display:flex; flex-direction:column; gap:6px; padding:14px 16px; background:rgba(45,106,79,.05); border:1px solid rgba(45,106,79,.14); border-radius:12px; color:#2D6A4F; }
  .ig-cites-card strong{ font-family:'IBM Plex Sans',sans-serif; font-size:13px; font-weight:600; color:#1f3a2d; line-height:1.3; }
  .ig-cites-card span{ font-family:'IBM Plex Sans',sans-serif; font-size:11.5px; color:#57534e; line-height:1.35; }
  .ig-cites-note{ font-family:'IBM Plex Sans',sans-serif; font-size:13px; color:#57534e; border-top:1px solid rgba(45,106,79,.16); padding-top:14px; }
  @media (max-width:640px){ .ig-cites{ padding:20px 18px; } .ig-cites-grid{ grid-template-columns:1fr; } }

  /* Link-magnet: Buyer's CITES Verification Checklist (matches .ig-cites family) */
  .ig-verify{ max-width:760px; margin:0 auto 2.25rem; padding:26px 28px; background:#fff; border:1px solid rgba(32,52,43,.12); border-radius:20px; box-shadow:0 4px 24px rgba(60,30,10,.06); display:flex; flex-direction:column; gap:18px; }
  @media (min-width:641px){ .ig-verify{ min-height:400px; justify-content:space-between; } }
  .ig-verify-eyebrow{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#b04228; }
  .ig-verify-title{ font-family:'Newsreader',Georgia,serif; font-size:1.35rem; font-weight:700; color:#1f3a2d; margin:.3rem 0 0; }
  .ig-verify-sub{ font-family:'IBM Plex Sans',sans-serif; font-size:13px; color:#57534e; margin:.4rem 0 0; line-height:1.5; }
  .ig-verify-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .ig-verify-item{ display:flex; align-items:flex-start; gap:10px; padding:12px 14px; background:rgba(45,106,79,.05); border:1px solid rgba(45,106,79,.14); border-radius:12px; }
  .ig-verify-item svg{ flex-shrink:0; margin-top:1px; }
  .ig-verify-item strong{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:13px; font-weight:600; color:#1f3a2d; line-height:1.3; }
  .ig-verify-item span{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:11.5px; color:#57534e; line-height:1.35; margin-top:3px; }
  .ig-verify-item--flag{ background:rgba(176,66,40,.05); border-color:rgba(176,66,40,.18); }
  .ig-verify-note{ font-family:'IBM Plex Sans',sans-serif; font-size:13px; color:#57534e; border-top:1px solid rgba(45,106,79,.16); padding-top:14px; }
  .ig-verify-note a{ color:#2D6A4F; font-weight:600; }
  @media (max-width:640px){ .ig-verify{ padding:20px 18px; } .ig-verify-grid{ grid-template-columns:1fr; } }
</style>
