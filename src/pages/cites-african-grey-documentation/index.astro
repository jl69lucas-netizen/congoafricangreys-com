---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrot CITES Documentation: What Every Buyer Needs to Know";
const description = "Is it legal to own an African Grey parrot? Yes — if it's captive-bred and CITES documented. Learn what documents your bird must have, why CITES matters, and how to verify compliance.";
const canonical = "https://congoafricangreys.com/cites-african-grey-documentation/";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is it legal to own an African Grey parrot in the United States?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — it is legal to own an African Grey parrot in the United States if the bird is captive-bred and comes with proper CITES Appendix II documentation. Wild-caught African Grey parrots cannot be legally imported or sold in the US. All legally sold African Greys in the US today are captive-bred, and must be accompanied by documentation confirming that captive-bred status."
      }
    },
    {
      "@type": "Question",
      "name": "What is CITES Appendix II for African Grey parrots?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CITES (the Convention on International Trade in Endangered Species) Appendix II lists African Grey parrots (Psittacus erithacus) as a species that can be traded commercially only under strict controls. For captive-bred birds sold within the US, this means the breeder must maintain documentation proving the bird was bred in captivity — not taken from the wild. Wild-capture of African Greys has been banned since 2016 under CITES Appendix I uplisting for wild populations."
      }
    },
    {
      "@type": "Question",
      "name": "What documents does a CITES-compliant African Grey come with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A properly documented captive-bred African Grey parrot should include: (1) CITES captive-bred certificate from the breeder/aviary confirming US captive birth; (2) DNA sexing certificate from a certified avian lab; (3) USDA health certificate, required for interstate transport; (4) Avian veterinarian health records. Some breeders also provide a leg band or microchip registration matching the documentation."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need CITES documentation if I buy an African Grey parrot within my state?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For intrastate (within your state) purchases, documentation requirements vary by state. However, we provide full CITES documentation with every bird regardless of location — because your bird will likely travel (vet visits, relocations, state moves) and the documentation protects you in every scenario. More importantly, documentation proves your bird is legally obtained, protecting you from wildlife enforcement issues."
      }
    },
    {
      "@type": "Question",
      "name": "Can I travel with my African Grey parrot to another country?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "International travel with an African Grey parrot requires a CITES export permit from the US and an import permit from the destination country. African Greys are CITES Appendix II, meaning all international trade — including personal travel — requires formal permits from both countries. Contact USDA APHIS Wildlife Services for current US export permit requirements. Some countries have additional restrictions or outright bans on parrot import."
      }
    },
    {
      "@type": "Question",
      "name": "How do I verify a breeder is selling legitimate CITES-documented African Greys?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ask for: (1) USDA AWA license number — verify at aphis.usda.gov; (2) A copy of the CITES captive-bred documentation before any payment; (3) The avian vet health certificate showing the bird was examined. Legitimate breeders will provide all documents willingly. If a seller hesitates, says documentation 'comes later,' or cannot name their avian vet, these are red flags of illegal or fraudulent operation."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I buy an African Grey parrot without CITES documentation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Purchasing an African Grey without proper CITES documentation puts you at legal risk. Wildlife enforcement agencies (USFWS, USDA) can seize an undocumented bird. You may face fines under the Lacey Act if the bird was wild-caught or illegally obtained. The bird would likely be transferred to a wildlife facility. Even if you purchased in good faith, proving that without documentation is difficult. Always demand full documentation before purchase."
      }
    },
    {
      "@type": "Question",
      "name": "Are African Grey parrots endangered?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wild African Grey parrot populations are listed as Endangered on the IUCN Red List, primarily due to habitat loss and historical wild capture for the pet trade. However, captive breeding programs have created robust legal populations in the US and Europe. Every bird from a USDA-licensed aviary like Congo African Greys contributes to the captive-bred population and does not impact wild populations in any way."
      }
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "African Grey Parrot CITES Documentation: Complete Buyer's Guide",
  "about": {
    "@type": "Thing",
    "name": "CITES Appendix II",
    "description": "Convention on International Trade in Endangered Species — Appendix II listing for African Grey parrots",
    "sameAs": "https://cites.org/eng/app/appendices.php"
  },
  "author": {
    "@type": "Person",
    "name": "Mark Benjamin",
    "jobTitle": "USDA AWA Licensed Bird Breeder"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Congo African Greys",
    "url": "https://congoafricangreys.com"
  },
  "datePublished": "2026-05-15",
  "dateModified": "2026-05-15",
  "mainEntityOfPage": "https://congoafricangreys.com/cites-african-grey-documentation/"
};
---

<BaseLayout {title} {description} {canonical}>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-3">Legal Ownership Guide · CITES Appendix II</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">African Grey Parrot CITES Documentation</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Everything you need to know about legal African Grey parrot ownership in the United States — what documents your bird must have and why they matter.</p>
    </div>
  </section>

  <TrustBar />

  <!-- Is It Legal -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Is It Legal to Own an African Grey Parrot?</h2>
      <div class="bg-green-50 border border-green-200 rounded-xl p-5 mb-6">
        <p class="text-green-800 font-semibold text-lg mb-2">Yes — with proper documentation.</p>
        <p class="text-green-700 text-sm">African Grey parrots are legal to own in the United States when they are captive-bred and come with CITES Appendix II documentation confirming that captive status. Wild-caught African Greys cannot be legally imported or sold. Every bird from a legitimate US aviary is captive-bred and fully documented.</p>
      </div>
      <p class="text-stone-700 mb-4">
        According to the <a href="https://cites.org/eng/app/appendices.php" target="_blank" rel="noopener" class="text-logo-dark underline hover:text-clay">CITES Appendix II registry</a>, African Grey parrots (Psittacus erithacus) have been internationally regulated since 1975. Wild populations have been under Appendix I protection (strictest level) since 2016. Captive-bred birds sold in the US operate under Appendix II regulations, which require documentation but permit legal commercial sale.
      </p>
      <p class="text-stone-700">
        The distinction matters: <strong>captive-bred = legal to own and trade with documentation. Wild-caught = illegal to import or sell in the US.</strong> Documentation is the only proof of which category your bird belongs to.
      </p>
    </div>
  </section>

  <!-- What CITES Means -->
  <section class="bg-stone-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What CITES Appendix II Means for Parrot Buyers</h2>
      <div class="grid sm:grid-cols-2 gap-6 mb-6">
        <div>
          <h3 class="font-lora font-semibold text-lg text-logo-dark mb-3">Appendix II in Plain Language</h3>
          <p class="text-stone-600 text-sm mb-3">CITES Appendix II means a species can be commercially traded, but trade must be controlled to prevent unsustainable exploitation. For African Greys, this means:</p>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-green-600">✓</span> Captive-bred birds: fully legal to own and sell</li>
            <li class="flex gap-2"><span class="text-green-600">✓</span> Documentation required to prove captive-bred status</li>
            <li class="flex gap-2"><span class="text-red-500">✗</span> Wild-caught birds: illegal to import or sell</li>
            <li class="flex gap-2"><span class="text-red-500">✗</span> Undocumented birds: legally ambiguous, risk of seizure</li>
          </ul>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-lg text-logo-dark mb-3">Why African Greys Need Protection</h3>
          <p class="text-stone-600 text-sm mb-3">Wild African Grey populations have declined by over 50% in parts of their range. Key drivers:</p>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-stone-400">•</span> Deforestation across Central/West Africa</li>
            <li class="flex gap-2"><span class="text-stone-400">•</span> Historical wild capture for pet trade (pre-2016)</li>
            <li class="flex gap-2"><span class="text-stone-400">•</span> Slow reproduction (2–4 eggs per clutch, once/year)</li>
            <li class="flex gap-2"><span class="text-stone-400">•</span> High intelligence = high demand</li>
          </ul>
          <p class="text-stone-500 text-xs mt-3">Buying from a USDA-licensed captive breeder contributes nothing to wild population decline and everything to sustainable captive breeding.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Document Package -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">The 4 Documents Your African Grey Must Have</h2>
      <p class="text-stone-700 mb-6">Every bird from Congo African Greys ships with a complete documentation package. Here's what each document does and why it matters.</p>
      <div class="space-y-4">
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <div class="flex items-start gap-4">
            <div class="bg-logo-dark text-gold font-bold text-sm px-3 py-1.5 rounded-lg flex-shrink-0">DOC 1</div>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">CITES Captive-Bred Certificate</h3>
              <p class="text-stone-600 text-sm mb-2">Issued by the breeder's USDA-registered aviary. Confirms the bird was born in captivity in the United States from captive-bred parent birds — not imported from Africa. This is the primary legal ownership document.</p>
              <p class="text-stone-500 text-xs"><strong>Protects you from:</strong> Wildlife enforcement action, seizure, and being held liable for wild-caught trafficking.</p>
            </div>
          </div>
        </div>
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <div class="flex items-start gap-4">
            <div class="bg-logo-dark text-gold font-bold text-sm px-3 py-1.5 rounded-lg flex-shrink-0">DOC 2</div>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">DNA Sexing Certificate</h3>
              <p class="text-stone-600 text-sm mb-2">Laboratory-confirmed sex from a certified avian DNA lab. Required because African Grey parrots are not visually sexable by sight alone (unlike some bird species). The certificate includes the lab name, submission date, and confirmed sex — with a sample reference number.</p>
              <p class="text-stone-500 text-xs"><strong>Why it matters:</strong> Undocumented sex claims are guesses. DNA sexing is definitive.</p>
            </div>
          </div>
        </div>
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <div class="flex items-start gap-4">
            <div class="bg-logo-dark text-gold font-bold text-sm px-3 py-1.5 rounded-lg flex-shrink-0">DOC 3</div>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">USDA Health Certificate</h3>
              <p class="text-stone-600 text-sm mb-2">Required by federal law for any bird transported across state lines. Issued by an accredited avian veterinarian within 10 days of the shipping or pickup date. Confirms the bird is healthy and free from infectious disease at time of transfer.</p>
              <p class="text-stone-500 text-xs"><strong>Required for:</strong> Interstate transport, airline shipping, crossing state borders.</p>
            </div>
          </div>
        </div>
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <div class="flex items-start gap-4">
            <div class="bg-logo-dark text-gold font-bold text-sm px-3 py-1.5 rounded-lg flex-shrink-0">DOC 4</div>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Avian Veterinarian Health Records</h3>
              <p class="text-stone-600 text-sm mb-2">Complete health history from our aviary vet, including all exams during weaning, any treatments administered, weight history, and the pre-sale comprehensive examination results. This file starts your bird's lifelong health record.</p>
              <p class="text-stone-500 text-xs"><strong>Important for:</strong> Your new avian vet appointment, insurance claims, and the bird's 40–60 year health history.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Verification Guide -->
  <section class="bg-stone-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">How to Verify a Breeder Is CITES Compliant</h2>
      <ol class="space-y-4">
        <li class="flex gap-4">
          <span class="bg-logo-dark text-gold font-bold rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0 text-sm">1</span>
          <div>
            <h3 class="font-semibold text-logo-dark mb-1">Ask for the USDA AWA License Number</h3>
            <p class="text-stone-600 text-sm">Go to <strong>aphis.usda.gov</strong> and use the Animal Care USDA search to verify the license number is valid and active. The license should match the breeder's name and facility address.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="bg-logo-dark text-gold font-bold rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0 text-sm">2</span>
          <div>
            <h3 class="font-semibold text-logo-dark mb-1">Request Documentation Before Payment</h3>
            <p class="text-stone-600 text-sm">Ask to see sample documentation from a previous bird placement, or confirmation of what documentation you will receive. Legitimate breeders can show you their documentation practices before you commit any funds.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="bg-logo-dark text-gold font-bold rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0 text-sm">3</span>
          <div>
            <h3 class="font-semibold text-logo-dark mb-1">Verify the Avian Veterinarian</h3>
            <p class="text-stone-600 text-sm">Ask for the name and practice of the avian vet who issues health certificates. You can call the vet to confirm they work with that breeder — a simple verification that takes 2 minutes and tells you a lot.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="bg-logo-dark text-gold font-bold rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0 text-sm">4</span>
          <div>
            <h3 class="font-semibold text-logo-dark mb-1">Never Accept "Documentation Follows" Promises</h3>
            <p class="text-stone-600 text-sm">CITES documentation and health certificates are issued before sale — not after. If a seller says "I'll send the papers once you pay," the papers likely don't exist. Documentation readiness at the time of sale is non-negotiable.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">CITES & African Grey Ownership: FAQs</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item: any) => (
          <details class="bg-stone-50 border border-stone-200 rounded-lg">
            <summary class="p-4 font-semibold text-logo-dark cursor-pointer hover:text-clay transition-colors list-none flex justify-between items-center">
              {item.name}
              <span class="text-stone-400 text-lg">+</span>
            </summary>
            <div class="px-4 pb-4 text-stone-600 text-sm leading-relaxed border-t border-stone-100 pt-3">
              {item.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="bg-logo-dark text-cream rounded-2xl p-8 text-center">
        <h2 class="font-lora font-bold text-2xl mb-3">Every Bird We Place Is Fully CITES Documented</h2>
        <p class="text-cream/80 mb-6">USDA AWA licensed. CITES captive-bred certificate. DNA sexing. Avian vet health records. You receive every document before your bird ships.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/trusted-african-grey-parrot-breeders/" class="bg-gold text-logo-dark font-semibold px-6 py-3 rounded-full hover:bg-cream transition-colors">Meet Our Breeders</a>
          <a href="/contact-us/" class="border-2 border-gold text-gold font-semibold px-6 py-3 rounded-full hover:bg-gold hover:text-logo-dark transition-colors">Ask About Documentation</a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
