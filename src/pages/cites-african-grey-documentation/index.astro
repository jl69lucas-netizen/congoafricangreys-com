---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Parrot CITES Documentation | CITES Appendix I Papers, Certificate & Closed Band Explained — Is It Legal to Own One in the USA & What Paperwork Comes With Every Bird? | C.A.Gs – Midland, TX";
const description = "African Grey CITES documentation explained: Greys are CITES Appendix I (uplisted at CoP17, effective January 2017); captive-bred birds are legal to own and transfer in the USA with proper papers — what the captive-bred certificate, hatch certificate and closed band prove | USDA breeders C.A.Gs.";
const canonical = "https://congoafricangreys.com/cites-african-grey-documentation/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Resources & Trust", url: "/trusted-african-grey-parrot-breeders/" },
  { name: "CITES Documentation", url: "/cites-african-grey-documentation/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system
// as the homepage + scam page; ids live on each section. Document order required.
const jumpSections = [
  { id: 'what-is-cites',             label: 'What Is CITES', part: 1 },
  { id: 'appendix-i',                label: 'Appendix I',    part: 1 },
  { id: 'is-it-legal',               label: 'Is It Legal?',  part: 1 },
  { id: 'documents',                 label: 'The 4 Docs',    part: 2 },
  { id: 'domestic-vs-international', label: 'Permits',       part: 2 },
  { id: 'verify',                    label: 'Verify Us',     part: 3 },
  { id: 'faq',                       label: 'FAQ',           part: 3 },
  { id: 'eggs-pairs',                label: 'Eggs & Pairs',  part: 3 },
  { id: 'contact',                   label: 'Ask Us',        part: 3 },
];
const jumpPartNames = {
  1: 'CITES Explained',
  2: 'Your Papers',
  3: 'Verify & Ask',
};

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
const faqs = [
  { q: "Is it legal to own an African Grey parrot in the United States?",
    a: "Yes. It is legal to own a captive-bred African Grey in the United States, provided the bird comes with documentation proving its captive-bred origin.\n\nAfrican Greys (Psittacus erithacus) sit on CITES Appendix I, so importing or commercially trading wild-caught specimens is banned — but a captive-bred bird is legal to own and transfer domestically with proper paperwork.\n\nEvery Grey we place here at C.A.Gs is U.S. captive-bred, closed-banded, and CITES Appendix I documented, so your ownership rests on solid legal ground." },
  { q: "What is CITES Appendix I for African Grey parrots?",
    a: "CITES — the Convention on International Trade in Endangered Species — lists species in three appendices by extinction risk.\n\nAppendix I is the strictest tier: commercial international trade in wild-caught specimens is prohibited and all cross-border movement is tightly permit-controlled.\n\nAfrican Greys were uplisted from Appendix II to Appendix I at CoP17, effective 2 January 2017, which ended legal trade in wild-caught birds.\n\nFor a captive-bred Grey sold inside the USA, Appendix I means the breeder must keep documentation proving the bird was bred in captivity rather than taken from the wild." },
  { q: "What documents come with a CITES-compliant African Grey from C.A.Gs?",
    a: "Every Grey we place ships with a complete packet: (1) a CITES Appendix I captive-bred certificate confirming U.S. captive birth; (2) a hatch certificate recording the closed-band number and hatch date; (3) a PCR DNA sexing certificate from an avian lab; (4) a board-certified avian-veterinarian health certificate, with PBFD and Polyomavirus screening, plus the USDA health certificate required for interstate transport.\n\nThe seamless closed band on the bird's leg ties the physical bird to that paperwork." },
  { q: "Do I need CITES paperwork to buy an African Grey within my own state?",
    a: "A federal CITES export or import permit is only required when a bird crosses an international border — it is not needed for an intrastate or interstate sale of a captive-bred bird inside the United States.\n\nThat said, some states have their own permit or record rules, and your Grey will travel for vet visits, moves and shipping over a 40-to-60-year life.\n\nThat is why we provide the full captive-bred certificate, hatch certificate and closed-band record with every bird regardless of where you live — the documentation protects you in every scenario." },
  { q: "Can I travel internationally with my African Grey parrot?",
    a: "Taking an African Grey across a national border requires a CITES export permit from the United States and an import permit from the destination country, because Appendix I covers personal as well as commercial movement.\n\nContact USDA APHIS Wildlife Services and the U.S. Fish & Wildlife Service for current export requirements well before you travel, and confirm the destination's own rules — some countries restrict or ban parrot import outright.\n\nThis is separate from the domestic ownership paperwork that travels with every Grey we sell." },
  { q: "How do I verify a breeder is selling legitimately CITES-documented African Greys?",
    a: "Ask for three things before any money changes hands: a verifiable USDA Animal Welfare Act license number you can check at aphis.usda.gov; a CITES captive-bred certificate for the exact bird you are reserving, not a generic letter; and the name of the avian veterinarian who issued its health certificate.\n\nA legitimate breeder produces all three willingly. If a seller says documentation 'comes after payment,' cannot name their vet, or offers a price far below the market floor, treat it as a red flag and read our guide to avoiding African Grey scams first." },
  { q: "What happens if I buy an African Grey without CITES documentation?",
    a: "An undocumented African Grey leaves you legally exposed.\n\nWildlife enforcement agencies such as the U.S. Fish & Wildlife Service can seize a bird whose captive-bred origin cannot be proven, and if the bird turns out to be wild-caught you could face penalties under the Lacey Act.\n\nEven an honest buyer struggles to prove good faith without papers. The fix is simple: demand the CITES captive-bred certificate, hatch certificate and closed-band record before you pay, every time." },
  { q: "Are African Grey parrots endangered, and does buying one harm wild flocks?",
    a: "Wild African Grey populations are listed as Endangered on the IUCN Red List, driven by habitat loss and decades of trapping for the pet trade — which is exactly why the species was uplisted to CITES Appendix I.\n\nA documented captive-bred bird does the opposite of harm: every captive-bred sale removes a unit of demand that might otherwise fund poaching.\n\nChoosing a closed-banded, CITES-documented Grey from a USDA-licensed aviary touches no wild bird and supports the conservation intent behind the Appendix I listing." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a.replace(/\n\n/g, " ") },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot CITES Documentation — Appendix I, the Papers & Legal Ownership Explained",
  description: "What African Grey CITES documentation means: Appendix I status (uplisted at CoP17, effective January 2017), the captive-bred certificate, hatch certificate and closed band, domestic transfer vs international export, and the documentation packet C.A.Gs provides with every Grey.",
  inLanguage: "en-US",
  about: {
    "@type": "Thing",
    name: "CITES Appendix I",
    description: "Convention on International Trade in Endangered Species — Appendix I listing for African Grey parrots (Psittacus erithacus)",
    sameAs: "https://cites.org/eng/app/appendices.php",
  },
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  datePublished: "2024-09-01",
  dateModified: "2026-06-10",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// NOTE: BreadcrumbList JSON-LD is emitted by <Breadcrumb /> itself (verified in dist) —
// we do NOT add a second copy here (interior standard: extend, never duplicate schema).

// ─── The 4-document packet (verified-claim ledger only) ───
const docs = [
  { tag: "DOC 1", title: "CITES Appendix I Captive-Bred Certificate",
    body: "Issued from our USDA-registered aviary, this confirms your bird was hatched in captivity in the United States from captive parents — not imported from Africa. It is the primary proof that your Grey is the legal, captive-bred kind.",
    foot: "Protects you from: seizure and any liability for wild-caught trafficking." },
  { tag: "DOC 2", title: "Hatch Certificate + Closed-Band Number",
    body: "Records the hatch date and the seamless closed leg-band number we slip onto each chick in its first weeks. Because that band cannot be fitted to an adult, it is tamper-evident, lifelong proof of where and when the bird was hatched.",
    foot: "Why it matters: physically ties the specific bird to its paperwork." },
  { tag: "DOC 3", title: "PCR DNA Sexing Certificate",
    body: "Laboratory-confirmed sex from an avian DNA lab — necessary because African Greys are not visually sexable. The certificate names the lab, the submission date, the confirmed sex and a sample reference number.",
    foot: "Why it matters: a DNA result is definitive; a sex 'guess' is not." },
  { tag: "DOC 4", title: "Avian-Vet Health Certificate",
    body: "A board-certified avian veterinarian examines every Grey before it leaves, with PBFD and Polyomavirus screening, plus the USDA health certificate required by federal law for any bird crossing state lines.",
    foot: "Required for: interstate transport, airline shipping and your new bird's lifelong health file." },
];

// ─── Verify-the-breeder steps ───
const verifySteps = [
  { n: 1, t: "Ask for the USDA AWA license number",
    d: "Go to aphis.usda.gov and use the Animal Care search to confirm the license is valid and active, and that it matches the breeder's name and facility. Ours is available on request before you pay anything." },
  { n: 2, t: "Request the CITES certificate before payment",
    d: "Ask to see the captive-bred certificate for the exact bird you are reserving — not a generic aviary letter. A legitimate breeder can show you the documentation practice before a single dollar moves." },
  { n: 3, t: "Verify the avian veterinarian",
    d: "Ask for the name and practice of the vet who issues the health certificates, then call to confirm they work with that breeder. It takes two minutes and tells you a great deal." },
  { n: 4, t: "Never accept 'papers come after payment'",
    d: "CITES documentation and health certificates are issued before a sale, never after. 'I'll send the papers once you pay' almost always means the papers do not exist. Documentation readiness at the time of sale is non-negotiable." },
];
