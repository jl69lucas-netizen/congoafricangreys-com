---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';

const title = "African Grey Parrot FAQ | 25 Real Buyer Questions Answered — Price, CITES Appendix I Documentation, Talking Ability, Care & Diet, 40–60 Year Lifespan & Nationwide Shipping | C.A.Gs – Midland, TX";
const description = "The complete African Grey parrot FAQ from C.A.Gs, USDA-licensed family breeders in Midland, TX — straight answers on Congo & Timneh pricing ($1,500–$2,500), CITES Appendix I paperwork, talking ability, diet and cage size, the 40–60 year lifespan, PBFD/Polyomavirus screening, and $185/$350 shipping.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-faq/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Parrot FAQ", url: "/african-grey-parrot-faq/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system
// as the homepage + scam page; ids live on each FAQ group section. Document order required.
const jumpSections = [
  { id: 'buying',   label: 'Pricing',  part: 1 },
  { id: 'cites',    label: 'CITES',    part: 1 },
  { id: 'talking',  label: 'Talking',  part: 2 },
  { id: 'care',     label: 'Care',     part: 2 },
  { id: 'health',   label: 'Health',   part: 2 },
  { id: 'shipping',   label: 'Shipping',     part: 3 },
  { id: 'eggs-pairs', label: 'Eggs & Pairs', part: 3 },
  { id: 'contact',    label: 'Ask Us',       part: 3 },
];
const jumpPartNames = {
  1: 'Buying',
  2: 'Living With One',
  3: 'Logistics',
};

// ─── FAQ groups (PAA + GSC buyer language) — answers carry woven links; schema strips HTML ───
const faqGroups = [
  {
    id: "buying",
    eyebrow: "Buying & Pricing",
    heading: "How Much Does an African Grey Cost — and How Do You Buy One?",
    lead: "Here at C.A.Gs a captive-bred Congo African Grey runs $1,700 (adult) to $2,500 (baby), a Timneh runs $1,500–$1,600, and a $200 deposit reserves your bird — with the full documentation packet shown before you pay anything.",
    items: [
      { q: "How much does an African Grey parrot cost?",
        a: `Here at C.A.Gs a baby Congo African Grey is $2,300–$2,500, an adult Congo is $1,700, and a Timneh African Grey is $1,500–$1,600; our bonded pair, Jins and Jeni, goes home together for $3,500. Every price already includes the PCR DNA sexing certificate, hatch certificate and avian-vet health certificate — no add-on paperwork fees.\n\nFor first-year and lifetime numbers, our <a href="/african-grey-parrot-price/">African Grey price guide</a> lays out the complete cost honestly.` },
      { q: "Why is a $500 “African Grey” online almost always a scam?",
        a: `Because no one can legally breed, hand-raise, screen and document an African Grey at that price — a sub-$1,500 “Grey” is a wild-caught bird, a sick bird, or no bird at all.\n\nOur <a href="/how-to-avoid-african-grey-parrot-scams/">scam-avoidance guide</a> walks through the tells: stock photos, wire-transfer-only payment, and “free parrot, just pay shipping” bait. Honest pricing exists because real costs — avian-vet care, DNA labs, CITES paperwork — exist.` },
      { q: "What is the difference between a Congo and a Timneh African Grey?",
        a: `The <a href="/congo-african-grey-for-sale/">Congo African Grey</a> is the larger variant — 400–600 grams, light silver plumage, a cherry-red tail — while the <a href="/timneh-african-grey-for-sale/">Timneh African Grey</a> is smaller and darker with a maroon tail, a generally steadier temperament, and an earlier start to talking.\n\nBoth are equally intelligent, equally long-lived, and carry identical documentation here at C.A.Gs. If you are deciding, our <a href="/congo-vs-timneh-african-grey/">Congo vs Timneh comparison</a> goes variant by variant.` },
      { q: "How do I reserve a bird — is there a deposit?",
        a: `A $200 deposit holds your chosen Grey, and we never release a chick before it is fully weaned and vet-cleared — typically 12–16 weeks old.\n\nStart through our <a href="#contact">inquiry form</a> with the variant and sex you are hoping for, and Mark or Teri will reply within 24 hours with what is available now and what is coming from the next clutch.` },
      { q: "Should I choose a male or a female African Grey?",
        a: `Honestly, the “better” sex is the one whose personality fits your home — individual temperament differences between Greys are far larger than sex-based ones.\n\nBecause males and females look identical, every bird we place is PCR DNA-sexed with the laboratory certificate included. Our <a href="/male-vs-female-african-grey-parrots-for-sale/">male vs female African Grey guide</a> explains what sexing does and does not predict.` },
    ],
  },
  {
    id: "cites",
    eyebrow: "Legality & CITES",
    heading: "Are African Greys Legal — What CITES Paperwork Should You Expect?",
    lead: "A captive-bred African Grey is fully legal to own and transfer within the United States with proper documentation. The species is CITES Appendix I (effective January 2017), which bans trade in wild-caught birds — not documented captive-bred ownership.",
    items: [
      { q: "Are African Grey parrots legal to own in the USA?",
        a: `Yes — a captive-bred African Grey is legal to own and transfer domestically with proper paperwork.\n\nOn the official <a href="https://cites.org/eng/app/appendices.php" target="_blank" rel="noopener noreferrer">CITES appendices</a>, the species was uplisted to Appendix I at CoP17, effective January 2017 — a change that ended commercial trade in wild-caught Greys while leaving documented captive-bred birds unaffected.\n\nEvery Grey we place is U.S. captive-bred, never wild-caught, so your ownership is clean from day one.` },
      { q: "What documentation comes with a C.A.Gs African Grey?",
        a: `Four documents travel with every bird: a CITES Appendix I captive-bred certificate, a hatch certificate recording the closed-band number, a PCR DNA sexing certificate from an avian laboratory, and a board-certified avian-vet health certificate — backed by our 72-hour written guarantee.\n\nOur <a href="/cites-african-grey-documentation/">CITES documentation guide</a> explains what each paper proves, and you see the packet before any deposit changes hands.` },
      { q: "How do I verify a breeder is legitimate before paying?",
        a: `Ask for the breeder's USDA Animal Welfare Act license number and verify it, then insist on bird-specific paperwork — a CITES captive-bred certificate tied to a closed-band number, not a generic PDF.\n\nOn our <a href="/trusted-african-grey-parrot-breeders/">trusted breeders page</a> we show exactly what verifiable looks like; a seller who stalls on documents or asks for gift cards or crypto is exhibiting the red flags our scam guide catalogs.` },
      { q: "What is a closed band, and why does it matter?",
        a: `A closed band is a seamless metal ring slipped over a chick's foot in its first weeks of life — it physically cannot be fitted to an adult bird, which makes it tamper-evident proof the Grey was aviary-raised.\n\nThe band number is recorded on the hatch certificate, tying the <a href="/captive-bred-african-grey-parrot/">captive-bred paper trail</a> to the actual bird in front of you, not just to a document.` },
    ],
  },
  {
    id: "talking",
    eyebrow: "Talking & Intelligence",
    heading: "Can African Greys Really Talk — and How Smart Are They?",
    lead: "African Greys are the most accomplished talking parrots on Earth: a socialized Grey learns 100–1,000 words and uses them in context — genuine comprehension, documented across three decades of research with a Congo Grey named Alex.",
    items: [
      { q: "Do African Grey parrots really talk?",
        a: `Yes — and it is more than mimicry. As <a href="https://parrots.org/encyclopedia/grey-parrot/" target="_blank" rel="noopener noreferrer">the World Parrot Trust species profile</a> notes, African Greys are renowned for using human words in correct context.\n\nDr. Irene Pepperberg's research with Alex showed a Grey identifying colors, shapes and quantities. Our own talking Congo, Maxy, greets visitors by name — the everyday version of what the research proved.\n\nOur <a href="/african-grey-parrot-guide/">complete species guide</a> covers the famous mind in depth.` },
      { q: "How many words can an African Grey learn?",
        a: `A well-socialized African Grey typically builds a working vocabulary of 100 to 1,000 words, plus household sounds — the microwave, the doorbell, your ringtone — reproduced with uncanny accuracy.\n\nThe deciding factors are early hand-raising, daily conversation and consistent social time, which is why a chick socialized by a whole family from a few weeks old has such a head start.` },
      { q: "When do African Greys start talking?",
        a: `Timnehs are usually the early talkers, often producing first clear words at four to six months; Congos typically start closer to their first birthday and then accelerate.\n\nBefore real words you will hear practice mumbling — quiet, garbled rehearsal, often at dusk. Patience, repetition and talking to your Grey like a member of the household do more than any training gadget.` },
      { q: "Are African Greys good pets for first-time bird owners?",
        a: `African Greys are sensitive, brilliant birds that need daily interaction, enrichment and a steady routine, so they reward committed owners more than casual ones.\n\nThat said, a prepared first-timer often does very well starting with a calm, hand-raised Timneh.\n\nWe talk through your home and schedule before placing any bird, and our <a href="/african-grey-pros-and-cons/">honest pros and cons page</a> will tell you plainly if a Grey is the wrong fit.` },
    ],
  },
  {
    id: "care",
    eyebrow: "Care & Diet",
    heading: "What Do African Greys Eat — and What Does Daily Care Involve?",
    lead: "A healthy African Grey eats a 60–70% formulated pellet base with fresh vegetables and limited fruit, lives in a cage of at least 24 x 24 x 36 inches, and needs 2–4 hours of daily interaction plus 10–12 hours of dark sleep.",
    items: [
      { q: "What do African Grey parrots eat?",
        a: `The foundation is a formulated, dye-free pellet at roughly 60–70% of daily intake, rounded out with leafy greens, fresh vegetables and a smaller share of fruit; seed-only diets cause serious deficiencies and shorten lives.\n\nOur <a href="/african-grey-parrot-diet/">African Grey diet guide</a> covers the nutrition science, and the <a href="/best-african-grey-parrot-food/">best-food guide</a> compares pellet options — every chick also goes home on its current food to keep the transition gentle.` },
      { q: "What foods are toxic to African Greys?",
        a: `Avocado is the headline danger — genuinely toxic to parrots — followed by chocolate, caffeine, alcohol, onion, garlic, and heavily salted or sugary human food.\n\nFumes matter as much as food: overheated non-stick (PTFE) cookware releases vapor that can kill a bird in minutes, so the cage never belongs in or beside the kitchen. When in doubt, leave it out and ask your avian vet.` },
      { q: "What size cage does an African Grey need?",
        a: `Plan on 24 x 24 x 36 inches as the absolute minimum, with 3/4-to-1-inch bar spacing and horizontal bars for climbing — and bigger is always better for a bird this active.\n\nPlacement counts too: a social room at or below eye level, away from drafts, direct sun and kitchen fumes. Our <a href="/african-grey-parrot-care-guide/">complete care guide</a> covers setup, perches and placement room by room.` },
      { q: "How much daily attention does an African Grey need?",
        a: `Budget 2–4 hours of genuine social interaction plus supervised out-of-cage time every day — Greys are flock animals, and chronic isolation shows up as screaming, anxiety or feather damage.\n\nA predictable routine and 10–12 hours of dark sleep keep a Grey calm and confident. Our <a href="/african-grey-care/">African Grey care hub</a> gathers everything we publish on daily life with a Grey.` },
      { q: "Why do African Greys need calcium and UV-B light?",
        a: `African Greys are unusually prone to calcium deficiency, and the body needs vitamin D3 — made in response to UV-B light — to absorb the calcium it gets.\n\nWindow glass blocks UV-B, so safe natural sunlight or an avian full-spectrum lamp plus calcium-rich greens close the gap. It is one of the quiet differences between a Grey that thrives for decades and one that develops problems by ten.` },
    ],
  },
  {
    id: "health",
    eyebrow: "Health & Lifespan",
    heading: "How Long Do African Greys Live — and How Do We Keep Them Healthy?",
    lead: "African Grey parrots live 40–50 years in the wild and up to 60 in human care. Every Grey we place is PBFD and Polyomavirus screened by a board-certified avian veterinarian and covered by our 72-hour written guarantee.",
    items: [
      { q: "How long do African Grey parrots live?",
        a: `African Greys live 40–50 years in the wild and up to 60 years in human care with sound nutrition, annual avian-vet exams and daily enrichment — one of the longest-lived companion parrots there is.\n\nThat longevity makes a Grey a genuine multi-decade commitment; many owners name a future caretaker. Our dedicated <a href="/african-grey-parrot-lifespan/">African Grey lifespan guide</a> covers what shortens and what extends those years.` },
      { q: "What health screening does a C.A.Gs Grey get before it leaves?",
        a: `Every bird is screened for PBFD (Psittacine Beak and Feather Disease) and Polyomavirus and examined by a board-certified avian veterinarian before it ships, with psittacosis awareness built into our aviary protocol.\n\nThe health certificate travels with the bird, and our <a href="/african-grey-parrot-health-guarantee/">written health guarantee</a> spells out the 72-hour window in plain terms — you know exactly what we stand behind.` },
      { q: "Do African Greys need a specialist avian veterinarian?",
        a: `Yes — a general small-animal vet is not a substitute, because parrots instinctively hide illness until it is advanced.\n\nThrough the <a href="https://www.aav.org/" target="_blank" rel="noopener noreferrer">Association of Avian Veterinarians directory</a> you can find a qualified avian vet near you; we recommend locating one before your bird arrives so the first wellness exam — the one that activates the guarantee — is booked on day one.` },
      { q: "Why do African Greys pluck their feathers?",
        a: `Feather-destructive behavior is almost always a symptom, not a quirk — boredom, stress, isolation, poor diet or an underlying medical issue turning that powerful problem-solving mind on itself.\n\nThe fix starts with a vet check to rule out illness, then daily enrichment and social time. Our guide to <a href="/how-to-tame-african-grey-parrot/">taming and bonding with a Grey</a> covers the trust-building that prevents it in the first place.` },
    ],
  },
  {
    id: "shipping",
    eyebrow: "Shipping & Delivery",
    heading: "How Does C.A.Gs Ship African Greys — and Is It Safe?",
    lead: "We ship nationwide two ways: $185 to your nearest major airport or $350 for home delivery — IATA-compliant live-animal transport on Delta, United or American, weather-checked at both ends before any bird flies.",
    items: [
      { q: "Do you ship African Grey parrots, and what does it cost?",
        a: `Yes — we ship to all 50 states. Airport-to-airport delivery is $185, and door-to-door home delivery is $350, both IATA-compliant on Delta, United or American live-animal cargo.\n\nWe book direct flights wherever possible and never ship in temperature extremes. Buyers who would rather meet us can also <a href="/buy-african-grey-parrot-near-me/">arrange pickup or local handoff</a> from Midland, Texas.` },
      { q: "Is air transport safe for an African Grey?",
        a: `Handled correctly, yes.\n\nIATA Live Animals Regulations govern crate size, ventilation and handling, and we add our own rules on top: early-morning departures in hot months, direct routes, weather checks at both origin and destination, and a delay — never a gamble — if conditions are wrong.\n\nDecades of airline live-animal programs exist precisely because this is a routine, regulated process.` },
      { q: "What happens after my bird arrives — what if something is wrong?",
        a: `Take your Grey to an avian vet within 72 hours of arrival — that exam activates our written guarantee — and call us immediately if anything seems off; do not wait to see if symptoms pass.\n\nWe stay reachable for the life of the bird, and what buyers say in our <a href="/african-grey-reviews/">African Grey reviews</a> reflects how we handle the after, not just the sale.` },
    ],
  },
];

const allFaqs = faqGroups.flatMap((g) => g.items);
const stripHtml = (s: string) => s.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: allFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(f.a) },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot FAQ — 25 Real Buyer Questions, Answered",
  description: "The complete African Grey parrot FAQ: pricing, CITES Appendix I documentation, talking ability, care and diet, health screening, lifespan, and nationwide shipping — answered by the USDA-licensed breeders at C.A.Gs in Midland, Texas.",
  inLanguage: "en-US",
  about: {
    "@type": "Thing",
    name: "African Grey Parrot",
    alternateName: "Psittacus erithacus",
    sameAs: "https://parrots.org/encyclopedia/grey-parrot/",
  },
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  datePublished: "2024-09-01",
  dateModified: "2026-06-10",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// ─── TOC (grouped jump links) ───
const tocParts = [
  {
    label: "Part One",
    sub: "Buying with confidence",
    rows: [
      { n: 1, t: "How Much Does an African Grey Cost — and How Do You Buy One?", href: "#buying" },
      { n: 2, t: "Are African Greys Legal — What CITES Paperwork Should You Expect?", href: "#cites" },
      { n: 3, t: "Can African Greys Really Talk — and How Smart Are They?", href: "#talking" },
    ],
  },
  {
    label: "Part Two",
    sub: "Living with your Grey",
    rows: [
      { n: 4, t: "What Do African Greys Eat — and What Does Daily Care Involve?", href: "#care" },
      { n: 5, t: "How Long Do African Greys Live — and Stay Healthy?", href: "#health" },
      { n: 6, t: "How Does C.A.Gs Ship African Greys — and Is It Safe?", href: "#shipping" },
      { n: 7, t: "Do You Sell Only Single Birds — or Eggs and Breeding Pairs Too?", href: "#eggs-pairs" },
    ],
  },
];
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="faq-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 1. HERO (cag-hero-v3:b idiom · Authority Green) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="hero-eyebrow font-sora">FAQ Pillar · 25 Buyer Questions · Answered by Our Aviary</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              African Grey Parrot FAQ — Every Buyer Question, Answered Honestly
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Buying an African Grey is a 40-to-60-year decision, and the questions deserve straight answers — not sales copy.</p>
          <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Here at C.A.Gs in Midland, Texas, we hand-raise CITES Appendix I documented, captive-bred Congo and Timneh Greys under a USDA AWA license, and these are the 25 questions buyers actually ask us, grouped by topic: pricing, legality and paperwork, talking ability, daily care, health and shipping.</p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#buying" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Start With Pricing →</a>
              <a href="#contact" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">Ask Us Directly →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/african-grey-head-scratch-cags-breeder.webp"
                  alt="A hand-raised Congo African Grey leaning into a head scratch at the C.A.Gs family aviary in Midland, Texas — the kind of trusting, captive-bred bird this FAQ is written about."
                  title="Hand-raised Congo African Grey — C.A.Gs FAQ, Midland TX"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover object-center" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <Newsletter variant="top" action="https://formspree.io/f/xrejpnvn" heading="Still Have Questions? Get Our Answers, Plus Clutch Alerts" sub="Join the list for straight answers on owning a Grey and early word on every new Congo or Timneh chick." cta="Join the list" />

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "25", label: "Questions Answered" },
      { num: "24h", label: "Reply Guarantee" },
      { num: "40–60", label: "Yrs Lifespan" },
      { num: "App. I", label: "CITES Status" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The short answers"
      heading="What Should an African Grey Buyer Know First?"
      badge="6 facts · 30-sec read"
      items={[
        { stat: "$1,500+",  label: "Honest Floor Price",   body: "Timnehs from $1,500, Congos from $1,700 ($2,300–$2,500 as babies) — anything dramatically cheaper is a scam signal, not a deal." },
        { stat: "Appx I",   label: "CITES Status",          body: "African Greys are CITES Appendix I (since Jan 2017); only documented captive-bred birds are legal to own and transfer in the USA." },
        { stat: "4 Docs",   label: "Per Bird",              body: "CITES captive-bred certificate, hatch certificate + closed band, PCR DNA sexing certificate, board-certified avian-vet health certificate." },
        { stat: "100–1,000", label: "Words in Context",     body: "A socialized Grey learns hundreds of words and uses them meaningfully — the best talker of any companion parrot." },
        { stat: "40–60 yr", label: "Lifespan",              body: "A Grey can live up to 60 years in human care — plan for the whole life, including who cares for the bird after you." },
        { stat: "$185/$350", label: "Nationwide Shipping",  body: "IATA-compliant on Delta, United or American — $185 to your nearest airport or $350 to your door, weather-checked first." },
      ]}
    />

    <!-- 4. TOC (jump links, grouped) -->
    <nav class="toc-faq py-10 px-4 bg-cream md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this FAQ</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">6 topics · 25 questions · jump anywhere</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            {tocParts.map((part) => (
              <div>
                <div class="mb-2.5 flex items-baseline gap-2.5">
                  <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">{part.label}</span>
                  <span class="h-px flex-1 bg-black/[0.08]"></span>
                </div>
                <p class="font-lora mb-3 text-lg font-semibold italic text-green">{part.sub}</p>
                <ol class="space-y-0">
                  {part.rows.map((it) => (
                    <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                  ))}
                </ol>
              </div>
            ))}
          </div>
        </div>
      </div>
    </nav>

