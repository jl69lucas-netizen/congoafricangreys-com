  .cag-faq-panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .2s ease; }
  .cag-faq-item.open .cag-faq-panel { grid-template-rows: 1fr; }
  .cag-faq-panel-inner { overflow: hidden; }

  /* Section seam — centered wordmark divider (verbatim scope). */
  .faq-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
