      { num: "3–4h", label: "Direct Interaction" },
      { num: "10–12h", label: "Dark Sleep Nightly" },
      { num: "60–80%", label: "Pellet Base" },
      { num: "40–60", label: "Yrs Lifespan" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
