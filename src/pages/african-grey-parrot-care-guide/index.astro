---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import TocV3 from '../../components/cag-library/TocV3.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Parrot Care Guide | What Do African Greys Eat, How Big a Cage & How Long Do They Live? | Diet, Housing, Health & CITES Care for Congo & Timneh Greys | C.A.Gs – Midland, TX";
const description = "Our complete African Grey parrot care guide from USDA-licensed breeders: how to feed (60–80% pellets), house (bar spacing ¾–1in), enrich (3–4 hrs/day), groom, light (UV-B + vitamin D3), and protect a captive-bred Congo or Timneh Grey through a 40–60 year life | CITES Appendix I docs explained.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-care-guide/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Care Guide", url: "/african-grey-parrot-care-guide/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + scam/adoption pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'diet',            label: 'Diet',            part: 1 },
  { id: 'housing',         label: 'Housing',         part: 1 },
  { id: 'enrichment',      label: 'Enrichment',      part: 1 },
  { id: 'grooming',        label: 'Grooming',        part: 1 },
  { id: 'lighting',        label: 'UV-B Light',      part: 2 },
  { id: 'health',          label: 'Health',          part: 2 },
  { id: 'vet',             label: 'Avian Vet',       part: 2 },
  { id: 'congo-vs-timneh', label: 'Congo v Timneh',  part: 3 },
  { id: 'available-birds', label: 'Available',       part: 3 },
  { id: 'faq',             label: 'FAQ',             part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',      part: 3 },
];
const jumpPartNames = {
  1: 'Daily Care',
  2: 'Health & Light',
  3: 'Choose & Reserve',
};

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + price-matrix.json ───
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Energetic, curious, and impossible to ignore.',
    notes: "Hand-raised male, 4 months old. Thrives in a lively home where there's always something to watch." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'She mimics your laugh before you finish it.',
    notes: 'Premium hand-raised female, 3 months old. Full social training. Responds to her name already.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, easy, and the bird first-time owners dream of.',
    notes: 'Soft temperament, easy to handle. 1-year-old female — personality fully developed, ready to bond.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird. Bigger personality than you expected.',
    notes: 'Hand-raised male Timneh African Grey, 5 months old. Full social training. Ready to go home.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, and ready to come home.',
    notes: 'Hand-raised female Timneh African Grey, 6 months old. Full social training. Gentle and sociable.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two birds, one bond. They go together — and so do you.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised with full social training.' },
];

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
const faqs = [
  { q: "What do African Grey parrots eat?",
    a: "A healthy African Grey eats a base of 60–80% formulated pellets (Harrison's or Zupreem Natural), plus fresh vegetables — dark leafy greens, bell peppers, and orange veg like sweet potato and carrot for vitamin A — and only limited fruit. Never feed avocado, onion, garlic, chocolate, caffeine, alcohol, or fruit pits, all of which are toxic. We send every C.A.Gs bird home on the exact diet it is already eating to prevent digestive stress." },
  { q: "How big does an African Grey parrot cage need to be?",
    a: "The minimum cage for a single Congo African Grey is 36\" W × 24\" D × 48\" H with ¾\"–1\" bar spacing — narrower traps toes, wider traps the head. A Timneh can use a slightly smaller cage. Use stainless steel, never zinc-coated or painted bars, and bigger is always better for a bird that forages up to 12 hours a day." },
  { q: "How much attention does an African Grey need daily?",
    a: "An African Grey needs 3–4 hours of direct interaction and supervised out-of-cage time every day. They are intensely social, and chronic loneliness or boredom is the leading cause of feather-destructive behavior. A second bird does not replace human time — both birds still need individual attention." },
  { q: "Do African Greys need a UV-B light?",
    a: "Yes — we strongly recommend it. African Greys are prone to hypocalcemia (low blood calcium), and they need vitamin D3 to absorb the calcium they eat. A full-spectrum UV-B bird lamp on a 10–12 hour cycle, mounted within 12–18 inches of a perch and replaced every 6–12 months, lets a Grey synthesise D3 indoors. We raise our Greys with UV-B lighting and D3 support so this routine is already familiar." },
  { q: "How often should I bathe my African Grey?",
    a: "Offer a bath two to three times a week — a shallow dish, a gentle mist with plain lukewarm water, or a perch in the shower. African Greys produce powder down (fine white feather dust), and regular bathing keeps that dander down, supports healthy feathers, and discourages over-preening. Skip soaps and additives; plain water is all a Grey needs." },
  { q: "Are African Grey parrots good for beginners?",
    a: "African Greys are not the easiest first parrot — they are sensitive to change, can develop phobias, and have complex emotional needs. A prepared first-time owner can absolutely succeed, but of the two species the calmer, earlier-talking Timneh African Grey is a gentler starting point than the more reactive Congo." },
  { q: "How long do African Grey parrots live?",
    a: "Properly cared-for African Grey parrots commonly live 40 to 60 years, and some documented birds reach 70+. This is a genuine multi-decade, lifetime commitment — many owners name a guardian for their Grey in their estate documents. We talk every buyer through that reality before placement." },
  { q: "Why is my African Grey plucking its feathers?",
    a: "Feather plucking in African Greys is most often behavioral — boredom, loneliness, stress, or a disrupted routine — but it can also be medical, including low calcium, vitamin-A deficiency, skin infection, or disease such as PBFD. Because Greys hide illness, any new plucking warrants an avian-vet workup first, then a review of enrichment, sleep, diet, and out-of-cage time." },
  { q: "Do I need an avian vet for an African Grey?",
    a: "Yes. African Greys are prey animals that mask illness until it is advanced, so an annual wellness exam with an avian-certified veterinarian — CBC, gram stain, and weight check — is essential, not optional. Every C.A.Gs Grey also leaves with a board-certified avian-vet health certificate dated within 10 days of travel." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Care Guide — Diet, Housing, Health & CITES",
  description: "A complete African Grey parrot care guide from USDA-licensed breeders C.A.Gs: diet, cage requirements, enrichment, grooming, UV-B lighting, common health issues, veterinary care, and CITES Appendix I documentation for captive-bred Congo and Timneh Greys.",
  image: "https://congoafricangreys.com/african-grey-parrot-free-exploration.webp",
  inLanguage: "en-US",
  datePublished: "2024-09-01",
  dateModified: "2026-06-06",
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
