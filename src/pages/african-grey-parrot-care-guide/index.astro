<style is:global>
  /* ============================================================
     CARE-GUIDE PAGE — Direction-D-aware interior wrapper (.care-d)
     Mirrors the homepage .home-d seam + lead-spacing scope so the
     global theme applies and the seam-logo divider renders correctly.
     The global body.theme-d already supplies Newsreader/IBM Plex,
     lead paragraphs, eyebrow ticks, card + button motion — NOT re-done.
     ============================================================ */
  .care-d { --rule: rgba(45,106,79,.16); }

  /* AA: clay as small readable text on this page's LIGHT sections → #b04228 (4.5:1).
     Mirrors the homepage .home-d rule. Clay on the green hero stays bright. */
  .care-d a.text-clay, .care-d .text-clay { color:#b04228; }
  /* Hero clay accent stays bright on the green hero; clay FILLS keep white text
     (global .bg-clay renders --clay-ink #bd4129, 5.3:1 — the old shared rule leaked
     dark stone via color:inherit onto every clay button/tag = ~2.5:1 FAIL). */
  .care-d .hero-v3-b .text-clay { color:inherit; }
  .care-d .bg-clay { color:#fff; }

  /* CompareTableE ships text-3xl (30px) on its H2 — ties mobile H1. Cap on small
     screens, desktop unchanged at 30px. */
  .care-d h2.text-3xl { font-size:clamp(1.375rem, 3.8vw, 1.875rem); }

  /* Jump targets clear the 96px sticky header; respect reduced motion. */
  .care-d section[id], .care-d div[id] { scroll-margin-top:110px; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior:auto; } }

  /* "↓ Continue:" section next-nav (JS-injected; this block is is:global so the
     page-class scope reaches the injected DOM). */
  .care-d .section-next-nav { text-align:right; padding-top:18px; margin-top:14px; border-top:1px solid #ede5dc; }
  .care-d .section-next-link { font-family:'IBM Plex Sans',sans-serif; font-size:.85rem; font-weight:600;
    color:#b04228; text-decoration:none; display:inline-block; padding:10px 0 10px 12px; margin:-10px 0; }
  .care-d .section-next-link:hover { text-decoration:underline; }

  /* External links open in a new tab — subtle outward arrow affordance. */
  .care-d p a[target="_blank"]::after { content:"\2197"; font-size:.7em; line-height:0; vertical-align:super; opacity:.5; margin-left:.12em; }

  /* Woven in-content links: clay, underlined, AA-safe — applies to all the
     mid-sentence internal/external links in body copy. */
  .care-d p a:not(.rounded-full):not(.bg-clay),
  .care-d li a:not(.rounded-full):not(.bg-clay) {
    color:#b04228; font-weight:500; text-decoration:underline;
