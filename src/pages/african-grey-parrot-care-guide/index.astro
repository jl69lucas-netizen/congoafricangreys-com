---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrot Care Guide | Food, Housing & Health | CongoAfricanGreys.com";
const description = "Complete African Grey parrot care guide: diet, cage size, enrichment, health, lifespan and CITES documentation. Written by USDA-licensed breeders with 10+ years experience.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-care-guide/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Care Guide", url: "/african-grey-parrot-care-guide/" },
];

const faqs = [
  {
    q: "What do African Grey parrots eat?",
    a: "African Greys thrive on 70% high-quality pellets (Harrison's or Zupreem Natural), 20% fresh vegetables (leafy greens, bell peppers, carrots), and 10% fruit. Avoid avocado, onion, chocolate, and caffeine — all are toxic. Seed-only diets cause vitamin A deficiency and early death.",
  },
  {
    q: "How big does an African Grey parrot cage need to be?",
    a: "Minimum cage size is 36\" W × 24\" D × 48\" H for a single bird. Bar spacing must be ¾\" to 1\" to prevent head entrapment. Stainless steel cages are safest — avoid zinc-coated or lead-painted bars. Bigger is always better for a species that spends 12 hours a day active.",
  },
  {
    q: "How much attention does an African Grey need daily?",
    a: "African Greys require 3–4 hours of direct interaction and supervised out-of-cage time daily. They are highly social and develop feather-destructive behaviors from chronic loneliness. A second bird does NOT replace human interaction — both birds still need individual time.",
  },
  {
    q: "Are African Grey parrots good for beginners?",
    a: "African Greys are not ideal as a first parrot. They are sensitive to change, can develop phobias, and have complex emotional needs. First-time owners who research thoroughly and commit to 40–60 years of care can succeed — but a Timneh African Grey's calmer temperament makes it a better starting point than a Congo.",
  },
  {
    q: "How long do African Grey parrots live?",
    a: "Properly cared-for African Grey parrots commonly live 40 to 60 years. Some documented individuals reach 70+. This is a multi-decade, lifetime commitment. Plan for guardianship arrangements in your estate documents.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="care-hero">
    <div class="page-container">
      <h1 class="care-h1">African Grey Parrot Care Guide</h1>
      <p class="care-sub">
        Everything you need to know about feeding, housing, enrichment, and veterinary care
        for a captive-bred African Grey — written by USDA-licensed breeders with over a decade
        of hands-on experience.
      </p>
      <a class="btn-primary" href="/african-grey-parrot-for-sale/">See Available Birds</a>
    </div>
  </section>

  <!-- DIET -->
  <section class="care-section">
    <div class="page-container text-wrap">
      <h2 class="care-h2">Diet and Nutrition</h2>
      <p>
        African Grey parrots thrive on a diet built around <strong>70% high-quality pellets</strong>,
        <strong>20% fresh vegetables</strong>, and <strong>10% fruit</strong>. Harrison's Adult
        Lifetime Fine and Zupreem Natural are the two gold-standard pellet brands recommended by
        avian veterinarians. Pellets provide a nutritionally complete base that seed-heavy diets
        simply cannot match.
      </p>
      <p>
        The vegetable portion should emphasize dark leafy greens (kale, Swiss chard, collard greens),
        orange-pigmented vegetables (sweet potato, carrots, butternut squash), and bell peppers.
        These foods are rich in beta-carotene, which African Greys convert to vitamin A — the
        nutrient most commonly deficient in improperly fed birds. Vitamin A deficiency causes
        chronic upper respiratory infections, blunted choanal papillae, and significantly shortened
        lifespan.
      </p>
      <p>
        The following foods are <strong>toxic and must never be fed</strong>: avocado (all parts
        including skin, flesh, and pit), onion, garlic, chocolate, caffeine, alcohol, xylitol, and
        all fruit pits (cherry, apple, peach, and plum pits contain cyanogenic compounds). PTFE
        fumes from overheated non-stick cookware are airborne and can kill a bird within minutes —
        never cook with Teflon-coated pans near your parrot.
      </p>
    </div>
  </section>

  <!-- HOUSING -->
  <section class="care-section care-alt">
    <div class="page-container text-wrap">
      <h2 class="care-h2">Housing and Cage Requirements</h2>
      <p>
        The minimum cage size for a single Congo African Grey is <strong>36" W × 24" D × 48" H</strong>
        with bar spacing of ¾" to 1". Smaller bar spacing risks toe entrapment; wider spacing risks
        head entrapment. A Timneh can be housed in a slightly smaller cage, but larger is always
        preferable for a species that is active and foraging for up to 12 hours daily in the wild.
      </p>
      <p>
        <strong>Stainless steel cages are the safest and most durable option.</strong> Avoid cages
        with zinc-coated bars (common in lower-priced models) and any cage with visible paint,
        which may contain lead. Both zinc and lead cause heavy metal toxicosis — a veterinary
        emergency that can be fatal.
      </p>
      <p>
        Cage placement matters. Position the cage against a wall (never in the center of a room),
        at roughly human eye level, away from windows with direct afternoon sun, and far from the
        kitchen. Kitchen proximity exposes birds to PTFE fumes from non-stick cookware, cooking
        spray aerosolization, and carbon monoxide from gas stoves. The bedroom is acceptable;
        high-traffic family living areas where the bird can observe household activity tend to
        produce more socialized birds.
      </p>
    </div>
  </section>

  <!-- ENRICHMENT -->
  <section class="care-section">
    <div class="page-container text-wrap">
      <h2 class="care-h2">Enrichment and Mental Stimulation</h2>
      <p>
        African Greys have the cognitive ability of a 5-year-old human child. A bird left in a
        bare cage with nothing to do will develop destructive behaviors — feather plucking, screaming,
        and aggression — within months. Mental stimulation is not optional; it is essential healthcare.
      </p>
      <p>
        Provide <strong>5–7 rotating foraging toys</strong> that change on a weekly cycle so the bird
        never habituates to them. Offer at least <strong>three types of perches</strong>: natural
        wood perches of varying diameter (manzanita, java, or eucalyptus), a rope perch for foot
        conditioning, and a flat platform perch for resting. Out-of-cage time of 3–4 hours daily
        in a safe, bird-proofed room is non-negotiable.
      </p>
      <p>
        Speech training typically begins between 12 and 18 months, though some birds attempt words
        sooner. Training sessions of 10–15 minutes, three to four times daily, using positive
        reinforcement (target sticks, preferred food rewards) produce the best results. Never punish
        a bird for failing to perform — fear-based training permanently damages trust.
      </p>
    </div>
  </section>

  <!-- VET CARE -->
  <section class="care-section care-alt">
    <div class="page-container text-wrap">
      <h2 class="care-h2">Veterinary Care</h2>
      <p>
        African Greys are prey animals. They instinctively mask illness until it becomes critical —
        by the time you notice visible symptoms, the bird may already be seriously compromised.
        This makes <strong>proactive annual wellness exams with an avian-certified veterinarian</strong>
        essential, not optional.
      </p>
      <p>
        Annual exams should include a complete blood count (CBC) to detect anemia, infection, or
        organ dysfunction; a gram stain to screen for bacterial or yeast overgrowth; and a weight
        check. Weight loss of even 10–15 grams (2–4% of body weight) can indicate disease in a
        bird that otherwise appears normal. Keep a weekly weight log using a kitchen gram scale.
      </p>
      <p>
        African Greys are uniquely prone to <strong>hypocalcemia</strong> (low blood calcium).
        Symptoms include muscle tremors, seizure-like episodes, and falling off the perch. Provide
        cuttlebone free-choice as a calcium source, feed dark leafy greens regularly, and consider
        a full-spectrum UVB light on a 10–12 hour daily cycle to support vitamin D3 synthesis.
        If you see any neurological signs, treat this as an emergency.
      </p>
    </div>
  </section>

  <!-- CITES -->
  <section class="care-section">
    <div class="page-container text-wrap">
      <h2 class="care-h2">CITES Documentation</h2>
      <p>
        Every African Grey parrot — Congo and Timneh — is listed under
        <strong>CITES Appendix I</strong>, which regulates international trade to protect wild
        populations. This does not prevent ownership of captive-bred birds within the United States,
        but it does mean that proper documentation is both legally required and ethically important.
      </p>
      <p>
        When purchasing any African Grey, demand the following documentation from your breeder:
      </p>
      <ul class="care-list">
        <li>CITES captive-bred letter from the breeder's licensed facility</li>
        <li>Closed leg band with the hatch year stamped into the band</li>
        <li>DNA sexing certificate from an accredited avian genetics lab</li>
        <li>Hatch certificate matching the band number</li>
        <li>Avian veterinary health certificate issued within 10 days of shipping</li>
      </ul>
      <p>
        Any seller who cannot provide these documents is either selling a wild-caught bird or
        operating outside legal requirements. Wild-caught African Greys have a very high
        post-import mortality rate and should never be purchased. See our detailed guide at
        <a href="/cites-african-grey-documentation/" class="care-link">/cites-african-grey-documentation/</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="care-section care-alt">
    <div class="page-container text-wrap">
      <h2 class="care-h2">African Grey Care: Frequently Asked Questions</h2>
      <div class="care-faq">
        {faqs.map((f) => (
          <details class="care-faq-item">
            <summary class="care-faq-q">{f.q}</summary>
            <p class="care-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div style="text-align:center;padding:8px 0 32px;font-family:Sora,sans-serif;font-size:0.88rem;color:#6b6560;">
    This guide is part of the <a href="/african-grey-care/" style="color:#2D6A4F;font-weight:600;text-decoration:none;">African Grey Care Hub</a> →
  </div>

  <CTA
    headline="Ready to Bring Home a Captive-Bred African Grey?"
    sub="Every bird from CongoAfricanGreys.com is fully weaned, hand-raised, CITES-documented, DNA sexed, and vet-certified. Reach out to start the conversation."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap {
    max-width: 760px;
  }
  .care-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .care-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .care-hero {
    background: #2D6A4F;
    color: #faf7f4;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .care-hero .care-h1 {
    color: #faf7f4;
  }
  .care-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto 1.75rem;
  }
  .btn-primary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.9rem;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    background: #e8604c;
    color: #fff;
    transition: background 0.2s ease;
  }
  .btn-primary:hover {
    background: #d44e3b;
  }
  .care-section {
    padding: 3rem 0;
  }
  .care-alt {
    background: #faf7f4;
  }
  .care-section p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.2rem;
  }
  .care-list {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    padding-left: 1.5rem;
    margin: 0.5rem 0 1.2rem;
  }
  .care-list li {
    margin-bottom: 0.4rem;
    max-width: 70ch;
  }
  .care-link {
    color: #e8604c;
    text-decoration: underline;
  }
  .care-link:hover {
    color: #d44e3b;
  }
  .care-faq {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .care-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .care-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .care-faq-q::-webkit-details-marker { display: none; }
  .care-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) {
    .page-container { padding: 0 16px; }
  }
  @media (min-width: 768px) and (max-width: 1024px) {
    .page-container { padding: 0 32px; }
  }
</style>
