    <!-- 4. TOC -->
    <nav class="toc-care py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this guide</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">10 sections · everything to keep a Grey healthy</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Daily care</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "What Do African Greys Eat — Diet & Nutrition?", href: "#diet" },
                  { n: 2, t: "How Big a Cage Does an African Grey Need?", href: "#housing" },
                  { n: 3, t: "How Much Enrichment & Out-of-Cage Time?", href: "#enrichment" },
                  { n: 4, t: "How Do You Groom & Bathe an African Grey?", href: "#grooming" },
                  { n: 5, t: "Does an African Grey Need a UV-B Light?", href: "#lighting" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Health, species & buying</p>
              <ol class="space-y-0">
                {[
                  { n: 6, t: "What Health Problems Are African Greys Prone To?", href: "#health" },
                  { n: 7, t: "How Often Does an African Grey See a Vet?", href: "#vet" },
                  { n: 8, t: "Do Congo & Timneh Greys Need Different Care?", href: "#congo-vs-timneh" },
                  { n: 9, t: "Which Hand-Raised C.A.Gs Greys Are Available?", href: "#available-birds" },
                  { n: 10, t: "African Grey Care Questions, Answered", href: "#faq" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
