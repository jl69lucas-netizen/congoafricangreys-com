    transition:text-decoration-color .2s ease;
  }
  .care-d p a:not(.rounded-full):not(.bg-clay):hover,
  .care-d li a:not(.rounded-full):not(.bg-clay):hover { text-decoration-color:#b04228; }

  /* Section seam — centered wordmark divider (verbatim scope from index.astro) */
  .care-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
  .care-d .cag-seam img{ height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
  @media (max-width:600px){ .care-d > .cag-seam{ gap:16px; } .care-d .cag-seam img{ height:24px; } }
</style>
