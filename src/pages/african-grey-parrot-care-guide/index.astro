      if (!qs.length) return;
      qs.forEach(btn => btn.addEventListener('click', () => {
        const item = btn.closest('.cag-faq-item');
        const open = item.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['diet','housing','enrichment','grooming','lighting','health','vet','congo-vs-timneh','available-birds','faq','contact'];
      var labels = {
        'housing':         'Housing & Cage Setup',
        'enrichment':      'Enrichment & Out-of-Cage Time',
        'grooming':        'Grooming & Bathing',
        'lighting':        'UV-B Light & Vitamin D3',
        'health':          'Common Health Problems',
        'vet':             'Avian Vet Care',
        'congo-vs-timneh': 'Congo vs Timneh Care',
        'available-birds': 'Available Greys',
        'faq':             'Care FAQ',
        'contact':         'Ask C.A.Gs',
      };
      for (var i = 0; i < ids.length - 1; i++) {
        var cur = document.getElementById(ids[i]);
        if (!cur) continue;
        var nav = document.createElement('div');
        nav.className = 'section-next-nav';
        nav.innerHTML = '<a href="#' + ids[i + 1] + '" class="section-next-link">&#8595; Continue: ' + (labels[ids[i + 1]] || ids[i + 1]) + '</a>';
        cur.appendChild(nav);
      }
    })();
  </script>
