---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "African Grey Parrot Shipping — Safe IATA Delivery Nationwide";
const description = "We ship hand-raised African Grey parrots nationwide via IATA-approved carriers. CITES documents included. Vet-checked before shipping. Learn how it works.";
const canonical = "https://congoafricangreys.com/buy-african-grey-parrots-with-shipping/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-green text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-3">Ships To All 50 States</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Buy African Grey Parrots With Shipping</h1>
      <p class="text-white/80 text-lg">IATA-compliant airline transport from Midland, TX. Same-day &amp; next-day shipping available. Health certificate included on every bird.</p>
    </div>
  </section>

  <TrustBar />

  <!-- Where We Ship -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6 text-center">Where We Ship</h2>
      <p class="text-stone-600 text-center mb-8 max-w-2xl mx-auto">We offer nationwide shipping, covering local and major airports across the U.S. Whether you're in Texas, Florida, or California, our expert team ensures your parrot arrives safely and stress-free.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          'Wausau, WI — Fast shipping available',
          'Oak Ridge, TN — Talking parrots',
          'Princeton, NJ — Delivered safely',
          'Asheville, NC — Congo African Greys',
          'Harrison, AR — Certified breeders',
          'MI, MD, FL — Fertile eggs available',
        ].map(loc => (
          <div class="flex items-start gap-3 p-4 border border-stone-100 rounded-xl bg-white">
            <span class="text-green text-lg mt-0.5">📍</span>
            <p class="text-stone-600 text-sm">{loc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How Airline Shipping Works -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-10 text-center">✈ How Airline Shipping Works</h2>
      <div class="space-y-8">
        {[
          { step: '1', title: 'Flight Booking & Scheduling', body: 'Once your order is confirmed, we book the next available flight. We prioritize direct and non-stop flights to minimize stress and prevent unnecessary delays.' },
          { step: '2', title: 'Pre-Flight Health Check & Documentation', body: 'Every parrot undergoes a comprehensive health check before flying. We provide all required airline-approved health certificates, ensuring compliance with aviation safety standards.' },
          { step: '3', title: 'Temperature-Controlled Travel Crates', body: 'Your African Grey travels in a well-ventilated, airline-approved pet carrier with soft bedding, fresh food, and water dispensers.' },
          { step: '4', title: 'Live Tracking & Updates', body: 'Once your bird is in transit, we provide real-time flight tracking and arrival updates so you can plan for smooth airport pickup.' },
        ].map(item => (
          <div class="flex gap-5 items-start">
            <div class="w-10 h-10 rounded-full bg-green text-white font-bold font-lora flex items-center justify-center shrink-0 text-lg">{item.step}</div>
            <div>
              <h3 class="font-lora font-semibold text-logo-dark text-lg mb-1">{item.title}</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Delivery Options -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8 text-center">Delivery Options</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-gold/30 rounded-2xl p-8 bg-white shadow-sm">
          <div class="text-3xl mb-3">✈️</div>
          <h3 class="font-lora font-bold text-xl text-logo-dark mb-3">Airline Shipping</h3>
          <p class="text-stone-600 text-sm leading-relaxed mb-4">Your parrot flies in a climate-controlled cabin, supervised by experienced pet nannies or licensed animal chaperones. We partner with United, American, Delta, and Alaska Airlines.</p>
          <ul class="text-sm text-stone-600 space-y-2">
            <li>✅ Same-Day &amp; Next-Day Shipping</li>
            <li>✅ Pick up at your nearest major airport</li>
            <li>✅ Arrives within 3–8 hours of departure</li>
          </ul>
        </div>
        <div class="border border-gold/30 rounded-2xl p-8 bg-white shadow-sm">
          <div class="text-3xl mb-3">🚛</div>
          <h3 class="font-lora font-bold text-xl text-logo-dark mb-3">Home Delivery</h3>
          <p class="text-stone-600 text-sm leading-relaxed mb-4">For select locations, we offer door-to-door transport with a licensed animal chaperone. Fully managed — we handle all logistics and paperwork.</p>
          <ul class="text-sm text-stone-600 space-y-2">
            <li>✅ Door-to-door convenience</li>
            <li>✅ Licensed chaperone accompanies your bird</li>
            <li>✅ Available for select U.S. locations</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8 text-center">Shipping FAQs</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does shipping cost?', a: 'Nationwide airline shipping costs $185. This covers the flight booking, IATA-approved carrier crate, health certificate, and all documentation.' },
          { q: 'Do you ship to all 50 states?', a: 'Yes. We ship IATA-compliant to all 50 states. Birds are transported to your nearest major airport and you pick them up at the cargo or pet desk.' },
          { q: 'What airlines do you use?', a: 'We work with United Airlines, American Airlines, Delta, and Alaska Airlines — choosing the fastest, most direct route available for your location.' },
          { q: 'Is my bird safe during the flight?', a: 'Yes. Every bird travels in a temperature-controlled cabin in an airline-approved crate. We schedule direct flights when possible and provide real-time tracking updates.' },
          { q: 'What documentation comes with the bird?', a: 'Every bird ships with an avian vet health certificate (dated within 10 days of shipment), CITES captive-bred documentation, hatch certificate, band number, and DNA sexing certificate.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Schema type="local-business" />
  <CTA headline="Ready to Ship Your African Grey Home?" sub="Book your bird today — we handle all shipping logistics, documentation, and real-time tracking so your parrot arrives safe." />
</BaseLayout>
