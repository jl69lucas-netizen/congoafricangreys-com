---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "African Grey Parrot Comparison Hub | All Side-by-Side Comparisons";
const description = "Compare African Grey parrots to other species and variants. Congo vs Timneh, male vs female, African Grey vs macaw, cockatoo, and Amazon parrot — all side-by-side.";
const canonical = "https://congoafricangreys.com/african-grey-comparison/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Compare", url: "/african-grey-comparison/" },
];

// Featured comparison — pulled out of the grid for hierarchy.
const featured = {
  href: "/congo-vs-timneh-african-grey/",
  glance: [
    ["~400–550 g", "size", "~275–375 g"],
    ["Silver grey", "color", "Charcoal"],
    ["Black beak", "beak", "Horn upper"],
    ["$1,500+", "price", "$1,200+"],
  ],
};

// Remaining comparisons, grouped for editorial structure.
const speciesComparisons = [
  { title: "African Grey vs Macaw", href: "/african-grey-vs-macaw/", badge: "Species Comparison",
    desc: "Intelligence vs. spectacle. Quiet apartment bird vs. bold statement bird. Full comparison of talking, noise, price, and care demands." },
  { title: "African Grey vs Cockatoo", href: "/african-grey-vs-cockatoo/", badge: "Species Comparison",
    desc: "Talking ability vs. physical affection. Moderate dander vs. allergy-triggering powder. Which parrot fits your home?" },
  { title: "African Grey vs Amazon Parrot", href: "/african-grey-vs-amazon-parrot/", badge: "Species Comparison",
    desc: "Two of the best-talking parrots compared. African Grey precision vs. Amazon charisma, plus hormonal aggression differences." },
  { title: "African Grey vs Eclectus", href: "/blog/african-grey-vs-eclectus/", badge: "Species Comparison",
    desc: "Two smart, calm companions compared: talking ability, the Eclectus' specialised diet, dramatic sexing differences, and which fits your home." },
];

const greyComparisons = [
  { title: "Male vs Female African Grey", href: "/male-vs-female-african-grey-parrots-for-sale/", badge: "Buyer Question",
    desc: "Does sex affect talking ability, bonding, or hormonal behavior in African Greys? The honest answer with real data.", cta: "Compare now →" },
  { title: "African Grey Pros & Cons", href: "/african-grey-pros-and-cons/", badge: "Self-Assessment",
    desc: "An honest look at what makes African Greys exceptional, and what makes them the wrong bird for many households.", cta: "Read the honest list →" },
];

// Comparison-intent FAQ — PAA-sourced, CITES-compliant.
const faqItems = [
  { q: "Which African Grey is the better talker, Congo or Timneh?",
    a: "Both subspecies are among the best talking parrots in the world. Congos often build the largest vocabularies and are the \"classic\" talking Grey, while Timnehs tend to start talking younger and speak just as clearly. Talking ability comes down far more to the individual bird and daily interaction than to subspecies." },
  { q: "Is an African Grey better than a macaw for a first-time owner?",
    a: "For most first-time owners in a home or apartment, an African Grey is the easier fit: it is quieter than a large macaw, less destructive, and thrives on mental engagement rather than sheer space. Macaws are louder, larger, and more demanding of room. Our African Grey vs Macaw comparison breaks down noise, cost, and care side by side." },
  { q: "Does a male or female African Grey talk more?",
    a: "No. Talking ability in African Greys is not tied to sex. Both males and females learn to talk equally well, which is why we DNA-sex every bird for certainty rather than for talking potential. The male vs female page covers the real, evidence-based differences." },
  { q: "Are African Greys louder than cockatoos or amazons?",
    a: "Generally no. African Greys are among the quieter large parrots, which is part of why they suit apartments. Cockatoos can be extremely loud and produce allergy-triggering dander, and many Amazons are louder and more hormonally vocal. Each species comparison page details noise levels honestly." },
  { q: "Which parrot is best for an apartment?",
    a: "Among the species compared here, the African Grey is usually the most apartment-friendly: moderate volume, manageable size, and a strong need for the mental stimulation that engaged owners enjoy providing. The vs Macaw and vs Cockatoo pages show why." },
  { q: "How should I choose between an African Grey and another parrot?",
    a: "Start with the three things that break most placements: noise tolerance, daily time, and lifespan commitment. Read the relevant species comparison, then our honest pros and cons page. If the African Grey still fits, we can talk through Congo vs Timneh and which available bird suits your household." },
];

// BreadcrumbList JSON-LD is emitted by <Breadcrumb> itself — no duplicate here.
// Semantic SEO: model this hub as a CollectionPage whose mainEntity is an
// ItemList enumerating every comparison page it links to.
const allComparisons = [
  { name: "Congo vs Timneh African Grey", url: "https://congoafricangreys.com/congo-vs-timneh-african-grey/" },
  ...speciesComparisons.map(c => ({ name: c.title, url: `https://congoafricangreys.com${c.href}` })),
  ...greyComparisons.map(c => ({ name: c.title, url: `https://congoafricangreys.com${c.href}` })),
];
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "African Grey Parrot Comparison Hub",
  "description": description,
  "url": canonical,
  "isPartOf": { "@type": "WebSite", "name": "C.A.Gs – Midland, TX", "url": "https://congoafricangreys.com/" },
  "about": { "@type": "Product", "name": "Captive-bred Congo & Timneh African Grey parrots" },
  "mainEntity": {
    "@type": "ItemList",
    "name": "African Grey Parrot Comparisons",
    "numberOfItems": allComparisons.length,
    "itemListElement": allComparisons.map((c, i) => ({
      "@type": "ListItem", "position": i + 1, "name": c.name, "url": c.url,
    })),
  },
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <div class="mx-auto max-w-[1200px]">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Hero -->
  <section class="bg-green text-cream py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-clay-lt font-sora text-xs font-semibold uppercase tracking-widest mb-4">African Grey Comparison Center</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl text-white mb-4">Which Parrot Is Right for You?</h1>
      <p class="text-cream/85 text-lg max-w-2xl mx-auto leading-relaxed">Side-by-side comparisons that answer the real questions: talking ability, noise level, affection, cost, and CITES documentation requirements.</p>
    </div>
  </section>

  <TrustBar />

  <!-- Featured comparison -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-[1100px]">
      <div class="max-w-xl mb-9">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Start Here</p>
        <h2 class="font-lora font-bold text-logo-dark mb-2">The Comparison Most Buyers Make First</h2>
        <p class="text-stone-600 text-[15px] leading-relaxed" style="max-width:60ch;">Before you compare an African Grey to anything else, most families are deciding between its two subspecies. Here is the one that matters most.</p>
      </div>
      <div class="grid md:grid-cols-[1.15fr_.85fr] rounded-3xl overflow-hidden border border-line cag-warm-shadow bg-white">
        <div class="p-8 md:p-10">
          <span class="inline-block bg-clay text-white font-sora text-[11px] font-bold uppercase tracking-wide px-3 py-1.5 rounded-full">Most Popular</span>
          <h3 class="font-lora font-bold text-2xl md:text-3xl text-green mt-4 mb-3">Congo vs Timneh African Grey</h3>
          <p class="text-stone-600 text-[15px] leading-relaxed mb-6" style="max-width:46ch;">The two subspecies compared on size, color, temperament, talking ability, and price. Which variant is right for your household?</p>
          <a href={featured.href} class="inline-flex items-center gap-2 bg-clay text-white font-sora font-semibold text-[15px] px-7 py-3.5 rounded-full hover:bg-clay-dk transition-colors">Compare Congo vs Timneh →</a>
        </div>
        <div class="bg-green-lt p-8 md:p-9 border-t md:border-t-0 md:border-l border-line flex flex-col justify-center">
          <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.12em] text-green mb-3.5">At a glance</p>
          <div class="flex justify-between font-lora font-bold text-logo-dark mb-1.5"><span>Congo</span><span>Timneh</span></div>
          {featured.glance.map(([l, m, r]) => (
            <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2.5 py-2.5 border-b border-green/10 last:border-b-0">
              <span class="font-sora font-semibold text-sm text-logo-dark">{l}</span>
              <span class="font-sora text-[10px] uppercase tracking-wide text-stone-400">{m}</span>
              <span class="font-sora font-semibold text-sm text-logo-dark text-right">{r}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Group A: African Grey vs other parrots -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="mx-auto max-w-[1100px]">
      <div class="text-center max-w-xl mx-auto mb-10">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Species Comparisons</p>
        <h2 class="font-lora font-bold text-logo-dark mb-2">African Grey vs Other Parrots</h2>
        <p class="text-stone-600 text-[15px] leading-relaxed">How the Grey stacks up against the other parrots families weigh it against most often.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {speciesComparisons.map((c) => (
          <a href={c.href} class="block bg-white border border-line rounded-2xl p-6 cag-warm-shadow hover:-translate-y-1 hover:border-clay transition-all">
            <span class="inline-block font-sora text-[10.5px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full bg-green/10 text-green">{c.badge}</span>
            <h3 class="font-lora font-bold text-lg text-logo-dark mt-3.5 mb-2">{c.title}</h3>
            <p class="text-stone-600 text-[13.5px] leading-relaxed" style="max-width:70ch;">{c.desc}</p>
            <span class="block mt-4 text-clay font-sora font-semibold text-[13.5px]">Compare now →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Group B: Know your Grey -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-[1100px]">
      <div class="text-center max-w-xl mx-auto mb-10">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Before You Commit</p>
        <h2 class="font-lora font-bold text-logo-dark mb-2">Know Your Grey Before You Buy</h2>
        <p class="text-stone-600 text-[15px] leading-relaxed">Two questions every serious buyer should answer about the African Grey itself.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-5 max-w-3xl mx-auto">
        {greyComparisons.map((c) => (
          <a href={c.href} class="block bg-white border border-line rounded-2xl p-6 cag-warm-shadow hover:-translate-y-1 hover:border-clay transition-all">
            <span class="inline-block font-sora text-[10.5px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full bg-clay/10 text-clay-dk">{c.badge}</span>
            <h3 class="font-lora font-bold text-lg text-logo-dark mt-3.5 mb-2">{c.title}</h3>
            <p class="text-stone-600 text-[13.5px] leading-relaxed" style="max-width:70ch;">{c.desc}</p>
            <span class="block mt-4 text-clay font-sora font-semibold text-[13.5px]">{c.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Depth -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="mx-auto max-w-[680px]">
      <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Why It Matters</p>
      <h2 class="font-lora font-bold text-logo-dark mb-4">Why These Comparisons Matter</h2>
      <p class="text-logo-dark text-lg leading-snug mb-4" style="max-width:65ch;">African Greys are a 40–60 year commitment. Choosing the wrong species, or the wrong variant, leads to rehoming, behavioral problems, and birds that never reach their potential.</p>
      <p class="text-stone-600 leading-relaxed mb-4" style="max-width:65ch;">Every comparison on this hub is written by <strong class="text-logo-dark">Mark &amp; Teri Benjamin</strong>, USDA AWA licensed breeders who have raised <a href="/congo-african-grey-for-sale/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">Congo</a> and <a href="/timneh-african-grey-for-sale/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">Timneh</a> African Greys since 2014. The data reflects real husbandry experience, not aggregated forum posts.</p>
      <p class="text-stone-600 leading-relaxed" style="max-width:65ch;">All birds sold through C.A.Gs ship with <a href="/cites-african-grey-documentation/" class="text-clay font-medium underline decoration-clay/30 hover:decoration-clay">CITES Appendix I documentation</a>, required by U.S. law for captive-bred African Greys.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-16 px-4 scroll-mt-20">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-10">
        <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Common Questions</p>
        <h2 class="font-lora font-bold text-logo-dark">Comparison Questions, Answered</h2>
      </div>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group bg-white rounded-2xl border border-line cag-warm-shadow p-5 open:shadow-md">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-lora font-bold text-[16px] text-logo-dark leading-snug list-none">
              {item.q}
              <span class="text-clay text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="font-sora text-stone-600 text-[14px] leading-relaxed mt-3" style="max-width:68ch;">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Schema type="faq" data={{ mainEntity: faqItems.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) }} />

  <CTA headline="Found the Right Match?" />
</BaseLayout>
