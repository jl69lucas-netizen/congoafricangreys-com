---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "African Grey Parrot Comparison: How the Grey Compares to Every Parrot | Best Talking Parrot & Which Grey Fits You | C.A.Gs – Congo & Timneh Grey Breeders";
const description = "The African Grey parrot comparison hub: how the Grey compares to macaws, cockatoos, Amazons and its own Congo and Timneh variants on talking, noise, size and cost, why it ranks the best talking parrot, plus an interactive selector that routes you to the right comparison.";
const canonical = "https://congoafricangreys.com/african-grey-comparison/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
];

// §2 master matrix — fresh one-line cells (never copied spoke rows).
// icon: real emoji asset where we have one; species without a supplied emoji
// render the neutral line-icon fallback until the breeder's files land.
const matrixRows = [
  { species: "Congo African Grey", sub: "The classic red-tail", icon: "/emoji/cag-congo-64.webp", link: "/congo-african-grey-for-sale/", talk: "Exceptional", talkNote: "~1,000 words", talkTier: "top", noise: "Moderate", noiseTier: "mid", size: "400–650 g", beginner: "Intermediate", begTier: "mid", best: "Talking and problem-solving" },
  { species: "Timneh African Grey", sub: "The calmer, earlier talker", icon: "/emoji/cag-timneh-64.webp", link: "/timneh-african-grey-for-sale/", talk: "Exceptional", talkNote: "earlier onset", talkTier: "top", noise: "Low–moderate", noiseTier: "low", size: "275–375 g", beginner: "Intermediate", begTier: "mid", best: "A calmer grey, apartments" },
  { species: "Macaw", sub: "The showstopper", icon: "/emoji/macaw-64.webp", link: "/african-grey-vs-macaw/", talk: "Good", talkNote: "", talkTier: "good", noise: "Very loud", noiseTier: "loud", size: "900 g+", beginner: "Advanced", begTier: "adv", best: "Big, bold, space-rich homes" },
  { species: "Cockatoo", sub: "The velcro cuddler", icon: "/emoji/cockatoo-64.webp", link: "/african-grey-vs-cockatoo/", talk: "Fair", talkNote: "", talkTier: "fair", noise: "Extremely loud", noiseTier: "loud", size: "Medium–large", beginner: "Advanced", begTier: "adv", best: "Cuddle-seekers who accept demand" },
  { species: "Amazon Parrot", sub: "The stage performer", icon: "/emoji/amazon-64.webp", link: "/african-grey-vs-amazon-parrot/", talk: "Good", talkNote: "loves to sing", talkTier: "good", noise: "Loud, seasonal", noiseTier: "loud", size: "Medium", beginner: "Intermediate", begTier: "mid", best: "Outgoing, musical households" },
];

// §3 best-talker ranked list (cited synthesis, not spoke prose)
const talkerRank = [
  { rank: "01", bird: "African Grey", icon: "/emoji/cag-congo-64.webp", badge: "The benchmark", note: "Largest working vocabularies and the clearest contextual use — every published ranking's number one" },
  { rank: "02", bird: "Amazon Parrot", icon: "/emoji/amazon-64.webp", badge: "", note: "Strong talker with a musical, sing-song delivery" },
  { rank: "03", bird: "Eclectus", icon: "", badge: "", note: "Clear speech, calmer volume, smaller vocabulary" },
  { rank: "04", bird: "Quaker Parakeet", icon: "", badge: "", note: "Chatty and clear for its size, a budget talker" },
  { rank: "05", bird: "Budgie", icon: "", badge: "", note: "Can out-word a Grey in count, but mumbled and hard to parse" },
];

// §10 use-case grid → spokes/blogs
const useCases = [
  { ic: "talk", title: "Best talking parrot", pick: "African Grey", link: "/blog/african-grey-parrot-facts/", why: "No companion parrot matches its clarity and contextual use" },
  { ic: "home", title: "Best for apartments", pick: "Timneh Grey", link: "/congo-vs-timneh-african-grey/", why: "A quieter, smaller grey with the same intelligence" },
  { ic: "family", title: "Best for families", pick: "Amazon or Grey", link: "/african-grey-vs-amazon-parrot/", why: "Outgoing birds that tolerate a busy household, with boundaries" },
  { ic: "seed", title: "Best first bird", pick: "Rarely a grey", link: "/blog/is-african-grey-good-for-beginners/", why: "A grey's sensitivity punishes under-preparation — start smaller" },
];

// §19 ItemList — the 7 spokes
const spokes = [
  { href: "/congo-vs-timneh-african-grey/", img: "/congo-vs-timneh-hub-card.webp", alt: "Congo vs Timneh African Grey side-by-side comparison", title: "Congo vs Timneh African Grey", blurb: "The two Grey subspecies, raised side by side — size, price and talking onset." },
  { href: "/african-grey-vs-macaw/", img: "/african-grey-vs-macaw-hub-card.webp", alt: "African Grey vs macaw talking and size comparison", title: "African Grey vs Macaw", blurb: "The quiet genius against eleven macaw species — talking, size and volume." },
  { href: "/african-grey-vs-cockatoo/", img: "/african-grey-vs-cockatoo-hub-card.webp", alt: "African Grey vs cockatoo temperament and noise comparison", title: "African Grey vs Cockatoo", blurb: "The talker and the cuddler, weighed honestly on need, noise and dander." },
  { href: "/african-grey-vs-amazon-parrot/", img: "/african-grey-vs-amazon-hub-card.webp", alt: "African Grey vs Amazon parrot talking versus singing comparison", title: "African Grey vs Amazon Parrot", blurb: "Talking versus singing, temperament and dust between two clever mimics." },
  { href: "/male-vs-female-african-grey-parrots-for-sale/", img: "/male-vs-female-african-grey-hub-card.webp", alt: "Male vs female African Grey appearance and DNA-sexing comparison", title: "Male vs Female African Grey", blurb: "Why you cannot eye-sex a Grey, and whether sex matters for a pet." },
  { href: "/african-grey-pros-and-cons/", img: "/african-grey-pros-and-cons-hub-card.webp", alt: "African Grey pros and cons owner decision balance", title: "African Grey Pros and Cons", blurb: "The talking and the bond against the 40–60 year commitment and cost." },
  { href: "/african-grey-parrot-breeders-comparison/", img: "/african-grey-breeders-comparison-hub-card.webp", alt: "How to compare African Grey breeders red flags versus green flags", title: "African Grey Breeders Comparison", blurb: "How to compare breeders on documentation, and spot the scam signals." },
];

// §16 owner reviews — verified set (Catherine's quote is not used on the pros/cons spoke)
const stories = [
  { name: "Catherine Kempf", loc: "Schaumburg, IL", meta: "Congo African Grey", avatar: "/catherine-kempf-schaumburg-il-review-112.webp",
    highlight: "the experience was flawless", tail: "Her documented Congo arrived healthy and well-trained, and now bonds with her whole household." },
  { name: "Richard Woodard", loc: "Winter Haven, FL", meta: "Congo African Grey", avatar: "/richard-woodard-winter-haven-fl-review-112.webp",
    highlight: "made the process stress-free", tail: "Unsure about ordering a bird online at first, he now calls his Congo the daily star of the family." },
];

// §17 available birds (link-out, sold retires)
const available = ((clutch as any).birds as any[]).filter((b) => b.status === 'available' && b.sex !== 'pair').sort((a, b) => (a.variant === 'congo_african_grey' ? -1 : 1));
const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a documented female Congo African Grey at the C.A.Gs aviary, resting on her keeper's lap" },
  "amie": { src: "/amie-congo-african-grey-handfed-baby-card.webp", alt: "Amie, a hand-fed female Congo African Grey with full captive-bred paperwork" },
  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey documented from hatch at C.A.Gs" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a documented young male Timneh African Grey stretching his wings" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a documented female Timneh African Grey with her CITES paperwork folder" },
};
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// §18 FAQ — hub-level comparison questions (distinct from spoke FAQs)
const faqs = [
  { q: "Which parrot is the smartest?", a: "The African Grey is widely regarded as the most intelligent companion parrot. The famous studies with a Grey named Alex showed a bird that could label objects, count, and even grasp the idea of zero — cognition on the level of a young child, which is why the Grey heads nearly every smartest-parrot list. Macaws, cockatoos and Amazons are bright, social birds, but none carries the same documented problem-solving record." },
  { q: "Which parrot talks the best?", a: "The African Grey. It combines the largest working vocabularies in aviculture with an unusual knack for using words in the right context, which is why it tops essentially every best-talking-parrot ranking. Amazons talk well and love to sing, and a budgie can technically out-count a Grey in raw words, but for clarity and contextual speech the Grey stands alone." },
  { q: "Is an African Grey better than a macaw, cockatoo or Amazon?", a: "Better is the wrong frame — each bird suits a different home. Choose an African Grey for talking, cognition and a moderate noise level; a macaw for size and boldness if you have the space and volume tolerance; a cockatoo for cuddling if you can meet its intense demand; an Amazon for an outgoing, musical bird that handles a busy household. Our per-species comparisons weigh each head-to-head honestly." },
  { q: "Which African Grey should I get, Congo or Timneh?", a: "Both are the same species of bird with the same intelligence and talking ability. A Congo is larger with the iconic bright red tail; a Timneh is smaller, often a touch calmer, tends to start talking earlier, and its maroon tail and horn-coloured upper beak set it apart. For an apartment or a first grey, many owners lean Timneh; for the classic look, Congo. Our Congo-vs-Timneh guide covers the choice in full." },
  { q: "Is a male or female African Grey a better pet?", a: "Neither. African Greys are monomorphic, meaning males and females look alike and behave alike as pets — personality is individual, not sex-linked. The only reliable way to know a Grey's sex is a DNA test, which is why every bird we place is PCR DNA-sexed. Choose the individual bird whose temperament fits your home, not a sex." },
  { q: "Which parrot is best for a first-time owner?", a: "Rarely an African Grey. A Grey's intelligence and sensitivity make it an intermediate-to-advanced bird that punishes under-preparation. A committed beginner who has genuinely done the research can succeed, but most first-timers do better starting smaller. Our beginner-fit guide covers when a first-time owner can take on a Grey responsibly." },
  { q: "Which parrot is quietest for an apartment?", a: "Among the birds compared here, the African Grey — and the Timneh especially — is the apartment-friendly choice. Greys are prolific talkers rather than screamers, and a Timneh runs quieter still. Macaws and cockatoos are among the loudest parrots kept and are genuinely hard on shared walls; an Amazon lands in between with loud, seasonal outbursts." },
  { q: "Which parrot lives the longest?", a: "All of these are long-lived birds, and the larger species are effectively lifetime commitments. A healthy African Grey commonly reaches 40 to 60 years; large macaws can reach 50 or more, cockatoos 40 to 70, and Amazons 40 to 60. Whichever you choose, plan for a bird that can share most of your adult life and, for some owners, outlive them." },
  { q: "How much does an African Grey cost compared to other parrots?", a: "A documented Congo African Grey runs $1,700–$3,500 and a Timneh $1,500–$1,600 from a licensed U.S. breeder, before $185 airport or $350 home-delivery shipping. Large macaws and Moluccan cockatoos often cost more; smaller Amazons can be less. Across every species, a price that looks impossibly low is the classic signal of a deposit-and-vanish scam, not a bargain." },
  { q: "Are all these parrots captive-bred and legal to own?", a: "The birds we place are. African Greys sit at CITES Appendix I, so a legal sale depends on captive-bred documentation — a closed leg band, hatch record and CITES paperwork that a wild-caught bird can never produce. Wild-caught trade harms threatened wild flocks and is illegal; a documented, captive-bred bird from a USDA-licensed breeder is the ethical and lawful choice." },
];

// further reading (each carries a real thumbnail)
const readCards = [
  { href: "/blog/african-grey-parrot-facts/", img: "/african-grey-parrot-facts-hero-card.webp", alt: "African Grey parrot intelligence facts worth knowing", tag: "Facts", title: "Why the Grey Out-Thinks the Field" },
  { href: "/african-grey-parrot-guide/", img: "/african-grey-parrot-guide-hero-card.webp", alt: "Complete African Grey parrot species guide", tag: "Species", title: "The Complete African Grey Guide" },
  { href: "/african-grey-parrot-price/", img: "/african-grey-price-hero-card.webp", alt: "African Grey parrot price and lifetime cost breakdown", tag: "Cost", title: "The Real Lifetime Cost of a Grey" },
];

const shipAirport = [
  { href: "/african-grey-parrot-for-sale-dallas/", label: "Dallas" },
  { href: "/african-grey-parrot-for-sale-tampa/", label: "Tampa" },
];
const shipHome = [
  { href: "/african-grey-parrot-for-sale-bay-area/", label: "Bay Area" },
  { href: "/african-grey-parrot-for-sale-cleveland/", label: "Cleveland" },
];
const shipCourier = [
  { href: "/african-grey-parrots-for-sale-near-me/", label: "Find your nearest route" },
];

const tocItems = [
  { id: "what-apart", label: "What Sets Greys Apart" },
  { id: "matrix", label: "The Master Matrix" },
  { id: "best-talker", label: "Best Talking Parrot?" },
  { id: "vs-macaw", label: "vs Macaw" },
  { id: "vs-cockatoo", label: "vs Cockatoo" },
  { id: "vs-amazon", label: "vs Amazon" },
  { id: "vs-timneh", label: "Congo vs Timneh" },
  { id: "vs-sex", label: "Male vs Female" },
  { id: "selector", label: "Which Comparison Fits?" },
  { id: "use-case", label: "Best by Use Case" },
  { id: "pros-cons", label: "Pros & Cons" },
  { id: "breeder", label: "Choosing a Breeder" },
  { id: "cost", label: "What It Costs" },
  { id: "commitment", label: "The 40–60 Yr Commitment" },
  { id: "shipping", label: "Documented & Shipped" },
  { id: "story", label: "An Owner's Story" },
  { id: "available", label: "Meet a Documented Grey" },
  { id: "faq", label: "FAQ" },
  { id: "explore", label: "Every Comparison" },
  { id: "reading", label: "Further Reading" },
  { id: "reserve", label: "Reserve a Grey" },
];
const num = (i: number) => String(i + 1).padStart(2, "0");

const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
const itemListSchema = {
  "@context": "https://schema.org", "@type": "ItemList",
  name: "African Grey Parrot Comparisons",
  itemListElement: spokes.map((s, i) => ({ "@type": "ListItem", position: i + 1, url: `https://congoafricangreys.com${s.href}`, name: s.title })),
};
const pageSchema = {
  "@context": "https://schema.org", "@type": "CollectionPage",
  name: "African Grey Parrot Comparison",
  description: description,
  url: canonical, isPartOf: { "@type": "WebSite", url: "https://congoafricangreys.com/" },
  datePublished: "2026-06-03", dateModified: "2026-07-13",
};
const orgSchema = {
  "@context": "https://schema.org", "@type": "Organization",
  name: "C.A.Gs – Congo African Greys", url: "https://congoafricangreys.com/",
  address: { "@type": "PostalAddress", addressLocality: "Midland", addressRegion: "TX", postalCode: "79707", addressCountry: "US" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52", bestRating: "5" },
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta
  heroPreload="/hero-available-african-greys-for-sale-720.webp"
  heroPreloadSrcset="/hero-available-african-greys-for-sale-720.webp 720w, /hero-available-african-greys-for-sale.webp 1376w"
  heroPreloadSizes="(max-width: 900px) 92vw, 560px">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <div class="cvt">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- S1 HERO — hub survey hero -->
  <section class="cvt-hero hero-trust pnc-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><span class="eb-tick" aria-hidden="true"></span>Every parrot rivalry, settled from one Grey-centred verdict</p>
        <h1 class="cag-h1">African Grey Parrot Comparison: How the Grey Stacks Up Against Every Rival</h1>
        <p class="lead">Seven honest head-to-heads in one place — the Grey against macaws, cockatoos, Amazons, and its own Congo and Timneh variants. We raise and place these birds, so this hub ranks them the way a breeder actually weighs them, then points you to the exact comparison you need.</p>
        <p class="hero-cta"><a class="btn-clay" href="#matrix">See the Master Matrix</a> <a class="btn-ghost" href="#selector">Which Comparison Fits Me?</a></p>
        <p class="hero-micro"><span><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>7 comparisons</span><span><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>#1 talking parrot</span><span><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Interactive selector inside</span></p>
      </div>
      <div class="hero-imgs solo">
        <figure class="hero-single">
          <img src="/hero-available-african-greys-for-sale-720.webp"
            srcset="/hero-available-african-greys-for-sale-720.webp 720w, /hero-available-african-greys-for-sale.webp 1376w"
            sizes="(max-width: 900px) 92vw, 560px"
            width="560" height="360" alt="African Grey parrot comparison hub, documented Congo and Timneh Greys raised at C.A.Gs in Midland, TX" fetchpriority="high">
          <figcaption class="chip">Documented · Midland, TX</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- S2 COUNTER — hub-specific premise strip -->
  <section class="cvt-counter"><div class="container counter-row">
    <div class="cs"><b>7</b><span class="cs-l">Comparisons in one hub</span></div>
    <div class="cs"><b>#1</b><span class="cs-l">Talking parrot, cited</span></div>
    <div class="cs"><b>100%</b><span class="cs-l">CITES documented (ours)</span></div>
    <div class="cs"><b>24h</b><span class="cs-l">Reply to inquiries</span></div>
  </div></section>

  <!-- S3 mobile jump rail -->
  <nav class="cvt-rail" aria-label="Jump to section"><div class="container rail-row">
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </div></nav>

  <div class="container cvt-body">
  <aside class="cvt-toc" aria-label="On this page">
    <p class="toc-title"><span class="toc-tick" aria-hidden="true"></span>On this page</p>
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </aside>

  <div class="cvt-main">

  <!-- S4 QUICK ANSWER -->
  <section id="what-apart">
    <h2 class="cag-h2">What Sets African Greys Apart From Other Parrots?</h2>
    <a class="inf" href="/african-grey-parrot-guide/"><img class="sec-img inf-img" src="/african-grey-vs-field-comparison-hero.webp" srcset="/african-grey-vs-field-comparison-hero-760.webp 760w, /african-grey-vs-field-comparison-hero.webp 1376w" sizes="(max-width:900px) 92vw, 760px" width="1376" height="768" alt="African Grey parrot comparison chart placing the Grey at the centre of macaw, cockatoo and Amazon rivals" loading="lazy"></a>
    <div class="qa-cream">
      <p><strong>Quick answer:</strong> What sets the African Grey apart is its mind. It is the most intelligent and clearest-talking companion parrot — child-level problem-solving and the largest working vocabularies in aviculture — at a noise level most homes can live with. It is not the biggest, cuddliest or quietest bird, and it is rarely the easiest first parrot. Every comparison on this page turns on that trade-off: unmatched cognition and talking, in exchange for a demanding, sensitive, decades-long companion.</p>
    </div>
    <h3 class="cag-h3">The One-Line Verdict</h3>
    <p>Across our whole species guide, one line holds: the Grey wins on talking and intelligence, trades away size, cuddliness and beginner-friendliness, and sits in the middle on noise. Hold that against whatever rival you are weighing and most of the decision answers itself.</p>
    <h4 class="cag-h4">How to Use This Comparison Hub</h4>
    <p>Start with the master matrix below for the whole field on one screen, jump to any head-to-head that interests you, or let the interactive selector route you. Every rival section is a short, honest synthesis that links out to the full comparison — the hub is the map, the spokes are the territory.</p>
  </section>

  <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy"></div>

  <!-- S5 MASTER MATRIX -->
  <section id="matrix">
    <h2 class="cag-h2">African Grey vs the Field: The Master Comparison Matrix</h2>
    <a class="inf" href="#matrix"><img class="sec-img inf-img" src="/african-grey-vs-parrots-comparison-matrix.webp" srcset="/african-grey-vs-parrots-comparison-matrix-760.webp 760w, /african-grey-vs-parrots-comparison-matrix.webp 1376w" sizes="(max-width:900px) 92vw, 760px" width="1376" height="768" alt="African Grey vs parrots matrix scoring talking, noise, size and beginner fit across five species" loading="lazy"></a>
    <p>Here is the whole field on one screen. Read down the talking column and the Grey and Timneh lead; read across noise and size and the picture flips. Tap any bird to open its full comparison.</p>
    <div class="tbl-wrap">
      <table class="score-tbl matrix-tbl">
        <thead><tr><th scope="col">Parrot</th><th scope="col">Talking</th><th scope="col">Noise</th><th scope="col">Adult size</th><th scope="col">Owner level</th><th scope="col">Best for</th></tr></thead>
        <tbody>
          {matrixRows.map((r) => (
            <tr>
              <td class="sc-trait" data-label="Parrot">
                <a class="sp-cell" href={r.link}>
                  <span class="sp-ic" aria-hidden="true">
                    {r.icon
                      ? <img src={r.icon} width="26" height="26" alt="" loading="lazy" />
                      : <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h.01"/><path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/><path d="m20 7 2 .5-2 .5"/><path d="M10 18v3"/><path d="M14 17.75V21"/><path d="M7 18a6 6 0 0 0 3.84-10.61"/></svg>}
                  </span>
                  <span class="sp-id"><b>{r.species}</b><small>{r.sub}</small></span>
                </a>
              </td>
              <td data-label="Talking"><span class={`tier t-${r.talkTier}`}>{r.talk}</span>{r.talkNote && <small class="tier-note">{r.talkNote}</small>}</td>
              <td data-label="Noise"><span class={`tier n-${r.noiseTier}`}>{r.noise}</span></td>
              <td class="num" data-label="Adult size">{r.size}</td>
              <td data-label="Owner level"><span class={`tier b-${r.begTier}`}>{r.beginner}</span></td>
              <td class="sc-note" data-label="Best for">{r.best}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <h3 class="cag-h3">Reading the Matrix at a Glance</h3>
    <p>The pattern holds down every column: the Grey and Timneh lead on talking and intelligence, the macaw takes size, the cockatoo takes cuddliness, and the Amazon takes musical flair — so your right pick is whichever trait tops your own list.</p>
    <h4 class="cag-h4">What We Scored, and Why</h4>
    <p>We scored the six traits buyers ask about most — talking, noise, size, owner level, and the best-fit home — because they decide the vast majority of placements. Price and lifespan get their own sections below.</p>
    <h5 class="cag-h5">What the Matrix Does Not Capture</h5>
    <p>A grid cannot score the individual bird in front of you. Two Greys from the same clutch can differ in talkativeness, boldness and cuddliness, so treat the matrix as the starting shape of the decision, not the last word on any single parrot.</p>
    <h6 class="cag-h6">Breeder note: personality varies bird to bird</h6>
    <p>In our nursery the quietest chick in a clutch sometimes grows into the biggest talker. We match temperament to household case by case, which is why we never promise a specific personality from a species row alone.</p>
