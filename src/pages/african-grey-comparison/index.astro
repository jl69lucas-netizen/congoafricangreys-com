  <script is:inline>
    (function () {
      var navLinks = document.querySelectorAll('.cvt-toc a, .rail-row a');
      var sections = [].slice.call(document.querySelectorAll('.cvt-main section[id]'));
      if (navLinks.length && sections.length && 'IntersectionObserver' in window) {
        var current = '';
        var spy = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) current = e.target.id; });
          navLinks.forEach(function (a) { a.classList.toggle('on', a.getAttribute('href') === '#' + current); });
        }, { rootMargin: '-25% 0px -65% 0px' });
        sections.forEach(function (sec) { spy.observe(sec); });
      }
      var btn = document.getElementById('sel-btn');
      if (btn) {
        var routes = {
          cuddle: { href: '/african-grey-vs-cockatoo/', label: 'African Grey vs Cockatoo', why: 'you want a hands-on, cuddly bird — see whether a cockatoo suits you better than a Grey' },
          bold: { href: '/african-grey-vs-macaw/', label: 'African Grey vs Macaw', why: 'you want a big, bold parrot — weigh the macaw against the Grey honestly' },
          sing: { href: '/african-grey-vs-amazon-parrot/', label: 'African Grey vs Amazon Parrot', why: 'you want an outgoing, musical bird — the Amazon may fit better than a Grey' }
        };
        btn.addEventListener('click', function () {
          var want = document.getElementById('sel-want').value;
          var home = document.getElementById('sel-home').value;
          var exp = document.getElementById('sel-exp').value;
          var out = document.getElementById('sel-result');
          var r;
          if (routes[want]) {
            r = routes[want];
          } else if (want === 'quiet') {
            r = { href: '/congo-vs-timneh-african-grey/', label: 'Congo vs Timneh African Grey', why: 'a Timneh is the quieter, apartment-friendlier grey — this guide settles the choice' };
          } else {
            r = (home === 'apartment')
              ? { href: '/congo-vs-timneh-african-grey/', label: 'Congo vs Timneh African Grey', why: 'you want the best talker but live in an apartment — the calmer Timneh is likely your grey' }
              : { href: '/congo-african-grey-for-sale/', label: 'Congo African Grey', why: 'you want the best talker with room to spare — the classic Congo is your grey' };
          }
          var extra = (exp === 'first')
            ? ' Because this would be your first parrot, read our <a href="/blog/is-african-grey-good-for-beginners/">beginner-fit guide</a> before you commit.'
            : '';
          out.innerHTML = '<strong>Start with the ' + r.label + ' comparison.</strong> Based on your answers, ' + r.why + '. <a href="' + r.href + '">Open it now →</a>' + extra;
          out.hidden = false;
          out.setAttribute('data-in', '');
        });
      }
    })();
  </script>
