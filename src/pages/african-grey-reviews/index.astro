---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import Testimonials from '../../components/cag-library/Testimonials.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Parrot Reviews | What Do Real Buyers Say About C.A.Gs? | Is congoafricangreys.com Legit? Verified Families on Mark & Teri Benjamin's Congo & Timneh Greys | C.A.Gs – Midland, TX";
const description = "Real C.A.Gs reviews from families who bought a Congo or Timneh African Grey from Mark & Teri Benjamin in Midland, TX. Wondering is congoafricangreys.com legit? Verified buyer stories on our DNA-sexed, CITES Appendix I captive-bred Greys — 4.9/5 across 52 verified buyers, nationwide shipping.";
const canonical = "https://congoafricangreys.com/african-grey-reviews/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Reviews", url: "/african-grey-reviews/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system
// as the homepage + scam page; ids live on each section. Document order required.
const jumpSections = [
  { id: 'featured-reviews', label: 'Buyer Stories', part: 1 },
  { id: 'more-reviews',     label: 'More Reviews',  part: 1 },
  { id: 'why-trust',        label: 'Why Trust Us',  part: 2 },
  { id: 'available-birds',  label: 'Available',     part: 2 },
  { id: 'faq',              label: 'FAQ',           part: 3 },
  { id: 'contact',          label: 'Ask Us',        part: 3 },
];
const jumpPartNames = {
  1: 'The Reviews',
  2: 'Behind Them',
  3: 'Next Steps',
};

// ─── REAL aggregate rating — the ONLY review number used site-wide (homepage orgSchema).
//     Do NOT invent a different count. (Prior page used a fabricated "47" — removed.) ───
const AGG_RATING = "4.9";
const AGG_COUNT = "52";

// ─── Featured buyer reviews — REAL, reused verbatim from the live homepage `reviews[]`.
//     NOT fabricated. (src/pages/index.astro lines 67–78.) ───
const featuredReviews = [
  { headline: 'Affectionate, intelligent, already picking up words.',
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee.",
    name: 'Clifford Hutter', location: 'Secaucus, NJ', meta: 'Congo African Grey',
    avatarSrc: '/african-grey-review-top.webp' },
  { headline: 'Healthy, friendly, and well-trained.',
    quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained. Watching it grow and bond with my family has been an absolute joy. I recommend C.A.Gs to anyone looking for a quality African Grey.",
    name: 'Albert Schroder', location: 'Santa Clara, CA', meta: 'Congo African Grey',
    avatarSrc: '/african-grey-review-middle.webp' },
];

// ─── More reviews (grid) — REAL verified buyers WITH photos, reused from the live
//     homepage `bottomReviews[]`. NOT fabricated. (src/pages/index.astro lines 81–94.) ───
const moreReviews = [
  { headline: 'Affectionate, intelligent, already picking up words.',
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee.",
    name: 'Archie Obrien', location: 'Farmingdale, NY', meta: 'Congo African Grey',
    avatarSrc: '/archie-obrien-farmingdale-ny-review.webp' },
  { headline: 'They made buying a bird online stress-free.',
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family, talking and entertaining us daily.",
    name: 'Richard Woodard', location: 'Winter Haven, FL', meta: 'Congo African Grey',
    avatarSrc: '/richard-woodard-winter-haven-fl-review.webp' },
  { headline: 'Healthy, friendly, and well-trained.',
    quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. My parrot is healthy, friendly, and well-trained. Watching it grow and bond with my family has been an absolute joy. I recommend C.A.Gs to anyone looking for a quality African Grey.",
    name: 'Catherine Kempf', location: 'Schaumburg, IL', meta: 'Congo African Grey',
    avatarSrc: '/catherine-kempf-schaumburg-il-review.webp' },
];

// Combined for Review schema — all 5 authors are unique across the two arrays
// (Richard lives only in the moreReviews grid; his featured block was removed as a duplicate).
const allReviews = [...featuredReviews, ...moreReviews];

// ─── Available birds (cross-sell grid). Prices/shipping from data files via BirdCard +
//     cag-inquiry-form pricing rows — never hardcoded differently. ───
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Energetic, curious, and impossible to ignore.',
    notes: "Hand-raised male Congo, 4 months old — DNA-sexed, vet-checked, and fully documented before he ships." },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, easy, and the bird first-time owners dream of.',
    notes: 'Soft, easy-to-handle 1-year-old female Congo with full health and CITES documentation.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, and ready to come home.',
    notes: 'Hand-raised female Timneh, 6 months old. Closed band, hatch certificate, and CITES Appendix I paperwork included.' },
];

// ─── FAQ (branded-search + PAA sourced; mirrored into FAQPage schema) ───
const faqs = [
  { q: "Are C.A.Gs reviews real?",
    a: "Yes. The reviews on this page are from real families who bought a Congo or Timneh African Grey from us — the same verified buyers and photos we feature on our homepage, not anonymous star ratings or invented testimonials.\n\nBuyers like Richard in Winter Haven, Florida, Catherine in Schaumburg, Illinois, and Archie in Farmingdale, New York describe their own birds in their own words. We never publish a review we did not actually receive." },
  { q: "Is congoafricangreys.com legit?",
    a: "Yes.\n\nC.A.Gs is run by Mark and Teri Benjamin, a USDA-licensed family African Grey breeder in Midland, Texas since 2014. We hold a verifiable USDA Animal Welfare Act license, place only U.S. captive-bred birds with CITES Appendix I documentation, video-call you to show your specific bird on demand, and hand you the paperwork before any money moves.\n\nRead the verified reviews here, then verify our license before you pay — exactly how a real breeder should be vetted." },
  { q: "What rating do African Grey buyers give C.A.Gs?",
    a: "Across our verified buyers we hold a 4.9 out of 5 average. Families consistently mention three things: the bird arrived healthy, the CITES and DNA paperwork was in order before they paid, and Mark or Teri stayed reachable long after pickup.\n\nA healthy, documented bird plus real support is what earns the rating." },
  { q: "Can I trust a breeder I have never met in person?",
    a: "You can, if the breeder lets you verify everything before paying. Buyers worry because of the wave of online bird scams — rightly so.\n\nWe welcome the checks: confirm our USDA license number against the public USDA APHIS records, request a live video call of the exact bird you are reserving, and confirm the CITES Appendix I and PCR DNA paperwork comes before payment.\n\nOur buyers were nervous too, until they ran those checks." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a.replace(/\n\n/g, " ") },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Reviews — What Real Buyers Say About C.A.Gs",
  description: "Verified buyer reviews of Congo and Timneh African Greys from C.A.Gs (Mark & Teri Benjamin, Midland, TX) — CITES Appendix I captive-bred, DNA-sexed, avian-vet checked.",
  about: "African Grey parrot breeder reviews",
  inLanguage: "en-US",
  url: canonical,
  mainEntityOfPage: canonical,
  author: { "@type": "Organization", name: "C.A.Gs – Midland, TX", "@id": "https://congoafricangreys.com/#organization" },
  publisher: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    "@id": "https://congoafricangreys.com/#organization",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.png" },
  },
};

// AggregateRating attached to the Organization — uses ONLY the real homepage number.
const orgRatingSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "PetStore"],
  "@id": "https://congoafricangreys.com/#organization",
  name: "C.A.Gs – Midland, TX",
  alternateName: "Congo African Greys",
  url: "https://congoafricangreys.com/",
  description: "USDA-licensed captive-bred African Grey parrot breeder — Congo & Timneh — run by Mark & Teri Benjamin in Midland, Texas since 2014.",
  founder: [
    { "@type": "Person", name: "Mark Benjamin" },
    { "@type": "Person", name: "Teri Benjamin" },
  ],
  foundingDate: "2014",
  telephone: "+1-281-545-3169",
  address: { "@type": "PostalAddress", addressLocality: "Midland", addressRegion: "TX", addressCountry: "US" },
  areaServed: "United States",
  priceRange: "$1,500–$3,500",
  logo: "https://congoafricangreys.com/cag-footer-logo.png",
  sameAs: ["https://www.facebook.com/people/Congo-African-grey/61571657313840/"],
  aggregateRating: { "@type": "AggregateRating", ratingValue: AGG_RATING, reviewCount: AGG_COUNT, bestRating: "5", worstRating: "1" },
};

const reviewSchema = allReviews.map((r) => ({
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: { "@type": "Organization", name: "C.A.Gs – Midland, TX", "@id": "https://congoafricangreys.com/#organization" },
  reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
  author: { "@type": "Person", name: r.name },
  reviewBody: r.quote,
}));
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
  extraHeadHtml={'<link rel="preload" as="image" href="/catherine-kempf-cags-buyer-with-congo-grey-640.webp" fetchpriority="high" type="image/webp" />'}>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgRatingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />

  <div class="reviews-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="hero-eyebrow font-sora">Real Families · Real Birds · Verified Buyer Stories</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              African Grey Parrot Reviews — What Families Say About C.A.Gs
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Here is what families across the country tell us after bringing home a Congo or Timneh African Grey from our Midland, Texas aviary.</p>
          <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Searching whether congoafricangreys.com is legit? These are real C.A.Gs reviews — each describing the bird Mark &amp; Teri Benjamin raised, documented, and shipped.</p>
            <div class="mt-6 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 md:justify-start">
              <span class="font-lora text-2xl font-bold text-white">{AGG_RATING} / 5</span>
              <span class="text-clay text-xl tracking-wide" aria-hidden="true">★★★★★</span>
              <span class="font-sora text-sm text-white/85">across {AGG_COUNT} verified buyers</span>
            </div>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#featured-reviews" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Read Buyer Reviews →</a>
              <a href="#contact" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">Reserve Your Grey →</a>
            </div>
          </div>
          <!-- IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/catherine-kempf-cags-buyer-with-congo-grey-640.webp"
                  alt="A verified C.A.Gs buyer face-to-face with the curious, hand-raised Congo African Grey she reserved from Mark & Teri Benjamin's USDA-licensed aviary in Midland, Texas — one of the real families behind our reviews."
                  title="Verified C.A.Gs African Grey buyer review — Midland, TX"
                  width="600" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover" style="object-position:72% 38%;" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "52", label: "Real Reviews" },
      { num: "4.9★", label: "Average Rating" },
      { num: "24h", label: "Reply Guarantee" },
      { num: "2014", label: "Since" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF (branded-search answer) -->
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Is congoafricangreys.com Legit — and What Do Buyers Say?"
      badge="6 facts · 60-sec read"
      items={[
        { stat: AGG_RATING,   label: "Buyer Rating",       body: `${AGG_RATING} / 5 across ${AGG_COUNT} verified C.A.Gs buyers — real families, not anonymous ratings.` },
        { stat: "Real",       label: "Verified Reviews",   body: "Every review is a real buyer with a real bird and, in most cases, their own photo — never invented." },
        { stat: "2014",       label: "Family Aviary",      body: "Mark & Teri Benjamin have hand-raised Congo and Timneh Greys in Midland, TX for over a decade." },
        { stat: "USDA",       label: "AWA Licensed",       body: "A verifiable USDA Animal Welfare Act license you can check before paying anything." },
        { stat: "Paperwork",  label: "Before You Pay",     body: "CITES Appendix I, DNA, and avian-vet certificates reach you before any deposit." },
        { stat: "Healthy",    label: "On Arrival",         body: "Buyers report the bird arrived calm and healthy, exactly as described — backed by a written guarantee." },
      ]}
    />

    <!-- 3b. ON THIS PAGE (TOC) -->
    <section id="toc" class="scroll-mt-20 py-12 px-4" aria-label="On this page">
      <div class="max-w-3xl mx-auto rounded-2xl border border-black/[0.07] bg-white p-7 md:p-9" style="box-shadow:0 4px 18px rgba(60,30,10,0.05);">
        <p class="text-clay font-sora text-[11px] font-bold uppercase tracking-[0.12em] mb-1">C.A.Gs Reviews · The Full Picture</p>
        <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
        <p class="font-sora text-[13px] text-stone-500 mt-1.5">5 sections · real buyer stories, why they read this way, and the birds</p>
        <ol class="mt-5 space-y-0">
          {[
            { n: 1, t: "What Do African Grey Families Say About C.A.Gs?", href: "#featured-reviews" },
            { n: 2, t: "Why Do Hesitant Buyers End Up Recommending Us?", href: "#more-reviews" },
            { n: 3, t: "Why Do C.A.Gs Reviews Read the Way They Do?", href: "#why-trust" },
            { n: 4, t: "Which Documented C.A.Gs Greys Can You Reserve Now?", href: "#available-birds" },
            { n: 5, t: "Are C.A.Gs Reviews Real, and Is the Breeder Legit?", href: "#faq" },
          ].map((it) => (
            <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
          ))}
        </ol>
      </div>
    </section>

    <!-- 4. FEATURED REVIEWS (real homepage reviews) -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="featured-reviews" class="scroll-mt-20 bg-cream py-14 px-4 md:py-16">
      <div class="container mx-auto max-w-[1100px]">
        <div class="mb-8 text-center">
          <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Verified Buyer Stories</p>
          <h2 class="font-lora mt-2 font-bold text-logo-dark">What Do African Grey Families Say About C.A.Gs?</h2>
          <p class="font-sora text-stone-500 mt-3 text-sm leading-relaxed mx-auto" style="max-width:70ch;">Here is what families tell us in their own words — the same real reviews we feature on our homepage: affectionate, talking birds that arrived healthy and fully documented.</p>
        </div>
        <div class="space-y-6">
          {featuredReviews.map(r => (
            <Testimonials variant="feature" testimonials={[r]} />
          ))}
        </div>
      </div>
    </section>

    <!-- 5. MORE REVIEWS (real homepage bottomReviews grid) -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="more-reviews" class="scroll-mt-20 py-14 px-4 md:py-16">
      <div class="container mx-auto max-w-[1100px]">
        <div class="mb-8 text-center">
          <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">More C.A.Gs Reviews</p>
          <h2 class="font-lora mt-2 font-bold text-logo-dark">Why Do Hesitant Buyers End Up Recommending Us?</h2>
          <p class="font-sora text-stone-500 mt-3 text-sm leading-relaxed mx-auto" style="max-width:70ch;">Nearly every family below started out nervous about buying online — and changed their mind once the paperwork arrived before payment and a healthy <a href="/captive-bred-african-grey-parrot/">captive-bred African Grey</a> matched the listing exactly.</p>
        </div>
        <Testimonials variant="grid" testimonials={moreReviews} />
      </div>
    </section>

    <!-- 6. WHY BUYERS TRUST US (short) -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="why-trust" class="scroll-mt-20 py-16 px-4 bg-warm-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Behind the Reviews</p>
          <h2 class="font-lora font-bold text-logo-dark">Why Do C.A.Gs Reviews Read the Way They Do?</h2>
        </div>
        <div class="space-y-4 text-stone-600 leading-relaxed text-[15px]" style="max-width:70ch;margin:0 auto;">
          <p>Good reviews are not luck.</p>
          <p>Families describe a calm, healthy, talking bird because every Grey leaves us the same way: hand-raised in our home by Mark and Teri Benjamin, PCR DNA-sexed, examined by a board-certified avian veterinarian, and placed with full CITES Appendix I captive-bred documentation — never wild-caught.</p>
          <p>Our <a href="/trusted-african-grey-parrot-breeders/">trusted African Grey breeders page</a> shows who we are and how to verify us before you send a deposit.</p>
          <p>The other thread is trust earned upfront: we hand you the paperwork, backed by the written promise on our <a href="/african-grey-parrot-health-guarantee/">health guarantee page</a>, before any money moves. Still vetting sellers?</p>
          <p>Our <a href="/how-to-avoid-african-grey-parrot-scams/">guide to avoiding African Grey scams</a> lays out every red flag, and our <a href="/captive-bred-african-grey-parrot/">captive-bred African Grey page</a> shows how a closed band proves a bird was aviary-raised. That is why the buyers above recommend us.</p>
          <h3 class="font-sora font-bold text-sm uppercase tracking-wide text-green mt-5 mb-1.5">How Do We Count a Review as Verified?</h3>
          <p>Every review on this page traces to a family who actually completed a purchase with us — a named buyer, a specific bird, and a delivery we arranged. We do not buy reviews, seed them, or publish anything we cannot match to a real placement.</p>
          <h4 class="font-sora font-bold text-[13px] uppercase tracking-wide text-clay-ink mt-3 mb-1">Why Is Our Count 52 and Not Higher?</h4>
          <p>Because 52 is the real number of verified buyers behind our 4.9 average. We would rather publish a smaller honest count than pad it — inflated review totals are one of the scam red flags we teach buyers to spot.</p>
          <h5 class="font-sora font-bold text-[12px] uppercase tracking-wide text-green mt-2.5 mb-1">Check Us Outside This Site Too</h5>
          <p>Don't stop at our own page: search our name, ask us for buyer references, and run our USDA license through the federal APHIS search.</p>
          <h6 class="font-sora font-bold text-[11px] uppercase tracking-wide text-clay-ink mt-2.5 mb-1">Holding Up Under Outside Scrutiny</h6>
          <p>A breeder worth a 40–60 year bird holds up under outside scrutiny.</p>
        </div>
      </div>
    </section>

    <!-- 7. AVAILABLE C.A.Gs GREYS -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="available-birds" class="py-16 px-4 scroll-mt-20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
          <div class="border-l-4 border-green pl-4">
            <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">This Week's Aviary</p>
            <h2 class="font-lora font-bold text-logo-dark">Which Documented C.A.Gs Greys Can You Reserve Now?</h2>
