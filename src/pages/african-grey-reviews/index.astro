        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['featured-reviews','more-reviews','why-trust','available-birds','faq','contact'];
      var labels = {
        'more-reviews':    'More C.A.Gs Reviews',
