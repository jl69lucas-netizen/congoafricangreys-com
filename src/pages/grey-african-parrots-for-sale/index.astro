---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Congo African Grey Parrots for Sale | CITES-Documented — C.A.Gs, Midland TX | From $1,600";
const description = "Congo African grey parrots for sale from $1,600. CITES-documented, DNA-sexed, vet-checked. Hand-raised by USDA-licensed breeders in Midland, TX. Ships USA-wide.";
const canonical = "https://congoafricangreys.com/grey-african-parrots-for-sale/";

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Congo African Grey Parrot for Sale",
  "description": "Hand-raised Congo African grey parrots (Psittacus erithacus erithacus). CITES-documented, DNA-sexed, vet-certified. USDA-licensed breeder in Midland, TX.",
  "url": canonical,
  "brand": { "@type": "Brand", "name": "Congo African Greys (C.A.Gs)" },
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "1600",
    "highPrice": "3500",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
});
---

<BaseLayout {title} {description} {canonical} {schemaJson}>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">CITES Appendix II Compliant · USDA AWA Licensed · Ships USA-Wide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Congo African Grey Parrots for Sale</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">Intelligent, talkative, and CITES-documented Congo African grey parrots (<em>Psittacus erithacus erithacus</em>) — hand-raised by ethical breeders in Midland, Texas. From $1,600.</p>
      <a href="/contact-us/" class="inline-block bg-clay text-white font-semibold px-8 py-3 rounded-full hover:bg-clay-dk transition-colors">
        Shop Congo African Greys →
      </a>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="bg-green/10 border-y border-green/20 py-3 px-4">
    <div class="max-w-4xl mx-auto flex flex-wrap justify-center gap-6 text-sm text-green font-sora font-semibold">
      <span>✔ CITES Captive-Bred Documented</span>
      <span>✔ DNA-Sexed Certificate Included</span>
      <span>✔ USDA AWA Licensed Breeder</span>
      <span>✔ Full Vet Health Records</span>
    </div>
  </div>

  <article class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <div class="prose prose-lg max-w-none mb-10">
      <p>Welcome to Congo African Greys (C.A.Gs) — your premier destination for intelligent, talkative, and affectionate Congo African grey parrots (<em>Psittacus erithacus erithacus</em>). Our birds are renowned for their exceptional talking ability, emotional intelligence, and gentle temperament.</p>
      <p>Every Congo African grey parrot we offer is:</p>
      <ul>
        <li>Captive-bred with CITES Appendix II documentation — never wild-caught</li>
        <li>DNA-sexed with laboratory certification</li>
        <li>Fully weaned, hand-raised, and socialized from hatch</li>
        <li>Vet-checked with a complete health guarantee</li>
        <li>Shipped nationwide via IATA-compliant air cargo ($185)</li>
      </ul>
    </div>

    <!-- CITES section -->
    <section class="mb-12 bg-green text-cream rounded-2xl p-6">
      <h2 class="font-lora font-bold text-xl mb-4">Why CITES Documentation Matters</h2>
      <p class="text-cream/80 text-sm mb-4">African grey parrots are listed on <strong>CITES Appendix II</strong> — which means international trade is regulated to prevent harm to wild populations. All C.A.Gs birds are captive-bred with full documentation proving their legal origin.</p>
      <ul class="space-y-2 text-sm text-cream/90">
        <li>✔ Every bird ships with CITES captive-bred certificate</li>
        <li>✔ USDA AWA (Animal Welfare Act) licensed facility</li>
        <li>✔ No wild-caught birds — ever</li>
      </ul>
      <p class="mt-4 text-sm"><a href="/cites-african-grey-documentation/" class="text-gold hover:underline">Learn more about CITES documentation for African Grey parrots →</a></p>
    </section>

    <!-- Species info -->
    <section class="mb-12">
      <h2 class="font-lora font-bold text-2xl text-green mb-6">About the Congo African Grey Parrot</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-cream border border-gold/30 rounded-xl p-5">
          <h3 class="font-lora font-semibold text-green mb-3">Species Profile</h3>
          <ul class="space-y-2 text-sm">
            <li><strong>Scientific Name:</strong> Psittacus erithacus erithacus</li>
            <li><strong>Size:</strong> 12–14 inches · 400–650g</li>
            <li><strong>Lifespan:</strong> 40–60 years in captivity</li>
            <li><strong>Talking Ability:</strong> Exceptional — 200+ words</li>
            <li><strong>Origin:</strong> Central &amp; West Africa (captive-bred at C.A.Gs)</li>
          </ul>
        </div>
        <div class="bg-cream border border-gold/30 rounded-xl p-5">
          <h3 class="font-lora font-semibold text-green mb-3">Why Choose a Congo Grey?</h3>
          <ul class="space-y-2 text-sm">
            <li>✔ World's best talking parrot species</li>
            <li>✔ Emotionally intelligent — mirrors owner moods</li>
            <li>✔ Long-lived companions (40–60 year commitment)</li>
            <li>✔ Adaptable to family and apartment living</li>
            <li>✔ Distinctive bright-red tail feathers</li>
          </ul>
        </div>
      </div>
      <p class="text-sm text-gray-600 mt-4">Looking for the smaller variant? See our <a href="/congo-african-grey-for-sale/" class="text-green hover:text-clay">Congo African Grey for Sale</a> page or compare with our Timneh variant.</p>
    </section>

    <!-- Pricing -->
    <section class="mb-12">
      <h2 class="font-lora font-bold text-2xl text-green mb-4">Congo African Grey Parrot Pricing</h2>
      <div class="prose prose-lg max-w-none">
        <p>Our Congo African grey parrots for sale are priced between <strong>$1,600 and $3,500</strong>, depending on age, training, and current availability. Each bird's price includes:</p>
        <ul>
          <li>DNA sexing certificate</li>
          <li>Vet health report</li>
          <li>CITES captive-bred documentation</li>
          <li>Health guarantee coverage</li>
        </ul>
        <p>Nationwide air shipping: <strong>$185 flat rate</strong> via Delta or United Airlines cargo. We also offer home delivery for $300 additional (selected areas).</p>
        <p>For full pricing details: <a href="/african-grey-parrot-for-sale/">African Grey Parrots for Sale</a> · <a href="/african-grey-breeding-pair-for-sale/">Breeding Pairs</a> · <a href="/african-grey-parrot-bird-eggs-for-sale-usa/">Fertile Eggs from $40</a></p>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-logo-dark text-cream rounded-2xl p-8 text-center">
      <h2 class="font-lora font-bold text-2xl mb-3">Find Your Congo African Grey Parrot</h2>
      <p class="text-cream/80 mb-6">Contact C.A.Gs for current availability. All Congo African grey parrots come with CITES documentation, DNA sexing, vet records, and health guarantee.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact-us/" class="bg-clay text-white font-semibold px-8 py-3 rounded-full hover:bg-clay-dk transition-colors">Inquire Now →</a>
        <a href="/how-to-avoid-african-grey-parrot-scams/" class="border border-cream/40 text-cream font-semibold px-8 py-3 rounded-full hover:border-gold hover:text-gold transition-colors">How to Avoid Scams</a>
      </div>
      <p class="text-xs text-cream/50 mt-4">2508 Briaroaks Ct · Midland, Texas 79707 · (956) 564-6067</p>
    </section>

  </article>

</BaseLayout>
