---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey vs Cockatoo | Talking Ability, Affection & Care Compared";
const description = "African Grey vs Cockatoo compared: talking ability, affection level, noise, lifespan, price, and care demands. Which parrot fits your lifestyle?";
const canonical = "https://congoafricangreys.com/african-grey-vs-cockatoo/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey vs Cockatoo", url: "/african-grey-vs-cockatoo/" },
];

const comparisonRows = [
  { attr: "Body size", ag: "12–14 inches (Congo)", ctoo: "12–28 inches depending on species" },
  { attr: "Weight", ag: "400–550 grams (Congo)", ctoo: "300–850 grams" },
  { attr: "Noise level", ag: "Moderate", ctoo: "Very loud — Moluccan cockatoos are among the loudest birds" },
  { attr: "Talking ability", ag: "Exceptional — top talking parrot", ctoo: "Limited — cockatoos talk less and with less clarity" },
  { attr: "Affection level", ag: "Bonded but not velcro — independent", ctoo: "Extremely velcro — requires constant physical contact" },
  { attr: "Dust production", ag: "Moderate", ctoo: "Very high — triggers allergies; serious concern for asthma sufferers" },
  { attr: "Price range", ag: "$1,700 – $3,500", ctoo: "$1,500 – $3,500 depending on species" },
  { attr: "Lifespan", ag: "40–60 years", ctoo: "40–80 years depending on species" },
  { attr: "Feather destruction risk", ag: "Moderate risk if under-stimulated", ctoo: "High risk — severe feather destruction is common in cockatoos" },
  { attr: "CITES status", ag: "Appendix II", ctoo: "Many species Appendix I (restricted) or Appendix II" },
];

const faqs = [
  {
    q: "Do African Greys or cockatoos talk better?",
    a: "African Greys are far superior talkers. They are widely regarded as the best-talking parrot species in the world, with vocabularies of 200–1,000+ words and near-human voice clarity. Cockatoos can learn a few words and phrases but are not known for talking ability.",
  },
  {
    q: "Are cockatoos more affectionate than African Greys?",
    a: "Yes — cockatoos are among the most physically affectionate parrots, requiring constant touch and contact. African Greys form deep bonds but are more independent and prefer interaction on their own terms. Neither is 'better' — it depends entirely on what type of bond you want.",
  },
  {
    q: "Can people with allergies own a cockatoo?",
    a: "Cockatoos produce extremely high levels of powder/dander that can trigger or worsen allergies and asthma. People with any respiratory sensitivities should avoid cockatoos. African Greys produce moderate dander — significantly less than cockatoos — making them a better choice for allergy-conscious households.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="page-container">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- HERO -->
  <section class="ctoo-hero">
    <div class="page-container">
      <h1 class="ctoo-h1">African Grey vs Cockatoo: Which Parrot Fits Your Life?</h1>
      <p class="ctoo-sub">
        Talking ability vs. physical affection. Intelligence vs. velcro bonding. Moderate dander
        vs. allergy-triggering powder. The right answer depends entirely on what you want from a parrot.
      </p>
    </div>
  </section>

  <!-- DUST WARNING -->
  <section class="ctoo-section ctoo-warn-section">
    <div class="page-container text-wrap">
      <div class="ctoo-warning">
        <strong>Important for allergy sufferers:</strong> Cockatoos produce extremely high levels
        of powder down (feather dust). This is a serious health concern for people with asthma,
        bird allergies, or any respiratory sensitivity. If you or anyone in your household has
        breathing sensitivities, an African Grey produces significantly less dander and is the
        safer choice.
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="ctoo-section">
    <div class="page-container">
      <h2 class="ctoo-h2">African Grey vs Cockatoo: Side-by-Side</h2>
      <div class="ctoo-table-wrap">
        <table class="ctoo-table">
          <thead>
            <tr>
              <th>Attribute</th>
              <th>African Grey</th>
              <th>Cockatoo</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <th scope="row">{row.attr}</th>
                <td>{row.ag}</td>
                <td>{row.ctoo}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- VERDICT CARDS -->
  <section class="ctoo-section ctoo-alt">
    <div class="page-container">
      <h2 class="ctoo-h2">Which Bird Is Right for You?</h2>
      <div class="ctoo-verdict-grid">
        <div class="ctoo-verdict-card">
          <h3 class="ctoo-verdict-title">Choose an African Grey if&hellip;</h3>
          <ul class="ctoo-verdict-list">
            <li>Talking ability is important to you</li>
            <li>You want a more independent, less clingy bird</li>
            <li>Anyone in your household has allergies or asthma</li>
            <li>You want a bird that bonds deeply but on its own terms</li>
            <li>Moderate noise levels are important in your home</li>
          </ul>
        </div>
        <div class="ctoo-verdict-card">
          <h3 class="ctoo-verdict-title">Choose a Cockatoo if&hellip;</h3>
          <ul class="ctoo-verdict-list">
            <li>You want maximum physical affection and constant contact</li>
            <li>Talking ability is not a priority</li>
            <li>No one in your household has respiratory sensitivities</li>
            <li>You can meet very high daily attention requirements</li>
            <li>You have space for regular, thorough cage cleaning (heavy powder)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILED COMPARISON -->
  <section class="ctoo-section">
    <div class="page-container text-wrap">
      <h2 class="ctoo-h2">Key Differences in Depth</h2>

      <h3 class="ctoo-h3">Talking Ability: African Grey Leads by a Wide Margin</h3>
      <p class="ctoo-p">
        African Greys are, by scientific consensus and owner experience, the best-talking parrots
        in the world. Vocabularies of 200 to 1,000+ words are common in well-trained birds.
        More importantly, African Greys demonstrate contextual language use — they apply words
        appropriately to situations rather than randomly reciting them.
      </p>
      <p class="ctoo-p">
        Cockatoos can learn some words and phrases. The Bare-Eyed Cockatoo and Sulphur-Crested
        Cockatoo are among the more vocal cockatoo species. But cockatoos are fundamentally not
        known for talking ability — they are known for affection, personality, and noise.
        If hearing your bird say your name and describe what it wants is important to you,
        African Grey is the clear choice.
      </p>

      <h3 class="ctoo-h3">Affection Style: Velcro vs. Independent Bond</h3>
      <p class="ctoo-p">
        Cockatoos are called "velcro birds" for a reason. They crave physical contact continuously.
        A cockatoo that is not getting enough contact time will scream, become destructive, or
        develop severe feather destructive behavior. The emotional needs of a cockatoo are among
        the highest of any pet species.
      </p>
      <p class="ctoo-p">
        African Greys bond just as deeply, but differently. They form a profound attachment to
        their primary person and are acutely tuned in to that person's emotional state. But they
        prefer to be near you rather than on you — they are observers and companions, not lap birds.
        Many owners find this type of relationship more sustainable over 40+ years.
      </p>

      <h3 class="ctoo-h3">Dust and Dander: A Health Consideration You Cannot Ignore</h3>
      <p class="ctoo-p">
        Cockatoos and cockatiel-family birds produce a fine white powder down from specialized
        feathers. This powder coats surfaces in the room and becomes airborne during preening.
        In a household with any member who has asthma, bird allergies, or chronic respiratory
        conditions, this is a significant and non-trivial health risk.
      </p>
      <p class="ctoo-p">
        African Greys produce dander at a moderate level — significantly less than cockatoos.
        For anyone with respiratory sensitivities, African Grey is the safer choice if you are
        comparing these two species. That said, no parrot is truly hypoallergenic — assess your
        household's specific sensitivities before committing.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ctoo-section ctoo-alt">
    <div class="page-container text-wrap">
      <h2 class="ctoo-h2">African Grey vs Cockatoo: FAQ</h2>
      <div class="ctoo-faq">
        {faqs.map((f) => (
          <details class="ctoo-faq-item">
            <summary class="ctoo-faq-q">{f.q}</summary>
            <p class="ctoo-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="ctoo-section">
    <div class="page-container text-wrap">
      <h2 class="ctoo-h2">Related Comparisons</h2>
      <ul class="ctoo-links">
        <li><a href="/congo-vs-timneh-african-grey/" class="ctoo-link">Congo vs Timneh African Grey</a> — compare the two African Grey subspecies</li>
        <li><a href="/african-grey-vs-macaw/" class="ctoo-link">African Grey vs Macaw</a> — noise, size, and talking ability compared</li>
      </ul>
    </div>
  </section>

  <CTA
    headline="Interested in an African Grey?"
    sub="Every bird from CongoAfricanGreys.com is hand-raised, fully weaned, CITES-documented, and vet-certified before shipping."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap { max-width: 760px; }
  .ctoo-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .ctoo-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .ctoo-h3 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.2rem;
    margin: 1.75rem 0 0.6rem;
  }
  .ctoo-hero {
    background: #2D6A4F;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .ctoo-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto;
  }
  .ctoo-section { padding: 3rem 0; }
  .ctoo-warn-section { padding: 1.5rem 0 0; }
  .ctoo-alt { background: #faf7f4; }
  .ctoo-p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.1rem;
  }
  .ctoo-warning {
    background: #fff3cd;
    border-left: 4px solid #e8604c;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    color: #7a3a00;
    line-height: 1.6;
    max-width: 70ch;
  }
  .ctoo-table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid #e7e5e4;
    box-shadow: 0 2px 8px rgba(60,30,10,0.07);
  }
  .ctoo-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.95rem;
  }
  .ctoo-table thead tr { background: #2D6A4F; }
  .ctoo-table thead th {
    color: #faf7f4;
    font-weight: 600;
    text-align: left;
    padding: 0.9rem 1.25rem;
  }
  .ctoo-table tbody tr:nth-child(even) { background: #faf7f4; }
  .ctoo-table tbody tr:nth-child(odd) { background: #fff; }
  .ctoo-table tbody th {
    font-weight: 600;
    color: #2D6A4F;
    padding: 0.8rem 1.25rem;
    text-align: left;
    white-space: nowrap;
  }
  .ctoo-table tbody td {
    padding: 0.8rem 1.25rem;
    color: #44403c;
    line-height: 1.5;
  }
  .ctoo-verdict-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
  }
  .ctoo-verdict-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 2px 8px rgba(60,30,10,0.06);
  }
  .ctoo-verdict-title {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }
  .ctoo-verdict-list { padding-left: 1.25rem; margin: 0; }
  .ctoo-verdict-list li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.97rem;
    line-height: 1.6;
    color: #44403c;
    margin-bottom: 0.5rem;
  }
  .ctoo-links { padding-left: 1.5rem; margin: 0; }
  .ctoo-links li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    margin-bottom: 0.5rem;
  }
  .ctoo-link { color: #e8604c; text-decoration: underline; }
  .ctoo-link:hover { color: #d44e3b; }
  .ctoo-faq { display: flex; flex-direction: column; gap: 0.75rem; }
  .ctoo-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .ctoo-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .ctoo-faq-q::-webkit-details-marker { display: none; }
  .ctoo-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) {
    .page-container { padding: 0 16px; }
    .ctoo-verdict-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) and (max-width: 1024px) { .page-container { padding: 0 32px; } }
</style>
