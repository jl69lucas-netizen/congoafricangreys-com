          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Choosing the food</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "What Makes a Good African Grey Food?", href: "#criteria" },
                  { n: 2, t: "Best Pellet Brands Reviewed (Harrison's, Zupreem, Roudybush, TOP's)", href: "#pellet-brands" },
                  { n: 3, t: "Where Do Seed Mixes Fit — Treat, Not Base", href: "#seed-mixes" },
                  { n: 4, t: "Best Treats, Nuts & Foraging Products", href: "#treats" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Feeding, switching & buying</p>
              <ol class="space-y-0">
                {[
                  { n: 5, t: "What We Feed Our Greys at C.A.Gs", href: "#what-we-feed" },
                  { n: 6, t: "How to Transition a Grey to a New Food", href: "#transition" },
                  { n: 7, t: "Which Well-Fed C.A.Gs Greys Are Available?", href: "#available-birds" },
                  { n: 8, t: "Best African Grey Food Questions, Answered", href: "#faq" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
