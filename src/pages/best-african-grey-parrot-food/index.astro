        { stat: "Same", label: "Congo = Timneh", body: "Both species eat the identical food; the larger Congo just eats a bit more than the smaller Timneh." },
      ]}
    />

    <!-- 4. TOC -->
    <nav class="toc-food py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this review</p>
