---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "Best Food for African Grey Parrots | Which Pellet Brands Are Best — Harrison's, Zupreem, Roudybush or TOP's? | Pellets vs Seed, Treats & Foraging Reviewed | C.A.Gs – Midland, TX";
const description = "Our breeder review of the best African Grey parrot food: which dye-free pellet brands are best (Harrison's, Zupreem Natural, Roudybush, TOP's), where seed mixes fit, the best treats, nuts and foraging products, and how to switch a Grey to a new food | USDA-licensed Congo & Timneh breeders.";
const canonical = "https://congoafricangreys.com/best-african-grey-parrot-food/";
const updated = "June 2026";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Care Guides", url: "/african-grey-care/" },
  { name: "Best African Grey Parrot Food", url: "/best-african-grey-parrot-food/" },
];

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + price-matrix.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Already weaned onto a pellet base.',
    notes: "Hand-raised male, 4 months old — eating a full formulated-pellet-and-vegetable diet before he ever leaves us." },
