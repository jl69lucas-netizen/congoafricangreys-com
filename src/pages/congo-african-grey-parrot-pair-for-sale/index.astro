---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "Congo African Grey Parrot Pair for Sale | Breeding Pair with CITES Documentation";
const description = "Congo African Grey parrot breeding pairs for sale. USDA AWA licensed. Both birds CITES documented, DNA sexed, and health certified. Inquire about available pairs.";
const canonical = "https://congoafricangreys.com/congo-african-grey-parrot-pair-for-sale/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Congo African Grey for Sale", url: "/congo-african-grey-for-sale/" },
  { name: "Congo African Grey Pair for Sale", url: "/congo-african-grey-parrot-pair-for-sale/" },
];

const faqs = [
  {
    q: "What's included with a breeding pair purchase?",
    a: "Each bird in the pair comes with its own CITES Appendix I documentation, DNA sexing certificate, vet health certificate, and hatch certificate. The pair is confirmed as a compatible male/female match before sale.",
  },
  {
    q: "Do breeding pairs always produce fertile eggs?",
    a: "Not immediately. Congo African Greys typically begin breeding between ages 3–5 years. A compatible pair may take 6–24 months to settle in a new environment before producing fertile clutches. Pair bonding takes time — rushing the process produces stress and infertile eggs.",
  },
  {
    q: "What CITES permits are needed to breed African Greys in the U.S.?",
    a: "In the U.S., captive-bred African Greys require CITES Appendix I documentation for any interstate sale. Breeders must maintain breeding records and documentation for each clutch. Contact the U.S. Fish & Wildlife Service for current captive-breeding permit requirements in your state.",
  },
  {
    q: "How are breeding pairs shipped?",
    a: "Breeding pairs ship together in a single IATA-approved container or in separate adjacent compartments, depending on the pair's bonding status and the airline's requirements. Both birds travel on the same flight for minimum stress. Full documentation ships with each bird.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section style="background:#2D6A4F;padding:4rem 1rem">
    <div style="max-width:900px;margin:0 auto;text-align:center">
      <p style="color:#f0c674;font-family:var(--font-sora,sans-serif);font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:1rem">USDA AWA Licensed · CITES Documented Pairs</p>
      <h1 style="font-family:var(--font-lora,serif);font-weight:700;font-size:clamp(2rem,5vw,3rem);color:#faf7f4;margin-bottom:1rem">Congo African Grey Parrot Pair for Sale</h1>
      <p style="color:rgba(250,247,244,.8);font-size:1.1rem;max-width:680px;margin:0 auto 2rem">DNA-confirmed male/female Congo African Grey pairs, both fully documented under CITES Appendix I. Pair availability is limited — inquire directly for current status.</p>
      <a href="/contact-us/" style="display:inline-block;background:#e8604c;color:white;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.875rem 2rem;border-radius:50px;text-decoration:none;font-size:1rem">Inquire About Available Pairs →</a>
    </div>
  </section>

  <section style="padding:3.5rem 1rem;background:#faf7f4">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.5rem;color:#2D6A4F;margin-bottom:1rem">About Our Breeding Pairs</h2>
      <p style="color:#374151;line-height:1.7;max-width:70ch;margin-bottom:1rem">Congo African Grey breeding pairs are among the most sought-after additions for established aviculturists. We sell pairs that have been raised together or successfully introduced under supervised conditions — not random adult birds shipped together for the first time.</p>
      <p style="color:#374151;line-height:1.7;max-width:70ch">Both birds in every pair are DNA sexed, CITES documented, and current on avian vet examinations. Hatch certificates establish captive-bred lineage for every bird.</p>
    </div>
  </section>

  <section style="padding:4rem 1rem;background:white">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;margin-bottom:2rem">Breeding Pair Questions</h2>
      <div style="display:flex;flex-direction:column;gap:1rem">
        {faqs.map((faq) => (
          <details style="background:#faf7f4;border:1px solid #e7e2db;border-radius:12px;padding:1.25rem">
            <summary style="font-family:var(--font-sora,sans-serif);font-weight:600;cursor:pointer;color:#1f2937;list-style:none">{faq.q}</summary>
            <p style="margin-top:.75rem;color:#4b5563;line-height:1.7;max-width:70ch">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
