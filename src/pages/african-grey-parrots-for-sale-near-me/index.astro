---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrots for Sale Near Me | CITES Documented, Ships All 50 States";
const description = "African Grey parrots for sale near you — captive-bred, CITES documented, IATA live-shipped. Congo and Timneh variants available from USDA AWA licensed breeders.";
const canonical = "https://congoafricangreys.com/african-grey-parrots-for-sale-near-me/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Parrots for Sale Near Me", url: "/african-grey-parrots-for-sale-near-me/" },
];

const faqs = [
  {
    q: "Are there African Grey parrots for sale near me?",
    a: "We ship captive-bred African Greys to all 50 U.S. states. Your nearest airport becomes the pickup point — most shipments arrive within 24–48 hours. We're USDA AWA licensed breeders in Midland, TX, and have delivered birds across the country.",
  },
  {
    q: "What's the difference between Congo and Timneh African Greys?",
    a: "Congo African Greys are larger (12–14 inches), have a bright red tail, and are priced $1,700–$3,500. Timneh African Greys are smaller (9–11 inches), have a darker maroon tail, and are priced $1,200–$2,500. Both are exceptional talkers. Timnehs mature earlier and are often recommended for first-time owners.",
  },
  {
    q: "What documentation comes with the bird?",
    a: "Every bird ships with CITES Appendix II documentation, a vet health certificate, DNA sexing certificate, hatch certificate, and our written health guarantee. CITES documentation is required by U.S. law for interstate transport of African Greys.",
  },
  {
    q: "How do I find a legitimate African Grey breeder near me?",
    a: "Look for USDA AWA license numbers, verifiable CITES documentation, and physical addresses with verifiable histories. Avoid sellers with no license number, no documentation, or prices far below market rate ($1,200+ for Timneh, $1,700+ for Congo). We're USDA AWA Licensed #74-B-0247, based in Midland, TX.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section style="background:#2D6A4F;padding:4rem 1rem">
    <div style="max-width:900px;margin:0 auto;text-align:center">
      <p style="color:#f0c674;font-family:var(--font-sora,sans-serif);font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:1rem">Ships to All 50 States · USDA AWA Licensed</p>
      <h1 style="font-family:var(--font-lora,serif);font-weight:700;font-size:clamp(2rem,5vw,3rem);color:#faf7f4;margin-bottom:1rem">African Grey Parrots for Sale Near Me</h1>
      <p style="color:rgba(250,247,244,.8);font-size:1.1rem;max-width:680px;margin:0 auto 2rem">Captive-bred Congo and Timneh African Greys, fully weaned, CITES documented, and IATA live-shipped directly to your nearest airport.</p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center">
        <a href="/congo-african-grey-for-sale/" style="display:inline-block;background:#e8604c;color:white;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.875rem 1.75rem;border-radius:50px;text-decoration:none">Congo African Grey →</a>
        <a href="/timneh-african-grey-for-sale/" style="display:inline-block;background:white;color:#2D6A4F;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.875rem 1.75rem;border-radius:50px;text-decoration:none">Timneh African Grey →</a>
      </div>
    </div>
  </section>

  <section style="padding:2rem 1rem;background:#1b4332">
    <div style="max-width:960px;margin:0 auto;display:flex;flex-wrap:wrap;gap:1.5rem;justify-content:center">
      {["USDA AWA Licensed (#74-B-0247)", "CITES Appendix II Documented", "DNA Sexed", "IATA Live Shipping", "Written Health Guarantee"].map((t) => (
        <span style="color:white;font-family:var(--font-sora,sans-serif);font-size:.85rem;font-weight:600">✅ {t}</span>
      ))}
    </div>
  </section>

  <section style="padding:4rem 1rem;background:#faf7f4">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;margin-bottom:2rem">Frequently Asked Questions</h2>
      <div style="display:flex;flex-direction:column;gap:1rem">
        {faqs.map((faq) => (
          <details style="background:white;border:1px solid #e7e2db;border-radius:12px;padding:1.25rem">
            <summary style="font-family:var(--font-sora,sans-serif);font-weight:600;cursor:pointer;color:#1f2937;list-style:none">{faq.q}</summary>
            <p style="margin-top:.75rem;color:#4b5563;line-height:1.7;max-width:70ch">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
