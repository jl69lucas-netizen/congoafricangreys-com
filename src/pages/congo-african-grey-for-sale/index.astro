---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import clutch from '../../../data/clutch-inventory.json';

// Meta — 3-part extended format (Primary KW | conversational query | number+positive | brand — LSI), ≤280
const title = "Congo African Grey Parrots for Sale | Where Can I Buy a Real Congo Grey Without Getting Scammed? | 3 Hand-Raised, DNA-Tested & CITES-Documented | C.A.Gs, Midland TX — Psittacus erithacus, Verify in 60 Seconds, From $1,700";
// Desc — Primary benefit | secondary benefit | trust signal + CTA, ≤300
const description = "Congo African Grey parrots for sale from a USDA-licensed Texas breeder — Roys, Amie and Bery, hand-raised, DNA-sexed and CITES-documented from $1,700. Verify us in 60 seconds, video-call your bird before any deposit, ship nationwide $185 airport / $350 home. We reply within 24 hours.";
const canonical = "https://congoafricangreys.com/congo-african-grey-for-sale/";

const IMG = "/images/congo-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "Congo African Grey for Sale", url: "/congo-african-grey-for-sale/" },
];

// Real inventory — Congo singles + companion pair only (Timneh out of scope on this page); never hardcode status
const available = ((clutch as any).birds as any[])
  .filter((b) => b.variant === "congo_african_grey" && b.status === "available")
  .sort((a, b) => (a.sex === "pair" ? 1 : -1));

const birdImg: Record<string, { src: string; alt: string; pos: string }> = {
  "roys": { src: IMG + "roys-congo-african-grey-male-card.webp", pos: "center 28%", alt: "Roys, a confident young male Congo African Grey for sale, perched with his bright red tail showing" },
  "amie": { src: IMG + "amie-congo-african-grey-female-card.webp", pos: "center 26%", alt: "Amie, a hand-fed baby female Congo African Grey being socialized against a keeper's shoulder" },
  "bery": { src: IMG + "bery-congo-african-grey-female-card.webp", pos: "center 30%", alt: "Bery, a cuddly one-year-old female Congo grey parrot resting calmly on a lap" },
  "jins-jeni": { src: IMG + "jins-jeni-congo-african-grey-pair-card.webp", pos: "center 34%", alt: "Jins and Jeni, a bonded Congo African Grey companion pair raised together in Midland, Texas" },
};

const birdBlurb: Record<string, string> = {
  "roys": "Confident, energetic young male who thrives in busy, active family homes.",
  "amie": "Hand-fed baby hen in full social training — gentle and people-focused from hatch.",
  "bery": "Cuddly, gentle one-year hen who settles fast and loves a calm lap.",
  "jins-jeni": "Unrelated companion pair raised side by side — they rehome as a bonded two.",
};
const cardChips = ["DNA-sexed", "PBFD/APV PCR", "Vet certificate"];

// Avail filter cats — counts derived from real inventory (never hardcoded)
const maleCount = available.filter((b) => b.sex === "male").length;
const femaleCount = available.filter((b) => b.sex === "female").length;
const pairCount = available.filter((b) => b.sex === "pair").length;
const filterCats = [
  { key: "all", label: "All Congos", n: available.length },
  { key: "male", label: "Males", n: maleCount },
  { key: "female", label: "Females", n: femaleCount },
  { key: "bonded", label: "Companion pair", n: pairCount },
];
const catFor = (b: any) => (b.sex === "pair" ? "bonded" : b.sex === "male" ? "male" : "female");

// Geo shipping cards — DISTINCT state/city set vs the egg page (cannibalization guard), real location slugs
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-los-angeles/", label: "Congo African Greys for sale Los Angeles", note: "LAX live-animal cargo" },
  { href: "/african-grey-parrot-for-sale-chicago/", label: "Congo African Grey parrots Chicago", note: "O'Hare cargo hub" },
  { href: "/african-grey-parrot-for-sale-dallas/", label: "Hand-raised Congo greys Dallas", note: "Short in-state transit" },
  { href: "/african-grey-parrot-for-sale-miami/", label: "Congo African Grey for sale Miami", note: "Warm-route scheduling" },
  { href: "/african-grey-parrot-for-sale-arizona/", label: "DNA-tested Congo greys Arizona", note: "Phoenix Sky Harbor" },
  { href: "/african-grey-parrot-for-sale-washington/", label: "Congo African Grey breeder Washington", note: "Sea-Tac cargo desk" },
  { href: "/african-grey-parrot-for-sale-virginia/", label: "Congo African Grey parrots Virginia", note: "East-coast delivery" },
  { href: "/african-grey-parrot-for-sale-tennessee/", label: "Congo African Greys for sale Tennessee", note: "Nashville pickup route" },
];

// Real reviews only (verified homepage/reviews set)
const stories = [
  { name: "Richard Woodard", loc: "Winter Haven, FL", meta: "Congo African Grey",
    avatar: "/richard-woodard-winter-haven-fl-review-112.webp",
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family, talking and entertaining us daily." },
  { name: "Archie Obrien", loc: "Farmingdale, NY", meta: "Congo African Grey",
    avatar: "/archie-obrien-farmingdale-ny-review.webp",
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee." },
];

// Further reading — real blog/resource pages with matching thumbnails
const readMore = [
  { href: "/how-to-avoid-african-grey-parrot-scams/", img: IMG + "real-vs-fake-congo-african-grey-breeder-comparison-760.webp", kicker: "Scam guide", title: "How to avoid African Grey parrot scams", sub: "The red flags every fake Congo listing shares — and how to walk past them." },
  { href: "/congo-vs-timneh-african-grey/", img: "/congo-vs-timneh-key-differences-fast-facts-infographic.webp", kicker: "Which grey", title: "Congo vs Timneh African Grey", sub: "Size, talking, temperament and price, compared side by side." },
  { href: "/african-grey-parrot-price/", img: IMG + "congo-african-grey-price-1500-to-8500-explained-infographic-760.webp", kicker: "Pricing", title: "African Grey price — what you actually pay for", sub: "Why a real Congo starts near $1,700 and a $800 bird is a warning." },
  { href: "/cites-african-grey-documentation/", img: "/buy-an-african-grey-safely-checklist-infographic.webp", kicker: "Legality", title: "CITES documentation, explained", sub: "The exact Appendix I records that follow a legal, captive-bred Congo home." },
];

const faqs = [
  { q: "How much does a Congo African Grey cost?", a: "Our hand-raised Congo African Grey singles run $1,700–$2,500, and a bonded companion pair is $3,500. We never list a Congo below $1,500 — a healthy, DNA-sexed, captive-bred Congo African Grey costs real money to raise and document, so a suspiciously cheap $800 bird is one of the clearest scam tells there is." },
  { q: "Is it legal to buy a Congo African Grey in the USA?", a: "Yes. African Greys are listed on CITES Appendix I, yet captive-bred birds can be legally owned and rehomed inside the United States when the paperwork is in order. Every Congo African Grey we sell was hatched in Texas to captive parents — never wild-caught — and comes with CITES captive-bred documentation plus a USDA-licensed breeder's paper trail." },
  { q: "Do Congo African Greys really talk?", a: "Congo African Greys are among the best talking parrots in the world, often building vocabularies of well over 100 words and mimicking household sounds with uncanny clarity. Because we hand-raise and socialize every chick daily, our Congos start associating words with people and objects early, which is the foundation of a strong talking bird." },
  { q: "How long do Congo African Greys live?", a: "A Congo African Grey typically lives 40–60 years in good care, so buying one is a multi-decade commitment closer to adopting a child than getting a pet. We raise ours to be healthy, well-socialized companions precisely because they'll be part of your family for that long." },
  { q: "How do I avoid a Congo African Grey scam?", a: "Verify the seller before you send a cent: look up their USDA license on APHIS, ask for a live video call with the actual bird, and refuse any seller who wants gift cards, Western Union, or PayPal Friends & Family. Our full scam guide walks through every red flag, and we invite the same checks on ourselves." },
  { q: "Can a Congo African Grey be shipped safely?", a: "Yes — a reserved Congo ships on IATA live-animal cargo with Delta, United or American for $185 to your nearest airport, or $350 by climate-controlled home delivery. If you live within 2–3 hours of Midland, Texas, local pickup is the gentlest option, and every bird travels with its full document folder and health certificate." },
  { q: "What's included when I reserve a Congo African Grey?", a: "Every Congo comes home with a DNA-sexing certificate, a closed leg band, an avian-vet health record, PBFD and Avian Polyomavirus PCR screening, a care guide, a welcome kit, and our lifetime breeder support — the same documentation stack a fake listing can never assemble." },
  { q: "Why do Congo African Grey prices range from $1,500 to $8,500?", a: "Price tracks age, hand-raising, DNA and disease testing, temperament, and documentation. A weaned, well-socialized chick from a documented pair sits in the credible middle of the market, while an already-tame, talking adult can reach the top of the range. Our $1,700–$2,500 singles sit squarely in that honest middle." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: "Congo African Grey Parrot for Sale (Psittacus erithacus)",
  image: [ site + IMG + "congo-african-grey-parrot-for-sale-hero.webp", site + IMG + "roys-congo-african-grey-male-card.webp" ],
  description: "A hand-raised, DNA-sexed Congo African Grey parrot from C.A.Gs, a USDA-licensed family aviary in Midland, Texas. Captive-bred, CITES Appendix I documented, PBFD & Avian Polyomavirus PCR-screened, and placed with lifetime breeder support.",
  category: "Companion parrot",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52" },
  review: stories.map((s) => ({ "@type": "Review", author: { "@type": "Person", name: s.name },
    reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" }, reviewBody: s.quote })),
  offers: { "@type": "AggregateOffer", lowPrice: "1700", highPrice: "3500", priceCurrency: "USD", offerCount: String(available.length),
    availability: "https://schema.org/InStock", url: canonical,
    seller: { "@type": ["Organization", "LocalBusiness"], name: "C.A.Gs – Midland, TX", alternateName: "Congo African Greys" } },
};

const itemListSchema = { "@context": "https://schema.org", "@type": "ItemList",
  itemListElement: available.map((b, i) => ({ "@type": "ListItem", position: i + 1,
    item: { "@type": "Product", name: b.name + " — Congo African Grey", category: "Companion parrot",
      offers: { "@type": "Offer", price: String(b.price), priceCurrency: "USD",
        availability: "https://schema.org/InStock", url: site + b.slug } } })) };

const sections = [
  { n: "01", id: "available", label: "Available Congos now", tag: "3 birds" },
  { n: "02", id: "short", label: "The short version", tag: "$1,700+" },
  { n: "03", id: "companion", label: "Why Congos are loved", tag: "Talking" },
  { n: "04", id: "legit", label: "Is this breeder legit?", tag: "Verify" },
  { n: "05", id: "price", label: "Why prices vary so much", tag: "$1.5–8.5k" },
  { n: "06", id: "included", label: "What's included", tag: "Docs" },
  { n: "07", id: "buy", label: "How to buy, step by step", tag: "4 steps" },
  { n: "08", id: "health", label: "Health & guarantee", tag: "PCR" },
  { n: "09", id: "legal", label: "Legal to own?", tag: "CITES I" },
  { n: "10", id: "shipping", label: "Shipping & cost", tag: "$185/$350" },
  { n: "11", id: "lifestyle", label: "Living with a Congo", tag: "Daily" },
  { n: "12", id: "families", label: "Buyer families", tag: "" },
  { n: "13", id: "faq", label: "Congo FAQs", tag: "" },
  { n: "14", id: "reserve", label: "Reserve yours", tag: "24h" },
];

// In-body TOC stepper (T5 Reserve-Path)
const steps = [
  { href: "#available", n: "1", h: "See who's available", sub: "3 Congos · 1 min" },
  { href: "#legit", n: "2", h: "Verify we're real", sub: "60-sec check · 2 min" },
  { href: "#price", n: "3", h: "Understand the price", sub: "$1.5–8.5k · 2 min" },
  { href: "#buy", n: "4", h: "Reserve & ship home", sub: "4 steps · 1 min" },
];
const seam = "/cag-fs-seam-emblem.webp";
---

<BaseLayout {title} {description} {canonical} ogType="product" hideGlobalCta
  heroPreload={IMG + "congo-african-grey-parrot-for-sale-hero.webp"}
  heroPreloadSrcset={IMG + "congo-african-grey-parrot-for-sale-hero-760.webp 760w, " + IMG + "congo-african-grey-parrot-for-sale-hero.webp 1280w"}
  heroPreloadSizes="(max-width:900px) 92vw, 520px">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="congo">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- HERO — Split-Hero B · Full-bleed warm gradient -->
  <header class="chero">
    <div class="container chero-grid">
      <div class="chero-copy">
        <p class="eyebrow">Est. 2014 · Midland, TX · USDA-licensed aviary</p>
        <h1 class="cag-h1">Congo African Grey <em>Parrots</em> for Sale — Hand-Raised, DNA-Tested &amp; CITES-Documented</h1>
        <p class="lead">Here at C.A.Gs we hand-raise Congo African Grey parrots (<i>Psittacus erithacus</i>) and place them nationwide from $1,700 — DNA-sexed, health-screened, and traced to named breeding pairs. No anonymous listing, no wild-caught birds: a USDA-licensed Texas breeder you can verify in about a minute and video-call before you pay a cent.</p>
        <div class="chero-cta">
          <a class="btn-clay" href="#available">See available Congos &rarr;</a>
          <a class="btn-ghost" href="#legit">Is this seller legit?</a>
        </div>
        <p class="chero-rate"><span class="stars" aria-hidden="true">★★★★★</span> <b>4.9</b> · 52 verified C.A.Gs buyers</p>
        <ul class="chero-ribbon">
          <li>USDA Class A</li><li>CITES Appendix I</li><li>PCR DNA-sexed</li><li>Ships nationwide</li>
        </ul>
      </div>
      <div class="chero-media">
        <img src={IMG + "congo-african-grey-parrot-for-sale-hero.webp"}
          srcset={IMG + "congo-african-grey-parrot-for-sale-hero-760.webp 760w, " + IMG + "congo-african-grey-parrot-for-sale-hero.webp 1280w"}
          sizes="(max-width:900px) 92vw, 520px" width="1280" height="960"
          fetchpriority="high" loading="eager" decoding="async"
          alt="Congo African Grey parrot for sale perched calmly, showing its grey scalloped plumage and bright red tail" />
        <span class="chero-tag">Hand-raised in Midland, TX</span>
      </div>
    </div>
  </header>

  <!-- COUNTER — for-sale outlined stat cards (Ledger-verified only) -->
  <div class="chero-counter">
    <div class="container counter-row">
      <div class="cs"><b>$1,700</b><span class="cs-l">Congo floor price</span></div>
      <div class="cs"><b>3</b><span class="cs-l">Congos reservable</span></div>
      <div class="cs"><b>60s</b><span class="cs-l">Verify our license</span></div>
      <div class="cs"><b>App. I</b><span class="cs-l">CITES documented</span></div>
      <div class="cs"><b>0</b><span class="cs-l">Wild-caught, ever</span></div>
      <div class="cs"><b>40–60</b><span class="cs-l">Year companion</span></div>
      <div class="cs"><b>24h</b><span class="cs-l">Inquiry reply</span></div>
    </div>
  </div>

  <!-- MOBILE JUMP RAIL — Rail A price-chip -->
  <nav class="chero-rail" aria-label="On this page">
    <div class="container railA">
      {sections.map((s, i) => (<a href={`#${s.id}`} class={i === 0 ? "on" : ""}><span class="p">{s.n}</span> {s.label}</a>))}
    </div>
  </nav>

  <div class="container">

    <!-- IN-BODY TOC — T5 Reserve-Path Stepper -->
    <nav class="stepper" aria-label="Your path to reserving a Congo African Grey">
      <p class="stepper-h">Your Path to Reserving a Congo — About 6 Minutes to Read</p>
      <ol class="stepper-row">
        {steps.map((s) => (
          <li><a href={s.href}><span class="st-n">{s.n}</span><span class="st-txt"><b>{s.h}</b><span>{s.sub}</span></span></a></li>
        ))}
      </ol>
    </nav>

    <div class="congo-body">

    <!-- DESKTOP DIAL TOC — Dial 2 · Dark Aviary (sticky left, dark-green) -->
    <nav class="cdial desk-only" aria-label="Contents" id="congoDial" style="--p:7">
      <div class="cdial-ring"><div><b id="dialNum">1</b><span>of 14</span></div></div>
      <div class="cdial-list">
        {sections.map((s, i) => (<a href={`#${s.id}`} data-i={i} class={i === 0 ? "on" : ""}><span class="num">{s.n}</span>{s.label}{s.tag && <span class="tag">{s.tag}</span>}</a>))}
      </div>
    </nav>

    <main class="congo-main">

      <!-- 1 · AVAILABLE -->
      <section id="available">
        <h2 class="cag-h2">Which Congo African Grey Parrots Do We Have for Sale Right Now?</h2>
        <p>Three hand-raised Congo African Greys are reservable at C.A.Gs today — Roys, a young male, and two hens, Amie and Bery — plus our bonded companion pair, Jins &amp; Jeni. Every one is a real bird in our Midland, Texas home, DNA-sexed and health-screened, and each card below opens that Congo's own page with its photos, parentage and full paperwork.</p>

        <!-- Avail-B · sticky sidebar filter + card grid -->
        <div class="availB">
          <aside class="availB-side" aria-label="Filter available Congo African Greys">
            <p class="side-h">Browse by</p>
            <div class="side-filters">
              {filterCats.map((c, i) => (
                <button type="button" class={"side-f" + (i === 0 ? " on" : "")} data-cat={c.key} aria-pressed={i === 0 ? "true" : "false"}>
                  <span>{c.label}</span><span class="side-n">{c.n}</span>
                </button>
              ))}
            </div>
            <div class="side-ship">
              <p><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg> <b>$185</b> · Airport, nationwide</p>
              <p><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg> <b>$350</b> · Home delivery from C.A.Gs</p>
            </div>
          </aside>

          <div class="availB-grid">
            {available.map((b) => {
              const cat = catFor(b);
              const badge = cat === "bonded" ? "Companion Pair" : cat === "male" ? "Congo · Male" : "Congo · Female";
              const meta = b.sex === "pair" ? "Bonded companion pair · " + b.age_at_listing : (b.sex === "male" ? "Male" : "Female") + " · " + b.age_at_listing + " · Congo African Grey";
              return (
                <article class="availB-c" data-cat={cat}>
                  <a class="availB-photo" href={b.slug} tabindex="-1">
                    {birdImg[b.id] && <img src={birdImg[b.id].src} width="800" height="720" loading="lazy" decoding="async" style={`object-position:${birdImg[b.id].pos}`} alt={birdImg[b.id].alt} />}
                    <span class={"availB-badge " + cat}>{badge}</span>
                    <span class="availB-dot" title="Available"></span>
                  </a>
                  <div class="availB-body">
                    <h3 class="availB-name"><a href={b.slug}>{b.name}</a></h3>
                    <p class="availB-meta">{meta}</p>
                    {birdBlurb[b.id] && <p class="availB-blurb">{birdBlurb[b.id]}</p>}
                    <ul class="availB-chips">{cardChips.map((c) => (<li>{c}</li>))}</ul>
                    <span class="availB-price">{b.price_display}</span>
                    <a class="btn-clay availB-btn" href="#reserve">Inquire about {b.name}</a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
        <p class="side-note">Ships nationwide · $185 airport · $350 home · Local pickup in Midland, TX (within 2–3 hours)</p>

        <h3 class="cag-h3">Meet Roys, Amie &amp; Bery, Our Available Congo Greys</h3>
        <p>Each of these Congos is a bird we've raised by hand since the nursery, so we can tell you their temperament rather than guess it: Roys is our bold, busy-household male, Amie is a gentle, people-focused baby hen still in daily socialization, and Bery is a cuddly one-year hen who settles onto a lap in minutes. Because they're individuals, we match each to the right home rather than sell a "type."</p>

        <h4 class="cag-h4">What Does Each Congo's Card Tell You?</h4>
        <p>Every card carries the four things a serious buyer checks first — sex, age, price and status — with the shipping line built in so nothing about cost is hidden. We keep availability honest, so a card marked available is a bird we truly have, and a reserved or sold Congo never sits here pretending to be in stock.</p>

        <h5 class="cag-h5">Every Available Congo Ships With a DNA-Sexing Certificate and Health Record</h5>
        <p>Sex on a Congo African Grey isn't a guess — it's confirmed by a DNA lab, and that certificate travels with the bird alongside an avian-vet health record. Because Congos are visually monomorphic (males and females look alike), that lab-confirmed paperwork is exactly what separates an honest listing from a hopeful one.</p>

        <h6 class="cag-h6">Roys (Male, $2,300) · Amie (Female, $2,500) · Bery (Female, $1,700) — Current, Real Birds</h6>
        <p>These are the live prices from our inventory, not placeholder numbers: Roys is $2,300, Amie is $2,500, and Bery is $1,700, each a specific bird with its own page. If a figure ever differs between pages, our <a href="/african-grey-parrot-price/">African Grey pricing guide</a> governs and we correct the card.</p>

        <h3 class="cag-h3">Prefer a Bonded Pair Over a Single Congo African Grey?</h3>
        <p>Some buyers want two birds who already love each other, and that's what our companion pair offers: Jins &amp; Jeni are two Congos raised side by side who rehome together. A bonded pair keeps each other company when you're out, though it does not replace your own daily interaction — Greys still need you.</p>
        <img class="sec-img og-photo" src={IMG + "congo-african-greys-socialized-with-amazon-parrot.webp"} srcset={IMG + "congo-african-greys-socialized-with-amazon-parrot-760.webp 760w, " + IMG + "congo-african-greys-socialized-with-amazon-parrot.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Two Congo African Greys socialized alongside an Amazon parrot in the C.A.Gs home aviary" />

        <h4 class="cag-h4">How Is the Jins &amp; Jeni Companion Pair Different From a Single Bird?</h4>
        <p>A companion pair is priced and placed as one unit because splitting bonded birds is unkind, so Jins &amp; Jeni go home as a two at $3,500. They're unrelated — raised together, not siblings — which is the healthiest way to form a companion bond without inbreeding risk.</p>

        <h5 class="cag-h5">Companion Pairs Are Sold Together — See Our Dedicated Pair Page</h5>
