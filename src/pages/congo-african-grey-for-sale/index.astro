---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "Congo African Grey For Sale | $1,500–$3,000 | Congo African Greys";
const description = "Congo African Grey parrots for sale. Hand-raised, CITES-documented, DNA sexed. Babies from $3,000, adults from $1,500. Ships nationwide from Midland, Texas.";
const canonical = "https://congoafricangreys.com/congo-african-grey-for-sale/";

const productSchema = {
  "name": "Congo African Grey For Sale",
  "description": "Psittacus erithacus erithacus — the larger Congo African Grey subspecies. Captive-bred, CITES documented, 400–600g, distinctive bright red tail.",
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "1500",
    "highPrice": "3000",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Congo African Greys" }
  }
};
---

<BaseLayout {title} {description} {canonical}>
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Congo African Grey for Sale", url: "/congo-african-grey-for-sale/" }
      ]} />
  </div>

  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Psittacus erithacus &middot; CITES Appendix II Captive-Bred</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-6">Congo African Grey For Sale</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">The most intelligent parrot on earth. Larger body (400–600g), iconic bright red tail, vocabulary of 1,000+ words. Hand-raised in our Midland, TX home aviary since 2014.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact-us/" class="bg-gold text-logo-dark font-semibold px-8 py-4 rounded-full text-lg hover:bg-cream transition-colors">Inquire About Congo Greys</a>
        <a href="tel:+19565646067" class="border-2 border-gold text-gold font-semibold px-8 py-4 rounded-full text-lg hover:bg-gold hover:text-logo-dark transition-colors">Call (956) 564-6067</a>
      </div>
    </div>
  </section>
  <TrustBar />

  {/* CAG Infographic: Comparison | Congo vs Timneh | height: 400px | Added: 2026-05-19 */}
  <div style="margin: 2rem auto; max-width: 900px; padding: 0 1rem;">
  <div aria-label="Congo vs Timneh African Grey Comparison" style="display:flex;flex-direction:column;height:400px;min-height:380px;max-height:420px;border-radius:12px;overflow:hidden;font-family:'Sora',sans-serif;box-shadow:0 4px 24px rgba(60,30,10,0.18);border:1px solid rgba(0,0,0,0.08);">
    <div style="background:#1a1a2e;color:#fff;padding:10px 16px;text-align:center;font-family:'Lora',serif;font-size:14px;font-weight:700;flex-shrink:0;line-height:1.3;">CONGO vs TIMNEH — Which African Grey Is Right For You?</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;flex:1;overflow:hidden;min-height:0;">
      <div style="background:#f0faf4;display:flex;flex-direction:column;border-right:2px solid #e5e7eb;">
        <div style="background:#dcfce7;color:#166534;padding:7px 10px;font-size:11px;font-weight:800;display:flex;align-items:center;gap:6px;flex-shrink:0;border-bottom:1px solid rgba(0,0,0,0.08);">
          <img src="/emoji/cag-congo.png" alt="" style="width:14px;height:14px;vertical-align:-2px;object-fit:contain;" loading="lazy" />
          <div>
            <div style="font-size:11px;font-weight:800;letter-spacing:0.03em;">CONGO AFRICAN GREY</div>
            <div style="font-size:12px;font-weight:800;color:#16a34a;">$1,500 – $3,000</div>
          </div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">📏</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">SIZE</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Larger — 400–600g, bright red tail, broader wingspan</div></div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">🧠</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">TALKING ABILITY</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Exceptional — 1,000+ word vocabulary, mimics voices precisely</div></div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">🏠</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">IDEAL HOME</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Experienced bird owners, large living spaces, active households</div></div>
        </div>
        <div style="padding:5px 10px;display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">⏳</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">LIFESPAN</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">50–60 years — a true lifetime companion</div></div>
        </div>
      </div>
      <div style="background:#fff8f3;display:flex;flex-direction:column;">
        <div style="background:#fed7aa;color:#9a3412;padding:7px 10px;font-size:11px;font-weight:800;display:flex;align-items:center;gap:6px;flex-shrink:0;border-bottom:1px solid rgba(0,0,0,0.08);">
          <img src="/emoji/cag-timneh.png" alt="" style="width:14px;height:14px;vertical-align:-2px;object-fit:contain;" loading="lazy" />
          <div>
            <div style="font-size:11px;font-weight:800;letter-spacing:0.03em;">TIMNEH AFRICAN GREY</div>
            <div style="font-size:12px;font-weight:800;color:#c2410c;">$1,200 – $2,500</div>
          </div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">📏</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">SIZE</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Compact — 275–375g, maroon tail, darker charcoal plumage</div></div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">🧠</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">TALKING ABILITY</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Starts talking earlier — calmer voice, equally intelligent</div></div>
        </div>
        <div style="padding:5px 10px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">🏠</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">IDEAL HOME</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">Apartments, first-time parrot owners, calmer households</div></div>
        </div>
        <div style="padding:5px 10px;display:flex;align-items:flex-start;gap:7px;flex:1;">
          <span style="font-size:15px;flex-shrink:0;width:20px;text-align:center;">⏳</span>
          <div><div style="font-size:10px;font-weight:700;color:#1a1a2e;line-height:1.2;">LIFESPAN</div><div style="font-size:9px;color:#555;line-height:1.3;margin-top:1px;">40–50 years — a lifelong bond</div></div>
        </div>
      </div>
    </div>
    <div style="background:#2D6A4F;color:#fff;padding:8px 16px;text-align:center;font-size:11px;font-weight:800;flex-shrink:0;display:flex;align-items:center;justify-content:center;gap:8px;">
      <span>Both variants CITES-documented, captive-bred, USDA AWA licensed</span>
      <span style="opacity:0.75;font-weight:400;font-size:9px;">CongoAfricanGreys.com</span>
    </div>
  </div>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">About the Congo African Grey</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Species Profile</h3>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li><strong>Scientific name:</strong> Psittacus erithacus erithacus</li>
            <li><strong>Weight:</strong> 400–600 grams</li>
            <li><strong>Tail color:</strong> Bright red</li>
            <li><strong>Lifespan:</strong> 40–60 years in captivity</li>
            <li><strong>Vocabulary:</strong> Up to 1,000+ words</li>
            <li><strong>Temperament:</strong> Emotionally sensitive, deeply bonded</li>
            <li><strong>CITES status:</strong> Appendix II — captive-bred documentation required</li>
          </ul>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Pricing</h3>
          <ul class="space-y-3 text-stone-600 text-sm">
            <li class="flex justify-between border-b border-stone-100 pb-2"><span>Baby (3–6 months)</span><strong class="text-logo-dark">$3,000</strong></li>
            <li class="flex justify-between border-b border-stone-100 pb-2"><span>Adult</span><strong class="text-logo-dark">$1,500</strong></li>
            <li class="flex justify-between border-b border-stone-100 pb-2"><span>Congo Pair</span><strong class="text-logo-dark">$2,700</strong></li>
            <li class="flex justify-between"><span>Deposit to reserve</span><strong class="text-logo-dark">$200</strong></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  <Schema type="product" data={productSchema} />
  <Schema type="organization" />
  <CTA headline="Ready to Bring Home a Congo African Grey?" />
</BaseLayout>
