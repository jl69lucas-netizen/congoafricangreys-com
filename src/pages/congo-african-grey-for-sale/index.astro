.cs-l{font-size:.71rem;font-weight:600;color:var(--mid);line-height:1.25}
/* MOBILE RAIL A */
.chero-rail{position:sticky;top:var(--hdr);z-index:40;background:rgba(250,247,244,.985);border-bottom:1px solid var(--bd);box-shadow:0 6px 14px rgba(60,30,10,.07);display:none}
.railA{display:flex;gap:8px;overflow-x:auto;padding:12px 0;scrollbar-width:none}
.railA::-webkit-scrollbar{display:none}
.railA a{flex:0 0 auto;font-size:.78rem;font-weight:600;color:var(--clay-t);border:1.5px solid var(--clay);border-radius:50px;padding:7px 14px;text-decoration:none;background:#fff;white-space:nowrap}
.railA a.on{background:var(--clay-ink);border-color:var(--clay-ink);color:#fff}
.railA a .p{font-weight:700}
/* STEPPER — in-body TOC (T5 Reserve-Path) */
.stepper{background:#fff;border:1px solid var(--bd);border-radius:18px;padding:16px 18px 6px;margin:16px 0 4px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.stepper-h{font-family:'Newsreader',serif;font-size:1.05rem;color:#2a2622;margin:0 0 12px}
.stepper-row{list-style:none;display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:0;padding:0}
.stepper-row li{position:relative}
.stepper-row a{display:flex;align-items:center;gap:11px;text-decoration:none;background:#faf5f1;border:1px solid var(--bd);border-radius:12px;padding:11px 13px;transition:border-color .15s,background-color .15s,transform .15s}
.stepper-row a:hover{border-color:var(--clay);background:#fdf0ea;transform:translateY(-2px)}
.st-n{flex:none;width:28px;height:28px;border-radius:9px;background:var(--f);color:#fff;font-family:'Newsreader',serif;font-weight:700;display:grid;place-items:center;font-size:.9rem}
.st-txt{display:flex;flex-direction:column;min-width:0}
.st-txt b{font-size:.86rem;color:#2a2622;line-height:1.2}
.st-txt span{font-size:.7rem;color:var(--mid)}
/* BODY GRID — sticky dial + main */
.congo-body{display:grid;grid-template-columns:196px minmax(0,1fr);gap:28px;align-items:start;margin-top:14px}
/* DIAL 2 · DARK AVIARY (dark-green sticky rail) */
.cdial{display:flex;flex-direction:column;gap:10px;align-items:stretch;background:#1c3a2e;border:1px solid #2c5344;border-radius:16px;padding:12px 10px;box-shadow:0 6px 18px rgba(20,45,32,.22);position:sticky;top:calc(var(--hdr) + 16px);max-height:calc(100vh - var(--hdr) - 32px);overflow-y:auto;scrollbar-width:thin;scrollbar-color:#3a6b54 transparent}
.cdial-ring{margin:2px auto 0;flex:none;width:64px;height:64px;border-radius:50%;background:conic-gradient(#8fd3ac calc(var(--p,7) * 1%),#2c5344 0);display:grid;place-items:center}
.cdial-ring>div{width:50px;height:50px;border-radius:50%;background:#1c3a2e;display:grid;place-items:center;text-align:center;font-family:'Newsreader',serif}
.cdial-ring b{font-size:15px;color:#a7e0c2;display:block;line-height:1}
.cdial-ring span{font-size:7px;color:#7fac96;letter-spacing:.08em;text-transform:uppercase}
.cdial-list{display:grid;grid-template-columns:1fr;gap:1px;border-top:1px dashed #38614c;padding-top:8px}
.cdial-list a{display:flex;gap:7px;align-items:baseline;color:#cfe3d8;text-decoration:none;font-size:.74rem;line-height:1.25;padding:5px 7px;border-radius:8px;transition:background-color .15s,color .15s}
.cdial-list a:hover{background:#26503f;color:#fff}
.cdial-list a.on{background:#2e5c48;color:#fff;font-weight:600}
.cdial-list a.on .num{color:#a7e0c2}
.cdial-list .num{font-family:'Newsreader',serif;font-weight:700;color:#6f9c86;width:16px;flex:none;font-size:.7rem;font-variant-numeric:tabular-nums}
.cdial-list .tag{margin-left:auto;font-size:.56rem;font-weight:600;letter-spacing:.02em;color:#1c3a2e;background:#8fd3ac;border-radius:50px;padding:1px 6px;white-space:nowrap}
/* SECTION CTA row */
.sec-cta{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin:4px 0 20px}
.sec-cta .btn-clay,.sec-cta .btn-ghost{padding:11px 22px;font-size:.86rem}
.sec-cta .btn-ghost{border:2px solid var(--f);color:var(--f);background:none}
.sec-cta .btn-ghost:hover{background:var(--f);color:#fff}
/* K1 receipt */
.k1{background:#fff;max-width:440px;box-shadow:0 6px 20px rgba(60,30,10,.1);padding:24px 26px 16px;border-radius:8px;margin:2px 0 18px;border:1px solid var(--bd)}
.k1-title{font-family:'Newsreader',serif;text-align:center;font-size:1.25rem;border-bottom:2px dashed var(--bd);padding-bottom:10px;margin:0 0 6px}
.k1 .row{display:flex;justify-content:space-between;gap:14px;font-size:.9rem;padding:8px 0;border-bottom:1px dotted #e6dad0}
.k1 .row b{color:var(--clay-t);white-space:nowrap}
.k1 .tot{display:flex;justify-content:space-between;font-weight:700;padding-top:12px;font-size:.98rem}
.k1 .tot span:last-child{color:var(--f)}
/* K3 green ledger band */
.k3{background:linear-gradient(135deg,#1e5038,#2d6a4f);color:#fff;border-radius:16px;padding:20px 24px;margin:6px 0 18px;max-width:560px;box-shadow:0 8px 24px rgba(30,80,56,.22)}
.k3-title{font-family:'Newsreader',serif;font-size:1.18rem;margin:0 0 10px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,.22);color:#fff}
.k3-row{display:flex;justify-content:space-between;gap:14px;font-size:.9rem;padding:9px 0;border-bottom:1px dashed rgba(255,255,255,.16)}
.k3-row.last{border-bottom:none;padding-bottom:0}
.k3-row span{color:rgba(255,255,255,.86)}
.k3-row b{color:#a7e0c2;white-space:nowrap}
/* MAIN type scale */
.congo-main{max-width:880px;min-width:0}
.congo-main section{margin-bottom:14px;scroll-margin-top:calc(var(--hdr) + 18px);padding-top:20px}
.congo .cag-h2{font-family:'Newsreader',serif;font-size:clamp(1.375rem,3.5vw,2rem);color:#2a2622;margin:8px 0 16px;line-height:1.18}
.congo .cag-h3{font-family:'Newsreader',serif;font-size:clamp(1.125rem,2.2vw,1.5rem);color:var(--f);margin:24px 0 10px;line-height:1.25}
.congo .cag-h4{font-family:'Newsreader',serif;font-size:clamp(1rem,1.8vw,1.25rem);margin:20px 0 8px;line-height:1.3;color:#2a2622}
.congo .cag-h5{font-family:'Newsreader',serif;font-size:clamp(.95rem,1.25vw,1.05rem);margin:16px 0 6px;color:#3a332c}
.congo .cag-h6{font-family:'IBM Plex Sans',sans-serif;font-size:clamp(.75rem,.95vw,.82rem);letter-spacing:.04em;text-transform:uppercase;color:var(--clay-t);margin:16px 0 4px}
.congo-main p{line-height:1.68;margin:0 0 15px;max-width:70ch}
.congo-main a{color:var(--clay-t);text-decoration:underline;text-underline-offset:2px}
.congo-main a.btn-clay,.congo-main a.btn-ghost{text-decoration:none}
.congo-main a.btn-clay{color:#fff}
/* External link ↗ arrow indicator */
.congo-main p a[target="_blank"]::after{content:"\2197";font-size:.78em;font-weight:700;margin-left:2px;text-decoration:none;display:inline-block;vertical-align:baseline}
.sec-img{display:block;width:100%;max-width:760px;aspect-ratio:1408/768;object-fit:cover;height:auto;border-radius:18px;margin:4px 0 18px;box-shadow:0 6px 20px rgba(60,30,10,.1)}
.sec-img.inf-img{box-shadow:0 4px 16px rgba(60,30,10,.08)}
/* SEAM */
.seam{display:flex;align-items:center;justify-content:center;gap:14px;margin:22px 0}
.seam::before,.seam::after{content:"";flex:1;max-width:220px;height:2px;border-radius:1px}
.seam::before{background:linear-gradient(90deg,transparent,rgba(200,71,47,.5))}
.seam::after{background:linear-gradient(90deg,rgba(200,71,47,.5),transparent)}
.seam img{width:auto;height:30px;object-fit:contain;opacity:.95}
/* TABLE A */
.otA{border-radius:18px;overflow:hidden;box-shadow:0 4px 16px rgba(60,30,10,.08);border:1px solid var(--bd);margin:6px 0 18px}
.otA table{border-collapse:collapse;width:100%}
.otA th{background:var(--clay-ink);color:#fff;padding:12px 14px;text-align:left;font-size:.8rem;font-weight:600}
.otA td{background:#fff;padding:12px 14px;border-bottom:1px solid #f3e6de;font-size:.86rem}
.otA tr:nth-child(even) td{background:#fdf4ef}
.otA td:first-child b{font-family:'Newsreader',serif;font-size:.98rem}
.otA .sub{display:block;font-size:.72rem;color:var(--clay-t)}
/* SHIP CARDS */
.ship-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.ship-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.ship-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.ship-c>img{display:block;width:100%;height:200px;object-fit:cover}
.ship-body{padding:16px 18px}
.ship-tier{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 12px;font-size:.7rem;font-weight:600}
.ship-tier.clay{background:var(--clay-ink)}
.ship-c b{font-family:'Newsreader',serif;display:block;margin:8px 0 2px;font-size:1.15rem}
.ship-price{color:var(--clay-t);font-weight:700;font-size:1.15rem}
.ship-c p{font-size:.82rem;color:#5b524a;margin:6px 0 0!important;max-width:none}
.ship-line{font-size:.78rem;color:#7a6f64;font-weight:600;border-top:1px dashed var(--bd);padding-top:8px}
/* GEO ROUTE CARDS */
.geo-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:6px 0 16px}
.geo-c{display:flex;align-items:center;gap:12px;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:12px 14px;text-decoration:none!important;transition:transform .15s,box-shadow .2s,border-color .2s}
.geo-c:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(60,30,10,.1);border-color:var(--clay)}
.geo-pin{flex:none;width:34px;height:34px;border-radius:10px;background:#fdf0eb;color:#9c3a23;display:grid;place-items:center}
.geo-pin svg{width:17px;height:17px}
.geo-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.geo-kw{font-size:.87rem;font-weight:600;color:#2a2622;line-height:1.3}
.geo-note{font-size:.72rem;color:#7a6f64}
.geo-arrow{flex:none;color:#9c3a23;font-weight:700}
/* DOC STACK */
.doc-stack{background:linear-gradient(135deg,#fff,#fdf4ef);border:1px solid var(--bd);border-radius:18px;padding:20px 22px;margin:6px 0 16px;max-width:560px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.ds-title{font-family:'Newsreader',serif;font-size:1.15rem;margin:0 0 12px;color:#2a2622;padding-bottom:10px;border-bottom:2px solid var(--f)}
.ds-list{list-style:none;margin:0;padding:0;counter-reset:ds}
.ds-list li{counter-increment:ds;display:flex;flex-direction:column;gap:1px;padding:9px 0 9px 40px;position:relative;border-bottom:1px dashed var(--bd)}
.ds-list li:last-child{border-bottom:none}
.ds-list li::before{content:counter(ds,decimal-leading-zero);position:absolute;left:0;top:10px;font-family:'Newsreader',serif;font-weight:700;font-size:.85rem;color:#fff;background:var(--f);width:28px;height:28px;border-radius:9px;display:grid;place-items:center}
.ds-list b{font-size:.9rem;color:#2a2622}
.ds-list span{font-size:.76rem;color:#6b625a}
/* CHECKLIST B (K4 clipboard) */
.chkB{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;margin:6px 0 18px;box-shadow:0 4px 16px rgba(60,30,10,.07)}
.chkB-head{background:#1c3a2e;padding:16px 22px}
.chkB-eyebrow{color:#8fd3ac;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin:0 0 3px}
.chkB-title{font-family:'Newsreader',serif;font-size:1.15rem;color:#fff;margin:0;line-height:1.25;max-width:none}
.chkB-grid{list-style:none;margin:0;padding:14px 22px 18px;display:grid;grid-template-columns:1fr 1fr;gap:2px 26px;counter-reset:chk}
.chkB-grid li{counter-increment:chk;display:flex;flex-direction:column;gap:1px;padding:10px 0 10px 36px;position:relative;border-bottom:1px dashed var(--bd)}
.chkB-grid li::before{content:"✓";position:absolute;left:0;top:11px;width:24px;height:24px;border-radius:8px;background:#e7f1ec;color:var(--f);font-weight:700;font-size:.8rem;display:grid;place-items:center}
.chkB-grid b{font-size:.88rem;color:#2a2622}
.chkB-grid span{font-size:.76rem;color:#6b625a;line-height:1.45}
/* QUOTES */
.quote-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 4px}
.quote-c{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:16px;margin:0}
.q-head{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.q-av{width:48px;height:48px;border-radius:50%;object-fit:cover;flex:none;border:2px solid #eaf4ef}
.q-id{flex:1;min-width:0}
.q-name{display:block;font-family:'Newsreader',serif;font-size:1rem;color:#2a2622;line-height:1.2}
.q-loc{display:block;font-size:.75rem;color:#7a6f64;margin-top:1px}
.stars{color:#c9a227;letter-spacing:2px;font-size:.85rem;flex:none}
.quote-c p{font-size:.9rem;font-style:italic;margin:0;max-width:none}
/* FORM */
.final-cta{background:var(--cream);border:1px solid var(--bd);border-radius:20px;padding:clamp(22px,4vw,36px);margin-bottom:20px}
.cta-form{display:grid;gap:12px;max-width:640px;margin:10px 0 0}
.cta-form label{display:grid;gap:5px;font-size:.85rem;font-weight:600;color:#3a332c}
.cta-form .opt{font-weight:400;color:#7a6f64}
.cta-form input,.cta-form textarea,.cta-form select{border:1.5px solid var(--bd);border-radius:12px;padding:11px 13px;font:inherit;font-weight:400;background:#fff9f6;width:100%}
.cta-form input:focus,.cta-form textarea:focus,.cta-form select:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.12)}
.form-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px}
.cta-form button{border:none;cursor:pointer}
.cta-form .btn-ghost{border:2px solid var(--f);color:var(--f);padding:11px 22px}
.cta-form .btn-ghost:hover{background:var(--f);color:#fff}
.form-note{font-size:.8rem;color:#7a6f64;margin:2px 0 0!important}
.hp{position:absolute;left:-9999px}
/* NEWSLETTER — for-sale split */
.fs-nl{margin:24px 0;border-radius:20px;overflow:hidden;box-shadow:0 6px 22px rgba(60,30,10,.08)}
.fs-nl.split{display:grid;grid-template-columns:minmax(0,320px) 1fr;background:#fff;border:1px solid var(--bd)}
.fs-nl-media{position:relative}
.fs-nl-media img{display:block;width:100%;height:100%;object-fit:cover;aspect-ratio:1408/768}
.fs-nl-cap{position:absolute;left:12px;bottom:12px;background:rgba(34,31,29,.8);color:#fff;font-size:.68rem;font-weight:600;padding:4px 11px;border-radius:50px}
.fs-nl-body{padding:clamp(20px,3vw,30px)}
.fs-nl-eyebrow{color:var(--clay-t);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px}
.fs-nl-h{font-family:'Newsreader',serif;font-size:clamp(1.15rem,2.2vw,1.45rem);line-height:1.2;margin:0 0 6px;color:#2a2622}
.fs-nl-sub{font-size:.86rem;line-height:1.55;margin:0 0 14px!important;max-width:62ch;color:#5b524a}
.fs-nl-form{display:flex;gap:10px;flex-wrap:wrap}
.fs-nl-form input{flex:1;min-width:200px;border:1.5px solid var(--bd);border-radius:50px;padding:12px 18px;font:inherit;background:#fff;color:#2a2622}
.fs-nl-form input:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.15)}
.fs-nl-form button{border:none;cursor:pointer}
.fs-nl-note{font-size:.74rem;color:var(--mid);margin:10px 0 0!important}
/* VIDEO */
.fs-video{margin:6px 0 18px;max-width:760px}
.fs-video-frame{position:relative;border-radius:18px;overflow:hidden;box-shadow:0 8px 26px rgba(60,30,10,.16);background:#1b1815}
.fs-video-frame video{display:block;width:100%;height:auto;aspect-ratio:1408/768;object-fit:cover}
.fs-video-tag{position:absolute;top:12px;left:12px;background:rgba(34,31,29,.82);color:#fff;font-size:.68rem;font-weight:600;letter-spacing:.04em;padding:5px 12px;border-radius:50px;pointer-events:none}
.fs-video figcaption{font-size:.8rem;color:var(--mid);margin-top:8px;font-style:italic}
/* AVAIL-B */
.availB{display:grid;grid-template-columns:200px 1fr;gap:18px;margin:6px 0;align-items:start}
.availB-side{position:sticky;top:calc(var(--hdr) + 14px);background:#fff;border:1px solid var(--bd);border-radius:18px;padding:16px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.side-h{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);margin:0 0 12px}
.side-filters{display:flex;flex-direction:column;gap:4px}
.side-f{display:flex;align-items:center;justify-content:space-between;gap:10px;background:none;border:1.5px solid transparent;border-radius:10px;padding:9px 12px;font:inherit;font-size:.9rem;font-weight:600;color:#2a2622;cursor:pointer;text-align:left;transition:background-color .15s,border-color .15s}
.side-f:hover{background:#faece7}
.side-f.on{border-color:var(--clay);color:var(--clay-ink)}
.side-n{font-size:.72rem;font-weight:700;color:var(--mid);background:#f4efe9;border-radius:50px;min-width:24px;text-align:center;padding:2px 8px}
.side-f.on .side-n{background:var(--clay-ink);color:#fff}
.side-ship{border-top:1px solid var(--bd);margin-top:12px;padding-top:12px;display:flex;flex-direction:column;gap:8px}
.side-ship p{font-size:.78rem;color:#5b524a;margin:0!important;display:flex;align-items:center;gap:8px;max-width:none}
.side-ship svg{color:var(--clay-t);flex:none;width:15px;height:15px}
.side-ship b{color:#2a2622}
.side-note{font-size:.76rem;color:#7a6f64;font-weight:600;margin:6px 0 14px;text-align:center}
.availB-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.availB-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;display:flex;flex-direction:column;transition:transform .15s,box-shadow .2s}
.availB-c:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(60,30,10,.13)}
.availB-photo{position:relative;display:block}
.availB-photo img{display:block;width:100%;height:210px;object-fit:cover;object-position:center 28%}
.availB-badge{position:absolute;top:10px;left:10px;font-size:.58rem;font-weight:600;letter-spacing:.02em;padding:3px 9px;border-radius:50px;background:rgba(255,255,255,.82);backdrop-filter:blur(3px);box-shadow:0 1px 4px rgba(0,0,0,.08)}
.availB-badge.male{color:#1e5038}
.availB-badge.female{color:#9c3a23}
.availB-badge.bonded{color:#6d5510}
.availB-dot{position:absolute;top:12px;right:12px;width:12px;height:12px;border-radius:50%;background:#3fbf6a;border:2px solid #fff;box-shadow:0 0 0 1px rgba(0,0,0,.06)}
.availB-body{padding:13px 15px 15px;display:flex;flex-direction:column;flex:1}
.availB-name{font-family:'Newsreader',serif;font-size:1.15rem;margin:0 0 3px;text-transform:uppercase;letter-spacing:.01em;line-height:1.1}
.availB-name a{color:#2a2622;text-decoration:none}
.availB-name a:hover{color:var(--clay-t)}
.availB-meta{font-size:.78rem;color:#7a6f64;margin:0 0 6px!important;max-width:none}
.availB-blurb{font-size:.8rem;color:#5b524a;line-height:1.45;margin:0 0 8px!important;max-width:none}
.availB-chips{list-style:none;margin:0 0 10px;padding:0;display:flex;flex-wrap:wrap;gap:5px}
.availB-chips li{font-size:.6rem;font-weight:600;color:var(--f);background:#eaf4ef;border:1px solid #cfe4da;border-radius:50px;padding:2px 8px;white-space:nowrap}
.availB-price{font-family:'Newsreader',serif;color:var(--clay-ink);font-weight:700;font-size:1.3rem;margin-bottom:12px}
.availB-btn{margin-top:auto;text-align:center;font-size:.85rem;padding:11px 14px}
.availB-c.hide{display:none}
/* FAQ-A · light bordered accordion */
.faqA{margin:8px 0 6px;display:flex;flex-direction:column;gap:8px}
.faqA-item{background:#fff;border:1px solid var(--bd);border-radius:12px;overflow:hidden;box-shadow:0 2px 10px rgba(60,30,10,.04)}
.faqA-item summary{list-style:none;cursor:pointer;display:flex;align-items:center;gap:14px;padding:15px 18px;color:#2a2622}
.faqA-item summary::-webkit-details-marker{display:none}
.faqA-q{font-family:'Newsreader',serif;font-size:1.02rem;font-weight:600;flex:1;line-height:1.3}
.faqA-x{position:relative;width:16px;height:16px;flex:none}
.faqA-x:before,.faqA-x:after{content:"";position:absolute;background:var(--clay-ink);border-radius:2px;transition:transform .2s}
.faqA-x:before{top:7px;left:0;width:16px;height:2px}
.faqA-x:after{left:7px;top:0;width:2px;height:16px}
.faqA-item[open] .faqA-x:after{transform:scaleY(0)}
.faqA-item[open] summary{border-bottom:1px solid var(--bd)}
.faqA-item p{color:#4a423b;font-size:.9rem;margin:0;padding:14px 18px 16px;max-width:none;line-height:1.6}
/* READ / BLOG cards */
.read-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:8px 0 6px}
.read-c{display:flex;gap:0;background:#fff;border:1px solid var(--bd);border-radius:16px;overflow:hidden;text-decoration:none;transition:transform .15s,box-shadow .2s}
.read-c:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(60,30,10,.12)}
.read-img{flex:0 0 148px;display:block;position:relative;overflow:hidden}
.read-img img{display:block;width:148px;height:100%;min-height:140px;object-fit:cover;transition:transform .2s}
.read-c:hover .read-img img{transform:scale(1.04)}
.read-body{display:flex;flex-direction:column;padding:14px 16px;min-width:0}
.read-kicker{font-size:.62rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#9c3a23}
.read-title{font-family:'Newsreader',serif;font-size:1.08rem;color:#2a2622;margin:4px 0 4px;line-height:1.25}
.read-c:hover .read-title{color:#9c3a23}
.read-sub{font-size:.8rem;color:#6b625a;line-height:1.45}
.read-more{font-size:.76rem;font-weight:700;color:var(--f);margin-top:auto;padding-top:10px}
/* CONTACT FORM two-column */
.form-head{max-width:640px}
.form-eyebrow{color:var(--clay-t);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px}
.form-wrap{display:grid;grid-template-columns:250px 1fr;gap:20px;margin-top:16px;align-items:start}
.form-side{background:#1c3a2e;color:#fff;border-radius:16px;padding:20px}
.fs-title{font-family:'Newsreader',serif;font-size:1.05rem;margin:0 0 12px;color:#fff}
.fs-list{list-style:none;margin:0;padding:0}
.fs-list li{display:flex;justify-content:space-between;gap:12px;font-size:.84rem;padding:8px 0;border-bottom:1px dashed rgba(255,255,255,.14);color:rgba(255,255,255,.85)}
.fs-list li b{color:#8fd3ac;white-space:nowrap}
.fs-ship{font-size:.72rem;color:rgba(255,255,255,.6);margin:12px 0 0!important}
/* ===== TABLET / MOBILE ===== */
@media(max-width:980px){
  .availB{grid-template-columns:1fr}
  .availB-side{position:static;display:flex;flex-wrap:wrap;align-items:center;gap:8px}
  .side-h{width:100%;margin:0 0 4px}
  .side-filters{flex-direction:row;flex-wrap:wrap;gap:8px;flex:1}
  .side-f{border:1.5px solid var(--bd);border-radius:50px;padding:7px 14px;font-size:.82rem}
  .side-ship{border-top:none;border-left:1px solid var(--bd);margin:0;padding:0 0 0 14px;flex-direction:column}
  .stepper-row{grid-template-columns:1fr 1fr}
}
@media(max-width:900px){
  .chero-grid{grid-template-columns:1fr;gap:14px}
  .chero-media{order:-1;aspect-ratio:16/10}
  .desk-only{display:none}
  .chero-rail{display:block}
  .congo-body{grid-template-columns:1fr;gap:0}
  .fs-nl.split{grid-template-columns:1fr}
  .fs-nl-media img{aspect-ratio:16/9;max-height:200px}
  .fs-nl-body{padding:18px 16px}
  .form-wrap{grid-template-columns:1fr}
  .form-side{order:2}
  .read-cards{grid-template-columns:1fr}
  .read-img{flex-basis:120px}
  .read-img img{width:120px}
  .availB-grid{grid-template-columns:1fr 1fr}
  .availB-photo img{height:230px;object-position:center 22%}
  .ship-cards,.quote-grid{grid-template-columns:1fr}
  .geo-cards{grid-template-columns:1fr}
  .chkB-grid{grid-template-columns:1fr;padding:10px 16px 14px}
  .chkB-head{padding:14px 16px}
  .form-2col{grid-template-columns:1fr}
  /* In-body images: container width; photos zoom a touch on mobile (taller crop), infographics stay 16:9 for their labels */
  .congo-main .sec-img{width:100%;max-width:100%;margin-left:0;border-radius:14px}
  .congo-main .sec-img.og-photo{aspect-ratio:5/4}
  .fs-video{max-width:none}
  /* TABLE A stacking */
  .otA table,.otA thead,.otA tbody,.otA tr,.otA th,.otA td{display:block}
  .otA thead{display:none}
  .otA tr{border-bottom:6px solid var(--cream)}
  .otA td{display:flex;justify-content:space-between;gap:14px;border-bottom:1px solid #f3e6de}
  .otA td:before{content:attr(data-label);font-weight:600;color:var(--mid);font-size:.72rem;letter-spacing:.02em}
  .otA td:first-child{display:block}
  .otA td:first-child:before{display:none}
}
@media(max-width:560px){.availB-grid{grid-template-columns:1fr}.stepper-row{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){.congo *{transition:none!important}}
</style>

<script>
  // Working scroll-progress dial + mobile rail
  const dial = document.getElementById('congoDial');
  const num = document.getElementById('dialNum');
  const secs = Array.from(document.querySelectorAll('.congo-main section[id]'));
  const dialLinks = dial ? Array.from(dial.querySelectorAll('a[data-i]')) : [];
  const railLinks = Array.from(document.querySelectorAll('.chero-rail .railA a'));
  const total = secs.length || 1;
  function setActive(i) {
    if (dial) dial.style.setProperty('--p', String(Math.round(((i + 1) / total) * 100)));
    if (num) num.textContent = String(i + 1);
    dialLinks.forEach((a, k) => a.classList.toggle('on', k === i));
    railLinks.forEach((a, k) => a.classList.toggle('on', k === i));
  }
  if (secs.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const i = secs.indexOf(e.target);
          if (i > -1) setActive(i);
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
    secs.forEach((s) => io.observe(s));
    setActive(0);
  }
  // Avail-B sidebar filter
  const fbtns = Array.from(document.querySelectorAll('.side-f'));
  const cards = Array.from(document.querySelectorAll('.availB-c'));
  fbtns.forEach((btn) => btn.addEventListener('click', () => {
    const cat = btn.getAttribute('data-cat');
    fbtns.forEach((b) => {
      const on = b === btn;
      b.classList.toggle('on', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
    cards.forEach((c) => c.classList.toggle('hide', cat !== 'all' && c.getAttribute('data-cat') !== cat));
  }));
</script>
