---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "African Grey Parrot For Sale Ohio | Ships to Columbus, Cleveland | Congo African Greys";
const description = "African Grey parrots for sale in Ohio. IATA-compliant shipping to Columbus, Cleveland, or Cincinnati airports. CITES documented, DNA sexed, from our Midland, TX family aviary.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-ohio/";
---

<BaseLayout {title} {description} {canonical}>
  <Header />
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Ships to Columbus &middot; Cleveland &middot; Cincinnati &middot; IATA Compliant</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-6">African Grey Parrot For Sale &mdash; Ohio</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">We ship CITES-documented African Grey parrots to Ohio buyers via IATA-compliant transport. Your bird arrives at your nearest Ohio airport for pickup.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact-us/" class="bg-gold text-logo-dark font-semibold px-8 py-4 rounded-full text-lg hover:bg-cream transition-colors">Inquire &mdash; Ohio Buyers</a>
        <a href="tel:+19565646067" class="border-2 border-gold text-gold font-semibold px-8 py-4 rounded-full text-lg hover:bg-gold hover:text-logo-dark transition-colors">Call (956) 564-6067</a>
      </div>
    </div>
  </section>
  <TrustBar />
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Shipping to Ohio</h2>
    <div class="grid sm:grid-cols-2 gap-6 text-sm text-stone-600">
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Ohio Airport Pickup</h3>
        <p>Birds ship IATA-compliant to Columbus (CMH), Cleveland (CLE), or Cincinnati (CVG). We coordinate all logistics and notify you of arrival time.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Full Documentation</h3>
        <p>Every bird arrives with CITES captive-bred certificate, hatch certificate, DNA sexing cert, and avian vet health certificate.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">3-Day Health Guarantee</h3>
        <p>All birds ship with a 3-day health guarantee and avian vet certificate dated within 10 days of shipment.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Reserve with $200 Deposit</h3>
        <p>Secure your bird with a $200 deposit. We hold your bird until shipping day and keep you updated throughout.</p>
      </div>
    </div>
  </section>
  <Schema type="local-business" />
  <CTA headline="African Grey Parrots Available for Ohio Buyers" />
  <Footer />
</BaseLayout>
