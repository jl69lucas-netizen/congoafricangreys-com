// Competitor comparison — grounded in Sprint 0 §3 (the scam-dominated egg SERP)
const compareRows = [
  { axis: "Seller identity", them: "Anonymous, keyword-named website", us: "Named breeders — Mark & Teri Benjamin, Midland, TX" },
  { axis: "USDA license", them: "None you can verify", us: "Active USDA AWA, lookup-able on APHIS" },
  { axis: "Fertility proof", them: '"100% fertile guaranteed"', us: "Candled before dispatch + dated video on request" },
  { axis: "Pricing", them: "One flat price across every species", us: "$95, honest, from named Congo lines" },
  { axis: "Hatch promise", them: '"Guaranteed hatch rate"', us: "Honest odds — no hatch is ever guaranteed" },
  { axis: "CITES paperwork", them: "Never mentioned", us: "Appendix I captive-bred documentation" },
  { axis: "Photos & video", them: "Stock or stolen images", us: "Our own nursery photos and hand-rearing video" },
];

// Avail-B sticky-sidebar filter — counts derived from real inventory (never hardcoded)
const congoCount = available.filter((b) => b.variant === "congo_african_grey" && b.sex !== "pair").length;
const timnehCount = available.filter((b) => b.variant === "timneh_african_grey").length;
const bondedCount = available.filter((b) => b.sex === "pair").length;
const filterCats = [
  { key: "all", label: "All available", n: available.length + 2 },        // birds + breeding pair + eggs
  { key: "congo", label: "Congo CAG", n: congoCount },
  { key: "timneh", label: "Timneh TAG", n: timnehCount },
  { key: "bonded", label: "Companion pair", n: bondedCount },
  { key: "breeding", label: "Breeding pair", n: 1 },
  { key: "eggs", label: "Fertile eggs", n: 1 },
];
const catFor = (b: any) => (b.sex === "pair" ? "bonded" : b.variant === "timneh_african_grey" ? "timneh" : "congo");

// Hero 2×2 photo grid (Split-Hero C) — 4 distinct egg/chick photos, per-image focal point so nothing crops out
const heroGrid = [
  { src: IMG + "real-african-grey-eggs-for-sale-hen-nest.webp", pos: "center 45%", alt: "Fertile African Grey parrot eggs under a brooding hen in our Texas nest box" },
  { src: IMG + "candling-african-grey-egg-fertility-stages.webp", pos: "center", alt: "Candling an African Grey egg reveals veins and the developing embryo" },
  { src: IMG + "african-grey-hatchlings-nest-box-aviary.webp", pos: "center 35%", alt: "African Grey hatchlings feathering out in the aviary nest box" },
  { src: IMG + "cuddly-hand-raised-african-grey-baby.webp", pos: "center 30%", alt: "A cuddly hand-raised African Grey baby, the outcome behind every fertile egg" },
];

// GEO fact tables (AI/answer-engine dense) — incubation metrics + day→milestone
const incMetrics = [
  { metric: "Incubation temperature", value: "99.5 °F (37.5 °C)", note: "Forced-air incubator, held stable" },
  { metric: "Relative humidity — days 1–25", value: "45–50%", note: "Managed for steady weight loss" },
  { metric: "Relative humidity — hatch (26–30)", value: "65–70%", note: "Raised to help the chick pip" },
  { metric: "Turning", value: "5–7× daily", note: "Automatic, until ~day 25" },
  { metric: "Incubation period", value: "28–30 days", note: "Set to external pip" },
  { metric: "Pip-to-hatch window", value: "24–72 hours", note: "Never assist early" },
];
const incMilestones = [
  { day: "Day 5", milestone: "Fine blood vessels visible on candling; embryo the size of a comma" },
  { day: "Day 10", milestone: "Spider-web of vessels + a defined air cell at the blunt end" },
  { day: "Day 18", milestone: "Dark embryo shadow fills most of the shell; movement on candling" },
  { day: "Day 25", milestone: "Turning stops; chick positions for internal pip; air cell drawn down" },
  { day: "Day 28–30", milestone: "External pip → zip → hatch over 24–72 hours; leave the chick be" },
];

// Further reading — real blog/resource pages with matching thumbnails, anchored later
const readMore = [
  { href: "/how-to-avoid-african-grey-parrot-scams/", img: IMG + "real-vs-fake-african-grey-egg-breeder-comparison-760.webp", kicker: "Scam guide", title: "How to avoid African Grey parrot scams", sub: "The 12 red flags every fake egg listing shares." },
  { href: "/baby-african-grey-parrot-for-sale/", img: IMG + "cuddly-hand-raised-african-grey-baby-760.webp", kicker: "Better path", title: "Baby African Greys for sale", sub: "Skip the incubator — reserve a weaned, hand-raised chick." },
  { href: "/blog/african-grey-parrot-price-what-you-get/", img: IMG + "egg-vs-weaned-chick-cost-success-comparison-760.webp", kicker: "Pricing", title: "African Grey price — what you actually get", sub: "Why the real cost of an egg is higher than $95." },
  { href: "/cites-african-grey-documentation/", img: IMG + "captive-bred-cites-appendix-i-egg-documentation-760.webp", kicker: "Legality", title: "CITES documentation, explained", sub: "What Appendix I paperwork travels with a captive-bred grey." },
];

const faqs = [
  { q: "How much does a fertile African Grey parrot egg cost?", a: "Our fertile African Grey parrot eggs are $95 each, and if you buy 5 eggs US shipping is free. A $200 deposit reserves a clutch. We price every egg the same across our Congo lines — flat pricing that changes by species is one of the scam tells we warn buyers about, so an honest African Grey egg price stays consistent." },
  { q: "How long do African Grey eggs take to hatch?", a: "Under correct incubation, African Grey eggs hatch in about 28–30 days, with the pip-to-hatch window running roughly 24–72 hours. That figure comes from published avian breeding data, not a marketing promise, and it assumes a stable incubator near 99°F with managed humidity and daily turning." },
  { q: "How many eggs do African Grey parrots lay?", a: "A hen typically lays a clutch of 2–4 eggs, one every other day, and begins full incubation after the second or third. That small clutch size is exactly why real fertile African Grey eggs are limited and why any listing offering unlimited flat-rate eggs across every species should raise your guard." },
  { q: "Are the parrot eggs for sale online real, or a scam?", a: "Most are a scam — our own scam guide flags the pattern. What separates a real egg program is verifiable identity: a USDA license you can look up, named breeding pairs, CITES Appendix I documentation, and candling proof. We publish all four, which is exactly what the fake egg farms cannot do." },
  { q: "How can you tell if an African Grey egg is fertile?", a: "Candling is how we tell — shining a light through the egg reveals veins by about day 5, a spider-web of vessels and an air cell by day 10, and a dark embryo shadow by day 18. We candle before dispatch and can send a dated photo or short video, so you see the fertility signs on your own clutch." },
  { q: "What incubator humidity do African Grey eggs need?", a: "Most keepers hold roughly 45–50% relative humidity for the main incubation stretch, then raise it for the final days before hatch to help the chick pip — while keeping temperature near 99°F and turning several times a day. Exact numbers vary by incubator and altitude, which is one more reason these eggs are sold for experienced breeders only, with no incubation support included." },
  { q: "Do you ship fertilized African Grey eggs near me?", a: "We ship fertile, fertilized African Grey parrot eggs nationwide from Midland, Texas — to Florida, North Carolina, South Carolina, California and every other state — in an insulated carton with a heat pack. If you live within 2–3 hours of Midland, local pickup is the gentlest option for live eggs." },
  { q: "Do you sell Congo African Grey eggs, or hatchlings, too?", a: "Yes. Our fertile eggs trace to Congo African Grey lines (Psittacus erithacus), and if you'd rather skip the incubator we also raise hatchlings through to fully weaned chicks. Most families are better served reserving a hand-raised African Grey baby than hatching an egg — and we will tell you so honestly." },
  { q: "Can I incubate African Grey parrot eggs at home?", a: "You can, but it is genuinely hard, expert work — which is why our eggs are sold for experienced breeders and no incubation support is included. A day-one chick needs round-the-clock hand-feeding. If that isn't your world yet, reserving a weaned chick is the honest, higher-success path." },
  { q: "Are captive-bred African Grey eggs legal to buy in the USA?", a: "Yes. African Greys are CITES Appendix I, and captive-bred birds and their eggs are legal to own and transfer within the United States with proper paperwork. Every egg traces to our USDA-licensed, captive-bred pairs — never wild-caught — and CITES captive-bred documentation follows the birds." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: "Fertile Congo African Grey Parrot Egg (Psittacus erithacus)",
  image: [ site + IMG + "real-african-grey-eggs-for-sale-hen-nest.webp", site + IMG + "candling-african-grey-egg-fertility-stages.webp" ],
  description: "A single fertile African Grey parrot egg from a named C.A.Gs breeding pair, candled before dispatch and shipped in an insulated carton. Sold to experienced breeders on honest hatch terms — no guaranteed-hatch claims.",
  category: "Fertile parrot hatching eggs",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  offers: { "@type": "Offer", price: "95", priceCurrency: "USD", availability: "https://schema.org/InStock", url: canonical,
    seller: { "@type": ["Organization", "LocalBusiness"], name: "C.A.Gs – Midland, TX", alternateName: "Congo African Greys" } },
};

const sections = [
  { n: "01", id: "scam", label: "Scam vs. real program", tag: "Start here" },
  { n: "02", id: "cost", label: "Price & what's included", tag: "$95" },
  { n: "03", id: "nursery", label: "Inside our nursery", tag: "Video" },
  { n: "04", id: "pairs", label: "Our breeding pairs", tag: "Named" },
  { n: "05", id: "candling", label: "Fertility, candled", tag: "Proof" },
  { n: "06", id: "incubation", label: "Incubation reality", tag: "28–30 days" },
  { n: "07", id: "shipping", label: "Packing & shipping", tag: "$185 / $350" },
  { n: "08", id: "egg-vs-chick", label: "Egg or weaned chick", tag: "The math" },
  { n: "09", id: "health", label: "Health & guarantee", tag: "PCR" },
  { n: "10", id: "legal", label: "Legal to buy?", tag: "CITES I" },
  { n: "11", id: "available", label: "Available now", tag: "Birds + eggs" },
  { n: "12", id: "stories", label: "Buyer stories", tag: "" },
  { n: "13", id: "compare", label: "How we compare", tag: "vs sellers" },
  { n: "14", id: "resources", label: "Keep reading", tag: "Guides" },
  { n: "15", id: "faq", label: "Egg FAQs", tag: "" },
  { n: "16", id: "reserve", label: "Reserve yours", tag: "24h reply" },
];
const seam = "/cag-fs-seam-emblem.webp";
---

<BaseLayout {title} {description} {canonical} ogType="product" hideGlobalCta
  heroPreload={IMG + "real-african-grey-eggs-for-sale-hen-nest.webp"}
  heroPreloadSrcset={IMG + "real-african-grey-eggs-for-sale-hen-nest-760.webp 760w, " + IMG + "real-african-grey-eggs-for-sale-hen-nest.webp 1408w"}
  heroPreloadSizes="(max-width:900px) 92vw, 520px">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="egg">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- HERO — Split-Hero C · Dark charcoal card + 2×2 photo grid -->
  <header class="egg-hero">
    <div class="container hero-grid">
      <div class="hero-card">
        <p class="eyebrow">Est. 2014 · Midland, TX · USDA-licensed</p>
        <h1 class="cag-h1">Can I <em>safely</em> buy fertile African Grey parrot eggs for sale in the USA?</h1>
        <p class="lead">Here at C.A.Gs we ship fertile African Grey parrot eggs nationwide for $95 each — candled before they leave, traced to named breeding pairs, and sold on honest hatch terms. No "guaranteed hatch," no anonymous farm — a USDA-licensed breeder you can verify in a minute.</p>
