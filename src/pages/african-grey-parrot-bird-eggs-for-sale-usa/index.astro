/* COUNTER — for-sale outlined stat cards */
.egg-counter{background:var(--cream);padding:4px 0 18px}
.counter-row{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:10px}
.cs{display:flex;flex-direction:column;gap:3px;align-items:flex-start;justify-content:center;min-height:74px;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:12px 14px;box-shadow:0 3px 12px rgba(60,30,10,.05)}
@media(max-width:1050px){.counter-row{grid-template-columns:repeat(4,1fr)}}
@media(max-width:640px){.counter-row{grid-template-columns:repeat(2,1fr)}.cs{min-height:66px}}
.counter-row b{font-family:'Newsreader',serif;font-size:1.5rem;line-height:1;color:var(--clay-ink);font-variant-numeric:tabular-nums}
.cs-l{font-size:.71rem;font-weight:600;color:var(--mid);line-height:1.25}
/* MOBILE RAIL A */
.egg-rail{position:sticky;top:var(--hdr);z-index:40;background:rgba(250,247,244,.985);border-bottom:1px solid var(--bd);box-shadow:0 6px 14px rgba(60,30,10,.07);display:none}
.railA{display:flex;gap:8px;overflow-x:auto;padding:12px 0;scrollbar-width:none}
.railA::-webkit-scrollbar{display:none}
.railA a{flex:0 0 auto;font-size:.78rem;font-weight:600;color:var(--clay-t);border:1.5px solid var(--clay);border-radius:50px;padding:7px 14px;text-decoration:none;background:#fff;white-space:nowrap}
.railA a.on{background:var(--clay-ink);border-color:var(--clay-ink);color:#fff}
.railA a .p{font-weight:700}
/* DIAL TOC */
.dial{display:flex;gap:26px;align-items:center;background:linear-gradient(135deg,#fff,#fdf1ec);border:1px solid var(--bd);border-radius:20px;padding:24px;margin:26px 0 8px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.dial-ring{flex:0 0 132px;width:132px;height:132px;border-radius:50%;background:conic-gradient(var(--clay-ink) calc(var(--p,6) * 1%),#f3d9d1 0);display:grid;place-items:center}
.dial-ring>div{width:100px;height:100px;border-radius:50%;background:#fff;display:grid;place-items:center;text-align:center;font-family:'Newsreader',serif}
.dial-ring b{font-size:28px;color:var(--clay-ink);display:block;line-height:1}
.dial-ring span{font-size:10px;color:var(--mid);letter-spacing:.08em;text-transform:uppercase}
.dial-list{flex:1;display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px 22px}
.dial-list a{display:flex;gap:9px;align-items:center;color:#2a2622;text-decoration:none;font-size:.85rem;padding:6px 6px;border-radius:10px}
.dial-list a:hover{background:#faece7}
.dial-list a.on{background:#faece7;font-weight:600}
.dial-list a.on .num{color:#9c3a23}
.dial-list .num{font-family:'Newsreader',serif;font-weight:700;color:#9c3a23;width:22px}
.dial-list .tag{margin-left:auto;font-size:.58rem;font-weight:700;letter-spacing:.03em;color:var(--f);background:#e7f1ec;border-radius:50px;padding:2px 8px;white-space:nowrap}
/* K4 / K1 */
.k4{max-width:600px;background:#fff;border:1px solid var(--bd);border-radius:16px;box-shadow:0 4px 16px rgba(60,30,10,.06);padding:34px 26px 20px;position:relative;margin:22px 0 8px}
.k4:before{content:"";position:absolute;top:-13px;left:50%;transform:translateX(-50%);width:104px;height:24px;background:var(--clay-ink);border-radius:8px}
.k4-title{font-family:'Newsreader',serif;font-size:1.15rem;line-height:1.25;margin:0 0 10px;color:#2a2622}
.k4 ul{margin:6px 0 0;padding:0}
.k4 li{list-style:none;font-size:.92rem;padding:8px 0 8px 32px;position:relative;border-bottom:1px dashed var(--bd)}
.k4 li:last-child{border-bottom:none}
.k4 li:before{content:"✓";position:absolute;left:4px;top:7px;width:20px;height:20px;border-radius:6px;background:#e7f1ec;color:var(--f);font-weight:700;display:grid;place-items:center;font-size:.8rem}
.k1{background:#fff;max-width:440px;box-shadow:0 6px 20px rgba(60,30,10,.1);padding:24px 26px 16px;border-radius:8px;margin:2px 0 18px;border:1px solid var(--bd)}
.k1-title{font-family:'Newsreader',serif;text-align:center;font-size:1.25rem;border-bottom:2px dashed var(--bd);padding-bottom:10px;margin:0 0 6px}
.k1 .row{display:flex;justify-content:space-between;gap:14px;font-size:.9rem;padding:8px 0;border-bottom:1px dotted #e6dad0}
.k1 .row b{color:var(--clay-t);white-space:nowrap}
.k1 .tot{display:flex;justify-content:space-between;font-weight:700;padding-top:12px;font-size:.98rem}
.k1 .tot span:last-child{color:var(--f)}
/* MAIN type scale */
.egg-main{max-width:880px;margin:0 auto}
.egg-main section{margin-bottom:14px;scroll-margin-top:calc(var(--hdr) + 18px);padding-top:20px}
.egg .cag-h2{font-family:'Newsreader',serif;font-size:clamp(1.375rem,3.5vw,2rem);color:#2a2622;margin:8px 0 16px;line-height:1.18}
.egg .cag-h3{font-family:'Newsreader',serif;font-size:clamp(1.125rem,2.2vw,1.5rem);color:var(--f);margin:24px 0 10px;line-height:1.25}
.egg .cag-h4{font-family:'Newsreader',serif;font-size:clamp(1rem,1.8vw,1.25rem);margin:20px 0 8px;line-height:1.3;color:#2a2622}
.egg .cag-h5{font-family:'Newsreader',serif;font-size:clamp(.95rem,1.25vw,1.05rem);margin:16px 0 6px;color:#3a332c}
.egg .cag-h6{font-family:'IBM Plex Sans',sans-serif;font-size:clamp(.75rem,.95vw,.82rem);letter-spacing:.04em;text-transform:uppercase;color:var(--clay-t);margin:16px 0 4px}
.egg-main p{line-height:1.68;margin:0 0 15px;max-width:70ch}
.egg-main a{color:var(--clay-t);text-decoration:underline;text-underline-offset:2px}
.egg-main a.btn-clay,.egg-main a.btn-ghost{text-decoration:none}
.egg-main a.btn-clay{color:#fff}
.egg-main .bird-photo,.egg-main .bird-name a,.egg-main .bird-cta a,.egg-main .ship-places a,.egg-main .pair-c a{text-decoration:none}
.sec-img{display:block;width:100%;max-width:760px;aspect-ratio:760/400;object-fit:cover;height:auto;border-radius:18px;margin:4px 0 18px;box-shadow:0 6px 20px rgba(60,30,10,.1)}
.sec-img.inf-img{aspect-ratio:1408/768;box-shadow:0 4px 16px rgba(60,30,10,.08)}
/* VIDEO */
.video-wrap{max-width:760px;margin:4px 0 18px;border-radius:18px;overflow:hidden;box-shadow:0 6px 20px rgba(60,30,10,.12);background:#1b3228}
.video-wrap video{display:block;width:100%;height:auto;aspect-ratio:1408/768;object-fit:cover}
/* SEAM — for-sale wordmark divider (new footer logo, no circle) */
.seam{display:flex;align-items:center;justify-content:center;gap:14px;margin:22px 0}
.seam::before,.seam::after{content:"";flex:1;max-width:220px;height:2px;border-radius:1px}
.seam::before{background:linear-gradient(90deg,transparent,rgba(200,71,47,.5))}
.seam::after{background:linear-gradient(90deg,rgba(200,71,47,.5),transparent)}
.seam img{width:auto;height:30px;object-fit:contain;opacity:.95}
.nl-inflow{margin:24px 0;border-radius:18px;overflow:hidden;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.nl-inflow>*{max-width:none}
/* TABLE A */
.otA{border-radius:18px;overflow:hidden;box-shadow:0 4px 16px rgba(60,30,10,.08);border:1px solid var(--bd);margin:6px 0 18px}
.otA table{border-collapse:collapse;width:100%}
.otA th{background:var(--clay-ink);color:#fff;padding:12px 14px;text-align:left;font-size:.8rem;font-weight:600}
.otA td{background:#fff;padding:12px 14px;border-bottom:1px solid #f3e6de;font-size:.86rem}
.otA tr:nth-child(even) td{background:#fdf4ef}
.otA td:first-child b{font-family:'Newsreader',serif;font-size:.98rem}
.otA .sub{display:block;font-size:.72rem;color:var(--clay-t)}
/* SHIP CARDS + HEALTH */
.ship-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 16px}
.ship-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.ship-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.ship-c>img{display:block;width:100%;height:200px;object-fit:cover}
.ship-body{padding:16px 18px}
.ship-tier{display:inline-block;background:var(--f);color:#fff;border-radius:50px;padding:3px 12px;font-size:.7rem;font-weight:600}
.ship-tier.clay{background:var(--clay-ink)}
.ship-c b{font-family:'Newsreader',serif;display:block;margin:8px 0 2px;font-size:1.15rem}
.ship-price{color:var(--clay-t);font-weight:700;font-size:1.15rem}
.ship-c p{font-size:.82rem;color:#5b524a;margin:6px 0 0!important;max-width:none}
.ship-line{font-size:.78rem;color:#7a6f64;font-weight:600;border-top:1px dashed var(--bd);padding-top:8px}
/* GEO ROUTE CARDS — for-sale shipping component (replaces comparison-style pills) */
.geo-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:6px 0 16px}
.geo-c{display:flex;align-items:center;gap:12px;background:#fff;border:1px solid var(--bd);border-radius:14px;padding:12px 14px;text-decoration:none!important;transition:transform .15s,box-shadow .2s,border-color .2s}
.geo-c:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(60,30,10,.1);border-color:var(--clay)}
.geo-pin{flex:none;width:34px;height:34px;border-radius:10px;background:#fdf0eb;color:#9c3a23;display:grid;place-items:center}
.geo-pin svg{width:17px;height:17px}
.geo-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.geo-kw{font-size:.87rem;font-weight:600;color:#2a2622;line-height:1.3}
.geo-note{font-size:.72rem;color:#7a6f64}
.geo-arrow{flex:none;color:#9c3a23;font-weight:700}
/* DOC STACK — "Every grey leaves with" (modernized) */
.doc-stack{background:linear-gradient(135deg,#fff,#fdf4ef);border:1px solid var(--bd);border-radius:18px;padding:20px 22px;margin:6px 0 16px;max-width:560px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.ds-title{font-family:'Newsreader',serif;font-size:1.15rem;margin:0 0 12px;color:#2a2622;padding-bottom:10px;border-bottom:2px solid var(--f)}
.ds-list{list-style:none;margin:0;padding:0;counter-reset:ds}
.ds-list li{counter-increment:ds;display:flex;flex-direction:column;gap:1px;padding:9px 0 9px 40px;position:relative;border-bottom:1px dashed var(--bd)}
.ds-list li:last-child{border-bottom:none}
.ds-list li::before{content:counter(ds,decimal-leading-zero);position:absolute;left:0;top:10px;font-family:'Newsreader',serif;font-weight:700;font-size:.85rem;color:#fff;background:var(--f);width:28px;height:28px;border-radius:9px;display:grid;place-items:center}
.ds-list b{font-size:.9rem;color:#2a2622}
.ds-list span{font-size:.76rem;color:#6b625a}
/* CHECKLIST B — modern hatching checklist */
.chkB{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;margin:6px 0 18px;box-shadow:0 4px 16px rgba(60,30,10,.07)}
.chkB-head{background:#221f1d;padding:16px 22px}
.chkB-eyebrow{color:#f08070;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin:0 0 3px}
.chkB-title{font-family:'Newsreader',serif;font-size:1.15rem;color:#fff;margin:0;line-height:1.25;max-width:none}
.chkB-grid{list-style:none;margin:0;padding:14px 22px 18px;display:grid;grid-template-columns:1fr 1fr;gap:2px 26px;counter-reset:chk}
.chkB-grid li{counter-increment:chk;display:flex;flex-direction:column;gap:1px;padding:10px 0 10px 36px;position:relative;border-bottom:1px dashed var(--bd)}
.chkB-grid li::before{content:"✓";position:absolute;left:0;top:11px;width:24px;height:24px;border-radius:8px;background:#e7f1ec;color:var(--f);font-weight:700;font-size:.8rem;display:grid;place-items:center}
.chkB-grid b{font-size:.88rem;color:#2a2622}
.chkB-grid span{font-size:.76rem;color:#6b625a;line-height:1.45}
/* BIRD CARDS */
.bird-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:6px 0 8px}
.bird-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;display:flex;flex-direction:column;transition:transform .15s,box-shadow .2s}
.bird-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.12)}
.bird-photo{position:relative;display:block}
.bird-photo img{display:block;width:100%;height:200px;object-fit:cover;object-position:center top}
.bird-badge{position:absolute;top:10px;left:10px;background:rgba(45,106,79,.94);color:#fff;font-size:.68rem;font-weight:600;padding:4px 11px;border-radius:50px}
.bird-body{padding:13px 15px 15px;display:flex;flex-direction:column;flex:1}
.bird-top{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:8px}
.bird-name{font-family:'Newsreader',serif;font-size:1.08rem;margin:0}
.bird-name a{color:#2a2622}
.bird-name a:hover{color:var(--clay-t)}
.bird-price{color:var(--clay-t);font-weight:700;font-size:1rem;white-space:nowrap}
.bird-docs{list-style:none;margin:0 0 12px;padding:0;display:flex;flex-wrap:wrap;gap:5px}
.bird-docs li{font-size:.62rem;font-weight:600;color:var(--f);background:#eaf4ef;border:1px solid #cfe4da;border-radius:50px;padding:3px 8px;white-space:nowrap}
.bird-cta{text-align:center;margin-top:auto}
.ship-mini{font-size:.66rem;color:#7a6f64;display:block;margin-top:10px;border-top:1px dashed var(--bd);padding-top:6px}
/* PAIR ROW */
.pair-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:0 0 16px}
.pair-c{background:#fff;border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:transform .15s,box-shadow .2s}
.pair-c:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(60,30,10,.11)}
.pair-c>img{display:block;width:100%;height:220px;object-fit:cover}
.pair-body{padding:15px 17px}
.pair-c b{font-family:'Newsreader',serif;font-size:1.1rem;display:block;margin-bottom:2px}
.pair-sub{font-size:.82rem;color:#7a6f64;display:block;margin:2px 0 10px}
.ctr{text-align:center}
/* QUOTES */
.quote-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:6px 0 4px}
.quote-c{background:#fff;border:1px solid var(--bd);border-radius:16px;padding:16px;margin:0}
.q-head{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.q-av{width:48px;height:48px;border-radius:50%;object-fit:cover;flex:none;border:2px solid #eaf4ef}
.q-id{flex:1;min-width:0}
.q-name{display:block;font-family:'Newsreader',serif;font-size:1rem;color:#2a2622;line-height:1.2}
.q-loc{display:block;font-size:.75rem;color:#7a6f64;margin-top:1px}
.stars{color:#c9a227;letter-spacing:2px;font-size:.85rem;flex:none}
.quote-c p{font-size:.9rem;font-style:italic;margin:0;max-width:none}
/* FAQ */
.faq-open{background:#fff;border:1px solid var(--bd);border-radius:12px;padding:14px 16px;margin-bottom:8px}
.faq-q{font-family:'Newsreader',serif;font-size:1rem;margin:0 0 6px;color:#2a2622}
.faq-open p{margin:0;font-size:.9rem;max-width:none}
.faq-d{background:#fff;border:1px solid var(--bd);border-radius:12px;padding:12px 16px;margin-bottom:8px}
.faq-d summary{font-family:'Newsreader',serif;font-weight:600;cursor:pointer;font-size:1rem}
.faq-d p{margin:8px 0 0;font-size:.9rem;max-width:none}
/* FORM */
.final-cta{background:var(--cream);border:1px solid var(--bd);border-radius:20px;padding:clamp(22px,4vw,36px);margin-bottom:20px}
.cta-form{display:grid;gap:12px;max-width:640px;margin:10px 0 0}
.cta-form label{display:grid;gap:5px;font-size:.85rem;font-weight:600;color:#3a332c}
.cta-form .opt{font-weight:400;color:#7a6f64}
.cta-form input,.cta-form textarea,.cta-form select{border:1.5px solid var(--bd);border-radius:12px;padding:11px 13px;font:inherit;font-weight:400;background:#fff9f6;width:100%}
.cta-form input:focus,.cta-form textarea:focus,.cta-form select:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.12)}
.form-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px}
.cta-form button{border:none;cursor:pointer}
.cta-form .btn-ghost{border:2px solid var(--f);color:var(--f);padding:11px 22px}
.cta-form .btn-ghost:hover{background:var(--f);color:#fff}
.form-note{font-size:.8rem;color:#7a6f64;margin:2px 0 0!important}
.hp{position:absolute;left:-9999px}
/* NEWSLETTER — for-sale */
.fs-nl{margin:24px 0;border-radius:20px;overflow:hidden;box-shadow:0 6px 22px rgba(60,30,10,.08)}
.fs-nl.banner{background:linear-gradient(135deg,#221f1d,#2f2926);color:#fff}
.fs-nl.banner .fs-nl-inner{padding:clamp(18px,3vw,28px) clamp(18px,3.4vw,34px);max-width:820px}
.fs-nl.split{display:grid;grid-template-columns:minmax(0,320px) 1fr;background:#fff;border:1px solid var(--bd)}
.fs-nl-media{position:relative}
.fs-nl-media img{display:block;width:100%;height:100%;object-fit:cover;aspect-ratio:1408/768}
.fs-nl-cap{position:absolute;left:12px;bottom:12px;background:rgba(34,31,29,.8);color:#fff;font-size:.68rem;font-weight:600;padding:4px 11px;border-radius:50px}
.fs-nl-body{padding:clamp(20px,3vw,30px)}
.fs-nl-eyebrow{color:var(--clay-t);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px}
.fs-nl.banner .fs-nl-eyebrow{color:#f08070}
.fs-nl-h{font-family:'Newsreader',serif;font-size:clamp(1.15rem,2.2vw,1.45rem);line-height:1.2;margin:0 0 6px;color:#2a2622}
.fs-nl.banner .fs-nl-h{color:#fff}
.fs-nl-sub{font-size:.86rem;line-height:1.55;margin:0 0 14px!important;max-width:62ch;color:#5b524a}
.fs-nl.banner .fs-nl-sub{color:rgba(255,255,255,.82)}
.fs-nl-form{display:flex;gap:10px;flex-wrap:wrap}
.fs-nl-form input{flex:1;min-width:200px;border:1.5px solid var(--bd);border-radius:50px;padding:12px 18px;font:inherit;background:#fff;color:#2a2622}
.fs-nl.banner .fs-nl-form input{border-color:rgba(255,255,255,.25)}
.fs-nl-form input:focus{outline:none;border-color:var(--clay);box-shadow:0 0 0 3px rgba(232,96,76,.15)}
.fs-nl-form button{border:none;cursor:pointer}
.fs-nl-note{font-size:.74rem;color:var(--mid);margin:10px 0 0!important}
.fs-nl.banner .fs-nl-note{color:rgba(255,255,255,.6)}
/* VIDEO — for-sale component */
.fs-video{margin:6px 0 18px;max-width:760px}
.fs-video-frame{position:relative;border-radius:18px;overflow:hidden;box-shadow:0 8px 26px rgba(60,30,10,.16);background:#1b1815}
.fs-video-frame video{display:block;width:100%;height:auto;aspect-ratio:1408/768;object-fit:cover}
.fs-video-tag{position:absolute;top:12px;left:12px;background:rgba(34,31,29,.82);color:#fff;font-size:.68rem;font-weight:600;letter-spacing:.04em;padding:5px 12px;border-radius:50px;pointer-events:none}
.fs-video figcaption{font-size:.8rem;color:var(--mid);margin-top:8px;font-style:italic}
/* AVAIL-B — sticky sidebar filter */
.availB{display:grid;grid-template-columns:200px 1fr;gap:18px;margin:6px 0;align-items:start}
.availB-side{position:sticky;top:calc(var(--hdr) + 14px);background:#fff;border:1px solid var(--bd);border-radius:18px;padding:16px;box-shadow:0 4px 16px rgba(60,30,10,.06)}
.side-h{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);margin:0 0 12px}
.side-filters{display:flex;flex-direction:column;gap:4px}
.side-f{display:flex;align-items:center;justify-content:space-between;gap:10px;background:none;border:1.5px solid transparent;border-radius:10px;padding:9px 12px;font:inherit;font-size:.9rem;font-weight:600;color:#2a2622;cursor:pointer;text-align:left;transition:background-color .15s,border-color .15s}
.side-f:hover{background:#faece7}
.side-f.on{border-color:var(--clay);color:var(--clay-ink)}
.side-n{font-size:.72rem;font-weight:700;color:var(--mid);background:#f4efe9;border-radius:50px;min-width:24px;text-align:center;padding:2px 8px}
.side-f.on .side-n{background:var(--clay-ink);color:#fff}
.side-ship{border-top:1px solid var(--bd);margin-top:12px;padding-top:12px;display:flex;flex-direction:column;gap:8px}
.side-ship p{font-size:.78rem;color:#5b524a;margin:0!important;display:flex;align-items:center;gap:8px;max-width:none}
.side-ship svg{color:var(--clay-t);flex:none;width:15px;height:15px}
.side-ship b{color:#2a2622}
.side-note{font-size:.76rem;color:#7a6f64;font-weight:600;margin:6px 0 14px;text-align:center}
.availB-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
