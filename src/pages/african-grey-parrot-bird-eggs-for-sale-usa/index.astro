---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "Fertilized African Grey Eggs for Sale | Fertile Parrot Eggs — C.A.Gs, Midland TX | Ships Nationwide";
const description = "Fertile, fertilized African grey parrot eggs for sale. Candle-tested, $40/egg. From CITES-documented breeding pairs. USDA-licensed. African grey eggs near me — ships USA-wide.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-bird-eggs-for-sale-usa/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">100% Fertile · Candle-Tested · Ships Nationwide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">African Grey Parrot Bird Eggs For Sale</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Premium-quality fertile African Grey parrot eggs collected from healthy, CITES-documented breeding pairs. Candle-tested and ready to hatch.</p>
    </div>
  </section>

  <!-- Product listing -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Images -->
      <div class="space-y-4">
        <img
          src="https://congoafricangreys.com/wp-content/uploads/african-grey-parrot-bird-eggs-for-sale-candled.jpg"
          alt="Candled African Grey parrot bird eggs for sale"
          class="w-full rounded-2xl shadow-md"
          loading="eager"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/healthy-african-grey-parrot-eggs.jpg"
          alt="Healthy African Grey parrot eggs ready to hatch"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/african-grey-parrot-egg-clutch-600x450.jpg"
          alt="Clutch of African Grey parrot eggs"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Pricing card -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8 sticky top-24">
        <div class="mb-2">
          <span class="bg-clay text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">Sale</span>
        </div>
        <h2 class="font-lora font-bold text-2xl text-logo-dark mb-1">African Grey Parrot Eggs</h2>
        <p class="text-stone-500 text-sm mb-6">100% fertile · candle-tested · CITES breeding pairs</p>

        <!-- Pricing table -->
        <div class="border border-stone-200 rounded-xl overflow-hidden mb-6">
          <div class="flex items-center justify-between p-4 bg-stone-50 border-b border-stone-200">
            <span class="font-semibold text-logo-dark text-sm">Quantity</span>
            <span class="font-semibold text-logo-dark text-sm">Price per Egg</span>
          </div>
          <div class="flex items-center justify-between p-4 border-b border-stone-100">
            <span class="text-stone-600 text-sm">1–19 eggs</span>
            <span class="font-lora font-bold text-clay">$40 / egg</span>
          </div>
          <div class="flex items-center justify-between p-4">
            <span class="text-stone-600 text-sm">20+ eggs (bulk)</span>
            <span class="font-lora font-bold text-clay">$35 / egg</span>
          </div>
        </div>

        <ul class="text-sm text-stone-600 space-y-2 mb-8">
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ships within 7 days of laying</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Candle-tested — 100% fertility verified</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Includes hatching &amp; incubation guide</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Expert post-purchase support</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> From CITES-documented breeding pairs</li>
        </ul>
        <a
          href="/contact-us/"
          class="block text-center bg-clay text-white font-semibold py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
        >
          Order Eggs — Inquire Now
        </a>
        <p class="text-xs text-stone-400 text-center mt-3">We reply within 24–48 hours · Nationwide shipping available</p>
      </div>
    </div>
  </section>

  <!-- Incubation guide -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Incubation Guide — Hatching Your African Grey</h2>
      <p class="text-stone-600 leading-relaxed mb-6">
        African Grey parrot eggs typically hatch in 25–28 days. The female lays 3–5 eggs per clutch (one per day) and begins incubating after the second egg. With the right setup, you can successfully hatch and hand-raise your own baby African Grey.
      </p>
      <div class="grid sm:grid-cols-3 gap-6 mb-8">
        {[
          { label: 'Incubation Period', value: '25–28 days' },
          { label: 'Clutch Size', value: '3–5 eggs' },
          { label: 'Laying Pattern', value: '1 egg / day' },
        ].map(stat => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-stone-100 text-center">
            <p class="font-lora font-bold text-2xl text-clay mb-1">{stat.value}</p>
            <p class="text-stone-500 text-sm">{stat.label}</p>
          </div>
        ))}
      </div>
      <h3 class="font-lora font-semibold text-logo-dark text-lg mb-4">Recommended Incubator Settings</h3>
      <ul class="text-stone-600 text-sm space-y-2">
        <li class="flex items-center gap-2"><span class="text-gold">✔</span> Digital temperature control (99.5°F / 37.5°C)</li>
        <li class="flex items-center gap-2"><span class="text-gold">✔</span> Automatic egg turner</li>
        <li class="flex items-center gap-2"><span class="text-gold">✔</span> Humidity control (55–65% RH)</li>
        <li class="flex items-center gap-2"><span class="text-gold">✔</span> Use an incubator designed for exotic bird eggs</li>
      </ul>
    </div>
  </section>

  <!-- Why our eggs -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Why Choose C.A.Gs Fertile Eggs?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Candle-Tested Fertility', body: 'Every egg is candled before shipping to verify 100% fertility — we never ship unfertilized eggs.' },
          { title: 'Fresh from Healthy Pairs', body: 'Collected only from top-quality, CITES-documented Congo African Grey breeding pairs with a track record of healthy clutches.' },
          { title: 'Ships Within 7 Days', body: 'Eggs ship within 7 days of laying for optimal freshness and hatchability.' },
          { title: 'Expert Support Included', body: 'We guide you through incubation, hatching, and early chick care — you\'re never alone in this process.' },
        ].map(card => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-stone-100">
            <h3 class="font-lora font-semibold text-logo-dark mb-2">{card.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much do African Grey parrot eggs cost?', a: '$40 per egg for orders of 1–19 eggs. $35 per egg for bulk orders of 20 or more. Contact us to confirm current availability.' },
          { q: 'Are the eggs really 100% fertile?', a: 'Yes — every egg is candle-tested before shipping. We only ship verified fertile eggs. If an egg arrives damaged, contact us immediately.' },
          { q: 'How long does hatching take?', a: 'African Grey eggs typically hatch in 25–28 days under proper incubation conditions (99.5°F, 55–65% humidity with automatic turning).' },
          { q: 'Do you provide incubation support?', a: 'Yes — every egg order includes our detailed hatching guide and post-purchase email support from our avian team.' },
          { q: 'Are the parent birds CITES documented?', a: 'Yes — all our breeding pairs are CITES Appendix II captive-bred. We are USDA AWA licensed and can provide full breeding pair documentation on request.' },
          { q: 'Do you sell fertilized African grey eggs near me?', a: 'We ship fertile, fertilized African grey parrot eggs to all 50 states from our aviary in Midland, Texas. Whether you\'re in Florida, California, Texas, or New York — we can ship directly to you.' },
          { q: 'Can I buy fertile exotic bird eggs for sale online?', a: 'Yes. C.A.Gs sells fertile African grey parrot eggs online with nationwide IATA-compliant shipping. Each order includes candle-test verification, our incubation guide, and expert support.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />
  <CTA headline="Order Fertile Eggs Today" sub="100% candle-tested. From CITES-documented breeding pairs. Expert hatching support included." />
  <Schema type="organization" />

</BaseLayout>
