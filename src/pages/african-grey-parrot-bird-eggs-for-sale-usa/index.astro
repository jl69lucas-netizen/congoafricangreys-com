</style>

<script>
  // Working scroll-progress dial + mobile rail
  const dial = document.getElementById('eggDial');
  const num = document.getElementById('dialNum');
  const secs = Array.from(document.querySelectorAll('.egg-main section[id]'));
  const dialLinks = dial ? Array.from(dial.querySelectorAll('a[data-i]')) : [];
  const railLinks = Array.from(document.querySelectorAll('.egg-rail .railA a'));
  const total = secs.length || 1;
  function setActive(i) {
    if (dial) dial.style.setProperty('--p', String(Math.round(((i + 1) / total) * 100)));
    if (num) num.textContent = String(i + 1);
    dialLinks.forEach((a, k) => a.classList.toggle('on', k === i));
    railLinks.forEach((a, k) => a.classList.toggle('on', k === i));
  }
  if (secs.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const i = secs.indexOf(e.target);
          if (i > -1) setActive(i);
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
    secs.forEach((s) => io.observe(s));
    setActive(0);
  }
  // Avail-B sidebar filter
  const fbtns = Array.from(document.querySelectorAll('.side-f'));
  const cards = Array.from(document.querySelectorAll('.availB-c'));
  fbtns.forEach((btn) => btn.addEventListener('click', () => {
    const cat = btn.getAttribute('data-cat');
    fbtns.forEach((b) => {
      const on = b === btn;
      b.classList.toggle('on', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
    cards.forEach((c) => c.classList.toggle('hide', cat !== 'all' && c.getAttribute('data-cat') !== cat));
  }));
</script>
