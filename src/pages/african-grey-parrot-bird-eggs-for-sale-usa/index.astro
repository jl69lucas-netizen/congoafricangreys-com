---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "Fertile African Grey Parrot Eggs for Sale in the USA — Candled, Documented, Shipped | C.A.Gs, Midland TX";
const description = "Fertile African Grey parrot eggs for sale from our USDA-licensed Texas aviary — $95 each, candled before dispatch, from named CITES Appendix I pairs. Honest hatch terms, nationwide shipping.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-bird-eggs-for-sale-usa/";

const IMG = "/images/egg-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "African Grey Eggs for Sale", url: "/african-grey-parrot-bird-eggs-for-sale-usa/" },
];

// Real inventory for the reserve form + cross-sell (never hardcoded).
const available = clutch.birds.filter((b) => b.status === "available");

const sections = [
  { n: "01", id: "scam", label: "Scam vs. real program", tag: "Start here" },
  { n: "02", id: "cost", label: "Price & what's included", tag: "$95" },
  { n: "03", id: "shipping", label: "How we pack & ship", tag: "Nationwide" },
  { n: "04", id: "pairs", label: "Our breeding pairs", tag: "Named" },
  { n: "05", id: "candling", label: "Fertility, candled", tag: "Proof" },
  { n: "06", id: "incubation", label: "Incubation reality", tag: "28–30 days" },
  { n: "07", id: "egg-vs-chick", label: "Egg or weaned chick", tag: "The math" },
  { n: "08", id: "legal", label: "Legal to buy?", tag: "CITES I" },
  { n: "09", id: "faq", label: "Egg FAQs", tag: "" },
  { n: "10", id: "reserve", label: "Reserve yours", tag: "24h reply" },
];

// Product + Offer (the egg is the primary product) — honest availability, no fabricated rating.
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Fertile Congo African Grey Parrot Egg (Psittacus erithacus)",
  image: [
    site + IMG + "fertile-african-grey-parrot-eggs-for-sale-usa.webp",
    site + IMG + "candling-african-grey-egg-fertility-stages.webp",
  ],
  description:
    "A single fertile African Grey parrot egg from a named C.A.Gs breeding pair, candled before dispatch and shipped in an insulated carton. Sold to experienced breeders on honest hatch terms — no guaranteed-hatch claims.",
  category: "Fertile parrot hatching eggs",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  offers: {
    "@type": "Offer",
    price: "95",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: canonical,
    seller: {
      "@type": ["Organization", "LocalBusiness"],
      name: "C.A.Gs – Midland, TX",
      alternateName: "Congo African Greys",
    },
  },
};

const faqs = [
  {
    q: "How much does a fertile African Grey parrot egg cost?",
    a: "Our fertile African Grey parrot eggs are $95 each, and if you buy 5 eggs US shipping is free. A $200 deposit reserves a clutch. We price every egg the same across our Congo lines — flat pricing that changes by species is one of the scam tells we warn buyers about.",
  },
  {
    q: "How long do African Grey eggs take to hatch?",
    a: "Under correct incubation, African Grey eggs hatch in about 28–30 days, with the pip-to-hatch window running roughly 24–72 hours. That figure comes from published avian breeding data, not a marketing promise, and it assumes a stable incubator at ~99°F with managed humidity and daily turning.",
  },
  {
    q: "Are the parrot eggs for sale online real, or a scam?",
    a: "Most of them are a scam — our own scam guide flags the pattern. What separates a real egg program is verifiable identity: a USDA license you can look up, named breeding pairs, CITES Appendix I documentation, and candling proof. We publish all four, which is exactly what the fake egg farms cannot do.",
  },
  {
    q: "How can you tell if an African Grey egg is fertile?",
    a: "Candling is how we tell — shining a light through the egg reveals veins by about day 5, a spider-web of vessels and an air cell by day 10, and a dark embryo shadow by day 18. We candle before dispatch and can send a dated photo or short video on request, so you see the fertility signs yourself.",
  },
  {
    q: "Do you ship fertilized African Grey eggs near me?",
    a: "We ship fertile, fertilized African Grey parrot eggs nationwide from Midland, Texas — to Florida, California, New York, North Carolina and every other state — in an insulated carton with a heat pack. If you live within 2–3 hours of Midland, local pickup is the gentlest option for live eggs.",
  },
  {
    q: "Can I incubate African Grey parrot eggs at home?",
    a: "You can, but it is genuinely hard, expert work — which is why our eggs are sold for experienced breeders and no incubation support is included. A day-one chick needs round-the-clock hand-feeding. If that isn't your world yet, reserving a weaned chick is the honest, higher-success path, and we'll say so.",
  },
  {
    q: "Are captive-bred African Grey eggs legal to buy in the USA?",
    a: "Yes. African Greys are CITES Appendix I, and captive-bred birds and their eggs are legal to own and transfer within the United States with proper paperwork. Every egg traces to our USDA-licensed, captive-bred pairs — never wild-caught — and CITES captive-bred documentation follows the birds.",
  },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const crossSell = [
  { name: "Bery", photo: "bery-congo-african-grey-female-1-year-card.webp", price: "$1,700", sub: "Congo hen · 1 yr", slug: "/available/bery/", alt: "Bery, a hand-raised Congo African Grey hen available as a weaned chick" },
  { name: "Roys", photo: "roys-congo-african-grey-male-tame-card.webp", price: "$2,300", sub: "Congo cock · 4 mo", slug: "/available/roys/", alt: "Roys, a hand-raised Congo African Grey cock ready to reserve" },
  { name: "Evie", photo: "evie-timneh-african-grey-female-6-months.webp", price: "$1,500", sub: "Timneh hen · 6 mo", slug: "/available/evie/", alt: "Evie, a hand-raised Timneh African Grey hen available now" },
];
---

<BaseLayout {title} {description} {canonical} ogType="product" hideGlobalCta
  heroPreload={IMG + "fertile-african-grey-parrot-eggs-for-sale-usa.webp"}
  heroPreloadSrcset={IMG + "fertile-african-grey-parrot-eggs-for-sale-usa-760.webp 760w, " + IMG + "fertile-african-grey-parrot-eggs-for-sale-usa.webp 1408w"}
  heroPreloadSizes="(max-width:900px) 92vw, 520px">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="egg">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- HERO — Split-Hero C (dark + photo grid) -->
  <header class="egg-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Candled before dispatch · CITES Appendix I · USDA-licensed aviary</p>
        <h1 class="cag-h1">Fertile African Grey Parrot Eggs for Sale in the USA — Candled, Documented, Shipped From Our Texas Aviary</h1>
        <p class="lead">Here at C.A.Gs in Midland, Texas, we ship fertile African Grey parrot eggs nationwide for $95 each — candled before they leave, traced to named breeding pairs, and sold on honest hatch terms. No "guaranteed hatch," no anonymous farm, just a USDA-licensed breeder you can verify in a minute.</p>
        <div class="hero-cta">
          <a class="btn-clay" href="#reserve">Reserve fertile eggs &rarr;</a>
          <a class="btn-ghost" href="#scam">Is this a scam? Read first</a>
        </div>
      </div>
      <div class="hero-media">
        <img class="hero-photo"
          src={IMG + "fertile-african-grey-parrot-eggs-for-sale-usa.webp"}
          srcset={IMG + "fertile-african-grey-parrot-eggs-for-sale-usa-760.webp 760w, " + IMG + "fertile-african-grey-parrot-eggs-for-sale-usa.webp 1408w"}
          sizes="(max-width:900px) 92vw, 520px"
          width="1408" height="768" fetchpriority="high" decoding="async"
          alt="Fertile African Grey parrot eggs for sale in the USA in a breeder nest box" />
      </div>
    </div>
  </header>

  <!-- COUNTER — Ledger-verified only -->
  <div class="egg-counter">
    <div class="container counter-row">
      <span class="cs"><b>$95</b><span class="cs-l">Per fertile egg</span></span>
      <span class="cs"><b>5</b><span class="cs-l">Eggs = free US ship</span></span>
      <span class="cs"><b>28–30</b><span class="cs-l">Days to hatch</span></span>
      <span class="cs"><b>App. I</b><span class="cs-l">CITES documented</span></span>
      <span class="cs"><b>USDA</b><span class="cs-l">Licensed aviary</span></span>
      <span class="cs"><b>0</b><span class="cs-l">Wild-caught, ever</span></span>
      <span class="cs"><b>24h</b><span class="cs-l">Inquiry reply</span></span>
    </div>
  </div>

  <!-- MOBILE JUMP RAIL — Rail A price-chip -->
  <nav class="egg-rail" aria-label="On this page">
    <div class="container railA">
      {sections.map((s, i) => (
        <a href={`#${s.id}`} class={i === 0 ? "on" : ""}><span class="p">{s.n}</span> {s.label}</a>
      ))}
    </div>
  </nav>

  <div class="container">

    <!-- DESKTOP DIAL TOC -->
    <nav class="dial desk-only" aria-label="Contents">
      <div class="dial-ring"><div><b>10</b><span>Sections</span></div></div>
      <div class="dial-list">
        {sections.map((s) => (
          <a href={`#${s.id}`}><span class="num">{s.n}</span>{s.label}{s.tag && <span class="tag">{s.tag}</span>}</a>
        ))}
      </div>
    </nav>

    <!-- K4 CLIPBOARD — proof takeaway -->
    <div class="k4" role="note" aria-label="What makes our egg program verifiable">
      <p class="k4-title">Why our egg program isn't the usual online scam</p>
      <ul>
        <li>USDA Animal Welfare Act license you can look up yourself</li>
        <li>Named Congo &amp; Timneh breeding pairs — not an anonymous "farm"</li>
        <li>Candled before dispatch, with a dated photo or video on request</li>
        <li>CITES Appendix I captive-bred documentation on every bird</li>
        <li>Honest hatch odds — we never claim "100% fertile" or a guaranteed hatch</li>
      </ul>
    </div>

    <main class="egg-main">

      <!-- 1 · SCAM VS REAL -->
      <section id="scam">
        <h2 class="cag-h2">Why are almost all "African Grey eggs for sale" listings a scam — and how are we different?</h2>
        <p>Buying fertile African Grey parrot eggs online is a minefield, and we'd rather lose a sale than pretend otherwise: nearly every egg listing you'll find is a fake-farm scam, a fact our own <a href="/how-to-avoid-african-grey-parrot-scams/">scam-prevention guide documents in detail</a>. The whole point of this page is to show you what a real, verifiable egg program looks like — because "different from those listings" is the only claim worth making here.</p>
        <img class="sec-img inf-img"
          src={IMG + "real-vs-fake-african-grey-egg-breeder-comparison.webp"}
          srcset={IMG + "real-vs-fake-african-grey-egg-breeder-comparison-760.webp 760w, " + IMG + "real-vs-fake-african-grey-egg-breeder-comparison.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="Comparison of real African Grey egg breeders versus fake egg-farm scam patterns" />

        <h3 class="cag-h3">What does a fake egg farm actually look like?</h3>
        <p>A fake egg farm is a keyword-stuffed website with no human behind it, and once you know the shape it's easy to spot: flat pricing across wildly different species, "free cage" bundled with an egg, and a promise no biologist would make. We call these out so you can walk past them, even the ones we don't run.</p>

        <h4 class="cag-h4">The five red flags every fake listing shares</h4>
        <p>These five tells — an anonymous seller, one flat price for Greys and macaws alike, a "100% fertile / guaranteed hatch" promise, a free-cage or gift hook, and no verifiable license — travel together on the scam pages. Real breeders fail at least one of them on purpose, because reality doesn't come with guarantees.</p>

        <h5 class="cag-h5">Why no honest breeder promises "100% fertile"</h5>
        <p>No honest breeder promises "100% fertile," and here's the biology: fertility is confirmed by candling days into incubation, not at the moment of sale, and even a fertile egg can quit. When a listing guarantees a hatch, it's guaranteeing something nature doesn't — which is why that phrase is a scam tell, not a selling point.</p>

        <h3 class="cag-h3" id="verify">How can you verify C.A.Gs in 60 seconds?</h3>
        <p>Verification is the antidote to egg-scam anxiety, and ours takes about a minute. Because we are a USDA Animal Welfare Act–licensed aviary in Midland, Texas, you can confirm we exist before you send a cent — something no fake farm can survive.</p>
        <img class="sec-img inf-img"
          src={IMG + "verify-usda-bird-breeder-license-steps.webp"}
          srcset={IMG + "verify-usda-bird-breeder-license-steps-760.webp 760w, " + IMG + "verify-usda-bird-breeder-license-steps.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="Three steps to verify a USDA bird breeder license before buying eggs" />

        <h4 class="cag-h4">Look up our USDA license yourself</h4>
        <p><a href="https://aphis.usda.gov/aphis/ourfocus/animalwelfare" target="_blank" rel="noopener">The USDA APHIS public search</a> is where you start: open the Animal Welfare Act license lookup, search our aviary, and match the name and active status. It's the fastest legitimacy check in the hobby, and we invite it.</p>

        <h5 class="cag-h5">What the APHIS public record shows</h5>
        <p>The APHIS record shows an active, licensed breeder tied to a real Texas address — not a stock-photo farm. Matching that public record against what we tell you is how a careful buyer separates C.A.Gs from the listings ranking beside us.</p>

        <h6 class="cag-h6">Breeder note — our facility &amp; contact of record</h6>
        <p>We are C.A.Gs (Congo African Greys), owned by Mark &amp; Teri Benjamin, a family aviary in Midland, TX 79707, operating since 2014. That NAP is the one on our USDA record and our <a href="/contact-us/">contact page</a> — if a listing's details don't match its paperwork, that's your answer.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 2 · COST -->
      <section id="cost">
        <h2 class="cag-h2">How much do fertile African Grey eggs cost, and what's included?</h2>
        <p>Our fertile African Grey parrot eggs are $95 each — a single, honest, same-across-our-Congo-lines price, because flat pricing that jumps by species is itself a scam tell. That $95 buys a candled egg from a named pair, packed for transit; it does not buy a hatch guarantee, and we'd rather say that plainly than sell you a fantasy.</p>
        <img class="sec-img inf-img"
          src={IMG + "african-grey-egg-clutch-price-candling.webp"}
          srcset={IMG + "african-grey-egg-clutch-price-candling-760.webp 760w, " + IMG + "african-grey-egg-clutch-price-candling.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="African Grey egg clutch priced at $95 each with a candling torch" />

        <div class="k1" role="note" aria-label="African Grey egg pricing summary">
          <p class="k1-title">African Grey egg pricing</p>
          <div class="row"><span>Single fertile egg</span><b>$95</b></div>
          <div class="row"><span>Buy 5 eggs</span><b>Free US shipping</b></div>
          <div class="row"><span>Deposit to reserve a clutch</span><b>$200</b></div>
          <div class="row"><span>Candling before dispatch</span><b>Included</b></div>
          <div class="row"><span>Incubation support</span><b>Not included</b></div>
          <div class="tot"><span>Sold to</span><span>Experienced breeders</span></div>
        </div>

        <h3 class="cag-h3">What does $95 an egg actually buy you?</h3>
        <p>The $95 covers a fertile Congo African Grey egg that we've candled and confirmed developing, drawn from a specific breeding pair we can name, and cradled for shipping. What it deliberately doesn't cover is hand-holding through incubation — these eggs are for breeders who already run an incubator, so you're paying for a genuine egg, not a course.</p>

        <h4 class="cag-h4">Buy 5 eggs and US shipping is free</h4>
        <p>Ordering five fertile African Grey eggs waives the shipping fee across the continental US, which is how most serious breeders buy — a full clutch gives incubation the redundancy a single egg can't. It's a real discount on volume, not a "buy more, get a free bird" gimmick.</p>

        <h5 class="cag-h5">Deposit &amp; reservation terms</h5>
        <p>A $200 deposit reserves a clutch against a confirmed laying, and we hold eggs only when we truly have them — honest availability beats a permanent "in stock" button. Exact refund-versus-replacement wording is confirmed with you in writing before you pay, never buried in fine print.</p>

        <h6 class="cag-h6">Citation — figures from our live price list</h6>
        <p>Every number here is pulled from our current C.A.Gs price list, the same source behind our <a href="/african-grey-parrot-price/">full African Grey pricing guide</a>. If a figure ever differs between pages, the price list governs and we correct the page.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 3 · SHIPPING -->
      <section id="shipping">
        <h2 class="cag-h2">How do we pack and ship African Grey eggs nationwide?</h2>
        <p>Shipping live eggs is the part scammers gloss over and we don't, because packaging is where hatchability is won or lost: we cradle each fertile egg in a foam-lined insulated carton with a heat pack and a handling card, then move it on the fastest honest transit we can. Even done right, shipped eggs carry more risk than local pickup — and you deserve to hear that before you order.</p>
        <img class="sec-img inf-img"
          src={IMG + "insulated-carton-parrot-egg-nationwide-shipping.webp"}
          srcset={IMG + "insulated-carton-parrot-egg-nationwide-shipping-760.webp 760w, " + IMG + "insulated-carton-parrot-egg-nationwide-shipping.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="Insulated carton packing fertile parrot eggs for safe nationwide shipping" />

        <h3 class="cag-h3">What does arrival day look like?</h3>
        <p>Arrival day is a rest-and-settle day, not an incubate-immediately scramble: we tell buyers to let shipped eggs sit pointed-end-up at room temperature for several hours so the air cell restabilizes before setting. That single instruction — which the fake farms never send — protects the clutch you paid for.</p>

        <h4 class="cag-h4">Insulated carton, heat pack, and transit window</h4>
        <p>The carton pairs foam egg cradles with a warming pack sized to the season, and we aim for the shortest realistic transit window because time in transit is the enemy of a viable egg. We confirm the carrier and the promised window with you before dispatch, so nothing about delivery is a surprise.</p>

        <h5 class="cag-h5">An honest word on shipping risk to live eggs</h5>
        <p>Here's the honest warning: parrot eggs are fragile cargo, and jostling, cold, or delay can end development even with perfect packing. If you live within 2–3 hours of Midland, TX, we'll steer you to <a href="/contact-us/">local pickup</a> instead — the gentlest handoff a fertile egg can get.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 4 · BREEDING PAIRS -->
      <section id="pairs">
        <h2 class="cag-h2">Which breeding pairs do our fertile eggs come from?</h2>
        <p>Named parents are the difference between a real egg program and a photo library, so we tell you whose clutch you're buying: our fertile eggs come from established Congo pairs like James &amp; Lois and our Timneh pair Levi &amp; Rily, birds we raise and health-screen ourselves. Traceable parentage is exactly what an anonymous farm can never offer.</p>
        <img class="sec-img inf-img"
          src={IMG + "congo-african-grey-breeding-pair-nest-box.webp"}
          srcset={IMG + "congo-african-grey-breeding-pair-nest-box-760.webp 760w, " + IMG + "congo-african-grey-breeding-pair-nest-box.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="Congo African Grey breeding pair whose clutch produces our fertile eggs" />

        <h3 class="cag-h3">Our named Congo &amp; Timneh pairs</h3>
        <p>Each producing pair in our aviary is a known quantity — bonded, mature adults with a track record we can speak to, not rotating stock. Because we breed both variants, an egg can trace to a Congo line (Psittacus erithacus) or a Timneh line (Psittacus timneh), and we tell you which.</p>

        <h4 class="cag-h4">Parentage, bounded to what we can document</h4>
        <p>We only claim parentage we can actually stand behind, so if we're not certain of a specific pairing we say "Congo line" rather than invent two names. That restraint is deliberate — overclaiming a pedigree is how the fake listings pad their pages, and we won't borrow the tactic.</p>

        <h5 class="cag-h5">PBFD &amp; Polyomavirus PCR-screened lines</h5>
        <p>Our breeding birds are PCR-screened for PBFD (Psittacine Beak and Feather Disease) and Avian Polyomavirus, with negatives required before placement, so the genetics behind your egg come from a health-tested foundation. It's the same screening standard behind every hand-raised chick we place.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 5 · CANDLING -->
      <section id="candling">
        <h2 class="cag-h2">How do we prove an African Grey egg is fertile before it ships?</h2>
        <p>Candling is our proof of fertility, and we do it before an egg ever leaves the aviary: passing a bright light through the shell reveals the developing embryo, so "fertile" is something we've seen, not something we've asserted. On request we'll send you a dated candling photo or short video of your own clutch — the transparency the scam farms structurally can't provide.</p>
        <img class="sec-img inf-img"
          src={IMG + "candling-african-grey-egg-fertility-stages.webp"}
          srcset={IMG + "candling-african-grey-egg-fertility-stages-760.webp 760w, " + IMG + "candling-african-grey-egg-fertility-stages.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="Candling an African Grey egg shows veins, air cell and embryo development by day" />

        <h3 class="cag-h3">What does candling reveal by day 5, 10 and 18?</h3>
        <p>Candling tells a developmental story on a schedule: fine veins appear around day 5, a web of vessels and a defined air cell by day 10, and a dark embryo shadow with a large air cell by day 18. Reading those stages is how we confirm an egg is truly progressing before we pack it.</p>

        <h4 class="cag-h4">Dated candling photo or video on request</h4>
        <p>Ask and we'll document it: a timestamped candling image or clip of your clutch, so your first fertility check happens before shipping, not after a loss. That single file resolves most egg-scam fear on its own, which is precisely why we offer it up front.</p>

        <h5 class="cag-h5">Veins, air cell and embryo — what we look for</h5>
        <p>Under the light we're reading three things — branching blood vessels, a clean air cell at the blunt end, and embryo movement or shadow — and a clear or "candle-through" egg with none of these is one we pull, not ship. Honest candling means some eggs don't make the cut.</p>

        <h6 class="cag-h6">Breeder note — Teri's candling routine</h6>
        <p>In Teri's words, she candles in a darkened room, blunt-end up, and re-checks anything ambiguous a few days later rather than guessing — patience beats optimism with a developing egg. It's the same careful eye she brings to every clutch we hatch here.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 6 · INCUBATION -->
      <section id="incubation">
        <h2 class="cag-h2">What does incubating an African Grey egg actually take?</h2>
        <p>Incubating a Psittacus erithacus egg is demanding, precise work, and we'd rather you walk in clear-eyed: it means holding roughly 99°F and managed humidity for 28–30 days, turning several times a day, then hand-feeding a helpless chick around the clock. We publish the real requirements because every fake farm promises a PDF and none of them tell you the truth.</p>
        <img class="sec-img inf-img"
          src={IMG + "african-grey-egg-incubation-timeline-28-30-days.webp"}
          srcset={IMG + "african-grey-egg-incubation-timeline-28-30-days-760.webp 760w, " + IMG + "african-grey-egg-incubation-timeline-28-30-days.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="African Grey egg incubation timeline from set to hatch over 28 to 30 days" />

        <h3 class="cag-h3">The 28–30 day reality</h3>
        <p>From set to pip runs about 28–30 days for an African Grey, with hatching itself unfolding over roughly 24–72 hours once the chick breaks through. Those are biological windows, not delivery estimates, and rushing or "helping" a hatch is a common way to lose a chick that would have made it.</p>

        <h4 class="cag-h4">Temperature, humidity and the turning schedule</h4>
        <p>Stable incubation lives on three dials — a temperature near 99°F, humidity managed to control moisture loss, and turning several times daily until roughly day 25 — and drift on any one can end development. This is why our eggs are sold to breeders who already own and trust their equipment.</p>

        <h5 class="cag-h5">The mistakes that cost first-timers a clutch</h5>
        <p>The classic first-timer losses are avoidable and heartbreaking: an unstable incubator, skipped turning, wrong humidity, or assisting a pip too early. If reading that list makes an incubator feel like a leap, that's useful information — it may mean a weaned chick is the better call for you.</p>

        <h6 class="cag-h6">Citation — incubation data</h6>
        <p>Our timeline figures track published avian sources such as <a href="https://birdsoftheworld.org/" target="_blank" rel="noopener">Cornell's Birds of the World</a> and peer-reviewed breeding-biology literature, not marketing copy. We cite them so you can check the numbers against science rather than take our word.</p>
      </section>

      <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 7 · EGG VS CHICK -->
      <section id="egg-vs-chick">
        <h2 class="cag-h2">Egg or weaned chick — which should you really buy?</h2>
        <p>Choosing between an egg and a weaned chick is really a choice about risk and skill, and we'll give you the honest math instead of the upsell: an egg is cheaper up front but adds an incubator, a brooder, hand-feeding hours, and real odds of loss, while a weaned chick is one fixed price and a bird that's already eating on its own. For most families, the chick is the higher-success path — and we'll tell you so even though the egg is the cheaper line item.</p>
        <img class="sec-img inf-img"
          src={IMG + "egg-vs-weaned-chick-cost-success-comparison.webp"}
          srcset={IMG + "egg-vs-weaned-chick-cost-success-comparison-760.webp 760w, " + IMG + "egg-vs-weaned-chick-cost-success-comparison.webp 1408w"}
          sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async"
          alt="True cost and success-rate comparison of hatching an egg versus reserving a weaned chick" />

        <h3 class="cag-h3">The true cost &amp; success-rate math</h3>
        <p>On paper an egg starts at $95 while a weaned Congo chick runs $1,700–$2,500, but the egg's real cost includes equipment, weeks of labor, and a success rate that depends entirely on your skill. When you price the whole path rather than the sticker, the "cheap" egg and the "expensive" chick are much closer than they look.</p>

        <div class="otA" role="table" aria-label="Egg versus weaned chick versus adult">
          <table>
            <thead><tr><th>Path</th><th>Starting price</th><th>Extra gear</th><th>Skill / labor</th><th>Best for</th></tr></thead>
            <tbody>
              <tr><td data-label="Path"><b>Fertile egg</b><span class="sub">Psittacus erithacus</span></td><td data-label="Starting price">$95 each</td><td data-label="Extra gear">Incubator + brooder</td><td data-label="Skill / labor">Expert · high</td><td data-label="Best for">Experienced breeders</td></tr>
              <tr><td data-label="Path"><b>Weaned chick</b><span class="sub">Congo, hand-raised</span></td><td data-label="Starting price">$1,700–$2,500</td><td data-label="Extra gear">Cage &amp; toys only</td><td data-label="Skill / labor">Beginner-friendly</td><td data-label="Best for">Most families</td></tr>
              <tr><td data-label="Path"><b>Timneh chick</b><span class="sub">Hand-raised</span></td><td data-label="Starting price">$1,500–$1,600</td><td data-label="Extra gear">Cage &amp; toys only</td><td data-label="Skill / labor">Beginner-friendly</td><td data-label="Best for">Calmer, earlier talker</td></tr>
            </tbody>
          </table>
        </div>

        <h4 class="cag-h4">Why most buyers should reserve a weaned chick instead</h4>
        <p>If your goal is a talking companion rather than a breeding project, reserving a <a href="/baby-african-grey-parrot-for-sale/">hand-raised weaned baby</a> skips every failure point between egg and fledgling. We hand-raise ours to 12–16 weeks, so you get a socialized bird — not a gamble — and we're glad to point you there.</p>

        <h5 class="cag-h5">Hand-feeding a day-one chick is expert-only work</h5>
        <p>A newly hatched African Grey needs formula at the right temperature every few hours, day and night, and mistakes cause crop burns or aspiration — this is genuinely expert-only work. Our own weaned chicks below are the shortcut past all of it.</p>

        <div class="bird-cards">
          {crossSell.map((b) => (
