              ))}
              <option>Proven breeding pair — $3,000</option>
              <option>Not sure yet — help me choose egg vs. chick</option>
            </select>
          </label>
          <div class="form-2col">
            <label for="egg-fname">First name<input id="egg-fname" name="first_name" type="text" autocomplete="given-name" required></label>
            <label for="egg-lname">Last name<input id="egg-lname" name="last_name" type="text" autocomplete="family-name" required></label>
          </div>
