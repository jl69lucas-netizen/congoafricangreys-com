        </div>
        <ul class="hero-chips">
          <li>USDA Class A</li><li>CITES Appendix I</li><li>Candled &amp; PCR-screened lines</li>
        </ul>
      </div>
      <div class="hero-imgs">
        {heroGrid.map((g) => (
          <img src={g.src}
            srcset={g.src.replace('.webp', '-760.webp') + " 760w, " + g.src + " 1408w"}
            sizes="(max-width:900px) 46vw, 300px" width="704" height="384"
            style={`object-position:${g.pos}`}
            fetchpriority="high" loading="eager" decoding="async" alt={g.alt} />
        ))}
      </div>
    </div>
  </header>

  <!-- COUNTER — for-sale outlined stat strip (Ledger-verified only) -->
  <div class="egg-counter">
    <div class="container counter-row">
      <div class="cs"><b>$95</b><span class="cs-l">Per fertile egg</span></div>
      <div class="cs"><b>5</b><span class="cs-l">Eggs = free US ship</span></div>
      <div class="cs"><b>28–30</b><span class="cs-l">Days to hatch</span></div>
      <div class="cs"><b>App. I</b><span class="cs-l">CITES documented</span></div>
      <div class="cs"><b>USDA</b><span class="cs-l">Licensed aviary</span></div>
