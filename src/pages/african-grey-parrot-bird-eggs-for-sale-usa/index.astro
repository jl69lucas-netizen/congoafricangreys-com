---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import clutch from '../../../data/clutch-inventory.json';

// Meta — 3-part extended format (Primary KW | conversational query | number+positive | brand — LSI), ≤280
const title = "Fertile African Grey Parrot Eggs for Sale in the USA | Can I Safely Buy & Hatch Parrot Eggs Online? | 9 Honest Answers + Candling Proof from a USDA-Licensed Breeder | C.A.Gs, Midland TX — CITES Appendix I, 28–30-Day Incubation, Named Congo & Timneh Pairs";
// Desc — Primary benefit | secondary benefit | trust signal + CTA, ≤300
const description = "Buy fertile African Grey parrot eggs for sale in the USA — $95 each, candled before dispatch and traced to named CITES Appendix I breeding pairs. Prefer no incubator risk? Reserve a hand-raised weaned chick instead. USDA-licensed Texas aviary you can verify in 60 seconds — reply within 24h.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-bird-eggs-for-sale-usa/";

const IMG = "/images/egg-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "African Grey Eggs for Sale", url: "/african-grey-parrot-bird-eggs-for-sale-usa/" },
];

// Real inventory — never hardcoded status
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === "available")
  .sort((a, b) => (a.variant === "timneh_african_grey" ? 1 : -1));

const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a cuddly tamed female Congo African Grey resting on her keeper's lap" },
