              <option value="">Choose one…</option>
              <option>Pickup in Midland, TX — if you live within 2–3 hours of us</option>
              <option>Airport pickup — $185</option>
              <option>Home delivery — $350</option>
              <option>Flight nanny (in-cabin) — from $750</option>
