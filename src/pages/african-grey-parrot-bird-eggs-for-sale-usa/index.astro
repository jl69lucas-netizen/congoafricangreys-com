---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "Fertile African Grey Parrot Eggs for Sale in the USA — Candled, Documented, Shipped | C.A.Gs, Midland TX";
const description = "Fertile African Grey parrot eggs for sale from our USDA-licensed Texas aviary — $95 each, candled before dispatch, from named CITES Appendix I pairs. Honest hatch terms, nationwide shipping.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-bird-eggs-for-sale-usa/";

const IMG = "/images/egg-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "African Grey Eggs for Sale", url: "/african-grey-parrot-bird-eggs-for-sale-usa/" },
];

// Real inventory — never hardcoded status
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === "available")
  .sort((a, b) => (a.variant === "timneh_african_grey" ? 1 : -1));

const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a cuddly tamed female Congo African Grey resting on her keeper's lap" },
  "amie": { src: "/amie-congo-african-grey-handfed-baby-card.webp", alt: "Amie, a hand-fed baby female Congo African Grey snuggled against a shoulder" },
  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey beside his toy ball" },
  "jins-jeni": { src: "/congo-african-grey-companion-pair-card.webp", alt: "Jins and Jeni, a Congo African Grey companion pair raised together" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a young male Timneh African Grey stretching his wings on a perch" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a female Timneh African Grey perched calmly, showing her horn-colored beak" },
};
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// Egg-page ship anchors — unique labels, distinct from the comparison cluster's set
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-florida/", label: "Florida egg buyers" },
  { href: "/african-grey-parrot-for-sale-north-carolina/", label: "North Carolina hatching-egg keepers" },
  { href: "/african-grey-parrot-for-sale-texas/", label: "Texas local egg pickup" },
  { href: "/african-grey-parrot-for-sale-georgia/", label: "Georgia incubator homes" },
  { href: "/african-grey-parrot-for-sale-ohio/", label: "Ohio breeder shipments" },
  { href: "/african-grey-parrot-for-sale-pennsylvania/", label: "Pennsylvania cargo route" },
];

// Real reviews only (verified homepage bottomReviews set)
const stories = [
  { name: "Richard Woodard", loc: "Winter Haven, FL", meta: "Congo African Grey",
    avatar: "/richard-woodard-winter-haven-fl-review-112.webp",
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family, talking and entertaining us daily." },
  { name: "Archie Obrien", loc: "Farmingdale, NY", meta: "Congo African Grey",
    avatar: "/archie-obrien-farmingdale-ny-review.webp",
    quote: "I searched for African Grey parrots for sale near me for months before finding C.A.Gs. Their birds are truly top-notch! My African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a health guarantee." },
];

// Competitor comparison — grounded in Sprint 0 §3 (the scam-dominated egg SERP)
const compareRows = [
  { axis: "Seller identity", them: "Anonymous, keyword-named website", us: "Named breeders — Mark & Teri Benjamin, Midland, TX" },
  { axis: "USDA license", them: "None you can verify", us: "Active USDA AWA, lookup-able on APHIS" },
  { axis: "Fertility proof", them: '"100% fertile guaranteed"', us: "Candled before dispatch + dated video on request" },
  { axis: "Pricing", them: "One flat price across every species", us: "$95, honest, from named Congo lines" },
  { axis: "Hatch promise", them: '"Guaranteed hatch rate"', us: "Honest odds — no hatch is ever guaranteed" },
  { axis: "CITES paperwork", them: "Never mentioned", us: "Appendix I captive-bred documentation" },
  { axis: "Photos & video", them: "Stock or stolen images", us: "Our own nursery photos and hand-rearing video" },
];

const faqs = [
  { q: "How much does a fertile African Grey parrot egg cost?", a: "Our fertile African Grey parrot eggs are $95 each, and if you buy 5 eggs US shipping is free. A $200 deposit reserves a clutch. We price every egg the same across our Congo lines — flat pricing that changes by species is one of the scam tells we warn buyers about, so an honest African Grey egg price stays consistent." },
  { q: "How long do African Grey eggs take to hatch?", a: "Under correct incubation, African Grey eggs hatch in about 28–30 days, with the pip-to-hatch window running roughly 24–72 hours. That figure comes from published avian breeding data, not a marketing promise, and it assumes a stable incubator near 99°F with managed humidity and daily turning." },
  { q: "How many eggs do African Grey parrots lay?", a: "A hen typically lays a clutch of 2–4 eggs, one every other day, and begins full incubation after the second or third. That small clutch size is exactly why real fertile African Grey eggs are limited and why any listing offering unlimited flat-rate eggs across every species should raise your guard." },
  { q: "Are the parrot eggs for sale online real, or a scam?", a: "Most are a scam — our own scam guide flags the pattern. What separates a real egg program is verifiable identity: a USDA license you can look up, named breeding pairs, CITES Appendix I documentation, and candling proof. We publish all four, which is exactly what the fake egg farms cannot do." },
  { q: "How can you tell if an African Grey egg is fertile?", a: "Candling is how we tell — shining a light through the egg reveals veins by about day 5, a spider-web of vessels and an air cell by day 10, and a dark embryo shadow by day 18. We candle before dispatch and can send a dated photo or short video, so you see the fertility signs on your own clutch." },
  { q: "What incubator humidity do African Grey eggs need?", a: "Most keepers hold roughly 45–50% relative humidity for the main incubation stretch, then raise it for the final days before hatch to help the chick pip — while keeping temperature near 99°F and turning several times a day. Exact numbers vary by incubator and altitude, which is one more reason these eggs are sold for experienced breeders only, with no incubation support included." },
  { q: "Do you ship fertilized African Grey eggs near me?", a: "We ship fertile, fertilized African Grey parrot eggs nationwide from Midland, Texas — to Florida, North Carolina, South Carolina, California and every other state — in an insulated carton with a heat pack. If you live within 2–3 hours of Midland, local pickup is the gentlest option for live eggs." },
  { q: "Do you sell Congo African Grey eggs, or hatchlings, too?", a: "Yes. Our fertile eggs trace to Congo African Grey lines (Psittacus erithacus), and if you'd rather skip the incubator we also raise hatchlings through to fully weaned chicks. Most families are better served reserving a hand-raised African Grey baby than hatching an egg — and we will tell you so honestly." },
  { q: "Can I incubate African Grey parrot eggs at home?", a: "You can, but it is genuinely hard, expert work — which is why our eggs are sold for experienced breeders and no incubation support is included. A day-one chick needs round-the-clock hand-feeding. If that isn't your world yet, reserving a weaned chick is the honest, higher-success path." },
  { q: "Are captive-bred African Grey eggs legal to buy in the USA?", a: "Yes. African Greys are CITES Appendix I, and captive-bred birds and their eggs are legal to own and transfer within the United States with proper paperwork. Every egg traces to our USDA-licensed, captive-bred pairs — never wild-caught — and CITES captive-bred documentation follows the birds." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: "Fertile Congo African Grey Parrot Egg (Psittacus erithacus)",
  image: [ site + IMG + "real-african-grey-eggs-for-sale-hen-nest.webp", site + IMG + "candling-african-grey-egg-fertility-stages.webp" ],
  description: "A single fertile African Grey parrot egg from a named C.A.Gs breeding pair, candled before dispatch and shipped in an insulated carton. Sold to experienced breeders on honest hatch terms — no guaranteed-hatch claims.",
  category: "Fertile parrot hatching eggs",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  offers: { "@type": "Offer", price: "95", priceCurrency: "USD", availability: "https://schema.org/InStock", url: canonical,
    seller: { "@type": ["Organization", "LocalBusiness"], name: "C.A.Gs – Midland, TX", alternateName: "Congo African Greys" } },
};

const sections = [
  { n: "01", id: "scam", label: "Scam vs. real program", tag: "Start here" },
  { n: "02", id: "cost", label: "Price & what's included", tag: "$95" },
  { n: "03", id: "nursery", label: "Inside our nursery", tag: "Video" },
  { n: "04", id: "pairs", label: "Our breeding pairs", tag: "Named" },
  { n: "05", id: "candling", label: "Fertility, candled", tag: "Proof" },
  { n: "06", id: "incubation", label: "Incubation reality", tag: "28–30 days" },
  { n: "07", id: "shipping", label: "Packing & shipping", tag: "$185 / $350" },
  { n: "08", id: "egg-vs-chick", label: "Egg or weaned chick", tag: "The math" },
  { n: "09", id: "health", label: "Health & guarantee", tag: "PCR" },
  { n: "10", id: "legal", label: "Legal to buy?", tag: "CITES I" },
  { n: "11", id: "available", label: "Available now", tag: "Birds + eggs" },
  { n: "12", id: "stories", label: "Buyer stories", tag: "" },
  { n: "13", id: "compare", label: "How we compare", tag: "vs sellers" },
  { n: "14", id: "faq", label: "Egg FAQs", tag: "" },
  { n: "15", id: "reserve", label: "Reserve yours", tag: "24h reply" },
];
const seam = "/cag-header-logo-160.webp";
---

<BaseLayout {title} {description} {canonical} ogType="product" hideGlobalCta
  heroPreload={IMG + "real-african-grey-eggs-for-sale-hen-nest.webp"}
  heroPreloadSrcset={IMG + "real-african-grey-eggs-for-sale-hen-nest-760.webp 760w, " + IMG + "real-african-grey-eggs-for-sale-hen-nest.webp 1408w"}
  heroPreloadSizes="(max-width:900px) 92vw, 520px">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="egg">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- HERO — Split-Hero C dark + real nest photo -->
  <header class="egg-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Candled before dispatch · CITES Appendix I · USDA-licensed aviary</p>
        <h1 class="cag-h1">Fertile African Grey Parrot Eggs for Sale in the USA — Candled, Documented, Shipped From Our Texas Aviary</h1>
        <p class="lead">Here at C.A.Gs in Midland, Texas, we ship fertile African Grey parrot eggs nationwide for $95 each — candled before they leave, traced to named breeding pairs we photograph on this page, and sold on honest hatch terms. No "guaranteed hatch," no anonymous farm, just a USDA-licensed breeder you can verify in a minute.</p>
        <div class="hero-cta">
          <a class="btn-clay" href="#reserve">Reserve fertile eggs &rarr;</a>
          <a class="btn-ghost" href="#scam">Is this a scam? Read first</a>
        </div>
      </div>
      <div class="hero-media">
        <img class="hero-photo"
          src={IMG + "real-african-grey-eggs-for-sale-hen-nest.webp"}
          srcset={IMG + "real-african-grey-eggs-for-sale-hen-nest-760.webp 760w, " + IMG + "real-african-grey-eggs-for-sale-hen-nest.webp 1408w"}
          sizes="(max-width:900px) 92vw, 520px" width="1408" height="768" fetchpriority="high" decoding="async"
          alt="Fertile African Grey parrot eggs for sale in the USA under a brooding hen with a newly hatched chick in our nest box" />
      </div>
    </div>
  </header>

  <!-- COUNTER — Ledger-verified only -->
  <div class="egg-counter">
    <div class="container counter-row">
      <span class="cs"><b>$95</b><span class="cs-l">Per fertile egg</span></span>
      <span class="cs"><b>5</b><span class="cs-l">Eggs = free US ship</span></span>
      <span class="cs"><b>28–30</b><span class="cs-l">Days to hatch</span></span>
      <span class="cs"><b>App. I</b><span class="cs-l">CITES documented</span></span>
      <span class="cs"><b>USDA</b><span class="cs-l">Licensed aviary</span></span>
      <span class="cs"><b>0</b><span class="cs-l">Wild-caught, ever</span></span>
      <span class="cs"><b>24h</b><span class="cs-l">Inquiry reply</span></span>
    </div>
  </div>

  <!-- NEWSLETTER — TOP -->
  <Newsletter variant="top" action="https://formspree.io/f/xrejpnvn"
    heading="Get First Word on Our Next Fertile Egg Clutch"
    sub="African Grey clutches are small and seasonal. Join the list and hear the moment candled fertile eggs — or a new weaned chick — open for reservation."
    cta="Join the egg list" />

  <!-- MOBILE JUMP RAIL — Rail A price-chip -->
  <nav class="egg-rail" aria-label="On this page">
    <div class="container railA">
      {sections.map((s, i) => (<a href={`#${s.id}`} class={i === 0 ? "on" : ""}><span class="p">{s.n}</span> {s.label}</a>))}
    </div>
  </nav>

  <div class="container">

    <!-- DESKTOP DIAL TOC -->
    <nav class="dial desk-only" aria-label="Contents">
      <div class="dial-ring"><div><b>15</b><span>Sections</span></div></div>
      <div class="dial-list">
        {sections.map((s) => (<a href={`#${s.id}`}><span class="num">{s.n}</span>{s.label}{s.tag && <span class="tag">{s.tag}</span>}</a>))}
      </div>
    </nav>

    <!-- K4 CLIPBOARD — proof takeaway -->
    <div class="k4" role="note" aria-label="What makes our egg program verifiable">
      <p class="k4-title">Why our egg program isn't the usual online scam</p>
      <ul>
        <li>USDA Animal Welfare Act license you can look up yourself</li>
        <li>Named Congo &amp; Timneh breeding pairs — not an anonymous "farm"</li>
        <li>Candled before dispatch, with a dated photo or video on request</li>
        <li>Our own nursery photos and a hand-rearing video, not stock images</li>
        <li>Honest hatch odds — we never claim "100% fertile" or a guaranteed hatch</li>
      </ul>
    </div>

    <main class="egg-main">

      <!-- 1 · SCAM VS REAL -->
      <section id="scam">
        <h2 class="cag-h2">Why are almost all "African Grey eggs for sale" listings a scam — and how are we different?</h2>
        <p>Buying fertile African Grey parrot eggs online is a minefield, and we'd rather lose a sale than pretend otherwise: nearly every egg listing you'll find is a fake-farm scam, a fact our own <a href="/how-to-avoid-african-grey-parrot-scams/">scam-prevention guide documents in detail</a>. The whole point of this page is to show you what a real, verifiable egg program looks like — because "different from those listings" is the only claim worth making here.</p>
        <img class="sec-img inf-img" src={IMG + "real-vs-fake-african-grey-egg-breeder-comparison.webp"} srcset={IMG + "real-vs-fake-african-grey-egg-breeder-comparison-760.webp 760w, " + IMG + "real-vs-fake-african-grey-egg-breeder-comparison.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Comparison of real African Grey egg breeders versus fake egg-farm scam patterns" />

        <h3 class="cag-h3">What does a fake egg farm actually look like?</h3>
        <p>A fake egg farm is a keyword-stuffed website with no human behind it, and once you know the shape it's easy to spot: flat pricing across wildly different species, "free cage" bundled with an egg, and a promise no biologist would make. We call these out so you can walk past them — even the ones we don't run.</p>

        <h4 class="cag-h4">The five red flags every fake listing shares</h4>
        <p>These five tells — an anonymous seller, one flat price for greys and macaws alike, a "100% fertile / guaranteed hatch" promise, a free-cage or gift hook, and no verifiable license — travel together on the scam pages. Real breeders fail at least one of them on purpose, because reality doesn't come with guarantees.</p>

        <h5 class="cag-h5">Why no honest breeder promises "100% fertile"</h5>
        <p>No honest breeder promises "100% fertile," and here's the biology: fertility is confirmed by candling days into incubation, not at the moment of sale, and even a fertile egg can quit. When a listing guarantees a hatch, it's guaranteeing something nature doesn't — which is why that phrase is a scam tell, not a selling point.</p>

        <h3 class="cag-h3" id="verify">How can you verify C.A.Gs in 60 seconds?</h3>
        <p>Verification is the antidote to egg-scam anxiety, and ours takes about a minute. Because we are a USDA Animal Welfare Act–licensed aviary in Midland, Texas, you can confirm we exist before you send a cent — something no fake farm can survive.</p>
        <img class="sec-img inf-img" src={IMG + "verify-usda-bird-breeder-license-steps.webp"} srcset={IMG + "verify-usda-bird-breeder-license-steps-760.webp 760w, " + IMG + "verify-usda-bird-breeder-license-steps.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Three steps to verify a USDA bird breeder license before buying eggs" />

        <h4 class="cag-h4">Look up our USDA license yourself</h4>
        <p><a href="https://aphis.usda.gov/aphis/ourfocus/animalwelfare" target="_blank" rel="noopener">The USDA APHIS public search</a> is where you start: open the Animal Welfare Act license lookup, search our aviary, and match the name and active status. It's the fastest legitimacy check in the hobby, and we invite it.</p>

        <h5 class="cag-h5">What the APHIS public record shows</h5>
        <p>The APHIS record shows an active, licensed breeder tied to a real Texas address — not a stock-photo farm. Matching that public record against what we tell you is how a careful buyer separates C.A.Gs from the listings ranking beside us.</p>

        <h6 class="cag-h6">Breeder note — our facility &amp; contact of record</h6>
        <p>We are C.A.Gs (Congo African Greys), owned by Mark &amp; Teri Benjamin, a family aviary in Midland, TX 79707, operating since 2014. That NAP is the one on our USDA record and our <a href="/contact-us/">contact page</a> — if a listing's details don't match its paperwork, that's your answer.</p>
      </section>

      <div class="seam"><img src={seam} width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 2 · COST -->
      <section id="cost">
        <h2 class="cag-h2">How much do fertile African Grey eggs cost, and what's included?</h2>
        <p>Our fertile African Grey parrot eggs are $95 each — a single, honest, same-across-our-Congo-lines African Grey egg price, because flat pricing that jumps by species is itself a scam tell. That $95 buys a candled egg from a named pair, packed for transit; it does not buy a hatch guarantee, and we'd rather say that plainly than sell you a fantasy.</p>
        <img class="sec-img inf-img" src={IMG + "fertile-african-grey-eggs-ready-for-incubator.webp"} srcset={IMG + "fertile-african-grey-eggs-ready-for-incubator-760.webp 760w, " + IMG + "fertile-african-grey-eggs-ready-for-incubator.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Nine cream fertile African Grey eggs packed and ready for the incubator" />

        <div class="k1" role="note" aria-label="African Grey egg pricing summary">
          <p class="k1-title">African Grey egg pricing</p>
          <div class="row"><span>Single fertile egg</span><b>$95</b></div>
          <div class="row"><span>Buy 5 eggs</span><b>Free US shipping</b></div>
          <div class="row"><span>Deposit to reserve a clutch</span><b>$200</b></div>
          <div class="row"><span>Candling before dispatch</span><b>Included</b></div>
          <div class="row"><span>Incubation support</span><b>Not included</b></div>
          <div class="tot"><span>Sold to</span><span>Experienced breeders</span></div>
        </div>

        <h3 class="cag-h3">What does $95 an egg actually buy you?</h3>
        <p>The $95 covers a fertile Congo African Grey egg that we've candled and confirmed developing, drawn from a specific breeding pair we can name, and cradled for shipping. What it deliberately doesn't cover is hand-holding through incubation — these eggs are for breeders who already run an incubator, so you're paying for a genuine egg, not a course.</p>

        <h4 class="cag-h4">Buy 5 eggs and US shipping is free</h4>
        <p>Ordering five fertile African Grey eggs waives the shipping fee across the continental US, which is how most serious breeders buy — a full clutch gives incubation the redundancy a single egg can't. It's a real discount on volume, not a "buy more, get a free bird" gimmick.</p>

        <h5 class="cag-h5">Deposit &amp; reservation terms</h5>
        <p>A $200 deposit reserves a clutch against a confirmed laying, and we hold eggs only when we truly have them — honest availability beats a permanent "in stock" button. Exact refund-versus-replacement wording is confirmed with you in writing before you pay, never buried in fine print.</p>

        <h6 class="cag-h6">Citation — figures from our live price list</h6>
        <p>Every number here is pulled from our current C.A.Gs price list, the same source behind our <a href="/african-grey-parrot-price/">full African Grey pricing guide</a>. If a figure ever differs between pages, the price list governs and we correct the page.</p>

        <h4 class="cag-h4">How many eggs are in a clutch?</h4>
        <p>An African Grey hen lays a small clutch of 2–4 eggs, one every other day, which is exactly why real fertile eggs are limited and seasonal. Any listing offering unlimited flat-rate eggs across every parrot species is describing a farm that biology doesn't allow.</p>
      </section>

      <div class="seam"><img src={seam} width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 3 · NURSERY + VIDEO -->
      <section id="nursery">
        <h2 class="cag-h2">What does it look like inside our African Grey nursery?</h2>
        <p>Real proof beats any promise, so instead of describing our aviary we'll show it: these are our own African Grey hatchlings and chicks in Midland, photographed and filmed here — the kind of evidence a stock-photo egg farm can never produce. Watching a clutch move from egg to fledgling is the honest picture behind every fertile egg we sell.</p>
        <img class="sec-img inf-img" src={IMG + "african-grey-hatchlings-nest-box-aviary.webp"} srcset={IMG + "african-grey-hatchlings-nest-box-aviary-760.webp 760w, " + IMG + "african-grey-hatchlings-nest-box-aviary.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="African Grey hatchlings feathering out in the nest box at our Texas aviary" />

        <h3 class="cag-h3">Watch our African Grey chicks being hand-reared</h3>
        <p>Press play on our own aviary footage — no narration, no stock clips, just our African Grey chicks during hand-rearing. It's the clearest answer to "are these real birds?" that we can give you before you ever reach out.</p>
        <div class="video-wrap">
          <video controls preload="none" width="1408" height="768" poster={IMG + "cags-african-grey-chicks-video-poster.webp"}>
            <source src={IMG + "cags-african-grey-chicks-hand-rearing.mp4"} type="video/mp4" />
            Your browser doesn't support embedded video — the clip shows our African Grey chicks being hand-reared at C.A.Gs.
          </video>
        </div>

        <h4 class="cag-h4">From hatch to weaning, in our hands</h4>
        <p>Every chick we place is hand-raised here from hatch to fully weaned at 12–16 weeks, which is why our birds arrive tame and socialized. That same nursery is where fertile eggs come from — so when you buy an egg, you're buying into a line we raise ourselves, not a shipment we flip.</p>
        <img class="sec-img inf-img" src={IMG + "congo-african-grey-chicks-brooder-hand-reared.webp"} srcset={IMG + "congo-african-grey-chicks-brooder-hand-reared-760.webp 760w, " + IMG + "congo-african-grey-chicks-brooder-hand-reared.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Downy Congo African Grey chicks hand-reared in the C.A.Gs brooder" />

        <h5 class="cag-h5">Hatchlings and fledglings, not just eggs</h5>
        <p>If an incubator isn't your world, our African Grey hatchlings grow into the weaned chicks listed further down this page. Buyers searching for hatchlings for sale usually want the outcome of an egg without the risk — and that outcome already lives in our nursery.</p>
      </section>

      <div class="seam"><img src={seam} width="54" height="54" alt="" loading="lazy" decoding="async"></div>

      <!-- 4 · BREEDING PAIRS -->
      <section id="pairs">
        <h2 class="cag-h2">Which breeding pairs do our fertile eggs come from?</h2>
        <p>Named parents are the difference between a real egg program and a photo library, so we tell you whose clutch you're buying: our fertile eggs come from established Congo pairs like James &amp; Lois and our Timneh pair Levi &amp; Rily, birds we raise and health-screen ourselves. Traceable parentage is exactly what an anonymous farm can never offer.</p>
        <img class="sec-img inf-img" src={IMG + "candled-african-grey-eggs-nest-warm-light.webp"} srcset={IMG + "candled-african-grey-eggs-nest-warm-light-760.webp 760w, " + IMG + "candled-african-grey-eggs-nest-warm-light.webp 1408w"} sizes="(max-width:860px) 92vw, 760px" width="1408" height="768" loading="lazy" decoding="async" alt="Candled African Grey eggs beside downy chicks under a warm brooding light in our nest box" />

        <h3 class="cag-h3">Our named Congo &amp; Timneh pairs</h3>
        <p>Each producing pair in our aviary is a known quantity — bonded, mature adults with a track record we can speak to, not rotating stock. Because we breed both variants, an egg can trace to a Congo line (Psittacus erithacus) or a Timneh line (Psittacus timneh), and we tell you which.</p>

        <h4 class="cag-h4">Parentage, bounded to what we can document</h4>
        <p>We only claim parentage we can actually stand behind, so if we're not certain of a specific pairing we say "Congo line" rather than invent two names. That restraint is deliberate — overclaiming a pedigree is how the fake listings pad their pages, and we won't borrow the tactic.</p>

        <h5 class="cag-h5">PBFD &amp; Polyomavirus PCR-screened lines</h5>
        <p>Our breeding birds are PCR-screened for PBFD (Psittacine Beak and Feather Disease) and Avian Polyomavirus, with negatives required before placement, so the genetics behind your egg come from a health-tested foundation. It's the same screening standard behind every hand-raised chick we place.</p>
      </section>

