  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey beside his toy ball" },
  "jins-jeni": { src: "/congo-african-grey-companion-pair-card.webp", alt: "Jins and Jeni, a Congo African Grey companion pair raised together" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a young male Timneh African Grey stretching his wings on a perch" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a female Timneh African Grey perched calmly, showing her horn-colored beak" },
};
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// Short per-bird card blurbs + trust chips (real, Ledger-safe facts only)
const birdBlurb: Record<string, string> = {
  "bery": "Cuddly, fully tamed young hen who settles on a lap within minutes.",
  "amie": "Hand-fed baby hen, gently socialized on our shoulders since hatch.",
  "roys": "Confident, playful young male who thrives in busy family homes.",
  "jins-jeni": "Companion pair raised side by side — they rehome together.",
  "elad": "Steady young Timneh male, already easy to handle and harness-curious.",
  "evie": "Calm, sweet Timneh hen with the classic horn-colored beak.",
};
const cardChips = ["DNA-sexed", "Vet certificate", "PCR screened"];

// Egg-page ship anchors — every label ENDS with the state/city; each href is a live location page
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-texas/", label: "African Grey eggs for sale Texas", note: "Local pickup near Midland" },
  { href: "/african-grey-parrot-for-sale-florida/", label: "Fertile parrot eggs shipped to Florida", note: "Our busiest egg route" },
  { href: "/african-grey-parrot-for-sale-north-carolina/", label: "African Grey hatching eggs North Carolina", note: "Insulated carton + heat pack" },
  { href: "/african-grey-parrot-for-sale-georgia/", label: "Parrot egg delivery Georgia", note: "Overnight-priority routing" },
  { href: "/african-grey-parrot-for-sale-ohio/", label: "Fertile African Grey eggs Ohio", note: "Cold-season heat packs" },
  { href: "/african-grey-parrot-for-sale-pennsylvania/", label: "African Grey egg shipping Pennsylvania", note: "Carrier confirmed pre-dispatch" },
  { href: "/african-grey-parrot-for-sale-houston/", label: "African Grey parrot eggs Houston", note: "Same-state, shortest transit" },
  { href: "/african-grey-parrot-for-sale-new-york/", label: "Fertile grey eggs to New York", note: "Airport cargo hub route" },
];

// Real reviews only (verified homepage bottomReviews set)
const stories = [
  { name: "Richard Woodard", loc: "Winter Haven, FL", meta: "Congo African Grey",
    avatar: "/richard-woodard-winter-haven-fl-review-112.webp",
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They provided detailed care instructions and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family, talking and entertaining us daily." },
  { name: "Archie Obrien", loc: "Farmingdale, NY", meta: "Congo African Grey",
