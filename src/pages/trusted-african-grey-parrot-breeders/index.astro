---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "Trusted African Grey Parrot Breeders | Congo African Greys — Midland, TX";
const description = "Meet Mark & Teri Benjamin — USDA AWA licensed African Grey parrot breeders in Midland, Texas since 2014. Captive-bred, CITES documented, hand-raised in a family home aviary. Ships nationwide.";
const canonical = "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-green text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-3">Midland, Texas &middot; Family Aviary Since 2014</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Trusted African Grey Parrot Breeders</h1>
      <p class="text-white/80 text-lg">Mark &amp; Teri Benjamin have dedicated over a decade to raising captive-bred, CITES-documented African Grey parrots in a loving home environment.</p>
    </div>
  </section>

  <TrustBar />

  <!-- About Mark & Teri -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">About Mark & Teri Benjamin</h2>
          <p class="text-stone-600 leading-relaxed mb-4">We're Mark and Teri Benjamin, a family in Midland, Texas who have been raising African Grey parrots since 2014. What started as a deep love for these extraordinary birds became a commitment to ethical, captive-bred breeding with full CITES documentation.</p>
          <p class="text-stone-600 leading-relaxed mb-4">Our birds are raised inside our home — not in a commercial facility. They grow up with our family, which means they're socialized from hatch and ready to bond with yours.</p>
          <p class="text-stone-600 leading-relaxed">Every bird we sell comes with a complete documentation package: CITES captive-bred certificate, hatch certificate, band number, DNA sexing certificate, and avian vet health certificate.</p>
        </div>
        <div class="space-y-4">
          {[
            { icon: '🏡', title: 'Home Aviary', body: 'Birds raised in our Midland, TX family home, not a commercial facility.' },
            { icon: '📋', title: 'USDA AWA Licensed', body: 'Federally licensed breeder under the Animal Welfare Act.' },
            { icon: '🌍', title: 'CITES Appendix II Compliant', body: 'Full captive-bred documentation on every bird.' },
            { icon: '🎓', title: '10+ Years Experience', body: 'Breeding since 2014. Hundreds of healthy placements.' },
            { icon: '✈️', title: 'Ships Nationwide', body: 'IATA-compliant transport to all 50 states from $185.' },
          ].map(item => (
            <div class="flex gap-4 p-4 bg-warm-white rounded-xl border border-stone-100">
              <span class="text-2xl mt-0.5">{item.icon}</span>
              <div>
                <p class="font-lora font-semibold text-logo-dark text-base">{item.title}</p>
                <p class="text-stone-500 text-sm">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Available Birds CTA -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">Buy a Trained Congo African Grey Today</h2>
      <p class="text-stone-600 mb-8 max-w-2xl mx-auto">As trusted African Grey parrot breeders, we ensure every bird is raised with a focus on physical health and mental enrichment. Nationwide shipping via Delta or United Airlines for just $185. Full health guarantee included.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/african-grey-parrot-for-sale/" class="inline-block bg-green text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay transition-colors">
          See Available Birds
        </a>
        <a href="/contact-us/" class="inline-block border-2 border-green text-green font-semibold px-8 py-4 rounded-full text-lg hover:bg-green hover:text-white transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Schema type="local-business" />
  <CTA />
</BaseLayout>
