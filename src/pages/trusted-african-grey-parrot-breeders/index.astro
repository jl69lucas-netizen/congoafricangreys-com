---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import OwnerCard from '../../components/cag-library/OwnerCard.astro';
import Testimonials from '../../components/cag-library/Testimonials.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "Trusted African Grey Parrot Breeders | Who We Are: Meet Mark & Teri at C.A.Gs | USDA-Licensed, CITES Appendix I Documented, DNA-Sexed Congo & Timneh Greys | About C.A.Gs – Midland, TX";
const description = "Who are we? C.A.Gs is a USDA-licensed family African Grey parrot breeder run by Mark & Teri Benjamin in Midland, TX since 2014. Why families trust us over unverified sellers: CITES Appendix I captive-bred documentation, PCR DNA sexing, avian-vet health certificates, and a written health guarantee.";
const canonical = "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Trusted Breeders / About C.A.Gs", url: "/trusted-african-grey-parrot-breeders/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system
// as the homepage + scam page; ids live on each section. Document order required.
const jumpSections = [
  { id: 'breeder-story',   label: 'Our Story',     part: 1 },
  { id: 'why-trust-us',    label: 'Credentials',   part: 2 },
  { id: 'trustworthy',     label: 'vs Scams',      part: 2 },
  { id: 'reviews',         label: 'Reviews',       part: 3 },
  { id: 'available-birds', label: 'Available',     part: 3 },
  { id: 'eggs-pairs',      label: 'Eggs & Pairs',  part: 3 },
  { id: 'faq',             label: 'FAQ',           part: 3 },
  { id: 'contact',         label: 'Ask Us',        part: 3 },
];
const jumpPartNames = {
  1: 'Our Story',
  2: 'Verify Us',
  3: 'Birds & Proof',
};

// ─── Available birds (cross-sell grid) — verified against price-matrix.json + clutch-inventory.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Hand-raised in our home from day one.',
    notes: "Hand-raised male Congo, 4 months old — DNA-sexed, vet-checked, and fully documented before he ever ships." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Socialized by our whole family.',
    notes: 'Premium hand-raised female Congo, 3 months old. Closed-banded, hatch-certified, CITES Appendix I documented.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, settled, paperwork in hand.',
    notes: 'Soft temperament, easy to handle. 1-year-old female Congo with full health and CITES documentation.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird, same documentation standard.',
    notes: 'Hand-raised male Timneh, 5 months old. DNA-sexed, avian-vet certified, captive-bred and never wild-caught.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, ready to come home.',
    notes: 'Hand-raised female Timneh, 6 months old. Closed band, hatch certificate, and CITES Appendix I paperwork included.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two bonded birds, one documented package.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised and fully documented.' },
];

// ─── Verified buyer reviews (same real reviews + photos used live on the homepage). NOT fabricated. ───
const reviews = [
  { headline: 'They made buying a bird online stress-free.',
    quote: "At first I was hesitant about buying a bird online, but C.A.Gs made the process stress-free. They handed me the CITES paperwork, the DNA certificate, and the vet health certificate before I paid, and my parrot arrived in perfect condition. My Congo African Grey is now the star of our family.",
    name: 'Richard Woodard', location: 'Winter Haven, FL', meta: 'Congo African Grey',
    avatarSrc: '/richard-woodard-winter-haven-fl-review.webp' },
  { headline: 'Affectionate, intelligent, already picking up words.',
    quote: "I searched for trusted African Grey breeders for months before finding C.A.Gs. Their birds are truly top-notch — my African Grey is affectionate, intelligent, and already picking up words. The shipping process was seamless, and they included a written health guarantee.",
    name: 'Archie Obrien', location: 'Farmingdale, NY', meta: 'Congo African Grey',
    avatarSrc: '/archie-obrien-farmingdale-ny-review.webp' },
  { headline: 'Healthy, friendly, and well-documented.',
    quote: "I ordered a Congo African Grey from C.A.Gs and the experience was flawless. Everything was verifiable — USDA license, captive-bred CITES papers, an avian-vet exam. My parrot is healthy, friendly, and well-trained. I recommend C.A.Gs to anyone asking is congoafricangreys.com legit.",
    name: 'Catherine Kempf', location: 'Schaumburg, IL', meta: 'Congo African Grey',
    avatarSrc: '/catherine-kempf-schaumburg-il-review.webp' },
];

// ─── FAQ (PAA + branded-search sourced; mirrored into FAQPage schema) ───
const faqs = [
  { q: "Who are the breeders behind C.A.Gs?",
    a: "C.A.Gs is a small, family African Grey parrot breeder run by Mark and Teri Benjamin, with our family, in Midland, Texas.\n\nWe have hand-raised captive-bred Congo and Timneh African Greys in our home since 2014 — over a decade of breeding the same two species, not a flipping operation reselling birds we have never met.\n\nEvery Grey is hand-fed inside our home and socialized by our family before it goes anywhere." },
  { q: "Is congoafricangreys.com legit?",
    a: "Yes. C.A.Gs holds a verifiable USDA Animal Welfare Act license, places only U.S. captive-bred birds with CITES Appendix I documentation, video-calls you to show your specific bird on demand, and hands you the paperwork before any money moves.\n\nYou can read real C.A.Gs reviews from verified buyers on this page and on our reviews page, and we accept reversible payment methods — none of which a scam storefront can offer." },
  { q: "What documents come with every African Grey from C.A.Gs?",
    a: "Each Grey leaves us with a CITES Appendix I captive-bred certificate, a PCR DNA sexing certificate, a board-certified avian-veterinarian health certificate dated within 10 days of travel, a hatch certificate, and a closed band number — all backed by our USDA Animal Welfare Act license and a written health guarantee.\n\nYou receive the documents before the deposit, not after." },
  { q: "How can I verify a C.A.Gs African Grey before I pay?",
    a: "Ask for our USDA AWA license number and check it against the public USDA APHIS Animal Welfare records, request a live video call showing the exact bird you are reserving, and confirm we will send the CITES Appendix I and DNA paperwork before payment.\n\nA legitimate breeder passes all three tests; a scammer fails at least one. We hand you everything upfront precisely so you never have to guess." },
  { q: "How is a trusted breeder different from a Facebook or Marketplace seller?",
    a: "A trusted African Grey breeder has a verifiable USDA license, a findable physical aviary, captive-bred CITES documentation, and accepts reversible payment.\n\nThe classic scam is a Facebook or Marketplace listing far below our $1,500 floor, payment demanded by CashApp, Zelle, or gift card, stolen photos, and a seller who vanishes after the deposit.\n\nWe built C.A.Gs as the opposite of that — read our guide to avoiding African Grey scams to see every red flag side by side." },
  { q: "Are C.A.Gs African Greys really captive-bred and legal to own?",
    a: "Yes. African Greys are listed on CITES Appendix I, which bans commercial trade in wild-caught birds, but captive-bred African Greys are legal to own and transfer domestically in the United States with proper documentation.\n\nEvery Grey we place is U.S. captive-bred — never wild-caught — with a closed band and a hatch certificate that prove it was raised in our aviary, so your ownership rests on solid legal ground." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a.replace(/\n\n/g, " ") },
  })),
};

// ─── About / Organization / LocalBusiness schema ───
const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About C.A.Gs — Trusted African Grey Parrot Breeders",
  description: "Who we are: C.A.Gs is a USDA-licensed family African Grey parrot breeder run by Mark & Teri Benjamin in Midland, TX since 2014, placing CITES Appendix I documented, DNA-sexed Congo & Timneh Greys.",
  url: canonical,
  inLanguage: "en-US",
  mainEntity: { "@id": "https://congoafricangreys.com/#organization" },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "PetStore"],
  "@id": "https://congoafricangreys.com/#organization",
  name: "C.A.Gs – Midland, TX",
  alternateName: "Congo African Greys",
  url: "https://congoafricangreys.com/",
  description: "USDA-licensed captive-bred African Grey parrot breeder — Congo & Timneh — run by Mark & Teri Benjamin in Midland, Texas since 2014. CITES Appendix I documentation, PCR DNA sexing, and avian-vet health certificates on every bird.",
  founder: [
    { "@type": "Person", name: "Mark Benjamin" },
    { "@type": "Person", name: "Teri Benjamin" },
  ],
  foundingDate: "2014",
  telephone: "+1-281-545-3169",
  address: { "@type": "PostalAddress", addressLocality: "Midland", addressRegion: "TX", addressCountry: "US" },
  areaServed: "United States",
  priceRange: "$1,500–$3,500",
  logo: "https://congoafricangreys.com/cag-footer-logo.webp",
  sameAs: ["https://www.facebook.com/people/Congo-African-grey/61571657313840/"],
  knowsAbout: ["African Grey parrot breeding", "CITES Appendix I captive-bred documentation", "PCR DNA sexing", "Avian veterinary health certification"],
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52" },
};

const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: "African Grey Socialization Training at C.A.Gs — Midland, TX",
  description: "A real daily socialization and handling session with a hand-raised African Grey parrot inside the Benjamin family home at C.A.Gs in Midland, Texas — the routine behind every captive-bred, CITES Appendix I documented Grey we place.",
  contentUrl: "https://congoafricangreys.com/african-grey-parrot-socialization-training.mp4",
  thumbnailUrl: "https://congoafricangreys.com/cags-tame-african-grey-parrot-with-owner.webp",
  uploadDate: "2026-06-11",
  inLanguage: "en-US",
  publisher: { "@id": "https://congoafricangreys.com/#organization" },
};

const reviewSchema = reviews.map((r) => ({
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: { "@type": "Organization", name: "C.A.Gs – Midland, TX", "@id": "https://congoafricangreys.com/#organization" },
  reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
  author: { "@type": "Person", name: r.name },
  reviewBody: r.quote,
}));
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
  extraHeadHtml={'<link rel="preload" as="image" href="/about-mark-teri-benjamin-african-grey-breeders-midland-tx.webp" fetchpriority="high" type="image/webp" />'}>

  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />

  <div class="trust-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green · trust tone) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="hero-eyebrow font-sora">Who We Are · Family Aviary Since 2014 · Midland, Texas · <span class="cag-updated">Updated June 2026</span></p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              Trusted African Grey Parrot Breeders — Meet the Family Behind C.A.Gs
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">
              We are Mark &amp; Teri Benjamin, and we have hand-raised captive-bred Congo and Timneh African Greys in our Midland, Texas home since 2014.
            </p>
            <p class="font-sora mx-auto mt-2.5 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">
              Most online sellers disappear after the deposit; we built C.A.Gs to be the opposite — a USDA-licensed, CITES-documented breeder who hands you the paperwork before you pay and answers the phone long after your bird comes home.
            </p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#breeder-story" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Read Our Breeder Story →</a>
              <a href="#contact" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">Ask Us a Question →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/about-mark-teri-benjamin-african-grey-breeders-midland-tx.webp"
                  alt="Mark Benjamin of C.A.Gs in Midland, Texas hand-feeding a captive-bred Congo African Grey chick in our aviary — the USDA-licensed hand-rearing behind every CITES Appendix I Grey we place."
                  title="Mark & Teri Benjamin — trusted African Grey breeders, C.A.Gs Midland TX"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover" style="object-position:66% 50%;" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask Mark & Teri →" ctaTarget="contact" />

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "52", label: "Verified Reviews" },
      { num: "4.9", label: "Average Rating" },
      { num: "USDA AWA", label: "Licensed Breeder" },
      { num: "2014", label: "Midland TX Since" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="What Makes C.A.Gs a Trusted African Grey Breeder?"
      badge="8 facts · 60-sec read"
      items={[
        { stat: "2014",      label: "Family Aviary",       body: "Mark & Teri Benjamin have hand-raised Congo and Timneh African Greys in their Midland, TX home for over a decade." },
        { stat: "USDA",      label: "AWA Licensed",        body: "We hold a verifiable USDA Animal Welfare Act license you can check before you pay anything." },
        { stat: "100%",      label: "CITES Documented",    body: "Every Grey is U.S. captive-bred with CITES Appendix I paperwork — never wild-caught." },
        { stat: "DNA",       label: "Sexed & Vet-Checked", body: "Each bird ships with a PCR DNA sexing certificate and an avian-vet health certificate." },
        { stat: "Paperwork", label: "Before The Deposit",  body: "You hold the documents in your hands before any money changes hands — the opposite of how scams work." },
        { stat: "72-hr",     label: "Health Guarantee",    body: "Every Grey is backed by a written health guarantee, in addition to the pre-ship avian-vet exam." },
        { stat: "$1,500+",   label: "Honest Pricing",      body: "Timneh Greys from $1,500, Congos from $1,700 — no $400 bait listings, ever." },
        { stat: "24h",       label: "We Answer",           body: "Mark or Teri reply within one business day, before the sale and for the bird's whole life." },
      ]}
    />

    <!-- 3b. ON THIS PAGE (TOC) -->
    <section id="toc" class="scroll-mt-20 py-12 px-4" aria-label="On this page">
      <div class="max-w-3xl mx-auto rounded-2xl border border-black/[0.07] bg-white p-7 md:p-9" style="box-shadow:0 4px 18px rgba(60,30,10,0.05);">
        <p class="text-clay font-sora text-[11px] font-bold uppercase tracking-[0.12em] mb-1">About C.A.Gs · The Full Story</p>
        <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
        <p class="font-sora text-[13px] text-stone-500 mt-1.5">6 sections · who we are, how to verify us, and the birds</p>
        <ol class="mt-5 space-y-0">
          {[
            { n: 1, t: "Why We Started Breeding African Greys", href: "#breeder-story" },
            { n: 2, t: "Why Should You Trust C.A.Gs With a 40-to-60-Year Companion?", href: "#why-trust-us" },
            { n: 3, t: "How Do You Tell a Trustworthy Breeder From a Scam?", href: "#trustworthy" },
            { n: 4, t: "What Do Families Say After Buying From C.A.Gs?", href: "#reviews" },
            { n: 5, t: "Which Documented C.A.Gs Greys Are Available Right Now?", href: "#available-birds" },
            { n: 6, t: "Do We Also Sell African Grey Eggs and Breeding Pairs?", href: "#eggs-pairs" },
            { n: 7, t: "What Do Buyers Ask Before Trusting a Breeder?", href: "#faq" },
          ].map((it) => (
            <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
          ))}
        </ol>
      </div>
    </section>

    <!-- 4. THE BREEDER STORY (H-S-S) -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.webp" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="breeder-story" class="scroll-mt-20 pt-14 px-4 md:pt-16">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Our Story</p>
          <h2 class="font-lora font-bold text-logo-dark">Why We Started Breeding African Greys</h2>
        </div>
        <div class="space-y-4 text-stone-600 leading-relaxed text-[15px]" style="max-width:70ch;margin:0 auto;">
          <p>We could not stand how many African Greys were being sold sick, undocumented, or shipped by people the buyer would never actually meet.</p>
          <p>Families were wiring thousands of dollars to a Facebook listing and getting back either nothing at all or a frightened, paperwork-less bird that landed in an avian clinic within the week.</p>
          <p>That is the problem we set out to fix when we began raising Greys in our Midland, Texas home in 2014.</p>
          <p>So we built C.A.Gs as the deliberate opposite of that. Every chick is hand-fed inside our home — by us and by our family — never warehoused in a back-room commercial facility.</p>
          <p>We chose to raise just two species, the <a href="/congo-african-grey-for-sale/">Congo African Grey</a> and the <a href="/timneh-african-grey-for-sale/">Timneh African Grey</a>, and to raise fewer of them well rather than churn out volume.</p>
          <p>We made mistakes early on, learned from our avian vet, and tightened our health protocol every year since.</p>
          <figure class="my-6 max-w-[420px] mx-auto">
            <img src="/hand-fed-african-grey-chick.webp"
              alt="A hand-fed Congo African Grey chick raised inside our Midland, Texas home at C.A.Gs — every clutch is fed by Mark, Teri, and the family, never warehoused."
              title="Hand-fed African Grey chick — raised in the Benjamin family home, C.A.Gs Midland TX"
              width="375" height="500" loading="lazy" decoding="async"
              class="w-full h-auto max-h-[440px] object-cover rounded-2xl border border-line" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);" />
            <figcaption class="font-sora text-[13px] text-stone-600 mt-2.5 text-center">One of our hand-fed chicks, mid-weaning — this is what "raised in our home" actually looks like. <a href="/hand-raised-african-grey-parrot-for-sale/" class="text-green underline decoration-1 underline-offset-2">See our hand-raised Greys →</a></figcaption>
          </figure>
          <p>A decade on, the principle has not changed: hand-feed every clutch, document every bird, and stay reachable long after pickup.</p>
          <p>We are a real family — not a brand, not a reseller — and the birds you see here are the ones we are actually raising right now.</p>
          <p>That is what we mean when we call ourselves trusted African Grey breeders: you can verify every claim on this page before you ever send a deposit.</p>
          <h3 class="font-sora font-bold text-sm uppercase tracking-wide text-green mt-5 mb-1.5">How Do You Verify Us Before You Pay?</h3>
          <p>Don't take our word for any of it — check us the same way you should check every breeder.</p>
          <p>Ask for our USDA Animal Welfare Act license number and run it through the federal APHIS search yourself; a legitimate breeder hands it over without hesitation, and a scammer changes the subject.</p>
          <h4 class="font-sora font-bold text-[13px] uppercase tracking-wide text-clay-ink mt-3 mb-1">Which Document Do You Ask For First?</h4>
          <p>Start with the CITES Appendix I captive-bred certificate for your specific bird. It anchors everything else — the closed band, the hatch certificate, and the PCR DNA sexing result all have to agree with it, detail for detail.</p>
          <h5 class="font-sora font-bold text-[12px] uppercase tracking-wide text-green mt-2.5 mb-1">Then Ask for the Live Video Call</h5>
          <p>We put your exact Grey on camera before any deposit, band in frame.</p>
          <h6 class="font-sora font-bold text-[11px] uppercase tracking-wide text-clay-ink mt-2.5 mb-1">Why a Live Call Beats Paperwork</h6>
          <p>Paperwork can be forged; a live bird answering to its own band number cannot.</p>
        </div>
      </div>
    </section>

    <!-- 4b. Owner card (Mark & Teri H-S-S, verified facts only) -->
    <OwnerCard storyHref="#why-trust-us" storyLabel="Verify Our Credentials →" />

    <!-- 5. WHY TRUST US — credentials -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.webp" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

