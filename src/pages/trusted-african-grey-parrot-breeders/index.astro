<style is:global>
  /* ============================================================
     TRUSTED-BREEDERS / ABOUT PAGE — Direction-D-aware interior wrapper (.trust-d)
     Mirrors the diet/care-guide seam + lead-spacing scope so the global theme
     applies and the seam-logo divider renders. body.theme-d already supplies
     Newsreader/IBM Plex, lead paragraphs, eyebrow ticks, card + button motion.
     ============================================================ */
  .trust-d { --rule: rgba(45,106,79,.16); }

  /* Smooth in-page jumps (JumpRail + TOC + next-nav) with reduced-motion guard. */
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

  /* Sticky header is ~96px tall — keep jumped-to headings visible below it. */
  .trust-d [id] { scroll-margin-top: 110px; }

  /* Hero eyebrow — homepage HeroV3 pattern: no pill, no uppercase. */
  .trust-d .hero-eyebrow { font-size:10px; font-weight:500; letter-spacing:.12em; color:rgba(255,255,255,.75); text-transform:none; }
  @media (min-width:768px) { .trust-d .hero-eyebrow { font-size:11px; } }

  /* AA: clay as small readable text on LIGHT sections → #b04228 (4.5:1).
