---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey Parrot Diet | What to Feed & What to Avoid | CongoAfricanGreys.com";
const description = "African Grey parrot diet guide: pellets, vegetables, fruits, toxic foods to avoid, and supplement needs. Written by USDA-licensed breeders.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-diet/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Diet", url: "/african-grey-parrot-diet/" },
];

const faqs = [
  {
    q: "What is the best diet for an African Grey parrot?",
    a: "The best diet is 70% high-quality pellets (Harrison's or Zupreem Natural), 20% fresh vegetables including leafy greens and bell peppers, and 10% fresh fruit. Seed-based diets cause hypovitaminosis A and significantly shorten lifespan — avoid them as a dietary staple.",
  },
  {
    q: "Can African Grey parrots eat fruit?",
    a: "Yes. Mango, papaya, pomegranate, berries, melon, and kiwi are excellent choices. Limit high-sugar fruits like grapes and bananas to occasional treats. Always remove fruit pits and seeds — cherry, apple, and peach seeds contain cyanogenic compounds toxic to parrots.",
  },
  {
    q: "What foods are toxic to African Grey parrots?",
    a: "Toxic foods include avocado (all parts), onion, garlic, chocolate, caffeine, alcohol, xylitol, and fruit pits. PTFE fumes from overheated non-stick cookware are airborne and lethal — never cook with Teflon near your bird.",
  },
  {
    q: "Do African Grey parrots need calcium supplements?",
    a: "African Greys are uniquely prone to hypocalcemia (low blood calcium). Provide cuttlebone for free-choice calcium. If your bird shows muscle tremors or seizure-like behavior, have an avian vet check calcium levels immediately.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="page-container">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- HERO -->
  <section class="diet-hero">
    <div class="page-container">
      <h1 class="diet-h1">African Grey Parrot Diet</h1>
      <p class="diet-sub">
        What to feed, what to avoid, and why seed-only diets are a leading cause of early
        death in African Greys — from USDA-licensed breeders who feed these birds every day.
      </p>
      <a class="btn-primary" href="/african-grey-parrot-care-guide/">Full Care Guide</a>
    </div>
  </section>

  <!-- 70/20/10 RULE -->
  <section class="diet-section">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">The 70/20/10 Rule</h2>
      <p>
        The most effective and widely recommended feeding framework for African Greys is:
      </p>
      <ul class="diet-list">
        <li><strong>70% high-quality pellets</strong> — the nutritional foundation</li>
        <li><strong>20% fresh vegetables</strong> — variety, color, and micronutrients</li>
        <li><strong>10% fresh fruit</strong> — natural sugars and enrichment</li>
      </ul>
      <p>
        Seeds should not exceed 5% of the total diet and are best used as training rewards,
        not dietary staples. Seeds are high in fat and low in vitamins A, D3, calcium, and
        amino acids that African Greys require. A bird eating primarily seeds will show
        hypovitaminosis A within months: blunted choanal papillae, chronic sinus infections,
        and a suppressed immune system that shortens lifespan by years.
      </p>
      <p>
        Converting a seed-addicted bird to pellets is possible but requires patience. Mix
        increasing proportions of pellets into the seed dish over 4–6 weeks while offering
        warm mashed pellets separately. Never withhold food to force acceptance — this causes
        dangerous blood sugar drops in birds.
      </p>
    </div>
  </section>

  <!-- BEST PELLETS -->
  <section class="diet-section diet-alt">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">Best Pellets for African Greys</h2>
      <p>
        <strong>Harrison's Adult Lifetime Fine</strong> is the pellet most commonly recommended
        by board-certified avian veterinarians. It is USDA-certified organic, uses no artificial
        colors or preservatives, and is formulated specifically for medium to large parrots.
        Harrison's is the gold standard.
      </p>
      <p>
        <strong>Zupreem Natural</strong> is a widely available, veterinarian-approved alternative.
        It is more accessible in retail stores and online, and many birds accept it more readily
        due to its fruit-like aroma. Avoid Zupreem's colored FruitBlend variety — artificial dyes
        have no nutritional benefit and some birds are sensitive to them.
      </p>
      <p>
        Avoid pellets with artificial colors, cane sugar listed in the first three ingredients,
        or "ethoxyquin" as a preservative. Pellets should be stored in an airtight container and
        used within 60 days of opening — rancid pellets can cause digestive problems.
      </p>
    </div>
  </section>

  <!-- BEST VEGETABLES -->
  <section class="diet-section">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">Best Vegetables for African Greys</h2>
      <p>
        Prioritize <strong>dark leafy greens</strong>: kale, Swiss chard, collard greens, mustard
        greens, and dandelion greens are all excellent. These are high in beta-carotene (provitamin A),
        calcium, and antioxidants. Spinach is acceptable in moderation but contains oxalates that
        can bind calcium — rotate with other greens rather than serving it daily.
      </p>
      <p>
        <strong>Orange and red vegetables</strong> are particularly important for vitamin A precursors:
        sweet potato, butternut squash, carrots, and red bell peppers. Cook starchy vegetables like
        sweet potato and squash — lightly steamed or baked — to improve digestibility. Raw bell
        peppers are fine and most birds enjoy them fresh.
      </p>
      <p>
        Broccoli, cauliflower, snap peas, green beans, and zucchini round out the vegetable
        rotation. Introduce new vegetables slowly and offer them alongside known favorites.
        African Greys can be neophobic — a bird may reject a new food 10–20 times before
        accepting it. Persistence pays off.
      </p>
    </div>
  </section>

  <!-- TOXIC FOODS -->
  <section class="diet-section diet-alt">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">Toxic Foods — Complete List</h2>
      <p>
        The following are confirmed toxic to African Greys and must never be offered:
      </p>
      <ul class="diet-toxic-list">
        <li><strong>Avocado</strong> — all parts (flesh, skin, pit, leaves) contain persin, which causes cardiac and respiratory failure in birds. Even small amounts can be lethal.</li>
        <li><strong>Onion and garlic</strong> — contain thiosulfate compounds that cause hemolytic anemia (destruction of red blood cells).</li>
        <li><strong>Chocolate and cocoa</strong> — theobromine and caffeine in all chocolate products cause vomiting, tremors, seizures, and cardiac arrest.</li>
        <li><strong>Caffeine</strong> — coffee, tea, energy drinks, and soda are all toxic. Caffeine causes cardiac arrhythmias in birds.</li>
        <li><strong>Alcohol</strong> — even trace amounts cause serious neurological and organ damage.</li>
        <li><strong>Xylitol</strong> — artificial sweetener found in sugar-free gum, candy, and some peanut butters. Causes rapid hypoglycemia and liver failure.</li>
        <li><strong>Fruit pits and apple seeds</strong> — cherry, peach, plum, and apricot pits; apple and pear seeds contain cyanogenic glycosides that release hydrogen cyanide when metabolized.</li>
        <li><strong>PTFE fumes (Teflon/non-stick cookware)</strong> — when non-stick pans overheat, they release polytetrafluoroethylene particles that are lethal to birds. This is an airborne toxin, not ingested. It kills within minutes. Never use non-stick cookware in a home with parrots.</li>
      </ul>
    </div>
  </section>

  <!-- CALCIUM / HYPOCALCEMIA -->
  <section class="diet-section">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">Calcium and African Grey Hypocalcemia</h2>
      <p>
        African Greys have a well-documented susceptibility to <strong>hypocalcemia</strong> —
        abnormally low blood calcium levels — compared to other parrot species. The exact mechanism
        is still being studied, but the condition is serious: affected birds experience muscle
        tremors, seizures, ataxia (loss of coordination), and sudden collapse from the perch.
      </p>
      <p>
        Prevention is straightforward. Offer <strong>cuttlebone free-choice</strong> at all times —
        most birds will self-regulate their calcium intake. Feed calcium-rich vegetables daily
        (kale, collard greens, bok choy, broccoli). Consider providing a <strong>full-spectrum
        UVB light</strong> on a 10–12 hour daily cycle; UVB exposure allows birds to synthesize
        vitamin D3 in the skin, which is essential for calcium absorption.
      </p>
      <p>
        If your bird shows any tremors, falls off its perch, or exhibits seizure-like activity,
        treat this as a veterinary emergency. Hypocalcemic episodes can be treated effectively
        if caught quickly — delayed care is the primary cause of fatalities from this condition.
        Have your avian vet check blood calcium levels at annual wellness exams.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="diet-section diet-alt">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">African Grey Diet: Frequently Asked Questions</h2>
      <div class="diet-faq">
        {faqs.map((f) => (
          <details class="diet-faq-item">
            <summary class="diet-faq-q">{f.q}</summary>
            <p class="diet-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="diet-section">
    <div class="page-container text-wrap">
      <h2 class="diet-h2">Related Guides</h2>
      <ul class="diet-links">
        <li><a href="/african-grey-parrot-care-guide/" class="diet-link">African Grey Parrot Care Guide</a> — housing, enrichment, veterinary care, and CITES documentation</li>
        <li><a href="/african-grey-parrot-lifespan/" class="diet-link">African Grey Parrot Lifespan</a> — how diet affects 40–60 year lifespan</li>
        <li><a href="/cites-african-grey-documentation/" class="diet-link">CITES African Grey Documentation</a> — what papers every bird must come with</li>
      </ul>
    </div>
  </section>

  <CTA
    headline="Interested in a Captive-Bred African Grey?"
    sub="Our birds are hand-raised on a proper pellet and vegetable diet from day one. Every bird ships with CITES documentation, DNA sexing, and a vet health certificate."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap {
    max-width: 760px;
  }
  .diet-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .diet-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .diet-hero {
    background: #2D6A4F;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .diet-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto 1.75rem;
  }
  .btn-primary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.9rem;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    background: #e8604c;
    color: #fff;
    transition: background 0.2s ease;
  }
  .btn-primary:hover { background: #d44e3b; }
  .diet-section { padding: 3rem 0; }
  .diet-alt { background: #faf7f4; }
  .diet-section p,
  .diet-links li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.2rem;
  }
  .diet-list,
  .diet-toxic-list {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    padding-left: 1.5rem;
    margin: 0.5rem 0 1.2rem;
  }
  .diet-list li,
  .diet-toxic-list li {
    margin-bottom: 0.5rem;
    max-width: 70ch;
  }
  .diet-links {
    padding-left: 1.5rem;
    margin: 0;
  }
  .diet-link {
    color: #e8604c;
    text-decoration: underline;
  }
  .diet-link:hover { color: #d44e3b; }
  .diet-faq { display: flex; flex-direction: column; gap: 0.75rem; }
  .diet-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .diet-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .diet-faq-q::-webkit-details-marker { display: none; }
  .diet-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) { .page-container { padding: 0 16px; } }
  @media (min-width: 768px) and (max-width: 1024px) { .page-container { padding: 0 32px; } }
</style>
