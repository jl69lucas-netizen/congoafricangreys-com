  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two birds, one shared food bowl routine.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both weaned and eating well.' },
];

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
const faqs = [
  { q: "What do African Grey parrots eat?",
    a: "A healthy African Grey eats a base of 60–80% formulated pellets, around 15–20% fresh vegetables — dark leafy greens plus orange veg like sweet potato, carrot and red bell pepper for vitamin A — and only a small amount of fruit, with a few nuts or seeds as treats. Never feed avocado, onion, garlic, chocolate, caffeine, alcohol, or fruit pits, all of which are toxic. We send every C.A.Gs Grey home on the exact diet it is already eating to prevent digestive stress." },
  { q: "How much should I feed an African Grey each day?",
    a: "A Congo African Grey eats roughly 1/4 to 1/3 cup of pellets a day plus a similar volume of fresh vegetables; a smaller Timneh eats a little less. Offer pellets free-choice, serve fresh food in the morning and remove it after a few hours, and weigh your bird weekly — a steady weight is the best sign the portion is right." },
  { q: "Can African Grey parrots eat fruit?",
    a: "Yes, but in moderation. Mango, papaya, pomegranate, berries, melon, apple (no seeds) and kiwi are great choices, while high-sugar fruits like grapes and banana are best kept as occasional treats. Always remove cherry, peach, plum and apricot pits and apple and pear seeds — they contain cyanogenic compounds toxic to parrots." },
  { q: "What foods are toxic to African Grey parrots?",
    a: "Never feed avocado (every part contains persin), onion and garlic (cause anemia), chocolate, caffeine, alcohol, xylitol, salt, or fruit pits and apple seeds. Just as dangerous is a non-food: PTFE (Teflon) fumes from overheated non-stick cookware are airborne and can kill a parrot within minutes, so keep your Grey well away from the kitchen." },
  { q: "Do African Grey parrots need calcium supplements?",
    a: "African Greys are uniquely prone to hypocalcemia (low blood calcium), so calcium matters more than for most parrots. Offer a cuttlebone or calcium block free-choice, feed calcium-rich greens daily, and provide UV-B light so your bird can make the vitamin D3 it needs to absorb that calcium. Only add an oral calcium or D3 supplement on your avian vet's advice — too much is harmful." },
  { q: "Why are seed-only diets bad for African Greys?",
    a: "An all-seed diet is high in fat and deficient in vitamin A, calcium, vitamin D3 and balanced amino acids, so a seed-junkie Grey develops hypovitaminosis A, chronic respiratory and sinus infections, fatty liver disease, and a shortened life. Seeds belong in the diet only as occasional treats, not as the staple — pellets and fresh vegetables are the foundation." },
  { q: "How do I switch an African Grey from seeds to pellets?",
    a: "Convert gradually over 4–8 weeks: mix a small amount of pellets into the familiar seed mix and slowly raise the pellet ratio, offer warm mashed pellets separately, and let your bird watch you 'eat' a pellet. Never starve a Grey onto pellets — birds have a fast metabolism and can crash quickly, so weigh daily and involve your avian vet if progress stalls." },
  { q: "What vegetables are best for African Greys?",
    a: "Build the fresh portion around dark leafy greens (kale, Swiss chard, collard, dandelion and mustard greens) for calcium and around orange and red vegetables (sweet potato, butternut squash, carrot and red bell pepper) for the beta-carotene a Grey converts to vitamin A. Rotate broccoli, snap peas, green beans and zucchini for variety, and introduce new veg patiently — a Grey may refuse a food 10–20 times before accepting it." },
  { q: "Do Congo and Timneh African Greys eat different diets?",
    a: "No — the nutrition is identical. Both our Congo and Timneh African Greys thrive on the same pellet-based diet with fresh vegetables, calcium support and UV-B lighting. The only real difference is volume: the larger Congo simply eats a bit more than the smaller Timneh, so portions scale with the bird, not the recipe." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Diet & Nutrition — Pellets, Vegetables, Calcium & Toxic Foods",
  description: "A complete African Grey parrot diet and nutrition guide from USDA-licensed breeders C.A.Gs: the pellet base, fresh vegetables for vitamin A, calcium and vitamin D3 for hypocalcemia-prone Greys, fruit and treats in moderation, foraging, water, and the full toxic-food list for captive-bred Congo and Timneh Greys.",
  image: "https://congoafricangreys.com/african-grey-parrot-free-exploration.webp",
  inLanguage: "en-US",
  datePublished: "2024-09-01",
  dateModified: "2026-06-06",
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
