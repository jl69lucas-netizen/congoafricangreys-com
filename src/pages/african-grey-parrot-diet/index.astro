          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">The everyday diet</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "What Should the Base Diet Be — Pellets vs Seeds?", href: "#base-diet" },
                  { n: 2, t: "Which Fresh Vegetables & Greens Are Best?", href: "#vegetables" },
                  { n: 3, t: "How Much Fruit, Nuts & Seeds Are Safe?", href: "#fruit-treats" },
                  { n: 4, t: "How Do Greys Get Enough Calcium & Vitamin D3?", href: "#calcium" },
                  { n: 5, t: "How Should You Feed — Foraging, Schedule & Portions?", href: "#feeding" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Water, safety, species & buying</p>
              <ol class="space-y-0">
                {[
                  { n: 6, t: "How Much Water Does an African Grey Need?", href: "#water" },
                  { n: 7, t: "Which Foods Are Toxic & Must Never Be Fed?", href: "#toxic" },
                  { n: 8, t: "Do Congo & Timneh Greys Eat Different Diets?", href: "#congo-vs-timneh" },
                  { n: 9, t: "Which Well-Fed C.A.Gs Greys Are Available?", href: "#available-birds" },
                  { n: 10, t: "African Grey Diet Questions, Answered", href: "#faq" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
