---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Parrot Diet | What Do African Greys Eat, How Much Pellet vs Veg & Which Foods Are Toxic? | Nutrition, Calcium, Vitamin A & Foraging for Congo & Timneh Greys | C.A.Gs – Midland, TX";
const description = "Our African Grey parrot diet guide from USDA-licensed breeders: the right pellet base (60–80%), fresh veg for vitamin A, calcium + vitamin D3 for hypocalcemia-prone Greys, treats in moderation, foraging, and the full toxic-food list (avocado, chocolate, onion, PTFE) | Congo & Timneh.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-diet/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Diet & Nutrition", url: "/african-grey-parrot-diet/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + scam/adoption pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'base-diet',       label: 'Pellet Base',     part: 1 },
  { id: 'vegetables',      label: 'Vegetables',      part: 1 },
  { id: 'fruit-treats',    label: 'Fruit & Treats',  part: 1 },
  { id: 'calcium',         label: 'Calcium',         part: 2 },
  { id: 'feeding',         label: 'Feeding',         part: 2 },
  { id: 'water',           label: 'Water',           part: 2 },
  { id: 'toxic',           label: 'Toxic Foods',     part: 2 },
  { id: 'congo-vs-timneh', label: 'Congo v Timneh',  part: 3 },
  { id: 'available-birds', label: 'Available',       part: 3 },
  { id: 'faq',             label: 'FAQ',             part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',      part: 3 },
];
const jumpPartNames = {
  1: 'What to Feed',
  2: 'Nutrition & Safety',
  3: 'Choose & Reserve',
};

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + price-matrix.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Already weaned onto pellets and greens.',
    notes: "Hand-raised male, 4 months old — eating a full pellet-and-vegetable diet before he ever leaves us." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Forages for her pellets like a pro.',
    notes: 'Premium hand-raised female, 3 months old. Weaning onto the same foraging routine this guide describes.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Loves leafy greens and bell pepper.',
    notes: 'Soft temperament, easy to handle. 1-year-old female, fully established on a varied fresh diet.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller appetite, same complete diet.',
    notes: 'Hand-raised male Timneh African Grey, 5 months old. Eating pellets, veg and a little fruit daily.' },
