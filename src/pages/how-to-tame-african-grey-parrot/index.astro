  /* Section seam — centered wordmark divider (verbatim scope). */
  .tame-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
  .tame-d .cag-seam img{ height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
  @media (max-width:600px){ .tame-d > .cag-seam{ gap:16px; } .tame-d .cag-seam img{ height:24px; } }

  /* Infographic — 7-step taming flow (760px wrapper, 400px desktop fixed) */
  .ig-tame{ max-width:760px; margin:0 auto 2.5rem; padding:26px 28px; background:#fff; border:1px solid rgba(32,52,43,.12); border-radius:20px; box-shadow:0 4px 24px rgba(60,30,10,.06); display:flex; flex-direction:column; gap:18px; }
  @media (min-width:641px){ .ig-tame{ height:400px; justify-content:space-between; } }
  .ig-tame-eyebrow{ display:block; font-family:'IBM Plex Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#b04228; }
  .ig-tame-title{ font-family:'Newsreader',Georgia,serif; font-size:1.35rem; font-weight:700; color:#1f3a2d; margin:.3rem 0 0; }
  .ig-tame-flow{ list-style:none; margin:0; padding:0; display:grid; grid-template-columns:repeat(2, 1fr); gap:10px; }
  @media (min-width:641px){ .ig-tame-flow{ grid-template-columns:repeat(4, 1fr); } .ig-tame-flow li:nth-child(n+5){ grid-column:span 1; } }
  .ig-tame-flow a{ display:flex; align-items:flex-start; gap:9px; padding:11px 12px; background:rgba(45,106,79,.05); border:1px solid rgba(45,106,79,.14); border-radius:12px; text-decoration:none; height:100%; transition:background .2s ease; }
  .ig-tame-flow a:hover{ background:rgba(45,106,79,.1); }
  .ig-tame-flow b{ flex-shrink:0; display:flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:50%; background:#2D6A4F; color:#fff; font-family:'Newsreader',Georgia,serif; font-size:.9rem; }
  .ig-tame-flow span{ display:flex; flex-direction:column; font-family:'IBM Plex Sans',sans-serif; font-size:13px; font-weight:600; color:#1f3a2d; line-height:1.25; }
  .ig-tame-flow em{ font-style:normal; font-weight:400; font-size:11.5px; color:#57534e; margin-top:2px; }
  .ig-tame-note{ font-family:'IBM Plex Sans',sans-serif; font-size:13px; color:#57534e; border-top:1px solid rgba(45,106,79,.16); padding-top:14px; }
  @media (max-width:640px){ .ig-tame{ padding:20px 18px; } }
</style>
