<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta
  heroPreload="/congo-african-grey-red-tail-comparison-hero.webp"
  heroPreloadSrcset="/congo-african-grey-red-tail-comparison-hero-320.webp 320w, /congo-african-grey-red-tail-comparison-hero-360.webp 360w, /congo-african-grey-red-tail-comparison-hero-480.webp 480w, /congo-african-grey-red-tail-comparison-hero.webp 760w"
  heroPreloadSizes="(max-width: 900px) 46vw, 268px">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <div class="cvt">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- S1 HERO -->
  <section class="cvt-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
