  <script is:inline>
    (function () {
      // mobile compare-table tabs
      var wrap = document.querySelector('.cmpe .tbl-wrap');
      var tabs = document.querySelectorAll('.cmpe-tab');
      if (wrap && tabs.length) {
        tabs.forEach(function (b) {
          b.addEventListener('click', function () {
            tabs.forEach(function (x) {
              var on = x === b;
              x.classList.toggle('active', on);
              x.setAttribute('aria-pressed', on ? 'true' : 'false');
            });
            wrap.classList.toggle('show-c', b.dataset.v === 'c');
            wrap.classList.toggle('show-t', b.dataset.v === 't');
          });
        });
      }

      // size comparator
      var sizeSelect = document.getElementById('size-select');
      var GREY_G = 500;
      var MAX_G = 1700;
      function updateSize() {
        if (!sizeSelect) return;
        var opt = sizeSelect.options[sizeSelect.selectedIndex];
        var g = parseInt(opt.value, 10);
        var name = opt.getAttribute('data-name');
        var greyFill = document.querySelector('.grey-fill');
        var macawFill = document.getElementById('size-macaw-fill');
        var macawVal = document.getElementById('size-macaw-val');
        var macawLabel = document.getElementById('size-macaw-label');
        var out = document.getElementById('size-out');
        if (greyFill) greyFill.style.width = Math.round((GREY_G / MAX_G) * 100) + '%';
        if (macawFill) macawFill.style.width = Math.round((g / MAX_G) * 100) + '%';
        if (macawVal) macawVal.textContent = g.toLocaleString() + ' g';
        if (macawLabel) macawLabel.textContent = name;
        if (out) {
          var ratio = (g / GREY_G).toFixed(1);
          if (g < GREY_G) {
            var inv = (GREY_G / g).toFixed(1);
            out.innerHTML = 'A ' + name + ' weighs roughly <strong>' + inv + '× lighter</strong> than a Congo African Grey.';
          } else {
            out.innerHTML = 'A ' + name + ' weighs roughly <strong>' + ratio + '×</strong> a Congo African Grey.';
          }
        }
      }
      if (sizeSelect) {
        sizeSelect.addEventListener('change', updateSize);
        updateSize();
      }

      // budget estimator
      var budgetTool = document.querySelector('.budget-tool');
      function updateBudget() {
        if (!budgetTool) return;
        var boxes = budgetTool.querySelectorAll('input[type="checkbox"]');
        var min = 0, max = 0;
        boxes.forEach(function (b) {
          if (b.checked) {
            min += parseInt(b.getAttribute('data-min'), 10);
            max += parseInt(b.getAttribute('data-max'), 10);
          }
        });
        var out = document.getElementById('budget-out');
        if (out) out.textContent = '$' + min.toLocaleString() + '–$' + max.toLocaleString();
      }
      if (budgetTool) {
        budgetTool.querySelectorAll('input[type="checkbox"]').forEach(function (b) {
          b.addEventListener('change', updateBudget);
        });
        updateBudget();
      }

      // scrollspy — highlight the current section in the TOC and the mobile rail
      var navLinks = document.querySelectorAll('.cvt-toc a, .rail-row a');
      var sections = [].slice.call(document.querySelectorAll('.cvt-main section[id]'));
      if (navLinks.length && sections.length && 'IntersectionObserver' in window) {
        var current = '';
        var spy = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) current = e.target.id; });
          navLinks.forEach(function (a) {
            a.classList.toggle('on', a.getAttribute('href') === '#' + current);
          });
        }, { rootMargin: '-25% 0px -65% 0px' });
        sections.forEach(function (sec) { spy.observe(sec); });
      }

      // lifestyle quiz
      var quizBtn = document.getElementById('quiz-submit');
      if (quizBtn) {
        quizBtn.addEventListener('click', function () {
          var total = 0;
          ['q1', 'q2', 'q3', 'q4'].forEach(function (name) {
            var checked = document.querySelector('input[name="' + name + '"]:checked');
            if (checked) total += parseInt(checked.value, 10);
          });
          var result = document.getElementById('quiz-result');
          if (!result) return;
          var html = '';
          if (total >= 6) {
            html = '<strong>Your match: African Grey.</strong> Apartment-friendly noise, room for a smaller footprint, and you value conversation over spectacle — every signal points toward a Grey. <a href="/available/">See available Greys →</a>';
          } else if (total >= 3) {
            html = '<strong>Your match: a smaller "mini" macaw species, or a Grey.</strong> You can absorb more noise than a strict apartment allows, but you\'re newer to large parrots — a Hahn\'s or Severe Macaw narrows the size gap, or a Grey stays the safer first bird either way. <a href="/african-grey-vs-macaw/#species">Compare mini macaw species ↑</a>';
          } else {
            html = '<strong>Your match: a large macaw species may genuinely fit.</strong> You have the space, the noise tolerance and some experience already — a Blue-and-Gold, Green-winged or Hyacinth is worth serious research. We don\'t breed macaws, so from here we\'d point you to a reputable macaw breeder or rescue rather than sell you something we don\'t raise.';
          }
          result.innerHTML = html;
          result.hidden = false;
          result.setAttribute('data-in', '');
          result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      }
    })();
  </script>
</BaseLayout>

