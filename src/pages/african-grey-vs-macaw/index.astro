---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';

const title = "African Grey vs Macaw: Bite Force, Size, Talking Ability & 11 Species Compared by Breeders Who Raise Greys | C.A.Gs – Honest African Grey vs Macaw Guide";
const description = "African Grey vs Macaw, compared honestly by breeders who raise Greys only: real bite-force data (61–96 N vs a Hyacinth's 540 N), talking ability, noise, cost and nutrition — plus all 11 macaw species, Mini to Hyacinth, and the succession question most comparison pages skip.";
const canonical = "https://congoafricangreys.com/african-grey-vs-macaw/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey vs Macaw", url: "/african-grey-vs-macaw/" },
];

// 11 macaw species subsections — every one has a real provided photo (2026-07-10 breeder set)
const species = [
  { pos: "50% 22%", id: "scarlet", name: "Scarlet Macaw", sci: "Ara macao", img: "/african-grey-vs-scarlet-macaw-comparison.webp",
    alt: "A Scarlet Macaw held on a hand indoors, its vivid red, yellow and blue plumage contrasting with the African Grey's understated silver-grey",
    size: "33–35 in · 900–1,100 g", noise: "Very loud", talk: "Moderate", trait: "Nature's brightest, not its best talker",
    body: "The Scarlet is the macaw people draw as a child — blazing red body, a rainbow wingtip, a personality as loud as its plumage. Against a Grey the trade is stark: you're swapping vocabulary for volume. Scarlets can pick up words, but they're prized for color and boldness, not conversation. They're also among the higher-strung macaws, known for hormonal mood swings during breeding season that even experienced keepers plan around. If a bird that stops a room visually is the goal, nothing a Grey does competes. If the goal is a bird you can talk to, this is the wrong direction entirely." },
  { pos: "50% 30%", id: "blue-and-gold", name: "Blue-and-Gold Macaw", sci: "Ara ararauna", img: "/african-grey-vs-blue-and-gold-macaw-comparison.webp",
    alt: "A Blue-and-Gold Macaw in close portrait, cobalt-blue back and golden-yellow chest, the most commonly kept pet macaw species",
    size: "33–35 in · 900–1,300 g", noise: "Very loud", talk: "Fair", trait: "The 'energizer bunny' of the macaw world",
    body: "This is the macaw most buyers picture when they type just \"macaw\" into a search bar, and the one behind your highest-intent search: whether it beats a Grey for a house pet. It doesn't, on the metrics that make a house livable — the Blue-and-Gold's contact call carries well past 100 decibels, close to a chainsaw, and it needs a genuinely large flight cage plus hours of daily out-of-cage time to stay sane. What it offers instead is relentless, extroverted energy: acrobatic, food-motivated, and famously food-driven for training. Against the Grey's laid-back, chatty reserve, the Blue-and-Gold is the louder, more physical, less conversational bird — wonderful in the right dedicated bird room, a poor fit for an apartment." },
  { pos: "50% 28%", id: "green-winged", name: "Green-winged Macaw", sci: "Ara chloropterus", img: "/african-grey-vs-green-winged-macaw-comparison.webp",
    alt: "A Green-winged Macaw in profile showing its deep red body and green wing band, one of the largest macaw species by length",
    size: "35–39 in · 1,000–1,700 g", noise: "Very loud", talk: "Limited", trait: "Among the largest macaws by length",
    body: "Nose to tail, the Green-winged is one of the biggest parrots you can legally own — deep crimson body, a green-and-blue wing band, and a beak built to crack macadamia shells whole. Owners describe them as gentle giants, calmer and less nippy than their size suggests, but \"gentle\" doesn't mean small: the beak alone drives a real monthly toy-replacement budget, easily $200–$300 for a bird that treats wooden perches as a snack. Against a Grey, the Green-winged trades talking ability and apartment-plausibility for sheer physical presence. If your home has the room and the budget for that beak, it's a genuinely different kind of companion than a Grey — not better or worse, just built for a different life." },
  { pos: "50% 30%", id: "hyacinth", name: "Hyacinth Macaw", sci: "Anodorhynchus hyacinthinus", img: "/african-grey-vs-hyacinth-macaw-comparison.webp",
    alt: "A Hyacinth Macaw in close portrait, deep cobalt-blue plumage with a bright yellow eye-ring, the largest flying parrot species", loading_priority: false,
    size: "40 in · 1,200–1,700 g", noise: "Very loud", talk: "Limited", trait: "The largest parrot alive, and the strongest bite ever measured in a bird",
    body: "The Hyacinth is the giant of the parrot world — the longest flying parrot species, cobalt-blue from head to tail, with a beak engineered to crack palm nuts most animals can't touch. It's also the bird behind the biggest number on this page: a 2025 Journal of Anatomy study measured a Hyacinth's bite at nearly 540 newtons in vivo, the highest recorded for any bird species. Against a Grey's 61–96 newtons, that's roughly five to nine times the force. Temperamentally, Hyacinths are often described as gentle and affectionate despite that beak — but \"gentle\" in a 1,700-gram bird with the strongest measured bite in aviculture still demands real caution around children. The Grey wins on talking, apartment life and everyday manageability; the Hyacinth wins on sheer scale and specialist appeal for keepers with the space, budget and diet knowledge it needs." },
  { pos: "50% 26%", id: "military", name: "Military Macaw", sci: "Ara militaris", img: "/african-grey-vs-military-macaw-comparison.webp",
    alt: "A Military Macaw showing its olive-green body and red forehead patch, a mid-sized macaw named for its uniform-like coloring",
    size: "28–33 in · 900–1,200 g", noise: "Loud", talk: "Moderate", trait: "Olive camouflage, not a camouflaged temperament",
    body: "Named for its muted olive-green body against military dress uniforms, this macaw sits in the middle of the size chart — bigger than a Grey, smaller than a Green-winged or Hyacinth. Militaries are capable talkers by macaw standards and known for strong one-on-one bonds, sometimes rivaling a Grey's devotion to a favorite person. Where they diverge sharply is volume and space: a Military still needs a large flight cage and produces the sustained contact calls that make macaws, as a group, apartment-incompatible. If the appeal is a bird that bonds hard and talks some, and your home can absorb macaw-level noise, a Military splits the difference between the Grey's conversational style and a bigger macaw's physical presence." },
  { pos: "50% 26%", id: "severe", name: "Severe Macaw", sci: "Ara severus", img: "/african-grey-vs-severe-macaw-comparison.webp",
    alt: "A Severe Macaw, a compact green mini-macaw with a maroon-brown forehead, closer in body size to an African Grey than most macaws",
    size: "18 in · 350–450 g", noise: "Loud for its size", talk: "Fair", trait: "A mini macaw close to the Grey's own size class",
    body: "The Severe, also called the Chestnut-fronted Macaw, is one of the true \"mini macaws\" — green-bodied with a maroon forehead patch, and at 350–450 grams it's the closest any macaw gets to sharing a Grey's actual weight class. That size similarity makes it the fairest apples-to-apples comparison on this page: same rough footprint, very different bird. The Severe still carries a macaw's higher-pitched, carrying scream and a macaw's love of destructive chewing, just delivered from a body a Grey owner would recognize the size of. It's a reasonable entry point for someone drawn to macaw personality who's nervous about macaw scale — though the noise gap with a Grey remains real regardless of the bird's size." },
  { pos: "50% 30%", id: "hahns", name: "Hahn's Macaw", sci: "Diopsittaca nobilis", img: "/african-grey-vs-hahns-macaw-comparison.webp",
    alt: "A Hahn's Macaw perched on a hand, the smallest true macaw species, green-bodied with a red shoulder patch",
    size: "12–14 in · 130–170 g", noise: "Moderate for a macaw", talk: "Fair", trait: "The smallest macaw — lighter than most Greys",
    body: "Hahn's Macaw, sometimes sold as the Red-shouldered Macaw, is the smallest macaw species that exists — smaller and lighter than a Timneh Grey, let alone a Congo. It's the macaw most often floated as \"macaw-curious apartment dwellers, start here,\" and there's real logic to that: its contact calls, while still a macaw's call, carry noticeably less raw power than a Blue-and-Gold's or Green-winged's. It won't out-talk a Grey and it still packs full macaw energy — bold, busy, food-driven — into a small package, which surprises owners expecting a quiet bird because of its size. Think of it as a macaw personality with the Grey's footprint, not a quiet macaw." },
  { pos: "50% 30%", id: "mini-macaw", name: "Mini Macaw (Miniature Species)", sci: "Diopsittaca & Primolius spp.", img: "/african-grey-vs-mini-macaw-comparison.webp",
    alt: "A small mini macaw species perched indoors, representative of the miniature macaw group that includes Hahn's and the Yellow-collared",
    size: "12–20 in · 130–300 g", noise: "Moderate for a macaw", talk: "Fair", trait: "The umbrella term for every small macaw",
    body: "\"Mini macaw\" isn't one species — it's the umbrella term for the smaller macaws (Hahn's, Yellow-collared, Red-bellied and a few others) that share a compact frame and a big-macaw personality. Buyers who search this term are usually asking the same question our apartment/house GSC query implies: is there a small-enough macaw for a smaller home? The honest answer is size helps with cage footprint and beak-driven destruction, but it doesn't fix the volume gap with a Grey — even the mini macaws are louder and more insistent than a Grey's dawn-and-dusk chatter. If the draw is genuinely macaw temperament in the smallest legal package, this category is where to start researching by name, species by species." },
  { pos: "50% 26%", id: "camelot", name: "Camelot Macaw (Hybrid)", sci: "Ara macao × Catalina hybrid", img: "/african-grey-vs-camelot-macaw-comparison.webp",
    alt: "A Camelot Macaw hybrid showing vivid orange-red plumage with blue wing tips, a deliberate cross between Scarlet and Catalina macaw lines",
    size: "34–36 in · 1,000–1,200 g", noise: "Very loud", talk: "Moderate", trait: "A deliberately bred hybrid, not a wild species",
    body: "The Camelot is a purpose-bred hybrid — a Catalina Macaw (itself a Blue-and-Gold × Scarlet cross) bred back to a Scarlet, aimed at concentrating the Scarlet's fire-orange color with a Catalina's build. It's not found in the wild; it exists because aviculturists selected for it. Almost every competitor page treats \"macaw\" as one bird and skips hybrids entirely, which is exactly the gap this section fills. Temperament tracks its parent species — bold, food-driven, macaw-loud — with breeders reporting hybrid vigor claims that, honestly, aren't independently studied the way the Grey's cognition research is. Against a Grey, a Camelot offers striking, camera-ready color and zero talking-ability edge." },
  { pos: "50% 22%", id: "catalina", name: "Catalina Macaw (Hybrid)", sci: "Ara ararauna × Ara macao", img: "/african-grey-vs-catalina-macaw-comparison.webp",
    alt: "A Catalina Macaw hybrid displaying a blend of blue, gold and red plumage from its Blue-and-Gold and Scarlet parent species",
    size: "30–35 in · 900–1,100 g", noise: "Very loud", talk: "Moderate", trait: "The original Blue-and-Gold × Scarlet cross",
    body: "The Catalina is the first-generation cross behind the Camelot — a Blue-and-Gold bred to a Scarlet, producing a bird with patchwork blue, gold and red plumage no two individuals wear quite the same way. Breeders and owner forums frequently describe Catalinas as unusually outgoing even by macaw standards, though that's anecdotal rather than a controlled finding, and we won't dress it up as more than that. What's not anecdotal is the noise and space math: a Catalina inherits full Blue-and-Gold-scale volume and cage requirements. If a one-of-a-kind color pattern matters more to you than a documented talking bird, the Catalina is the more honest hybrid pick than pretending any macaw closes the conversation gap with a Grey." },
  { pos: "50% 28%", id: "ruby", name: "Ruby Macaw (Hybrid)", sci: "Ara chloropterus hybrid", img: "/african-grey-vs-ruby-macaw-comparison.webp",
    alt: "A Ruby Macaw hybrid showing deep ruby-red plumage derived from Green-winged Macaw lineage, a less common aviculture cross",
    size: "32–37 in · 1,000–1,500 g", noise: "Very loud", talk: "Limited", trait: "A rarer Green-winged-line hybrid",
    body: "The Ruby is the least standardized name on this list — different aviaries use it for slightly different Green-winged-line crosses, which is itself worth knowing before you go shopping: \"Ruby Macaw\" isn't a fixed, documented bloodline the way Camelot and Catalina increasingly are. What's consistent across the crosses is scale — Green-winged genetics mean a large, powerful bird with the beak strength and space needs to match. We include it here because it rounds out the 11-macaw breakdown almost no competitor attempts, and because a buyer who's seen the name deserves an honest answer instead of silence: expect Green-winged-level size and noise, a striking red-toned coat, and the same talking-ability gap against a Grey that runs through every macaw on this page." },
];

// available birds, read live from clutch-inventory (never hardcoded status)
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === 'available' && b.sex !== 'pair')
  .sort((a, b) => (a.variant === 'congo_african_grey' ? -1 : 1));
const availablePair = ((clutch as any).birds as any[]).find((b) => b.sex === 'pair' && b.status === 'available');

const faqs = [
  { q: "Which is bigger, an African Grey or a macaw?", a: "Almost every macaw is bigger. A Congo African Grey runs 400–600 grams and 12–14 inches; a Timneh is smaller still at 275–375 grams. Even the smallest true macaw, Hahn's, is lighter than a Timneh at 130–170 grams, but most pet macaws — Blue-and-Gold, Scarlet, Green-winged, Hyacinth — run 900 grams to 1.7 kilograms and 28 to 40 inches. The one exception worth knowing: several \"mini macaw\" species are actually closer to a Grey's size than to a Blue-and-Gold's." },
  { q: "Is a blue macaw or an African Grey better for a house pet?", a: "For most houses, the African Grey. A Blue-and-Gold Macaw's contact call runs well past 100 decibels — close to a chainsaw — and it needs a large dedicated flight cage plus hours of daily exercise to stay mentally healthy. A Grey's vocalizations are moderate and its footprint is a third the size. The Blue-and-Gold wins on visual drama and playful, physical energy; the Grey wins on almost everything that makes a house livable day to day." },
  { q: "Is an African Grey, a Macaw, or a Cockatoo the better parrot?", a: "There's no single winner — each is built differently. The African Grey is the best talker and the most apartment-plausible of the three. Macaws are the boldest, most colorful and generally the loudest and largest. Cockatoos are the most physically affectionate \"velcro birds,\" trading talking ability for near-constant contact. See our full African Grey vs Cockatoo comparison for that half of the triangle." },
  { q: "Do African Greys or macaws talk better?", a: "African Greys, clearly. A Grey's word count can run into the hundreds or beyond, spoken with a clarity that fools people over a phone line, backed by decades of contextual-use research centered on Alex the Grey. Macaws pick up words and phrases — Blue-and-Gold and Military are the strongest talkers of the group — but none touch a Grey's precision or range." },
  { q: "How much stronger is a macaw's bite than an African Grey's?", a: "It depends entirely on the species. A Grey bites at roughly 61–96 newtons. A 2025 in-vivo study in the Journal of Anatomy measured a Hyacinth Macaw's bite at nearly 540 newtons — about five to nine times a Grey's force, and the highest bite force recorded for any bird. Smaller macaws like Hahn's or Severe bite considerably softer than a Hyacinth, though still harder than a Grey pound for pound." },
  { q: "Are macaws and African Greys similar birds?", a: "They're both intelligent, long-lived parrots that need serious daily enrichment, but they diverge sharply in practice. Greys are the quieter, more conversational, more independent bird; macaws are louder, larger-bodied (with a few mini exceptions), and lead with bold physicality over language. Housing, noise tolerance and cage-size needs differ enough that \"similar\" undersells the real gap a new owner will feel." },
  { q: "Which is louder, a macaw or an African Grey?", a: "Macaws, by a wide margin. Large macaw species produce contact-call screams that rank among the loudest sounds any companion bird makes, built in the wild to carry for miles through rainforest canopy. A Grey's vocal signature is whistles, talking and appliance mimicry, with real but far more moderate dawn-and-dusk peaks." },
  { q: "Can an African Grey and a macaw live in the same house?", a: "With separate, appropriately sized cages and careful supervision, yes — many multi-bird households manage it. The bite-force and size mismatch means unsupervised contact is never advisable, and the macaw's volume will be a daily reality for both birds and owners regardless of how well they otherwise coexist." },
  { q: "Which lives longer, an African Grey or a macaw?", a: "Both outlast most other pets by decades. A well-cared-for Grey reaches 40–60 years; Blue-and-Gold and Hyacinth Macaws are frequently cited at 50–80 in good captive conditions. Either one may still be alive when you're not, which is exactly why this page has a dedicated succession-planning section." },
  { q: "Which is more expensive to own, an African Grey or a macaw?", a: "Purchase prices can be comparable, but ongoing costs diverge: macaws need dramatically larger cages, eat more by volume, and — thanks to that stronger beak — go through toys and perches faster, often $200–$300 a month for the biggest species. A Grey's smaller footprint keeps first-year and annual costs meaningfully lower across the board." },
  { q: "Do macaws or African Greys need more space?", a: "Macaws, without exception. Even the smallest mini macaws need a substantial flight cage, and large species like the Green-winged or Hyacinth need dedicated bird-room-scale space plus daily out-of-cage flight time. A Grey's minimum cage footprint is meaningfully smaller, which is a major reason it's the more apartment-plausible of the two." },
  { q: "Is an African Grey or a macaw better for a first-time owner?", a: "Neither is a true beginner's bird — both are intelligent, decades-long commitments that punish neglect with plucking or screaming. Between the two, a Grey is generally the more forgiving first parrot: quieter, smaller, and less physically demanding than a large macaw, whose volume and space needs overwhelm many first-time owners." },
];

