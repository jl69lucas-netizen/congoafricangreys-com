---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "African Grey vs Macaw | Which Parrot Is Right for You?";
const description = "African Grey vs Macaw compared: size, noise, talking ability, lifespan, price, and temperament. Which species fits your home, schedule, and budget?";
const canonical = "https://congoafricangreys.com/african-grey-vs-macaw/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey vs Macaw", url: "/african-grey-vs-macaw/" },
];

const comparisonRows = [
  { attr: "Body size", ag: "12–14 inches (Congo) / 9–11 inches (Timneh)", macaw: "20–42 inches depending on species" },
  { attr: "Weight", ag: "400–550 grams (Congo)", macaw: "900–1,700 grams (Blue & Gold)" },
  { attr: "Noise level", ag: "Moderate — contact calls; much quieter than macaws", macaw: "Very loud — screaming is natural behavior" },
  { attr: "Talking ability", ag: "Exceptional — best talker of all parrots", macaw: "Good — fewer words, less clarity" },
  { attr: "Price range", ag: "$1,700 – $3,500", macaw: "$1,000 – $3,500 depending on species" },
  { attr: "Temperament", ag: "Intelligent, sensitive, can be reserved", macaw: "Playful, bold, can be nippy" },
  { attr: "Lifespan", ag: "40–60 years", macaw: "50–80+ years (Blue & Gold)" },
  { attr: "Cage size", ag: "36\"W × 24\"D × 48\"H minimum", macaw: "48\"W × 36\"D × 60\"H minimum" },
  { attr: "Apartment suitability", ag: "Good — quieter contact calls", macaw: "Poor — very loud, echoes in apartments" },
  { attr: "CITES status", ag: "Appendix II — full documentation required", macaw: "Varies by species — many Appendix I or II" },
];

const faqs = [
  {
    q: "Do African Greys or macaws talk better?",
    a: "African Greys are the superior talkers. They develop vocabularies of 200–1,000+ words, mimic voices with near-human clarity, and use words in context. Macaws can learn words and phrases but typically have smaller vocabularies and less precise enunciation than African Greys.",
  },
  {
    q: "Are African Greys or macaws better for apartments?",
    a: "African Greys are significantly better apartment birds. Their contact calls are moderate in volume. Macaws produce loud, piercing screams that carry through walls — they are poorly suited to apartment living and may violate noise ordinances.",
  },
  {
    q: "Which is more expensive to own, an African Grey or a macaw?",
    a: "Purchase prices are comparable ($1,700–$3,500 for both). Ongoing costs differ: macaws need much larger cages and consume more food daily due to their size. Veterinary costs are similar. Both are 40–80 year commitments with significant lifetime expenses.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="cmp-hero">
    <div class="page-container">
      <h1 class="cmp-h1">African Grey vs Macaw: Which Parrot Is Right for You?</h1>
      <p class="cmp-sub">
        Two of the most popular large parrots — compared side-by-side on size, noise, talking
        ability, lifespan, cost, and temperament so you can make the right choice for your home.
      </p>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="cmp-section">
    <div class="page-container">
      <h2 class="cmp-h2">African Grey vs Macaw: Side-by-Side</h2>
      <div class="cmp-table-wrap">
        <table class="cmp-table">
          <thead>
            <tr>
              <th>Attribute</th>
              <th>African Grey</th>
              <th>Macaw</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <th scope="row">{row.attr}</th>
                <td>{row.ag}</td>
                <td>{row.macaw}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- VERDICT CARDS -->
  <section class="cmp-section cmp-alt">
    <div class="page-container">
      <h2 class="cmp-h2">Which Bird Should You Choose?</h2>
      <div class="cmp-verdict-grid">
        <div class="cmp-verdict-card">
          <h3 class="cmp-verdict-title">Choose an African Grey if&hellip;</h3>
          <ul class="cmp-verdict-list">
            <li>Talking ability is your top priority</li>
            <li>You live in an apartment or shared housing</li>
            <li>You want a smaller, lighter bird</li>
            <li>You value a deep, quiet intelligent bond over bold personality</li>
            <li>You prefer moderate noise levels</li>
          </ul>
        </div>
        <div class="cmp-verdict-card">
          <h3 class="cmp-verdict-title">Choose a Macaw if&hellip;</h3>
          <ul class="cmp-verdict-list">
            <li>You want a bold, colorful, visually striking bird</li>
            <li>You have a large dedicated bird room with noise insulation</li>
            <li>You prefer playful, physically active bird interaction</li>
            <li>Talking ability is less important than personality</li>
            <li>You have outdoor space where noise is not an issue</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DEEPER COMPARISON PROSE -->
  <section class="cmp-section">
    <div class="page-container text-wrap">
      <h2 class="cmp-h2">The Key Differences That Matter Most</h2>

      <h3 class="cmp-h3">Noise: The Most Practical Difference</h3>
      <p class="cmp-p">
        Macaws scream. This is not a training failure — it is natural macaw behavior. Contact
        calls in Blue and Gold Macaws can exceed 105 decibels, comparable to a chainsaw at close
        range. In an apartment or townhouse, this will affect your neighbors, your lease, and
        possibly your hearing.
      </p>
      <p class="cmp-p">
        African Greys produce contact calls too, but at significantly lower volume. Their natural
        vocalizations are conversational rather than piercing. Most apartment dwellers can manage
        an African Grey without neighbor complaints; macaw ownership in dense housing is genuinely
        difficult to manage humanely.
      </p>

      <h3 class="cmp-h3">Talking: African Grey Wins Decisively</h3>
      <p class="cmp-p">
        Both species can talk. The comparison ends there. African Greys develop vocabularies of
        200 to 1,000+ words, reproduce voices with human-like clarity, and in well-documented
        cases use language contextually — using words appropriately in situations rather than
        randomly reciting them. Dr. Irene Pepperberg's work with Alex established that African
        Grey language comprehension is not mere mimicry.
      </p>
      <p class="cmp-p">
        Macaws can learn words and phrases. Blue and Golds and Military Macaws are the talkers of
        the macaw world. But their vocabularies are typically smaller and their enunciation less
        precise. If talking ability is your primary interest, African Grey is the correct choice.
      </p>

      <h3 class="cmp-h3">CITES and Legal Status</h3>
      <p class="cmp-p">
        Both African Greys and most macaw species are CITES-listed. African Greys are uniformly
        CITES Appendix II. Macaws vary: some popular species like the Blue and Gold are Appendix
        II; others like the Hyacinth Macaw are Appendix I (more restricted). Research the specific
        species before purchase and demand captive-bred documentation regardless of species.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cmp-section cmp-alt">
    <div class="page-container text-wrap">
      <h2 class="cmp-h2">African Grey vs Macaw: FAQ</h2>
      <div class="cmp-faq">
        {faqs.map((f) => (
          <details class="cmp-faq-item">
            <summary class="cmp-faq-q">{f.q}</summary>
            <p class="cmp-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="cmp-section">
    <div class="page-container text-wrap">
      <h2 class="cmp-h2">Related Comparisons</h2>
      <ul class="cmp-links">
        <li><a href="/congo-vs-timneh-african-grey/" class="cmp-link">Congo vs Timneh African Grey</a> — comparing the two subspecies</li>
        <li><a href="/african-grey-vs-cockatoo/" class="cmp-link">African Grey vs Cockatoo</a> — talking ability, affection, and dust compared</li>
      </ul>
    </div>
  </section>

  <CTA
    headline="Interested in an African Grey?"
    sub="Every bird from CongoAfricanGreys.com is hand-raised, CITES-documented, and vet-certified. We ship IATA-compliant to all 50 states."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap { max-width: 760px; }
  .cmp-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .cmp-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .cmp-h3 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.2rem;
    margin: 1.75rem 0 0.6rem;
  }
  .cmp-hero {
    background: #2D6A4F;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .cmp-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto;
  }
  .cmp-section { padding: 3rem 0; }
  .cmp-alt { background: #faf7f4; }
  .cmp-p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.1rem;
  }
  .cmp-table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid #e7e5e4;
    box-shadow: 0 2px 8px rgba(60,30,10,0.07);
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.95rem;
  }
  .cmp-table thead tr { background: #2D6A4F; }
  .cmp-table thead th {
    color: #faf7f4;
    font-weight: 600;
    text-align: left;
    padding: 0.9rem 1.25rem;
  }
  .cmp-table tbody tr:nth-child(even) { background: #faf7f4; }
  .cmp-table tbody tr:nth-child(odd) { background: #fff; }
  .cmp-table tbody th {
    font-weight: 600;
    color: #2D6A4F;
    padding: 0.8rem 1.25rem;
    text-align: left;
    white-space: nowrap;
  }
  .cmp-table tbody td {
    padding: 0.8rem 1.25rem;
    color: #44403c;
    line-height: 1.5;
  }
  .cmp-verdict-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
  }
  .cmp-verdict-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 2px 8px rgba(60,30,10,0.06);
  }
  .cmp-verdict-title {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }
  .cmp-verdict-list {
    padding-left: 1.25rem;
    margin: 0;
  }
  .cmp-verdict-list li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.97rem;
    line-height: 1.6;
    color: #44403c;
    margin-bottom: 0.5rem;
  }
  .cmp-links { padding-left: 1.5rem; margin: 0; }
  .cmp-links li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    margin-bottom: 0.5rem;
  }
  .cmp-link { color: #e8604c; text-decoration: underline; }
  .cmp-link:hover { color: #d44e3b; }
  .cmp-faq { display: flex; flex-direction: column; gap: 0.75rem; }
  .cmp-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .cmp-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .cmp-faq-q::-webkit-details-marker { display: none; }
  .cmp-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) {
    .page-container { padding: 0 16px; }
    .cmp-verdict-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) and (max-width: 1024px) { .page-container { padding: 0 32px; } }
</style>
