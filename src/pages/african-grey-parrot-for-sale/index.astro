---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot For Sale | Congo African Greys | USA";
const description = "Captive-bred African Grey parrots for sale from a USDA AWA licensed, CITES-documented breeder. Congo variants $1,700–$3,500, Timneh $1,500–$1,600. Ships nationwide.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale/";

const productSchema = {
  "name": "African Grey Parrot For Sale",
  "description": "Captive-bred Congo and Timneh African Grey parrots. CITES documented, DNA sexed, avian vet health certificate included.",
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "1500",
    "highPrice": "3500",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Congo African Greys" }
  },
  "image": "https://congoafricangreys.com/og-image.png"
};
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">CITES Captive-Bred &middot; USDA Licensed &middot; Ships Nationwide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-6">African Grey Parrot For Sale</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">Hand-raised Congo and Timneh African Greys from our family aviary in Midland, Texas. Every bird is DNA sexed, CITES documented, and comes with an avian vet health certificate.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact-us/" class="bg-gold text-logo-dark font-semibold px-8 py-4 rounded-full text-lg hover:bg-cream transition-colors">Inquire About Availability</a>
        <a href="tel:+19565646067" class="border-2 border-gold text-gold font-semibold px-8 py-4 rounded-full text-lg hover:bg-gold hover:text-logo-dark transition-colors">Call (956) 564-6067</a>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Breadcrumb -->
  <!-- Browse by State -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Grey Parrots for Sale", url: "/african-grey-parrot-for-sale/" }
      ]} />
  </div>

  <section class="state-grid-section" style="padding: 3rem 0;">
    <div class="container" style="max-width:1200px;margin:0 auto;padding:0 1rem;">
      <h2 style="font-family:'Lora',serif;font-weight:700;color:#2D6A4F;margin-bottom:1.5rem;">Browse African Grey Parrots by State</h2>
      <p style="max-width:70ch;margin-bottom:2rem;">We ship IATA-compliant to all 50 states. Select your state for local breeder information and availability.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
        <a href="/african-grey-parrot-for-sale-florida/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Florida</a>
        <a href="/african-grey-parrot-for-sale-texas/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Texas</a>
        <a href="/buy-intelligent-african-grey-for-sale-ca/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in California</a>
        <a href="/african-grey-parrot-for-sale-new-york/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in New York</a>
        <a href="/african-grey-parrot-for-sale-ohio/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Ohio</a>
        <a href="/african-grey-parrot-for-sale-michigan/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Michigan</a>
        <a href="/african-grey-parrot-for-sale-pennsylvania/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Pennsylvania</a>
        <a href="/african-grey-parrot-for-sale-illinois/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Illinois</a>
        <a href="/african-grey-parrot-for-sale-missouri/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Missouri</a>
        <a href="/african-grey-parrot-for-sale-minnesota/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Minnesota</a>
        <a href="/african-grey-parrot-for-sale-maryland/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Maryland</a>
        <a href="/african-grey-parrot-for-sale-kentucky/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Kentucky</a>
        <a href="/african-grey-parrot-for-sale-iowa/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Iowa</a>
        <a href="/african-grey-parrot-for-sale-indiana/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Indiana</a>
        <a href="/african-grey-parrot-for-sale-massachusetts/" style="display:block;padding:1rem 1.25rem;background:#fff;border:1px solid #e0d8d0;border-radius:12px;color:#2D6A4F;font-family:'Sora',sans-serif;font-weight:600;text-decoration:none;">African Greys in Massachusetts</a>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-center text-logo-dark mb-10">Current Pricing</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { label: 'Congo Baby (3–6 mo)', price: '$2,300–$2,500', note: 'Hand-raised, weaned, full social training' },
          { label: 'Congo Adult (1 yr+)', price: '$1,700', note: 'Tame, established personality' },
          { label: 'Timneh African Grey', price: '$1,500–$1,600', note: 'Calmer, earlier talker' },
          { label: 'Congo Pair (Jins+Jeni)', price: '$3,500', note: 'Unrelated pair — must go together' },
          { label: 'Breeding Pair',       price: '$3,000', note: 'Proven bonded pair, DNA certified' },
          { label: 'Deposit to Reserve', price: '$200', note: 'Applies to purchase price' },
        ].map(item => (
          <div class="border border-gold/30 rounded-xl p-6 bg-white shadow-sm text-center">
            <p class="text-stone-500 text-sm mb-1">{item.label}</p>
            <p class="font-lora font-bold text-2xl text-logo-dark mb-1">{item.price}</p>
            <p class="text-xs text-stone-400">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Schema type="product" data={productSchema} />
  <Schema type="organization" />

  <CTA headline="Inquire About Available African Greys" />
</BaseLayout>
