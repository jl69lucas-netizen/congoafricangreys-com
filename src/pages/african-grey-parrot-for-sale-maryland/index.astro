---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot For Sale Maryland | Ships to Baltimore & BWI | Congo African Greys";
const description = "African Grey parrots for sale in Maryland. IATA-compliant shipping to Baltimore/Washington (BWI). CITES documented, DNA sexed, 3-day health guarantee. From our Midland, TX family aviary.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-maryland/";
---

<BaseLayout {title} {description} {canonical}>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Grey Parrots for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "African Grey for Sale in Maryland", url: "/african-grey-parrot-for-sale-maryland/" }
    ]} />
  </div>

  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Ships to Baltimore &middot; BWI &middot; IATA Compliant</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-6">African Grey Parrot For Sale &mdash; Maryland</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">We ship CITES-documented, DNA-sexed African Grey parrots to Maryland buyers via IATA-compliant transport. Birds arrive at Baltimore/Washington International (BWI) for pickup.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact-us/" class="bg-clay text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors">Inquire &mdash; Maryland Buyers</a>
        <a href="tel:+19565646067" class="border-2 border-gold text-gold font-semibold px-8 py-4 rounded-full text-lg hover:bg-gold hover:text-logo-dark transition-colors">Call (956) 564-6067</a>
      </div>
    </div>
  </section>

  <TrustBar />

  <section class="py-16 px-4 max-w-4xl mx-auto">
    <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Shipping to Maryland</h2>
    <div class="grid sm:grid-cols-2 gap-6 text-sm text-stone-600">
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Maryland Airport Pickup</h3>
        <p>Birds ship IATA-compliant to Baltimore/Washington International Thurgood Marshall Airport (BWI). We coordinate all logistics and notify you of your bird's arrival time.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Full Documentation</h3>
        <p>Every bird arrives with CITES captive-bred certificate, hatch certificate, DNA sexing cert, and avian vet health certificate. All captive-bred &mdash; never wild-caught.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">3-Day Health Guarantee</h3>
        <p>All birds ship with a 3-day health guarantee and avian vet certificate dated within 10 days of shipment.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Reserve with $200 Deposit</h3>
        <p>Secure your bird with a $200 deposit. We hold your bird until shipping day and keep you updated throughout.</p>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Pricing for Maryland Buyers</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl border border-stone-100 p-6 shadow-sm">
          <h3 class="font-lora font-semibold text-logo-dark mb-2">Congo African Grey</h3>
          <p class="text-clay font-bold text-2xl mb-2">$1,700 &ndash; $3,500</p>
          <p class="text-stone-600 text-sm">The classic CAG &mdash; larger bird, bright red tail, renowned for vocabulary and emotional intelligence. Popular in the Baltimore metro and DC-adjacent Maryland communities.</p>
          <a href="/congo-african-grey-for-sale/" class="inline-block mt-4 text-logo-dark font-semibold text-sm underline hover:text-clay transition-colors">View Congo African Greys &rarr;</a>
        </div>
        <div class="bg-white rounded-xl border border-stone-100 p-6 shadow-sm">
          <h3 class="font-lora font-semibold text-logo-dark mb-2">Timneh African Grey</h3>
          <p class="text-clay font-bold text-2xl mb-2">$1,500 &ndash; $1,600</p>
          <p class="text-stone-600 text-sm">Smaller, calmer, and adapts quickly. The Timneh is a great fit for Maryland townhome and apartment living in the Baltimore-Annapolis corridor.</p>
          <a href="/timneh-african-grey-for-sale/" class="inline-block mt-4 text-logo-dark font-semibold text-sm underline hover:text-clay transition-colors">View Timneh African Greys &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'Do you ship African Greys to Maryland?', a: 'Yes. We ship IATA-compliant to Baltimore/Washington International (BWI). Shipping is $185 via Delta, United, or American Airlines cargo.' },
          { q: 'What documentation does the bird arrive with?', a: 'Every bird ships with CITES captive-bred certificate, hatch certificate with band number, DNA sexing certificate, and an avian vet health certificate dated within 10 days of shipment.' },
          { q: 'Are your birds wild-caught?', a: 'No. All of our African Greys are captive-bred at our USDA-licensed aviary in Midland, Texas. CITES Appendix II documentation is included with every bird.' },
          { q: 'Can I visit the aviary in person?', a: 'Yes &mdash; aviary visits are by appointment at our Midland, Texas location. Contact us to schedule. Maryland buyers can fly direct into Midland International.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 px-4 max-w-4xl mx-auto">
    <p class="text-xs text-stone-400 text-center">All birds are captive-bred and covered by CITES Appendix II documentation. CongoAfricanGreys.com is a USDA AWA-licensed breeder. Browse our <a href="/african-grey-parrots-for-sale/" class="underline hover:text-clay">full parrot listings</a> or contact us for availability.</p>
  </section>

  <Schema type="local-business" />
  <CTA headline="African Grey Parrots Available for Maryland Buyers" sub="Congo ($1,700–$3,500) and Timneh ($1,500–$1,600). Reserve with a $200 deposit." />

</BaseLayout>
