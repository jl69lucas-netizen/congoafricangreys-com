---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Parrot Health Guarantee | What Does Our Written Health Guarantee Cover, How Long Is the Window & What Documentation Comes With Every Bird? | Vet-Certified, DNA-Sexed & CITES Appendix I | C.A.Gs – Midland, TX";
const description = "Our African Grey parrot health guarantee from USDA-licensed breeders C.A.Gs: a written 72-hour guarantee on pre-existing congenital and infectious conditions, an avian-vet exam before every bird leaves, PCR DNA sexing, CITES Appendix I captive-bred documentation, a hatch certificate and closed band, and IATA shipping ($185 airport / $350 home). Exactly what is covered, the window, and what you do — in plain language.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-health-guarantee/";
const updated = "June 2026";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Resources & Trust", url: "/trusted-african-grey-parrot-breeders/" },
  { name: "Health Guarantee", url: "/african-grey-parrot-health-guarantee/" },
];

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + financial-entities.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Vet-cleared and ready before he ever leaves.',
    notes: "Hand-raised male, 4 months old — avian-vet examined, PCR DNA-sexed, and weaned before transfer." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Full documentation packet travels with her.',
    notes: 'Premium hand-raised female, 3 months old. CITES Appendix I captive-bred certificate, DNA sex result, and avian-vet health certificate included.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, fully established, vet-certified.',
    notes: 'Soft temperament, easy to handle. 1-year-old female, hatch certificate and closed band on file.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Same guarantee, same paperwork, smaller bird.',
    notes: 'Hand-raised male Timneh African Grey, 5 months old. Avian-vet examined, DNA-sexed, fully weaned and ready.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, weaned, and vet-cleared to come home.',
    notes: 'Hand-raised female Timneh African Grey, 6 months old. Backed by our written 72-hour health guarantee and full CITES documentation.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two birds, two complete documentation packets.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both vet-examined, DNA-sexed and weaned.' },
];

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
// NOTE: Every guarantee term below is PRESERVED VERBATIM from the prior page (72-hour window,
// avian-vet diagnosis, replacement/refund at our discretion, 24h shipping report, 5–7 day new-owner
// visit, no buyer's-remorse returns). No new terms invented; answers tightened for length only.
const faqs = [
  { q: "Do C.A.Gs African Greys come with a health guarantee?",
    a: "Yes. Every African Grey we place comes with a written health guarantee covering congenital conditions and infectious disease for 72 hours after pickup or delivery. Each bird is examined by an avian vet before it leaves our Midland, Texas aviary. If a certified avian veterinarian diagnoses a pre-existing condition within that window, we resolve it with you directly — including full replacement or refund at our discretion." },
  { q: "What does the African Grey health guarantee cover?",
    a: "Two things: pre-existing congenital conditions that existed before purchase, and infectious disease present but not detectable at our pre-sale exam — both confirmed by an independent avian vet within 72 hours of pickup or delivery — plus shipping-related health issues reported within 24 hours of arrival. It does not cover accidents, injuries after delivery, conditions from improper care or diet, behavioral issues, or changes in your circumstances." },
  { q: "How long is the health guarantee window?",
    a: "The window is 72 hours from the moment you take possession of your Grey, which is why we ask you to book an independent avian-vet exam right away. For shipped birds, any shipping-related concern must be reported within 24 hours of arrival at the destination airport. These windows are short on purpose — a fast, documented vet check protects both you and the bird." },
  { q: "Do I need to take my new African Grey to a vet after purchase?",
    a: "Yes — we recommend a new-owner avian-vet visit within 5–7 days of bringing your bird home, and a same-day or next-day exam is what activates the guarantee. It establishes a baseline health record, confirms our pre-purchase clearance, and starts your bird's lifelong health file — important for a species that lives 40–60 years. We send our aviary's vet records to make that appointment faster." },
  { q: "What documentation comes with my African Grey parrot?",
    a: "Every bird from C.A.Gs includes a complete packet: a CITES Appendix I captive-bred certificate confirming legal US captive breeding, a PCR DNA sexing certificate, an avian-vet health certificate, a hatch certificate with the closed leg-band number, and USDA inspection records from our AWA-licensed aviary. These documents prove your bird is legal to own and fully documented — critical if you ever travel or move states." },
  { q: "What happens if my bird arrives unwell after shipping?",
    a: "Birds are vet-checked within 48 hours before any shipping date and travel in IATA-compliant live-animal containers, with flights kept under 8 hours when possible. If your bird shows distress on arrival, contact us the same day, within 24 hours of arrival, to fall inside the guarantee. We keep standing protocols with our avian vet for remote consultation with buyers." },
  { q: "Is Congo African Greys USDA licensed?",
    a: "Yes. Here at C.A.Gs, Mark & Teri Benjamin operate under a USDA Animal Welfare Act (AWA) license for our Midland, Texas aviary. That means our facility is subject to USDA inspection, our animal-care practices meet federal standards, and our records are kept to government requirements. You can request our USDA license number and verify it yourself before you pay anything." },
  { q: "What is your return policy for African Grey parrots?",
    a: "We do not accept returns for buyer's remorse — African Greys are living beings, not products, and transfers are stressful for the bird. Our written health guarantee covers pre-existing conditions as described above. If a genuine life change ever makes care impossible, we help you find a responsible rehome rather than surrender to a rescue. We stay in touch with our birds' families for life." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Health Guarantee — What's Covered, the Window & the Documentation",
  description: "C.A.Gs African Grey parrot health guarantee from USDA-licensed breeders: a written 72-hour guarantee on pre-existing congenital and infectious conditions, an avian-vet exam before every bird ships, PCR DNA sexing, CITES Appendix I captive-bred documentation, a hatch certificate and closed band, and IATA shipping.",
  image: "https://congoafricangreys.com/hand-fed-african-grey-baby-breeder.webp",
  inLanguage: "en-US",
  datePublished: "2024-09-01",
  dateModified: "2026-06-07",
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.png" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// NOTE: BreadcrumbList JSON-LD is emitted by <Breadcrumb /> itself (verified in dist) —
// we do NOT add a second copy here (interior standard: extend, never duplicate schema).

// 4 credential cards (the brief's requested trust block: USDA AWA · CITES · DNA-Sexed · Health Guarantee).
// Built inline ON PURPOSE — TrustStats.astro hardcodes its 4 items (cannot render "USDA AWA") and relies on
// the undefined `bg-warm` + `font-display` tokens (verified absent from global.css), so its classic variant
// would render with no card background and the wrong font. This block uses only defined tokens. See session brief.
const credentials = [
  { t: "USDA AWA Licensed",
    sub: "Federal Animal Welfare Act license · inspected facility · license number available on request.",
    icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 21 8 3 8"/></svg>' },
  { t: "CITES Appendix I Documented",
    sub: "Captive-bred certificate on every Grey · legal ownership proven · never wild-caught.",
    icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
  { t: "DNA-Sexed + Vet-Certified",
    sub: "PCR DNA sex result · avian-veterinarian health exam before every bird leaves.",
    icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3c0 4.5 8 4.5 8 9s-8 4.5-8 9"/><path d="M16 3c0 4.5-8 4.5-8 9s8 4.5 8 9"/><line x1="9" y1="6.5" x2="15" y2="6.5"/><line x1="9.5" y1="12" x2="14.5" y2="12"/><line x1="9" y1="17.5" x2="15" y2="17.5"/></svg>' },
  { t: "Written 72-Hour Health Guarantee",
    sub: "Pre-existing congenital + infectious conditions · hatch certificate + closed band · lifetime owner support.",
    icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#2D6A4F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>' },
];
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
  extraHeadHtml={'<link rel="preload" as="image" href="/hand-fed-african-grey-baby-breeder.webp" fetchpriority="high" type="image/webp" />'}>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="guarantee-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green · trust-first) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.16em] text-white/70">USDA AWA Licensed · CITES Documented · Vet-Certified · Updated {updated}</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              Our African Grey Parrot Health Guarantee
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">
              Here at C.A.Gs in Midland, Texas, Mark &amp; Teri Benjamin back every captive-bred Congo and Timneh African Grey with a written health guarantee — you are bringing home a 40 to 60 year companion, not a product. Every bird is examined by an avian vet, PCR DNA-sexed, and placed with full CITES Appendix I documentation. This page lays out exactly what the guarantee covers, the window, and what you do.
            </p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#whats-covered" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">See What's Covered →</a>
              <a href="#contact" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">Ask Us About a Bird →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/hand-fed-african-grey-baby-breeder.webp"
                  alt="A hand-fed baby Congo African Grey being cared for at the C.A.Gs aviary in Midland, Texas — the hands-on, vet-supervised health protocol behind every bird we guarantee."
                  title="C.A.Gs African Grey health guarantee — hand-raised, vet-certified"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover object-center" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Do C.A.Gs African Greys Come With a Health Guarantee?"
      badge="The promise · 60-sec read"
      items={[
        { stat: "Yes", label: "Written Guarantee", body: "Every Grey ships with a written health guarantee — not a verbal promise — covering pre-existing conditions." },
        { stat: "72 hr", label: "Coverage Window", body: "Congenital and infectious conditions, confirmed by a certified avian vet within 72 hours of pickup or delivery." },
        { stat: "Vet", label: "Examined First", body: "An avian vet examines every bird before it leaves our Midland, Texas aviary." },
        { stat: "DNA", label: "PCR-Sexed", body: "Each Grey is PCR DNA-sexed with a laboratory certificate — sex confirmed, never guessed." },
        { stat: "100%", label: "CITES Documented", body: "Appendix I captive-bred certificate, hatch certificate and closed band travel with every bird." },
        { stat: "24 hr", label: "Shipping Report", body: "Any shipping-related health concern is reported within 24 hours of your bird's arrival at the airport." },
        { stat: "USDA", label: "AWA Licensed", body: "We hold a USDA Animal Welfare Act license you can verify before you pay anything." },
        { stat: "Life", label: "Owner Support", body: "Our support doesn't end at the door — we stay reachable for the bird's whole 40–60 year life." },
      ]}
    />

    <!-- 4. CREDENTIAL CARDS (trust block) -->
    <section class="py-12 px-4 bg-warm-white md:py-14" aria-label="Our credentials">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-8 max-w-2xl mx-auto">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Trust, in receipts</p>
          <h2 class="font-lora font-bold text-logo-dark">What Backs Our African Grey Health Guarantee?</h2>
          <p class="text-stone-600 leading-relaxed mt-3 text-[15px] mx-auto" style="max-width:70ch;">A guarantee is only as good as the paperwork behind it. Here is what we hand every buyer — and what you can verify before you ever send a deposit.</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {credentials.map(c => (
            <article class="bg-white rounded-2xl border border-line p-6 text-center" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);">
              <div class="flex justify-center mb-3" set:html={c.icon} />
              <h3 class="font-lora font-bold text-[17px] text-logo-dark leading-snug">{c.t}</h3>
              <p class="text-stone-500 text-[13px] leading-relaxed mt-2">{c.sub}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. TOC -->
    <nav class="toc-guarantee py-10 px-4 bg-cream md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this page</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">8 sections · the full policy in plain language</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">The guarantee itself</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "What Does Our Health Guarantee Cover?", href: "#whats-covered" },
                  { n: 2, t: "How Do We Prepare Every Bird — the Pre-Sale Protocol?", href: "#pre-sale" },
                  { n: 3, t: "What Do You Need to Do Inside the Window?", href: "#your-part" },
                  { n: 4, t: "Which Documentation Comes With Your Grey?", href: "#documentation" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Shipping, birds & questions</p>
              <ol class="space-y-0">
                {[
                  { n: 5, t: "How Do We Protect a Bird's Health in Transit?", href: "#shipping-health" },
                  { n: 6, t: "Which Vet-Certified C.A.Gs Greys Are Available?", href: "#available-birds" },
                  { n: 7, t: "Health Guarantee Questions, Answered", href: "#faq" },
                  { n: 8, t: "Ready to Bring Home a Documented Grey?", href: "#contact" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- 6. WHAT'S COVERED -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="whats-covered" class="py-16 px-4 scroll-mt-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-8 border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">The Guarantee · What's Covered</p>
          <h2 class="font-lora font-bold text-logo-dark">What Does Our African Grey Health Guarantee Actually Cover?</h2>
          <p class="text-stone-600 leading-relaxed mt-3 text-[15px]" style="max-width:70ch;"><strong>Our written health guarantee covers pre-existing congenital conditions and infectious disease for 72 hours after pickup or delivery, plus shipping-related health issues reported within 24 hours of arrival.</strong> The promise is deliberately specific so you and your vet both know where you stand. If a certified avian veterinarian diagnoses a covered condition inside the window, we resolve it with you directly — including full replacement or refund at our discretion.</p>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          <article class="bg-white rounded-2xl border border-green/25 p-7" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);">
            <h3 class="font-lora font-bold text-xl text-logo-dark flex items-center gap-2"><span class="text-green">✔</span> Congenital Conditions</h3>
            <p class="text-stone-600 mt-2 text-[14.5px] leading-relaxed">Any condition that existed before purchase and is diagnosed by a certified avian vet within 72 hours of pickup or delivery is covered — the hidden, present-from-hatch issues a single exam can miss.</p>
          </article>
          <article class="bg-white rounded-2xl border border-green/25 p-7" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);">
            <h3 class="font-lora font-bold text-xl text-logo-dark flex items-center gap-2"><span class="text-green">✔</span> Infectious Disease at Sale</h3>
            <p class="text-stone-600 mt-2 text-[14.5px] leading-relaxed">Active infections present but not detectable at our pre-sale exam are covered when confirmed by an independent avian vet — protecting you against what no single exam could reasonably catch.</p>
          </article>
          <article class="bg-white rounded-2xl border border-green/25 p-7" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);">
            <h3 class="font-lora font-bold text-xl text-logo-dark flex items-center gap-2"><span class="text-green">✔</span> Shipping-Related Issues</h3>
            <p class="text-stone-600 mt-2 text-[14.5px] leading-relaxed">Health problems directly attributable to shipping are covered when reported within 24 hours of your bird's arrival at the destination airport — transit is the most stressful moment of the journey.</p>
          </article>
        </div>

        <div class="max-w-3xl mt-10">
          <div class="rounded-xl border border-clay/25 bg-clay/[0.05] p-5">
            <h3 class="font-sora font-bold text-sm uppercase tracking-wide text-clay-ink mb-1.5">What Our Guarantee Does Not Cover</h3>
