---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CounterSnippet from '../../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../../components/cag-library/KeyTakeawayV2.astro';
import NewsletterV2 from '../../../components/cag-library/NewsletterV2.astro';
import JumpRail from '../../../components/cag-library/JumpRail.astro';

const title = "Best-Value Congo African Grey for Sale | Meet Bery — DNA-Sexed Female, PBFD/APV PCR Clear, Hand-Raised ~1-Year Congo, $1,700 | C.A.Gs – Midland, TX";
const description = "Bery is a hand-raised young female Congo African Grey for sale — about 1 year old, gentle and fully socialised, $1,700. DNA-sexed female, PBFD/APV PCR clear, CITES-documented, captive-bred in the USA. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/bery/";

const productSchema = {
  "name": "Bery — Female Congo African Grey For Sale (Hand-Raised Young Female)",
  "description": "Bery is a hand-raised young female Congo African Grey (Psittacus erithacus), about 1 year old, with a gentle, fully-socialised temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented, USDA AWA licensed aviary. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/birds/bery/bery-hero.webp",
  "category": "Congo African Grey Parrot",
  "sku": "cag-bery",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-21",
  "offers": {
    "@type": "Offer",
    "price": "1700",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/bery/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Bery DNA-sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Bery goes home with her DNA sex certificate confirming she is female, her avian-vet health certificate, her hatch certificate with closed leg-band number, and her CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with the full paperwork set." }
    },
    {
      "@type": "Question",
      "name": "How old is Bery and what is her temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bery is about 1 year old. We hand-fed her ourselves, and she has grown into a gentle, fully-socialised young grey who is calm and trusting with people. She suits a family or a couple who want a sweet, people-oriented companion they can bond with from the very start." }
    },
    {
      "@type": "Question",
      "name": "How much is Bery and how do I reserve her?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bery is $1,700. A $200 deposit reserves her and pauses her listing for you. The balance is due before she travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Bery be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Bery ships nationwide. Airport Pickup is $185, where you collect her at your nearest major airport via IATA-compliant live-animal cargo (IATA code LAR) on Delta, United, or American. Home Delivery is door-to-door for $350. An Avian Flight Nanny who carries her in-cabin is available too, quoted per route from about $750." }
    },
    {
      "@type": "Question",
      "name": "Do female Congo greys talk well?",
      "acceptedAnswer": { "@type": "Answer", "text": "Congo African Greys of either sex are among the most capable talking parrots, and sex is not a reliable predictor of how much an individual will say. Bery is at the developing stage at about 1 year. What shapes her eventual vocabulary most is daily interaction in the home, not whether she is female." }
    },
    {
      "@type": "Question",
      "name": "Why is Bery $1,700 when I've seen greys for $850?",
      "acceptedAnswer": { "@type": "Answer", "text": "An $850 'Congo' is the price of a bird with no verifiable paperwork — no DNA certificate, no CITES documentation, no avian-vet health check, and often no breeder you can actually hold accountable. Bery is $1,700 because that figure covers hand-rearing, her full documentation set, and a USDA AWA licensed aviary standing behind her. A documented hand-raised Congo honestly cannot be produced for $850." }
    }
  ]
};

const beryTocItems = [
  { n: 1,  label: "Is Bery the right African Grey for me?",               href: "#takeaway" },
  { n: 2,  label: "What is Bery like once she's settled in?",               href: "#temperament" },
  { n: 3,  label: "Will Bery learn to talk? A female Congo's voice",        href: "#talking" },
  { n: 4,  label: "Why is Bery $1,700 — the best-value Congo?",            href: "#price-counter" },
  { n: 5,  label: "What documentation comes with Bery?",                  href: "#documentation" },
  { n: 6,  label: "What's included when you reserve Bery?",               href: "#included" },
  { n: 7,  label: "How does Bery compare to our other available greys?",  href: "#comparison" },
  { n: 8,  label: "Is Bery healthy? Our PBFD & polyomavirus PCR screening", href: "#health" },
  { n: 9,  label: "Who are Bery's parents?",                              href: "#parents" },
  { n: 10, label: "Should you bring home an African Grey? Honest questions",href: "#decisions" },
  { n: 11, label: "Bery's first 30 days home — and the decades after",    href: "#lifestyle" },
  { n: 12, label: "Reviews — families who brought home a C.A.Gs grey",   href: "#reviews-mid" },
  { n: 13, label: "How do you bond with and train Bery?",                 href: "#training" },
  { n: 14, label: "What does a balanced diet look like for Bery?",        href: "#food" },
  { n: 15, label: "Bery's photo & video gallery",                         href: "#gallery" },
  { n: 16, label: "How do you buy Bery? Step-by-step",                   href: "#buy" },
  { n: 17, label: "How does Bery get home? Nationwide live-animal shipping", href: "#shipping" },
  { n: 18, label: "Bery — frequently asked questions",                    href: "#faq" },
  { n: 19, label: "Reviews — more happy C.A.Gs owners",                  href: "#reviews-bottom" },
  { n: 20, label: "African Grey care reading before Bery arrives",       href: "#resources" },
  { n: 21, label: "Why choose C.A.Gs for Bery over a cheap grey?",      href: "#marketplace" },
  { n: 22, label: "Ready to bring Bery home?",                           href: "#reserve" },
];

const beryCounterStats = [
  { num: "~1 yr",    label: "Current Age" },
  { num: "$1,700",  label: "Asking Price" },
  { num: "100%",    label: "CITES Documented" },
  { num: "24h",     label: "Reply Guarantee" },
];

const beryKeyTakeawayItems = [
  { stat: "Female",     label: "DNA-Sexed",        body: "Lab-confirmed female — no guesswork. Her DNA sex certificate travels home with her." },
  { stat: "~1 year",   label: "Age",              body: "A hand-raised young female — past the fragile baby stage, settled and confident, with a sweet, social personality already on full display." },
  { stat: "$1,700",     label: "Price",            body: "Covers a hand-raised, fully documented and fully-socialised Congo. A $200 deposit reserves her immediately." },
  { stat: "Congo",      label: "Variant",          body: "Psittacus erithacus — the large scarlet-tailed Congo, bred in our Midland, TX family aviary since 2014." },
  { stat: "CITES I",    label: "Captive-Bred USA", body: "Full Appendix I captive-bred documentation — the paperwork that proves Bery is legal to own and transfer." },
  { stat: "Full set",   label: "Papers Included",  body: "DNA cert · AAV health cert · hatch cert + band · CITES docs · weaning guidance. No chasing paperwork after." },
  { stat: "Nationwide", label: "Ships",            body: "Airport Pickup $185 or Home Delivery $350. IATA LAR-coded via Delta, United, and American." },
  { stat: "Gentle",     label: "Temperament",      body: "Calm, social, and people-oriented — a fully hand-raised young female who studies the room and warms quickly to a steady household." },
];

/* Mobile section-jump dial + desktop dot rail (page is >6,000 words) */
const beryJumpSections = [
  { id: "takeaway",     label: "Overview",    part: 1 },
  { id: "temperament",  label: "Personality", part: 1 },
  { id: "talking",      label: "Talking",     part: 1 },
  { id: "parents",      label: "Parents",     part: 1 },
  { id: "documentation",label: "Documents",   part: 2 },
  { id: "health",       label: "Health",      part: 2 },
  { id: "price-counter",label: "Why $1,700",  part: 2 },
  { id: "gallery",      label: "Gallery",     part: 3 },
  { id: "comparison",   label: "Compare",     part: 3 },
  { id: "reviews-mid",  label: "Reviews",     part: 3 },
  { id: "food",         label: "Diet",        part: 3 },
  { id: "included",     label: "Included",    part: 4 },
  { id: "buy",          label: "How to Buy",  part: 4 },
  { id: "shipping",     label: "Shipping",    part: 4 },
  { id: "faq",          label: "FAQ",         part: 4 },
  { id: "reserve",      label: "Reserve",     part: 4 },
];
const beryJumpParts = {
  1: "Meet Bery",
  2: "Proof & Papers",
  3: "See & Compare",
  4: "Buying Bery",
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <style>
    /* ── Bery page: homepage-parity rhythm (Direction D) ── */
    /* Compact section padding so the page reads tight, not endless */
    .bery-d .py-16 { padding-top: 2.4rem !important; padding-bottom: 2.4rem !important; }
    @media (min-width: 768px) {
      .bery-d .py-16 { padding-top: 3rem !important; padding-bottom: 3rem !important; }
    }
    .bery-d .py-12 { padding-top: 2rem !important; padding-bottom: 2rem !important; }

    /* Section-seam divider with the small footer logo (homepage pattern) */
    .bery-d .cag-seam { display: flex; align-items: center; gap: 26px; max-width: 1100px; margin: 0 auto; padding: 0.5rem 24px; }
    .bery-d .cag-seam__line { flex: 1; height: 1px; background: rgba(45,106,79,.16); }
    .bery-d .cag-seam img { height: 30px; width: auto; display: block; opacity: .92; flex-shrink: 0; }
    @media (max-width: 600px) { .bery-d .cag-seam { gap: 16px; } .bery-d .cag-seam img { height: 24px; } }

    /* Hero H1 — match homepage clamp (was text-4xl/5xl = oversized) */
    .bery-d .bery-hero h1 { font-size: clamp(1.7rem, 1.1rem + 2.6vw, 2.35rem) !important; line-height: 1.14 !important; }

    /* Standard media height so portrait crops aren't cut at the edges */
    .bery-d .bery-feature-img { max-height: 420px !important; object-position: center top; }
    @media (min-width: 768px) {
      .img-compact-desktop { max-width: 400px; margin-left: auto; margin-right: auto; }
    }
    /* Constrained 16/9 video frame for non-hero clips */
    .bery-d .bery-video-frame { position: relative; max-width: 640px; margin-left: auto; margin-right: auto; aspect-ratio: 16/9; }
    .bery-d .bery-video-frame video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  </style>

  <div class="bery-d">

  {/* ── BREADCRUMB ── */}
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys For Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Bery — Female Congo African Grey", url: "/available/bery/" }
    ]} />
  </div>

  {/* ── SECTION-JUMP DIAL — desktop dot rail + mobile bottom-sheet (page >6,000 words) ── */}
  <JumpRail
    sections={beryJumpSections}
    partNames={beryJumpParts}
    ctaLabel="Reserve Bery →"
    ctaTarget="reserve"
  />

  {/* ── HERO C: Trust-first + click-to-play video ── */}
  <section class="bery-hero bg-logo-dark text-cream py-14 px-4 md:py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">

      {/* LEFT: Vitals + CTA */}
      <div class="order-2 md:order-1">
        <p class="font-sora text-gold text-xs font-medium tracking-wide mb-3">
          <em>Psittacus erithacus</em> &middot; CITES Appendix&nbsp;I Captive-Bred &middot; Midland, TX
        </p>
        <h1 class="font-lora font-bold text-2xl sm:text-3xl leading-tight mb-5">
          Bery — Female Congo African Grey For Sale ($1,700, Hand-Raised &amp; DNA-Sexed)
        </h1>

        {/* Snapshot vitals */}
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-6">
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Sex</span>
            Female (DNA-sexed)
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Age</span>
            about 1 year
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Variant</span>
            Congo African Grey
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Price</span>
            $1,700
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Talking</span>
            Developing
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Status</span>
            Available
          </li>
        </ul>

        {/* Trust badges row */}
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>CITES Appendix&nbsp;I
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><path d="M9 3h6"/><path d="M10 3v6l-4.6 9.2A1.5 1.5 0 0 0 6.7 21h10.6a1.5 1.5 0 0 0 1.3-2.8L14 9V3"/></svg>DNA Sexed
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Avian Vet Cert
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 21 8 3 8"/></svg>USDA AWA Licensed
          </span>
        </div>

        <p class="font-sora text-cream/70 text-sm mb-7">Ships nationwide &middot; $185 airport &middot; $350 home</p>

        <a href="/contact-us/?bird=Bery"
           class="inline-block bg-clay text-white font-sora font-semibold px-8 py-4 rounded-full text-base hover:bg-clay-dk transition-colors"
           style="box-shadow:0 6px 20px rgba(232,96,76,0.35);">
          Ask About Bery
        </a>
      </div>

      {/* RIGHT: click-to-play video — shows first on mobile so visitors see Bery move */}
      <div class="order-1 md:order-2">
        <video
          poster="/birds/bery/bery-hero.webp"
          controls
          preload="none"
          width="640"
          height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          aria-label="Bery, our hand-raised female Congo African Grey — click to watch her play"
          style="max-height:440px;object-fit:cover;"
        >
          <source src="/birds/bery/bery-video-eating.mp4" type="video/mp4" />
          Your browser does not support the video element.
        </video>
        <p class="font-sora text-cream/50 text-xs text-center mt-2">Click to watch Bery at play — click again to pause.</p>
      </div>
    </div>
  </section>

  {/* ── COUNTER SNIPPET — moved directly under the hero (above "At a glance") ── */}
  <CounterSnippet stats={beryCounterStats} />

  {/* ── AEO SNAPSHOT — modern info card (green header band + spec tiles) ── */}
  <section class="py-12 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="overflow-hidden rounded-2xl border border-black/[0.07] bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">
        <div class="bg-logo-dark px-6 py-5 sm:px-8">
          <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.18em] text-gold mb-1.5">At a glance</p>
          <h2 class="font-lora font-bold text-xl sm:text-2xl text-cream leading-snug">Bery at a glance — Female Congo African Grey for Sale Snapshot</h2>
        </div>
        <div class="p-6 sm:p-8">
          <p class="font-sora text-stone-700 leading-relaxed mb-6">Bery is a hand-raised female Congo African Grey (<em>Psittacus erithacus</em>), about 1 year old, priced at $1,700. She is DNA-sexed, CITES-documented, captive-bred in the USA at our USDA AWA licensed aviary, and ships nationwide ($185 airport / $350 home).</p>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              ["Variant", "Congo African Grey"],
              ["Sex", "Female (DNA-sexed)"],
              ["Age", "about 1 year"],
              ["Price", "$1,700 · $200 deposit"],
              ["Talking", "Developing"],
              ["Documentation", "DNA · CITES · health cert"],
            ].map(([k, v]) => (
              <div class="rounded-xl border border-stone-200 bg-cream/60 px-4 py-3">
                <dt class="font-sora text-[11px] uppercase tracking-wide text-stone-500">{k}</dt>
                <dd class="font-sora text-sm font-semibold text-logo-dark mt-1 leading-snug">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 1: KEY TAKEAWAY — Is Bery right for me?
      Placed ABOVE the TOC (after the counter snippet) so the "short version"
      lands before the long table of contents.
      ══════════════════════════════════════════════ */}
  <section id="takeaway">
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Is Bery the right African Grey for me?"
      badge="8 facts · 90-sec read"
      items={beryKeyTakeawayItems}
    />
  </section>

  {/* ── TABLE OF CONTENTS ── */}
  <nav class="py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
    <div class="container mx-auto max-w-5xl">
      <div class="rounded-2xl border border-black/[0.07] bg-white px-6 py-7 md:px-10 md:py-9" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
        <div class="flex flex-col items-start justify-between gap-2 border-b border-black/[0.07] pb-5 md:flex-row md:items-end">
          <div>
            <p class="font-sora text-xs font-bold uppercase tracking-widest text-clay">Inside this page</p>
            <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark">On This Page</h2>
          </div>
          <p class="font-sora text-sm text-stone-500">22 sections · everything about Bery</p>
        </div>
        <div class="mt-6 grid grid-cols-1 gap-x-10 gap-y-1 md:grid-cols-2">
          {beryTocItems.map((item) => (
            <a href={item.href}
               class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/5 font-sora">
              <span class="text-xs font-semibold text-clay-ink">{String(item.n).padStart(2, "0")}</span>
              <span class="text-sm leading-snug text-stone-700">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  {/* ══════════════════════════════════════════════
      SECTION 2: TEMPERAMENT — What is Bery like to live with?
      Framework: EBP · Cat: A · ~180w
      Source: BUILD-1 section 5 (lines 128-138) — reused + image added
      ══════════════════════════════════════════════ */}
  <section id="temperament" class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">What is Bery like once she's settled in?</h2>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Bery is a gentle, people-oriented female Congo African Grey — a hand-raised young female who is calm in the hand and genuinely interested in the humans around her. Because we spoon-fed her ourselves from a few weeks old, she never learned to fear hands; she steps up softly, settles against a shoulder, and watches a room the way greys do when they are working out who everyone is. If you want a bird that bonds early rather than one you have to win over, that is exactly the head-start hand-rearing gives her.</p>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Here at C.A.Gs we raised Bery inside our Midland, Texas home, not in a barn out back, so what we tell you about her comes from holding her every day rather than from a sales sheet. The thing we noticed first is how much she studies people — she goes quiet and attentive when someone new talks, tracking the voice before she decides to lean in. That social curiosity is the foundation a talking, deeply-bonded grey is built on, and at three months she already has it.</p>

      {/* Personality infographic — placed mid-text to break up the section */}
      <figure class="my-7">
        <img
          src="/birds/bery/bery-cuddly-tamed-grey-african-parrot-for-sale.webp"
          alt="Bery's personality profile — a hand-fed female Congo African Grey rated for mimicry, intelligence, bonding, awareness, and trainability"
          width="760" height="430"
          class="w-full rounded-2xl border border-stone-200"
          loading="lazy"
          style="box-shadow:0 4px 20px rgba(60,30,10,0.07);"
        />
        <figcaption class="font-sora text-xs text-stone-400 mt-2 text-center">Bery at about 1 year — gentle, social, always studying the room</figcaption>
      </figure>

      <p class="font-sora text-stone-600 leading-relaxed mb-4">At about 1 year she is curious about everything and still forming her sense of the world. Congo greys are famously bright — the species, <em>Psittacus erithacus</em>, sits among the most studied talking parrots in the world, and <a href="https://parrots.org/encyclopedia/grey-parrot/" target="_blank" rel="noopener noreferrer" class="text-clay-text underline">the World Parrot Trust's grey parrot profile ↗</a> covers their cognition in depth. She suits a family or a couple who want a gentle, sociable companion to grow alongside — someone home enough to keep her engaged and talked-to as she develops.</p>
      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-2 mt-5">How does Bery settle in at first?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-3">Her first 30 days at home tend to follow a pattern we have seen across our greys. Week one she watches more than she plays, learning the rhythm of your house. By week two she starts claiming a favourite perch and testing which sounds get a reaction. By the end of the month, in a home that shows up for her daily, she is asking to come out and beginning the soft babble that comes before real words.</p>
      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2 mt-4">Is Bery good with children?</h4>
      <p class="font-sora text-stone-600 leading-relaxed">She does well with older children who understand that a bird is not a toy. She reads energy quickly — a calm, curious kid who offers a finger consistently is exactly the kind of relationship she builds on. Chaotic or grabbing handling is another matter. We are honest about that.</p>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 3: TALKING — Does a female Congo talk well?
      Framework: QAB · Cat: B · ~150w
      ══════════════════════════════════════════════ */}
  <section id="talking" class="py-12 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">Will Bery learn to talk? A female Congo's voice</h2>

      {/* 40-word featured-snippet answer */}
      <div class="bg-white border-l-4 border-green rounded-xl p-5 mb-6" style="box-shadow:0 2px 12px rgba(60,30,10,0.06);">
        <p class="font-sora text-stone-700 leading-relaxed">
          <strong>Short answer:</strong> Congo African Greys of either sex are among the most capable talking parrots alive. Sex is not a reliable predictor — individual motivation and daily interaction shape vocabulary far more than whether the bird is male or female.
        </p>
      </div>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Where is Bery right now?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">At about 1 year, Bery is in the developing stage. Her vocal learning is just beginning. We hear the soft contact calls and exploratory sounds a young grey makes before real mimicry clicks — that process happens over the coming months. Watch the playing video above to hear her as she is now: active, interactive, and already engaged with whoever holds the camera.</p>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Hear a grown C.A.Gs Congo actually talking</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">You do not have to take our word for what Bery is growing toward. This is <strong>Maxy</strong>, an adult hand-raised Congo African Grey from the same flock and the same Midland, TX home, talking on camera — the clearest proof of the vocabulary a well-socialised Congo develops.</p>
      <figure class="my-6">
        <div class="bery-video-frame rounded-2xl overflow-hidden border border-stone-200" style="box-shadow:0 4px 20px rgba(60,30,10,0.07);">
          <video controls preload="none" playsinline width="640" height="360" poster="/african-grey-breeder-with-bird-midland-tx.webp" aria-label="Maxy, a hand-raised adult Congo African Grey from C.A.Gs, talking on camera">
            <source src="/talking-african-grey-parrot-video.mp4" type="video/mp4" />
            Your browser does not support the video element.
          </video>
        </div>
        <figcaption class="font-sora text-xs text-stone-400 text-center mt-2">That's <strong>Maxy</strong>, one of our talking Congo Greys, at our Midland, TX aviary. Meet <a href="/" class="text-clay-text underline">more of our talking greys on the homepage</a>, or read our guide to <a href="/blog/african-grey-parrot-talking-ability/" class="text-clay-text underline">how African Greys learn to talk</a>.</figcaption>
      </figure>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">What shapes a Congo's eventual vocabulary?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">The single biggest factor is daily conversation in her home environment. Greys learn by listening and repeating what gets a real reaction — your name, your kitchen sounds, the things you say at the same time every day. A bird in a quiet house with minimal human contact will talk less than one at the centre of a busy family routine. Sex has almost nothing to do with it.</p>

      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2">How does Congo talking compare to Timneh?</h4>
      <p class="font-sora text-stone-600 leading-relaxed">Timnehs tend to start talking earlier — sometimes as young as 4–6 months — while Congos tend to develop larger and more dramatic vocabularies over time. <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Our Congo vs Timneh comparison</a> covers this side-by-side in detail if you are weighing the two.</p>

      <h5 class="font-lora font-semibold text-base text-logo-dark mt-5 mb-1">Can I speed up when Bery starts talking?</h5>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Not by drilling. Repetition without genuine social context rarely sticks. The greys that develop the fastest are the ones whose owners talk <em>with</em> them, not <em>at</em> them — narrating what they are doing, responding when the bird makes sounds, treating the conversation as two-way.</p>

      <h6 class="font-sora text-sm font-semibold text-logo-dark mt-4 mb-1">How long until Bery says her first word?</h6>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Most Congos begin mimicking household sounds and short words between 6 and 12 months, with clearer speech firming up through the first year. Bery is about a year old, so she is right in the heart of that window — many greys her age are already working on their first clear words.</p>
    </div>
  </section>

