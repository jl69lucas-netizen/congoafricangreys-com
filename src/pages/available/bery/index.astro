                style="border-radius:12px;box-shadow:0 4px 14px rgba(232,96,76,0.28);">
          Ask about Bery →
        </button>

        <div class="mt-6 flex flex-wrap gap-x-5 gap-y-1.5 text-xs font-sora text-stone-500 border-t border-stone-200 pt-4">
          <span><span style="color:#2D6A4F;font-weight:700;">✔</span> DNA-sexed + CITES documented</span>
          <span><span style="color:#2D6A4F;font-weight:700;">✔</span> Avian-vet health certificate</span>
          <span><span style="color:#2D6A4F;font-weight:700;">✔</span> USDA AWA licensed · family aviary since 2014</span>
        </div>
        <p class="font-sora text-xs font-normal text-stone-400 mt-3">Your details stay private — we never share or sell your information, and no payment is taken on this form.</p>
