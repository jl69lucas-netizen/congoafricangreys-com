---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustBar from '../../../components/TrustBar.astro';
import CTA from '../../../components/CTA.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const title = "Bery — Female Congo African Grey For Sale | $1,700 | C.A.Gs – Midland, TX";
const description = "Meet Bery, our hand-raised female Congo African Grey — 1 year old, gentle and people-bonded, $1,700. DNA sexed, CITES-documented, captive-bred. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/bery/";

const productSchema = {
  "name": "Bery — Female Congo African Grey",
  "description": "Bery is a hand-raised female Congo African Grey (Psittacus erithacus), 1 year old, with a gentle, people-bonded temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/bery-congo-african-grey-female-1-year.webp",
  "category": "Congo African Grey Parrot",
  "sku": "cag-bery",
  "datePublished": "2026-05-20",
  "dateModified": "2026-06-18",
  "offers": {
    "@type": "Offer",
    "price": "1700",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/bery/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Bery DNA sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Bery goes home with her DNA sex certificate confirming she is female, her avian-vet health certificate, her hatch certificate with leg-band number, and her CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork." }
    },
    {
      "@type": "Question",
      "name": "How old is Bery and what is her temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bery is 1 year old and fully weaned. We hand-raised her ourselves, and she has settled into a gentle, people-bonded grey who steps up willingly and enjoys quiet, steady company — a calm companion match rather than a high-energy bird." }
    },
    {
      "@type": "Question",
      "name": "How much is Bery and how do I reserve her?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bery is $1,700. A $200 deposit reserves her and pauses her listing for you. The balance is due before she travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Bery be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Bery ships nationwide. Airport Pickup is $185 (you collect her at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350." }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Bery — Female Congo African Grey", url: "/available/bery/" }
      ]} />
  </div>

  {/* 1 — HERO / BIRD VITALS + inquiry CTA */}
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <div>
        <img
          src="/bery-congo-african-grey-female-1-year.webp"
          alt="Bery, a hand-raised female Congo African Grey parrot, one year old, perched and looking toward the camera"
          width="640" height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
        />
      </div>
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Psittacus erithacus &middot; CITES Appendix I Captive-Bred</p>
        <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-5">Bery — Female Congo African Grey For Sale</h1>
        <p class="text-cream/80 text-lg mb-6 leading-relaxed">Here at C.A.Gs, our Bery is a gentle, people-bonded Congo girl we hand-raised by hand from the start. At 1 year old she is fully weaned, steady on the hand, and looking for the one home she will settle into for life.</p>
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-7">
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Sex</span>Female (DNA sexed)</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Age</span>1 year &middot; weaned</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Variant</span>Congo African Grey</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Price</span>$1,700</li>
        </ul>
        <p class="text-cream/70 text-sm mb-6">Ships nationwide &middot; $185 airport &middot; $350 home</p>
        <a href="/contact-us/?bird=Bery" class="inline-block bg-clay text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors">Inquire About Bery</a>
      </div>
    </div>
  </section>
  <TrustBar />

  {/* 2 — ABOUT BERY (archetype: SAGE / gentle companion) */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What is Bery like to live with?</h2>
      <p class="text-stone-600 leading-relaxed mb-4">If you have been picturing a calm grey who wants to be near you rather than run the room, Bery is that bird. We have watched her grow from a chick into a gentle, even-tempered companion — the kind of African Grey who quietly leans into a scratch, follows the household rhythm, and prefers steady one-on-one time to constant commotion. She steps up without fuss and is comfortable being handled, which is exactly what we work toward when we hand-raise a female grey ourselves.</p>
      <p class="text-stone-600 leading-relaxed mb-4">At a year old, Bery is past the messy hand-feeding stage and eating confidently on her own, so the bird you reserve is the bird who arrives — her personality is already settled. Congo greys are famously sensitive and they bond deeply, and Bery wears that on her sleeve. She suits a patient owner or family who wants a devoted, gentle feathered companion for the decades ahead. If you are weighing whether a Congo or a Timneh fits your home, our <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh comparison</a> walks through the differences.</p>
      <p class="text-stone-600 leading-relaxed">Greys are remarkable talkers and problem-solvers with 40–60 year lifespans — we cover the full species background in our <a href="/african-grey-parrot-guide/" class="text-clay-text underline">African Grey parrot guide</a> so this page can stay about Bery herself.</p>
    </div>
  </section>

  {/* 3 — HEALTH & DOCUMENTATION (ledger only) */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What documentation comes with Bery?</h2>
      <p class="text-stone-600 leading-relaxed mb-6">We never ask a buyer to take our word for it. Bery is captive-bred here in the USA and goes home with a complete paperwork set, the same standard we hold every C.A.Gs grey to:</p>
      <ul class="space-y-3 text-stone-600">
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>DNA sex certificate</strong> — lab-confirmed that Bery is female, so there is no guesswork.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Avian-vet health certificate</strong> — issued before she travels.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Hatch certificate + closed leg band</strong> — her traceable identity as a captive-bred bird.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>CITES captive-bred documentation</strong> — African Greys are CITES Appendix I; captive-bred birds are legal to own and transfer domestically with the right paperwork, and Bery has it. See our <a href="/cites-african-grey-documentation/" class="text-clay-text underline">CITES documentation page</a> for what that means.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Weaned</strong> — Bery is eating independently and ready to go to her new home.</span></li>
      </ul>
      <p class="text-stone-600 leading-relaxed mt-6">We are a USDA AWA licensed family aviary, and Bery is also covered by our <a href="/african-grey-parrot-health-guarantee/" class="text-clay-text underline">African Grey health guarantee</a>. Want proof a grey is DNA-tested before you commit? That is the whole point of our <a href="/dna-tested-african-grey-for-sale/" class="text-clay-text underline">DNA-tested greys</a>.</p>
    </div>
  </section>

  {/* 4 — WHY BERY */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Why Bery might be the right grey for you</h2>
      <p class="text-stone-600 leading-relaxed mb-4">A one-year-old, already-weaned female has real advantages. You skip the round-the-clock hand-feeding, you can see her settled temperament instead of guessing how a chick will turn out, and you still get decades of companionship ahead. Bery's gentleness makes her a forgiving first serious parrot for a committed owner, and a calm, affectionate addition for a family that wants a bird who bonds rather than performs.</p>
      <p class="text-stone-600 leading-relaxed">Because we hand-raised her ourselves, we can tell you honestly how she responds to handling, to new people, and to a quiet evening on the couch — and we would rather she go to the home that genuinely fits her than the first one to ask. That is the conversation we want to have with you.</p>
    </div>
  </section>

  {/* 5 — PRICING & WHAT'S INCLUDED */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">How much is Bery, and what's included?</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Price & reservation</h3>
          <ul class="space-y-3 text-stone-600 text-sm">
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Bery (female, 1 year)</span><strong class="text-logo-dark">$1,700</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Deposit to reserve</span><strong class="text-logo-dark">$200</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Airport Pickup (IATA, LAR)</span><strong class="text-logo-dark">$185</strong></li>
            <li class="flex justify-between"><span>Home Delivery (door-to-door)</span><strong class="text-logo-dark">$350</strong></li>
          </ul>
          <p class="text-stone-500 text-xs mt-3">Ships nationwide &middot; $185 airport &middot; $350 home &middot; Delta / United / American</p>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Included in her price</h3>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> DNA sex certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Avian-vet health certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Hatch certificate + leg band</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> CITES captive-bred documentation</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Health guarantee + go-home support</li>
          </ul>
        </div>
      </div>
      <p class="text-stone-600 leading-relaxed mt-6">A $200 deposit reserves Bery and pauses her listing for you; the balance is due before she travels. For how her price sits against the wider range, see our <a href="/african-grey-parrot-price/" class="text-clay-text underline">African Grey price guide</a>.</p>
    </div>
  </section>

  {/* 6 — PARENT BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Who are Bery's parents?</h2>
      <p class="text-stone-600 leading-relaxed">Bery was hatched and hand-raised inside our family aviary in Midland, Texas, which we have run since 2014. We are happy to share her specific parentage and pairing details on request during the reservation conversation, along with anything else you would like to verify before you commit. We would rather walk you through it directly than post it on a page.</p>
    </div>
  </section>

  {/* 7 — FAQ */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Bery — frequently asked questions</h2>
      <div class="space-y-4">
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Is Bery DNA sexed and documented?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes. Bery goes home with her DNA sex certificate confirming she is female, her avian-vet health certificate, her hatch certificate with leg-band number, and her CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How old is Bery and what is her temperament?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Bery is 1 year old and fully weaned. We hand-raised her ourselves, and she has settled into a gentle, people-bonded grey who steps up willingly and enjoys quiet, steady company — a calm companion match rather than a high-energy bird.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How much is Bery and how do I reserve her?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Bery is $1,700. A $200 deposit reserves her and pauses her listing for you. The balance is due before she travels. Reach out through our contact form and we reply within 24 hours.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Can Bery be shipped to me?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes — Bery ships nationwide. Airport Pickup is $185 (you collect her at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350.</p>
        </details>
      </div>
    </div>
  </section>

  {/* 8 — OTHER AVAILABLE BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Other African Greys we have available</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/available/amie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Amie</h3><p class="text-stone-500 text-sm">Female Congo &middot; 3 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,500</p></a>
        <a href="/available/roys/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Roys</h3><p class="text-stone-500 text-sm">Male Congo &middot; 4 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,300</p></a>
        <a href="/available/jins-jeni/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Jins &amp; Jeni</h3><p class="text-stone-500 text-sm">Congo pair &middot; must go together</p><p class="text-clay-text font-semibold text-sm mt-1">$3,500</p></a>
        <a href="/available/elad/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Elad</h3><p class="text-stone-500 text-sm">Male Timneh &middot; 5 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,600</p></a>
        <a href="/available/evie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Evie</h3><p class="text-stone-500 text-sm">Female Timneh &middot; 6 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,500</p></a>
        <a href="/african-grey-parrots-for-sale/" class="block bg-logo-dark text-cream rounded-2xl p-5 hover:opacity-90 transition-opacity"><h3 class="font-lora font-semibold">See every available grey</h3><p class="text-cream/70 text-sm mt-1">Browse the full nursery &rarr;</p></a>
      </div>
    </div>
  </section>

  <Schema type="product" data={productSchema} />
  <Schema type="faq" data={faqSchema} />
  <Schema type="organization" />

  {/* 9 — INQUIRY CTA */}
  <CTA headline="Ready to bring Bery home?" sub="Bery is a hand-raised, CITES-documented, DNA-sexed female Congo grey at $1,700. A $200 deposit reserves her — reach out and we reply within 24 hours." />
</BaseLayout>
