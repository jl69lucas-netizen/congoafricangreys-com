---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import NewsletterV2 from '../../components/cag-library/NewsletterV2.astro';

const title = "Available African Greys for Sale | Hand-Raised, DNA-Sexed & CITES-Documented Congo & Timneh — C.A.Gs, Midland TX";
const description = "See every African Grey we have available right now — hand-raised Congo and Timneh parrots, $1,500–$3,500, each DNA-sexed, CITES Appendix I documented and captive-bred in the USA. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/";

const birds = [
  { name: "Roys",        slug: "/available/roys/",      variant: "congo",  vlabel: "Congo",  sex: "Male",   age: "4 months", price: "$2,300", was: null,     img: "/roys-congo-african-grey-male-4-months.webp",                 pos: "center 40%", blurb: "Energetic, bold young male — built for a busy, interactive home." },
  { name: "Amie",        slug: "/available/amie/",      variant: "congo",  vlabel: "Congo",  sex: "Female", age: "3 months", price: "$2,500", was: null,     img: "/birds/amie/amie-handfed.webp",                                pos: "center 30%", blurb: "Social, curious hen — a lovely fit for a family or couple." },
  { name: "Bery",        slug: "/available/bery/",      variant: "congo",  vlabel: "Congo",  sex: "Female", age: "1 year",   price: "$1,700", was: null,     img: "/bery-congo-african-grey-female-1-year.webp",                  pos: "center 35%", blurb: "Gentle and already settled — an easy first African Grey." },
  { name: "Jins & Jeni", slug: "/available/jins-jeni/", variant: "congo",  vlabel: "Congo",  sex: "Bonded pair", age: "Adult", price: "$3,500", was: null,  img: "/jins-jeni-congo-african-grey-pair.webp",                      pos: "center 40%", blurb: "A bonded, talking Congo pair — placed together, never split." },
  { name: "Elad",        slug: "/available/elad/",      variant: "timneh", vlabel: "Timneh", sex: "Male",   age: "6 months", price: "$1,600", was: "$2,200", img: "/birds/elad/elad-timneh-african-grey-male-hero.webp",          pos: "center 30%", blurb: "Confident, early-talking Timneh boy — sibling to Evie." },
  { name: "Evie",        slug: "/available/evie/",      variant: "timneh", vlabel: "Timneh", sex: "Female", age: "6 months", price: "$1,500", was: "$2,200", img: "/birds/evie/evie-timneh-african-grey-female-hero.webp",        pos: "center 30%", blurb: "Gentle, affectionate Timneh hen — sibling to Elad." },
];
const placed = [
  { name: "Joys", note: "Female Congo" },
  { name: "Loti", note: "Male Congo" },
  { name: "Carl", note: "Male Congo" },
];

const compareRows = [
  ["Price",       "$2,300", "$2,500", "$1,700", "$3,500", "$1,600", "$1,500"],
  ["Variant",     "Congo",  "Congo",  "Congo",  "Congo",  "Timneh", "Timneh"],
  ["Sex",         "Male",   "Female", "Female", "Pair",   "Male",   "Female"],
  ["Age",         "4 mo",   "3 mo",   "1 yr",   "Adult",  "6 mo",   "6 mo"],
  ["Temperament", "Energetic, bold", "Social, curious", "Gentle, settled", "Bonded, talking", "Confident, early talker", "Gentle, affectionate"],
  ["Best for",    "Active home", "Family / couple", "First-time owner", "One pair home", "Interactive home", "Calm, gentle home"],
];

const counterStats = [
  { num: "6",        label: "Available Now" },
  { num: "$1,500+",  label: "Starting Price" },
  { num: "100%",     label: "CITES Documented" },
  { num: "24h",      label: "Reply Guarantee" },
];

const careGuides = [
  { label: "Care",   title: "The Complete African Grey Care Guide", desc: "Diet, enrichment, sleep, and what to expect decade by decade.", href: "/african-grey-parrot-care-guide/", img: "/timneh-african-grey-variant.webp", imgAlt: "An African Grey portrait — companion to the complete care guide" },
  { label: "Pricing",title: "What an African Grey Really Costs",     desc: "The full breakdown behind a documented grey's price and lifetime spend.", href: "/african-grey-parrot-price/", img: "/timneh-african-grey-breeding-pair.webp", imgAlt: "African Grey breeding pair — what a documented grey really costs" },
  { label: "Compare",title: "Congo vs Timneh African Grey",          desc: "Size, tail colour, talking age and temperament, side by side.", href: "/congo-vs-timneh-african-grey/", img: "/congo-african-grey-variant.webp", imgAlt: "Congo vs Timneh African Grey comparison" },
  { label: "Buying safely", title: "How to Avoid African Grey Scams", desc: "The documentation and breeder checks that separate real birds from bait listings.", href: "/how-to-avoid-african-grey-parrot-scams/", img: "/birds/avoid-african-grey-parrot-scam.webp", imgAlt: "How to avoid African Grey parrot scams infographic" },
];

const faqItems = [
  { q: "Which African Greys do you have available right now?", a: "Right now we have six hand-raised greys available: Roys, Amie, Bery and the bonded Jins & Jeni pair (all Congo African Greys), plus Elad and Evie (Timneh African Greys). Each has its own page with full photos, video where available, and documentation. Availability changes as birds are reserved, so the roster above is always current." },
  { q: "How much do your African Greys cost?", a: "Our available greys run from $1,500 to $3,500. Timnehs (Elad $1,600, Evie $1,500) sit at the lower end; single Congos run $1,700–$2,500; and the bonded Jins & Jeni pair is $3,500 because they are placed together. Every price includes hand-rearing, the full documentation set, and a USDA AWA licensed aviary standing behind the bird." },
  { q: "Are all of your African Greys DNA-sexed and documented?", a: "Yes. Every C.A.Gs grey is captive-bred in the USA and goes home with a DNA sex certificate, an AAV avian-vet health certificate, a hatch certificate with closed leg band, and CITES Appendix I captive-bred documentation. We never ask a buyer to take our word for it." },
  { q: "Can you ship an African Grey to my state?", a: "Yes — we ship to all 50 states. Airport Pickup is $185 (IATA LAR live-animal cargo on Delta, United or American to your nearest hub); Home Delivery is $350 door-to-door. An in-cabin avian flight nanny is available too, quoted per route." },
  { q: "Can I reserve a grey that isn't listed yet?", a: "Yes. If none of the available birds is quite right, join our waitlist and we will reach out first when our next hand-raised Congo or Timneh clutch is ready to place — before it is listed publicly." },
  { q: "What does a deposit do, and is it refundable?", a: "A $200 deposit reserves your chosen bird and pauses its listing for you; it comes off the total, it is not an extra fee. It is refundable any time before the bird ships. The balance is due before travel." },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Available African Greys for Sale — C.A.Gs, Midland TX",
  "description": description,
  "url": canonical,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": birds.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": `${b.name} — ${b.vlabel} African Grey`,
        "category": `${b.vlabel} African Grey Parrot`,
        "url": `https://congoafricangreys.com${b.slug}`,
        "offers": {
          "@type": "Offer",
          "price": b.price.replace(/[^0-9]/g, ""),
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": `https://congoafricangreys.com${b.slug}`,
          "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
        }
      }
    }))
  }
};

const faqSchema = {
  "mainEntity": faqItems.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <style>
    .avail-d .py-16 { padding-top: 2.4rem !important; padding-bottom: 2.4rem !important; }
    @media (min-width: 768px) { .avail-d .py-16 { padding-top: 3rem !important; padding-bottom: 3rem !important; } }
    .avail-d .py-12 { padding-top: 2rem !important; padding-bottom: 2rem !important; }
    .avail-d .cag-seam { display: flex; align-items: center; gap: 26px; max-width: 1100px; margin: 0 auto; padding: 0.5rem 24px; }
    .avail-d .cag-seam__line { flex: 1; height: 1px; background: rgba(45,106,79,.16); }
    .avail-d .cag-seam img { height: 30px; width: auto; display: block; opacity: .92; flex-shrink: 0; }
    @media (max-width: 600px) { .avail-d .cag-seam { gap: 16px; } .avail-d .cag-seam img { height: 24px; } }
    .avail-d .roster-card { transition: transform .2s, box-shadow .2s; }
    .avail-d .roster-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(60,30,10,0.12); }
    .avail-d .filter-btn[aria-pressed="true"] { background: #2D6A4F; color: #fff; border-color: #2D6A4F; }
  </style>

  <div class="avail-d">

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "Available African Greys", url: "/available/" }
    ]} />
  </div>

  {/* ── HERO ── */}
  <section class="bg-logo-dark text-cream py-14 px-4 md:py-16">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-sora text-gold text-xs font-medium tracking-widest uppercase mb-3">Congo &amp; Timneh &middot; CITES Appendix&nbsp;I Captive-Bred &middot; Midland, TX</p>
      <h1 class="font-lora font-bold text-cream mb-5" style="font-size:clamp(1.8rem,1.1rem+2.8vw,2.6rem);line-height:1.12;">Available African Greys for Sale — Hand-Raised, DNA-Sexed &amp; CITES-Documented</h1>
      <p class="font-sora text-cream/85 leading-relaxed mb-6" style="max-width:60ch;margin-left:auto;margin-right:auto;">Here at C.A.Gs, every grey below is one we hand-raised ourselves in our Midland, Texas home — Congo and Timneh African Greys, each DNA-sexed, fully documented, and captive-bred in the USA. This page is always current: when a bird is reserved, it comes off the list.</p>
      <p class="font-sora text-cream/70 text-sm mb-6">Ships nationwide &middot; $185 airport &middot; $350 home</p>
      <a href="#reserve" class="inline-block bg-clay text-white font-sora font-semibold px-8 py-4 rounded-full text-base hover:bg-clay-dk transition-colors" style="box-shadow:0 6px 20px rgba(232,96,76,0.35);">Start an inquiry</a>
    </div>
  </section>

  <CounterSnippet stats={counterStats} />

  {/* ── ROSTER ── */}
  <section id="roster" class="py-16 px-4 bg-cream">
    <div class="max-w-5xl mx-auto" style="max-width:1100px;">
      <div class="mb-7 border-l-4 border-green pl-4">
        <p class="font-sora text-xs font-semibold uppercase tracking-widest text-clay mb-2">Available right now</p>
        <h2 class="font-lora font-bold text-logo-dark">Which African Greys are available right now?</h2>
        <p class="font-sora text-stone-600 mt-2 text-sm leading-relaxed" style="max-width:70ch;">Six hand-raised birds are looking for homes. Filter by variant, or tap any bird to see its full page — photos, documentation, and how to reserve.</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-7" role="group" aria-label="Filter available greys">
        <button class="filter-btn font-sora text-sm font-semibold rounded-full border border-stone-300 px-5 py-2 text-stone-700 bg-white" data-filter="all" aria-pressed="true">All (6)</button>
        <button class="filter-btn font-sora text-sm font-semibold rounded-full border border-stone-300 px-5 py-2 text-stone-700 bg-white" data-filter="congo" aria-pressed="false">Congo (4)</button>
        <button class="filter-btn font-sora text-sm font-semibold rounded-full border border-stone-300 px-5 py-2 text-stone-700 bg-white" data-filter="timneh" aria-pressed="false">Timneh (2)</button>
      </div>

      <h3 class="sr-only">Congo and Timneh African Greys available now</h3>
      <div id="roster-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {birds.map((b) => (
          <article class={`roster-card flex flex-col overflow-hidden rounded-2xl border border-stone-100 bg-white variant-${b.variant}`} style="box-shadow:0 4px 20px rgba(60,30,10,0.07);">
            <a href={b.slug} class="relative block h-72 overflow-hidden bg-green/10">
              <img src={b.img} alt={`${b.name} — hand-raised ${b.sex.toLowerCase()} ${b.vlabel} African Grey for sale, captive-bred in Midland TX`} width="400" height="288" loading="lazy" class="w-full h-full object-cover" style={`object-position:${b.pos};`} />
              <span class="absolute top-3 left-3 bg-green text-white text-xs font-semibold px-3 py-1 rounded-full">Available</span>
              <span class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-stone-600 text-xs font-sora px-2 py-1 rounded-full">
                <svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Midland, TX
              </span>
            </a>
            <div class="p-5 flex flex-col flex-1">
              <div class="mb-2">
                <h4 class="font-lora font-bold text-xl text-logo-dark leading-tight">{b.name}</h4>
                <p class="text-stone-600 text-xs font-sora mt-0.5">{b.sex} &middot; {b.age} &middot; {b.vlabel} African Grey</p>
              </div>
              <p class="text-stone-700 text-sm font-semibold leading-snug mb-3 italic">"{b.blurb}"</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">CITES Cert</span>
                <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">PCR DNA-Sexed</span>
                <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">Vet Certified</span>
                <span class="text-xs bg-green/8 text-green font-sora px-2 py-0.5 rounded-full">Fully Weaned</span>
              </div>
              <p class="flex items-center gap-1.5 text-xs font-sora text-stone-600 mb-4 mt-auto">
                <svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg>
                Ships nationwide &middot; <strong class="text-logo-dark font-semibold">$185</strong> airport &middot; <strong class="text-logo-dark font-semibold">$350</strong> home
              </p>
              <div class="flex items-center justify-between pt-4 border-t border-stone-100">
                <div>
                  {b.was && <span class="text-stone-500 line-through text-sm mr-1.5">{b.was}</span>}
                  <span class="font-lora font-bold text-2xl text-clay">{b.price}</span>
                </div>
                <a href={b.slug} class="bg-clay text-white text-xs font-semibold px-5 py-2.5 rounded-full hover:bg-clay-dk transition-colors whitespace-nowrap">Meet {b.name} →</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-9">
        <h3 class="font-lora font-semibold text-lg text-logo-dark mb-2">Recently placed with their families</h3>
        <p class="font-sora text-stone-600 text-sm leading-relaxed" style="max-width:70ch;">These greys have already gone to their homes — kept here so you can see the pace at which our birds are placed: {placed.map((p, i) => (<span><strong class="text-logo-dark">{p.name}</strong> ({p.note}){i < placed.length - 1 ? ", " : "."}</span>))} If you would like a bird like one of these, <a href="#reserve" class="text-clay-text underline">join the waitlist</a>.</p>
      </div>
    </div>
  </section>

  {/* ── COMPARISON ── */}
  <section id="compare" class="py-16 px-4">
    <div class="max-w-5xl mx-auto" style="max-width:1100px;">
      <div class="mb-7 border-l-4 border-green pl-4">
        <h2 class="font-lora font-bold text-logo-dark">How do our available greys compare side by side?</h2>
        <p class="font-sora text-stone-600 mt-2 text-sm leading-relaxed" style="max-width:70ch;">Every bird is an individual. Here is the quick side-by-side so you can find the one that fits your home — then read its full page. Still weighing the two variants? See <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh</a>.</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-black/[0.07] bg-white" style="box-shadow:0 4px 24px rgba(60,30,10,0.07);">
        <div class="overflow-x-auto">
          <table class="w-full border-collapse" style="min-width:760px;">
            <thead>
              <tr>
                <th class="text-left font-sora text-xs font-bold uppercase tracking-widest text-stone-600 bg-white px-4 py-4 border-b border-black/[0.07]">Trait</th>
                {birds.map((b) => (
                  <th class="text-left px-4 py-4 text-white" style="background:linear-gradient(135deg,#2D6A4F,#1f4d39);">
                    <a href={b.slug} class="font-lora font-bold text-sm text-white hover:underline">{b.name}</a>
                    <span class="block font-sora text-[11px] opacity-80">{b.vlabel} · {b.sex}</span>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {compareRows.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-cream' : 'bg-white'}>
                  <td class="px-4 py-3 font-sora text-xs font-semibold text-stone-600 border-b border-black/[0.05]">{row[0]}</td>
                  {row.slice(1).map((cell) => (
                    <td class="px-4 py-3 font-sora text-sm text-stone-700 border-l border-black/[0.05] border-b border-black/[0.05]">{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <figure class="mt-6 mb-1">
        <a href="/available/elad/" class="block overflow-hidden rounded-2xl border border-stone-200" style="box-shadow:0 4px 20px rgba(60,30,10,0.06);">
          <img src="/birds/elad/timneh-vs-congo-african-grey-infographic.webp" alt="Congo vs Timneh African Grey infographic comparing size, tail colour, talking age and temperament side by side" title="Congo vs Timneh African Grey comparison" width="1200" height="746" loading="lazy" class="w-full h-auto" />
        </a>
        <figcaption class="font-sora text-xs text-stone-600 mt-2 leading-relaxed">How the two greys differ at a glance — our Timneh siblings sit at the smaller, early-talking end. <a href="/available/elad/" class="text-clay-text underline">See Elad's page →</a></figcaption>
      </figure>
    </div>
  </section>

  <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.webp" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

  {/* ── WHAT COMES WITH EVERY BIRD ── */}
  <section id="documentation" class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-logo-dark mb-4">What does every C.A.Gs grey come home with?</h2>
      <p class="font-sora text-stone-600 leading-relaxed mb-6">Whichever bird you choose, the standard is the same. Every grey leaves us captive-bred, documented, and health-checked — no chasing paperwork after the carrier opens.</p>

      <figure class="mb-7">
        <a href="/available/amie/" class="block overflow-hidden rounded-2xl border border-stone-200" style="box-shadow:0 4px 20px rgba(60,30,10,0.06);">
          <img src="/birds/amie/amie-whats-included.webp" alt="The full documentation and starter set that comes home with every C.A.Gs African Grey, including DNA, CITES and hatch certificates" title="What comes home with every C.A.Gs grey" width="1200" height="655" loading="lazy" class="w-full h-auto" />
        </a>
        <figcaption class="font-sora text-xs text-stone-600 mt-2 leading-relaxed">Everything that travels with your bird — DNA sex certificate, CITES Appendix I paperwork, hatch certificate and vet health record. <a href="/available/amie/" class="text-clay-text underline">See what comes with Amie →</a></figcaption>
      </figure>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-2">The documentation set every bird carries</h3>
      <ul class="space-y-2 mb-5">
        {["DNA sex certificate (lab-confirmed)","AAV avian-vet health certificate","Hatch certificate + closed leg band","CITES Appendix I captive-bred documentation","Weaning &amp; feeding guidance"].map((d) => (
          <li class="flex gap-3"><span style="color:#2D6A4F;font-weight:700;flex-shrink:0;">✔</span><span class="font-sora text-stone-600 text-sm" set:html={d}></span></li>
        ))}
      </ul>
      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2">How can you verify our paperwork yourself?</h4>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Our USDA AWA license number is public and searchable, the DNA certificate names the testing lab, and your own avian vet can confirm the AAV health certificate at the first wellness visit. See <a href="/cites-african-grey-documentation/" class="text-clay-text underline">our CITES documentation page</a> for what each form covers.</p>
      <h5 class="font-lora font-semibold text-base text-logo-dark mt-5 mb-1">Keep these documents for your bird's whole life</h5>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Store the originals safely — you will want the CITES and hatch paperwork for future vet records, interstate travel, and to prove captive-bred origin decades from now.</p>
      <h6 class="font-sora text-sm font-semibold text-logo-dark mt-4 mb-1">Source: CITES Appendix I captive-bred provisions (USFWS)</h6>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Captive-bred African Greys are legal to own and transfer domestically with proper documentation under <a href="https://www.fws.gov/program/international-affairs/what-cites" target="_blank" rel="noopener noreferrer" class="text-clay-text underline">U.S. Fish &amp; Wildlife Service CITES guidance ↗</a>.</p>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-2 mt-8">Our pre-placement health standard</h3>
      <p class="font-sora text-stone-600 text-sm leading-relaxed mb-3">We are a USDA Animal Welfare Act licensed facility, and every bird clears the same pre-placement checks before it is listed.</p>
      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2">What health checks does every grey clear?</h4>
      <ul class="space-y-2 mb-4">
        {["PBFD &amp; Polyomavirus PCR screening","Pre-placement avian-vet exam (AAV standard)","Weight &amp; condition assessment","Weaning verification before travel"].map((d) => (
          <li class="flex gap-3"><span style="color:#2D6A4F;font-weight:700;flex-shrink:0;">✔</span><span class="font-sora text-stone-600 text-sm" set:html={d}></span></li>
        ))}
      </ul>
      <h5 class="font-lora font-semibold text-base text-logo-dark mt-5 mb-1">A note on testing claims</h5>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">We only tell you what we have documented. If your vet recommends additional diagnostics beyond the AAV health certificate, that is a conversation we support. Every bird is also covered by <a href="/african-grey-parrot-health-guarantee/" class="text-clay-text underline">our health guarantee</a>.</p>
