---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustBar from '../../../components/TrustBar.astro';
import CTA from '../../../components/CTA.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const title = "Roys — Male Congo African Grey For Sale | $2,300 | C.A.Gs – Midland, TX";
const description = "Meet Roys, our hand-raised male Congo African Grey — 4 months old, energetic and great with families, $2,300. DNA sexed, CITES-documented, captive-bred. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/roys/";

const productSchema = {
  "name": "Roys — Male Congo African Grey",
  "description": "Roys is a hand-raised male Congo African Grey (Psittacus erithacus), 4 months old, with an energetic, family-friendly temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/roys-congo-african-grey-male-4-months.webp",
  "category": "Congo African Grey Parrot",
  "sku": "cag-roys",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-18",
  "offers": {
    "@type": "Offer",
    "price": "2300",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/roys/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Roys DNA sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Roys goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork." }
    },
    {
      "@type": "Question",
      "name": "How old is Roys and what is his temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Roys is 4 months old. We hand-raised him ourselves, and he has grown into an energetic, playful young grey who thrives on activity and does beautifully with a lively household — a confident bird who loves toys, foraging, and an engaged family around him." }
    },
    {
      "@type": "Question",
      "name": "How much is Roys and how do I reserve him?",
      "acceptedAnswer": { "@type": "Answer", "text": "Roys is $2,300. A $200 deposit reserves him and pauses his listing for you. The balance is due before he travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Roys be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Roys ships nationwide. Airport Pickup is $185 (you collect him at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350." }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Roys — Male Congo African Grey", url: "/available/roys/" }
      ]} />
  </div>

  {/* 1 — HERO / BIRD VITALS + inquiry CTA */}
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <div>
        <img
          src="/roys-congo-african-grey-male-4-months.webp"
          alt="Roys, a hand-raised male Congo African Grey parrot, four months old, perched and looking toward the camera"
          width="640" height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
        />
      </div>
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Psittacus erithacus &middot; CITES Appendix I Captive-Bred</p>
        <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-5">Roys — Male Congo African Grey For Sale</h1>
        <p class="text-cream/80 text-lg mb-6 leading-relaxed">Here at C.A.Gs, our Roys is an energetic, playful Congo boy we hand-raised from the start. At 4 months old he is confident, busy, and brilliant with families — the kind of grey who wants toys to shred, problems to solve, and people around to share it all.</p>
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-7">
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Sex</span>Male (DNA sexed)</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Age</span>4 months</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Variant</span>Congo African Grey</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Price</span>$2,300</li>
        </ul>
        <p class="text-cream/70 text-sm mb-6">Ships nationwide &middot; $185 airport &middot; $350 home</p>
        <a href="/contact-us/?bird=Roys" class="inline-block bg-clay text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors">Inquire About Roys</a>
      </div>
    </div>
  </section>
  <TrustBar />

  {/* 2 — ABOUT ROYS (archetype: REX/NOVA / energetic active-family) */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What is Roys like to live with?</h2>
      <p class="text-stone-600 leading-relaxed mb-4">If your home hums with activity and you want a grey who keeps up, Roys is built for it. We have watched him grow into a confident, high-energy Congo boy who is happiest with a job to do — a foraging toy to dismantle, a puzzle to crack, a household to be in the middle of. He is great with families precisely because he feeds off the busyness rather than shrinking from it. Give him stimulation and company and he gives back personality in spades.</p>
      <p class="text-stone-600 leading-relaxed mb-4">At 4 months Roys is curious about everything and forming his sense of the world, which makes this a great moment for an engaged family to shape his routine. Congo greys are famously bright, and Roys puts that intelligence to work all day. He suits an active owner or household ready to keep an energetic bird busy and involved, not one looking for a quiet ornament on a perch. If you are weighing whether a Congo or a Timneh fits your home, our <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh comparison</a> walks through the differences.</p>
      <p class="text-stone-600 leading-relaxed">Greys are remarkable talkers and problem-solvers with 40–60 year lifespans — we cover the full species background in our <a href="/african-grey-parrot-guide/" class="text-clay-text underline">African Grey parrot guide</a> so this page can stay about Roys himself.</p>
    </div>
  </section>

  {/* 3 — HEALTH & DOCUMENTATION (ledger only) */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What documentation comes with Roys?</h2>
      <p class="text-stone-600 leading-relaxed mb-6">We never ask a buyer to take our word for it. Roys is captive-bred here in the USA and goes home with a complete paperwork set, the same standard we hold every C.A.Gs grey to:</p>
      <ul class="space-y-3 text-stone-600">
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>DNA sex certificate</strong> — lab-confirmed that Roys is male, so there is no guesswork.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Avian-vet health certificate</strong> — issued before he travels.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Hatch certificate + closed leg band</strong> — his traceable identity as a captive-bred bird.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>CITES captive-bred documentation</strong> — African Greys are CITES Appendix I; captive-bred birds are legal to own and transfer domestically with the right paperwork, and Roys has it. See our <a href="/cites-african-grey-documentation/" class="text-clay-text underline">CITES documentation page</a> for what that means.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Weaning underway</strong> — Roys is progressing on schedule and will leave us only once he is eating independently.</span></li>
      </ul>
      <p class="text-stone-600 leading-relaxed mt-6">We are a USDA AWA licensed family aviary, and Roys is also covered by our <a href="/african-grey-parrot-health-guarantee/" class="text-clay-text underline">African Grey health guarantee</a>. Want proof a grey is DNA-tested before you commit? That is the whole point of our <a href="/dna-tested-african-grey-for-sale/" class="text-clay-text underline">DNA-tested greys</a>.</p>
    </div>
  </section>

  {/* 4 — WHY ROYS */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Why Roys might be the right grey for you</h2>
      <p class="text-stone-600 leading-relaxed mb-4">An energetic young male like Roys is a gift for the right home. His confidence and drive mean he adapts quickly to a busy family, takes to enrichment readily, and rewards an involved owner with a big, expressive personality. If you have children who will help keep him stimulated, or simply a full house that wants a bird in the thick of things, Roys is made for that life — and at 4 months you get decades of that energy ahead.</p>
      <p class="text-stone-600 leading-relaxed">Because we hand-raised him ourselves, we can tell you honestly how he responds to handling, to new people, and to a high-activity household — and we would rather he go to the home that genuinely fits him than the first one to ask. That is the conversation we want to have with you.</p>
    </div>
  </section>

  {/* 5 — PRICING & WHAT'S INCLUDED */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">How much is Roys, and what's included?</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Price & reservation</h3>
          <ul class="space-y-3 text-stone-600 text-sm">
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Roys (male, 4 months)</span><strong class="text-logo-dark">$2,300</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Deposit to reserve</span><strong class="text-logo-dark">$200</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Airport Pickup (IATA, LAR)</span><strong class="text-logo-dark">$185</strong></li>
            <li class="flex justify-between"><span>Home Delivery (door-to-door)</span><strong class="text-logo-dark">$350</strong></li>
          </ul>
          <p class="text-stone-500 text-xs mt-3">Ships nationwide &middot; $185 airport &middot; $350 home &middot; Delta / United / American</p>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Included in his price</h3>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> DNA sex certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Avian-vet health certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Hatch certificate + leg band</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> CITES captive-bred documentation</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Health guarantee + go-home support</li>
          </ul>
        </div>
      </div>
      <p class="text-stone-600 leading-relaxed mt-6">A $200 deposit reserves Roys and pauses his listing for you; the balance is due before he travels. For how his price sits against the wider range, see our <a href="/african-grey-parrot-price/" class="text-clay-text underline">African Grey price guide</a>.</p>
    </div>
  </section>

  {/* 6 — PARENT BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Who are Roys's parents?</h2>
      <p class="text-stone-600 leading-relaxed">Roys was hatched and hand-raised inside our family aviary in Midland, Texas, which we have run since 2014. We are happy to share his specific parentage and pairing details on request during the reservation conversation, along with anything else you would like to verify before you commit. We would rather walk you through it directly than post it on a page.</p>
    </div>
  </section>

  {/* 7 — FAQ */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Roys — frequently asked questions</h2>
      <div class="space-y-4">
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Is Roys DNA sexed and documented?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes. Roys goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How old is Roys and what is his temperament?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Roys is 4 months old. We hand-raised him ourselves, and he has grown into an energetic, playful young grey who thrives on activity and does beautifully with a lively household — a confident bird who loves toys, foraging, and an engaged family around him.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How much is Roys and how do I reserve him?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Roys is $2,300. A $200 deposit reserves him and pauses his listing for you. The balance is due before he travels. Reach out through our contact form and we reply within 24 hours.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Can Roys be shipped to me?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes — Roys ships nationwide. Airport Pickup is $185 (you collect him at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350.</p>
        </details>
      </div>
    </div>
  </section>

  {/* 8 — OTHER AVAILABLE BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Other African Greys we have available</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/available/bery/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Bery</h3><p class="text-stone-500 text-sm">Female Congo &middot; 1 year</p><p class="text-clay-text font-semibold text-sm mt-1">$1,700</p></a>
        <a href="/available/amie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Amie</h3><p class="text-stone-500 text-sm">Female Congo &middot; 3 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,500</p></a>
        <a href="/available/jins-jeni/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Jins &amp; Jeni</h3><p class="text-stone-500 text-sm">Congo pair &middot; must go together</p><p class="text-clay-text font-semibold text-sm mt-1">$3,500</p></a>
        <a href="/available/elad/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Elad</h3><p class="text-stone-500 text-sm">Male Timneh &middot; 5 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,600</p></a>
        <a href="/available/evie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Evie</h3><p class="text-stone-500 text-sm">Female Timneh &middot; 6 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,500</p></a>
        <a href="/african-grey-parrots-for-sale/" class="block bg-logo-dark text-cream rounded-2xl p-5 hover:opacity-90 transition-opacity"><h3 class="font-lora font-semibold">See every available grey</h3><p class="text-cream/70 text-sm mt-1">Browse the full nursery &rarr;</p></a>
      </div>
    </div>
  </section>

  <Schema type="product" data={productSchema} />
  <Schema type="faq" data={faqSchema} />
  <Schema type="organization" />

  {/* 9 — INQUIRY CTA */}
  <CTA headline="Ready to bring Roys home?" sub="Roys is a hand-raised, CITES-documented, DNA-sexed male Congo grey at $2,300. A $200 deposit reserves him — reach out and we reply within 24 hours." />
</BaseLayout>
