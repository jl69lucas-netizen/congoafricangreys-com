---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CounterSnippet from '../../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../../components/cag-library/KeyTakeawayV2.astro';
import NewsletterV2 from '../../../components/cag-library/NewsletterV2.astro';
import JumpRail from '../../../components/cag-library/JumpRail.astro';

const title = "Male Congo African Grey for Sale | Want a Hand-Raised, DNA-Sexed Boy? Meet Roys — 1 Healthy 4-Month Congo, $2,300 | C.A.Gs – Midland, TX";
const description = "Roys is a hand-raised male Congo African Grey for sale — 4 months old, energetic and great with families, $2,300. DNA sexed, CITES-documented, captive-bred in the USA. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/roys/";

const productSchema = {
  "name": "Roys — Male Congo African Grey For Sale",
  "description": "Roys is a hand-raised male Congo African Grey (Psittacus erithacus), 4 months old, with an energetic, family-friendly temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented, USDA AWA licensed aviary. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/birds/roys/roys-hero.webp",
  "category": "Congo African Grey Parrot",
  "sku": "cag-roys",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-19",
  "offers": {
    "@type": "Offer",
    "price": "2300",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/roys/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Roys DNA-sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Roys goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with closed leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with the full paperwork set." }
    },
    {
      "@type": "Question",
      "name": "How old is Roys and what is his temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Roys is 4 months old. We hand-raised him ourselves, and he has grown into an energetic, playful young grey who thrives on activity and does beautifully with a lively household. He is a confident bird who loves toys, foraging, and an engaged family around him." }
    },
    {
      "@type": "Question",
      "name": "How much is Roys and how do I reserve him?",
      "acceptedAnswer": { "@type": "Answer", "text": "Roys is $2,300. A $200 deposit reserves him and pauses his listing for you. The balance is due before he travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Roys be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Roys ships nationwide. Airport Pickup is $185, where you collect him at your nearest major airport via IATA-compliant live-animal cargo (IATA code LAR) on Delta, United, or American. Home Delivery is door-to-door for $350. An Avian Flight Nanny who carries him in-cabin is available too, quoted per route from about $750." }
    },
    {
      "@type": "Question",
      "name": "Do male Congo greys talk well?",
      "acceptedAnswer": { "@type": "Answer", "text": "Congo African Greys of either sex are among the most capable talking parrots, and sex is not a reliable predictor of how much an individual will say. Roys is at the developing stage at 4 months. What shapes his eventual vocabulary most is daily interaction in the home, not whether he is male." }
    },
    {
      "@type": "Question",
      "name": "Why is Roys $2,300 when I've seen greys for $850?",
      "acceptedAnswer": { "@type": "Answer", "text": "An $850 'Congo' is the price of a bird with no verifiable paperwork — no DNA certificate, no CITES documentation, no avian-vet health check, and often no breeder you can actually hold accountable. Roys is $2,300 because that figure covers hand-rearing, his full documentation set, and a USDA AWA licensed aviary standing behind him. A documented hand-raised Congo honestly cannot be produced for $850." }
    }
  ]
};

const roysTocItems = [
  { n: 1,  label: "Is Roys the right African Grey for me?",               href: "#takeaway" },
  { n: 2,  label: "What is Roys like to live with?",                      href: "#temperament" },
  { n: 3,  label: "Does a male Congo African Grey talk well?",             href: "#talking" },
  { n: 4,  label: "Why does Roys cost $2,300 when I see \"$850\" greys?", href: "#price-counter" },
  { n: 5,  label: "What documentation comes with Roys?",                  href: "#documentation" },
  { n: 6,  label: "What's included when you reserve Roys?",               href: "#included" },
  { n: 7,  label: "How does Roys compare to our other available greys?",  href: "#comparison" },
  { n: 8,  label: "Is Roys a healthy bird? Our health standard",          href: "#health" },
  { n: 9,  label: "Who are Roys's parents?",                              href: "#parents" },
  { n: 10, label: "What should you decide before buying an African Grey?",href: "#decisions" },
  { n: 11, label: "What's it like to own an African Grey long-term?",     href: "#lifestyle" },
  { n: 12, label: "Reviews — families who brought home a C.A.Gs grey",   href: "#reviews-mid" },
  { n: 13, label: "How do you train an African Grey like Roys?",          href: "#training" },
  { n: 14, label: "What do C.A.Gs recommend feeding African Greys?",      href: "#food" },
  { n: 15, label: "Roys's photo & video gallery",                         href: "#gallery" },
  { n: 16, label: "How do you buy Roys? Step-by-step",                   href: "#buy" },
  { n: 17, label: "Where do C.A.Gs deliver African Greys?",              href: "#shipping" },
  { n: 18, label: "Roys — frequently asked questions",                    href: "#faq" },
  { n: 19, label: "Reviews — more happy C.A.Gs owners",                  href: "#reviews-bottom" },
  { n: 20, label: "African Grey care guides for Roys's new family",      href: "#resources" },
  { n: 21, label: "Why buy from C.A.Gs instead of a marketplace?",       href: "#marketplace" },
  { n: 22, label: "Ready to bring Roys home?",                           href: "#reserve" },
];

const roysCounterStats = [
  { num: "4 mo",    label: "Current Age" },
  { num: "$2,300",  label: "Asking Price" },
  { num: "100%",    label: "CITES Documented" },
  { num: "24h",     label: "Reply Guarantee" },
];

const roysKeyTakeawayItems = [
  { stat: "Male",       label: "DNA-Sexed",        body: "Lab-confirmed male — no guesswork. His DNA sex certificate travels home with him." },
  { stat: "4 months",   label: "Age",              body: "Young enough to shape his routine, old enough to show a real personality. He is curious, confident, and busy." },
  { stat: "$2,300",     label: "Price",            body: "Covers a hand-raised, fully documented Congo. A $200 deposit reserves him immediately." },
  { stat: "Congo",      label: "Variant",          body: "Psittacus erithacus — the large scarlet-tailed Congo, bred in our Midland, TX family aviary since 2014." },
  { stat: "CITES I",    label: "Captive-Bred USA", body: "Full Appendix I captive-bred documentation — the paperwork that proves Roys is legal to own and transfer." },
  { stat: "Full set",   label: "Papers Included",  body: "DNA cert · AAV health cert · hatch cert + band · CITES docs · weaning guidance. No chasing paperwork after." },
  { stat: "Nationwide", label: "Ships",            body: "Airport Pickup $185 or Home Delivery $350. IATA LAR-coded via Delta, United, and American." },
  { stat: "Active",     label: "Temperament",      body: "Energetic forager, toy-shredder, problem-solver. Thrives with daily interaction and a full household." },
];

/* Mobile section-jump dial + desktop dot rail (page is >6,000 words) */
const roysJumpSections = [
  { id: "takeaway",     label: "Overview",    part: 1 },
  { id: "temperament",  label: "Personality", part: 1 },
  { id: "talking",      label: "Talking",     part: 1 },
  { id: "parents",      label: "Parents",     part: 1 },
  { id: "documentation",label: "Documents",   part: 2 },
  { id: "health",       label: "Health",      part: 2 },
  { id: "price-counter",label: "Why $2,300",  part: 2 },
  { id: "gallery",      label: "Gallery",     part: 3 },
  { id: "comparison",   label: "Compare",     part: 3 },
  { id: "reviews-mid",  label: "Reviews",     part: 3 },
  { id: "food",         label: "Diet",        part: 3 },
  { id: "included",     label: "Included",    part: 4 },
  { id: "buy",          label: "How to Buy",  part: 4 },
  { id: "shipping",     label: "Shipping",    part: 4 },
  { id: "faq",          label: "FAQ",         part: 4 },
  { id: "resources",    label: "Care Guides", part: 4 },
  { id: "reserve",      label: "Reserve",     part: 4 },
];
const roysJumpParts = {
  1: "Meet Roys",
  2: "Proof & Papers",
  3: "See & Compare",
  4: "Buying Roys",
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <style>
    /* ── Roys page: homepage-parity rhythm (Direction D) ── */
    /* Compact section padding so the page reads tight, not endless */
    .roys-d .py-16 { padding-top: 2.4rem !important; padding-bottom: 2.4rem !important; }
    @media (min-width: 768px) {
      .roys-d .py-16 { padding-top: 3rem !important; padding-bottom: 3rem !important; }
    }
    .roys-d .py-12 { padding-top: 2rem !important; padding-bottom: 2rem !important; }

    /* Section-seam divider with the small footer logo (homepage pattern) */
    .roys-d .cag-seam { display: flex; align-items: center; gap: 26px; max-width: 1100px; margin: 0 auto; padding: 0.5rem 24px; }
    .roys-d .cag-seam__line { flex: 1; height: 1px; background: rgba(45,106,79,.16); }
    .roys-d .cag-seam img { height: 30px; width: auto; display: block; opacity: .92; flex-shrink: 0; }
    @media (max-width: 600px) { .roys-d .cag-seam { gap: 16px; } .roys-d .cag-seam img { height: 24px; } }

    /* Hero H1 — match homepage clamp (was text-4xl/5xl = oversized) */
    .roys-d .roys-hero h1 { font-size: clamp(1.7rem, 1.1rem + 2.6vw, 2.35rem) !important; line-height: 1.14 !important; }

    /* Standard media height so portrait crops aren't cut at the edges */
    .roys-d .roys-feature-img { max-height: 420px !important; object-position: center top; }
    /* Constrained 16/9 video frame for non-hero clips */
    .roys-d .roys-video-frame { position: relative; max-width: 640px; margin-left: auto; margin-right: auto; aspect-ratio: 16/9; }
    .roys-d .roys-video-frame video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  </style>

  <div class="roys-d">

  {/* ── BREADCRUMB ── */}
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys For Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Roys — Male Congo African Grey", url: "/available/roys/" }
    ]} />
  </div>

  {/* ── SECTION-JUMP DIAL — desktop dot rail + mobile bottom-sheet (page >6,000 words) ── */}
  <JumpRail
    sections={roysJumpSections}
    partNames={roysJumpParts}
    ctaLabel="Reserve Roys →"
    ctaTarget="reserve"
  />

  {/* ── HERO C: Trust-first + click-to-play video ── */}
  <section class="roys-hero bg-logo-dark text-cream py-14 px-4 md:py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">

      {/* LEFT: Vitals + CTA */}
      <div class="order-2 md:order-1">
        <p class="font-sora text-gold text-xs font-medium tracking-wide mb-3">
          <em>Psittacus erithacus</em> &middot; CITES Appendix&nbsp;I Captive-Bred &middot; Midland, TX
        </p>
        <h1 class="font-lora font-bold text-2xl sm:text-3xl leading-tight mb-5">
          Roys — Male Congo African Grey For Sale ($2,300, Hand-Raised &amp; DNA-Sexed)
        </h1>

        {/* Snapshot vitals */}
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-6">
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Sex</span>
            Male (DNA-sexed)
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Age</span>
            4 months
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Variant</span>
            Congo African Grey
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Price</span>
            $2,300
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Talking</span>
            Developing
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Status</span>
            Available
          </li>
        </ul>

        {/* Trust badges row */}
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>CITES Appendix&nbsp;I
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><path d="M9 3h6"/><path d="M10 3v6l-4.6 9.2A1.5 1.5 0 0 0 6.7 21h10.6a1.5 1.5 0 0 0 1.3-2.8L14 9V3"/></svg>DNA Sexed
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Avian Vet Cert
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 21 8 3 8"/></svg>USDA AWA Licensed
          </span>
        </div>

        <p class="font-sora text-cream/70 text-sm mb-7">Ships nationwide &middot; $185 airport &middot; $350 home</p>

        <a href="/contact-us/?bird=Roys"
           class="inline-block bg-clay text-white font-sora font-semibold px-8 py-4 rounded-full text-base hover:bg-clay-dk transition-colors"
           style="box-shadow:0 6px 20px rgba(232,96,76,0.35);">
          Ask About Roys
        </a>
      </div>

      {/* RIGHT: click-to-play video — shows first on mobile so visitors see Roys move */}
      <div class="order-1 md:order-2">
        <video
          poster="/birds/roys/roys-hero.webp"
          controls
          preload="none"
          width="640"
          height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          aria-label="Roys, our hand-raised male Congo African Grey — click to watch him play"
          style="max-height:440px;object-fit:cover;"
        >
          <source src="/birds/roys/roys-video-playing.mp4" type="video/mp4" />
          Your browser does not support the video element.
        </video>
        <p class="font-sora text-cream/50 text-xs text-center mt-2">Click to watch Roys at play — click again to pause.</p>
      </div>
    </div>
  </section>

  {/* ── COUNTER SNIPPET — moved directly under the hero (above "At a glance") ── */}
  <CounterSnippet stats={roysCounterStats} />

  {/* ── AEO SNAPSHOT — modern info card (green header band + spec tiles) ── */}
  <section class="py-12 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="overflow-hidden rounded-2xl border border-black/[0.07] bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">
        <div class="bg-logo-dark px-6 py-5 sm:px-8">
          <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.18em] text-gold mb-1.5">At a glance</p>
          <h2 class="font-lora font-bold text-xl sm:text-2xl text-cream leading-snug">Roys at a glance — Male Congo African Grey for Sale Snapshot</h2>
        </div>
        <div class="p-6 sm:p-8">
          <p class="font-sora text-stone-700 leading-relaxed mb-6">Roys is a hand-raised male Congo African Grey (<em>Psittacus erithacus</em>), 4 months old, priced at $2,300. He is DNA-sexed, CITES-documented, captive-bred in the USA at our USDA AWA licensed aviary, and ships nationwide ($185 airport / $350 home).</p>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              ["Variant", "Congo African Grey"],
              ["Sex", "Male (DNA-sexed)"],
              ["Age", "4 months"],
              ["Price", "$2,300 · $200 deposit"],
              ["Talking", "Developing"],
              ["Documentation", "DNA · CITES · health cert"],
            ].map(([k, v]) => (
              <div class="rounded-xl border border-stone-200 bg-cream/60 px-4 py-3">
                <dt class="font-sora text-[11px] uppercase tracking-wide text-stone-500">{k}</dt>
                <dd class="font-sora text-sm font-semibold text-logo-dark mt-1 leading-snug">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 1: KEY TAKEAWAY — Is Roys right for me?
      Placed ABOVE the TOC (after the counter snippet) so the "short version"
      lands before the long table of contents.
      ══════════════════════════════════════════════ */}
  <section id="takeaway">
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Is Roys the right African Grey for me?"
      badge="8 facts · 90-sec read"
      items={roysKeyTakeawayItems}
    />
  </section>

  {/* ── TABLE OF CONTENTS ── */}
  <nav class="py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
    <div class="container mx-auto max-w-5xl">
      <div class="rounded-2xl border border-black/[0.07] bg-white px-6 py-7 md:px-10 md:py-9" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
        <div class="flex flex-col items-start justify-between gap-2 border-b border-black/[0.07] pb-5 md:flex-row md:items-end">
          <div>
            <p class="font-sora text-xs font-bold uppercase tracking-widest text-clay">Inside this page</p>
            <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark">On This Page</h2>
          </div>
          <p class="font-sora text-sm text-stone-500">22 sections · everything about Roys</p>
        </div>
        <div class="mt-6 grid grid-cols-1 gap-x-10 gap-y-1 md:grid-cols-2">
          {roysTocItems.map((item) => (
            <a href={item.href}
               class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/5 font-sora">
              <span class="text-xs font-semibold text-clay-ink">{String(item.n).padStart(2, "0")}</span>
              <span class="text-sm leading-snug text-stone-700">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  {/* ══════════════════════════════════════════════
      SECTION 2: TEMPERAMENT — What is Roys like to live with?
      Framework: EBP · Cat: A · ~180w
      Source: BUILD-1 section 5 (lines 128-138) — reused + image added
      ══════════════════════════════════════════════ */}
  <section id="temperament" class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">What is Roys like to live with?</h2>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Roys is a busy, confident male Congo African Grey who is happiest with a job to do and a household around him. If your home hums with activity, he is built for it. We have watched him grow from a clumsy chick into a young bird who treats an empty afternoon as a problem to solve, and he rewards an engaged family with a big, expressive personality.</p>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Here at C.A.Gs we hand-raised Roys ourselves, in our Midland, Texas home, so what we tell you about him comes from feeding him every day rather than from a sales sheet. One thing we noticed early: he works a foraging toy methodically, twisting and testing a knot until it gives, then looking up to check whether anyone caught the win. That drive is the whole personality. Give him stimulation and company and he gives it straight back.</p>

      {/* Personality infographic — placed mid-text to break up the section */}
      <figure class="my-7">
        <img
          src="/birds/roys/roys-personality.webp"
          alt="Roys' personality profile — a hand-raised male Congo African Grey rated for energy, talking potential, beginner-friendliness, social needs, and noise"
          width="760" height="430"
          class="w-full rounded-2xl border border-stone-200"
          loading="lazy"
          style="box-shadow:0 4px 20px rgba(60,30,10,0.07);"
        />
        <figcaption class="font-sora text-xs text-stone-400 mt-2 text-center">Roys at 4 months — alert, confident, always watching</figcaption>
      </figure>

      <p class="font-sora text-stone-600 leading-relaxed mb-4">At 4 months he is curious about everything and still forming his sense of the world. Congo greys are famously bright — the species, <em>Psittacus erithacus</em>, sits among the most studied talking parrots in the world, and <a href="https://parrots.org/encyclopedia/grey-parrot/" target="_blank" rel="noopener noreferrer" class="text-clay-text underline">the World Parrot Trust's grey parrot profile ↗</a> covers their cognition in depth. He suits an active owner or household ready to keep an energetic bird busy and involved.</p>
      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-2 mt-5">How does Roys settle in at first?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-3">His first 30 days at home tend to follow a pattern we have seen across our greys. Week one he watches more than he plays, learning the rhythm of your house. By week two he starts claiming a favourite perch and testing which sounds get a reaction. By the end of the month, in a home that shows up for him daily, he is asking to come out and beginning the soft babble that comes before real words.</p>
      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2 mt-4">Is Roys good with children?</h4>
      <p class="font-sora text-stone-600 leading-relaxed">He does well with older children who understand that a bird is not a toy. He reads energy quickly — a calm, curious kid who offers a finger consistently is exactly the kind of relationship he builds on. Chaotic or grabbing handling is another matter. We are honest about that.</p>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 3: TALKING — Does a male Congo talk well?
      Framework: QAB · Cat: B · ~150w
      ══════════════════════════════════════════════ */}
  <section id="talking" class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-4">Does a male Congo African Grey talk well?</h2>

      {/* 40-word featured-snippet answer */}
      <div class="bg-white border-l-4 border-green rounded-xl p-5 mb-6" style="box-shadow:0 2px 12px rgba(60,30,10,0.06);">
        <p class="font-sora text-stone-700 leading-relaxed">
          <strong>Short answer:</strong> Congo African Greys of either sex are among the most capable talking parrots alive. Sex is not a reliable predictor — individual motivation and daily interaction shape vocabulary far more than whether the bird is male or female.
        </p>
      </div>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Where is Roys right now?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">At 4 months, Roys is in the developing stage. His vocal learning is just beginning. We hear the soft contact calls and exploratory sounds a young grey makes before real mimicry clicks — that process happens over the coming months. Watch the playing video above to hear him as he is now: active, interactive, and already engaged with whoever holds the camera.</p>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Hear a grown C.A.Gs Congo actually talking</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">You do not have to take our word for what Roys is growing toward. This is <strong>Maxy</strong>, an adult hand-raised Congo African Grey from the same flock and the same Midland, TX home, talking on camera — the clearest proof of the vocabulary a well-socialised Congo develops.</p>
      <figure class="my-6">
        <div class="roys-video-frame rounded-2xl overflow-hidden border border-stone-200" style="box-shadow:0 4px 20px rgba(60,30,10,0.07);">
          <video controls preload="none" playsinline width="640" height="360" poster="/african-grey-breeder-with-bird-midland-tx.webp" aria-label="Maxy, a hand-raised adult Congo African Grey from C.A.Gs, talking on camera">
            <source src="/talking-african-grey-parrot-video.mp4" type="video/mp4" />
            Your browser does not support the video element.
          </video>
        </div>
        <figcaption class="font-sora text-xs text-stone-400 text-center mt-2">That's <strong>Maxy</strong>, one of our talking Congo Greys, at our Midland, TX aviary. Meet <a href="/" class="text-clay-text underline">more of our talking greys on the homepage</a>, or read our guide to <a href="/blog/african-grey-parrot-talking-ability/" class="text-clay-text underline">how African Greys learn to talk</a>.</figcaption>
      </figure>

      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">What shapes a Congo's eventual vocabulary?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">The single biggest factor is daily conversation in his home environment. Greys learn by listening and repeating what gets a real reaction — your name, your kitchen sounds, the things you say at the same time every day. A bird in a quiet house with minimal human contact will talk less than one at the centre of a busy family routine. Sex has almost nothing to do with it.</p>

      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2">How does Congo talking compare to Timneh?</h4>
      <p class="font-sora text-stone-600 leading-relaxed">Timnehs tend to start talking earlier — sometimes as young as 4–6 months — while Congos tend to develop larger and more dramatic vocabularies over time. <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Our Congo vs Timneh comparison</a> covers this side-by-side in detail if you are weighing the two.</p>

      <h5 class="font-lora font-semibold text-base text-logo-dark mt-5 mb-1">Can I speed up when Roys starts talking?</h5>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Not by drilling. Repetition without genuine social context rarely sticks. The greys that develop the fastest are the ones whose owners talk <em>with</em> them, not <em>at</em> them — narrating what they are doing, responding when the bird makes sounds, treating the conversation as two-way.</p>

      <h6 class="font-sora text-sm font-semibold text-logo-dark mt-4 mb-1">How long until Roys says his first word?</h6>
      <p class="font-sora text-stone-600 text-sm leading-relaxed">Most Congos begin mimicking household sounds and short words between 6 and 12 months, with clearer speech firming up through the first year. Roys is 4 months old, so he is right at the start of that window.</p>
    </div>
  </section>

