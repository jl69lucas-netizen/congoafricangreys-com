---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CounterSnippet from '../../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../../components/cag-library/KeyTakeawayV2.astro';
import NewsletterV2 from '../../../components/cag-library/NewsletterV2.astro';
import JumpNav from '../../../components/cag-jump-nav.astro';

const title = "Male Timneh African Grey for Sale | Want a Hand-Raised, DNA-Sexed Boy? Meet Elad — 1 Healthy 6-Month Timneh, $1,600 (was $2,200) | C.A.Gs – Midland, TX";
const description = "Elad is a hand-raised male Timneh African Grey for sale — 6 months old, an early-talking, even-tempered young Timneh, now $1,600 (reduced from a $2,200 starting price). DNA sexed, CITES Appendix I documented, captive-bred in the USA. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/elad/";

const productSchema = {
  "name": "Elad — Male Timneh African Grey For Sale",
  "description": "Elad is a hand-raised male Timneh African Grey (Psittacus erithacus timneh), 6 months old, with an early-talking, even-tempered, family-friendly temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented, USDA AWA licensed aviary. Now $1,600, reduced from a $2,200 starting price. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/birds/elad/elad-timneh-african-grey-male-hero.webp",
  "category": "Timneh African Grey Parrot",
  "sku": "cag-elad",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-19",
  "offers": {
    "@type": "Offer",
    "price": "1600",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/elad/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Elad DNA-sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Elad goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with closed leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with the full paperwork set." }
    },
    {
      "@type": "Question",
      "name": "How old is Elad and what is his temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Elad is 6 months old. We hand-raised him ourselves, and he has grown into an energetic, playful young grey who thrives on activity and does beautifully with a lively household. He is a confident bird who loves toys, foraging, and an engaged family around him." }
    },
    {
      "@type": "Question",
      "name": "How much is Elad and how do I reserve him?",
      "acceptedAnswer": { "@type": "Answer", "text": "Elad is $1,600. A $200 deposit reserves him and pauses his listing for you. The balance is due before he travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Elad be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Elad ships nationwide. Airport Pickup is $185, where you collect him at your nearest major airport via IATA-compliant live-animal cargo (IATA code LAR) on Delta, United, or American. Home Delivery is door-to-door for $350. An Avian Flight Nanny who carries him in-cabin is available too, quoted per route from about $750." }
    },
    {
      "@type": "Question",
      "name": "Do male Timneh African Greys talk early?",
      "acceptedAnswer": { "@type": "Answer", "text": "Timneh African Greys of either sex are among the most capable talking parrots, and Timnehs are reputed to start talking earlier than Congos — sometimes around 6–12 months. Sex is not a reliable predictor of how much an individual will say. Elad is developing at 6 months; what shapes his eventual vocabulary most is daily interaction in the home, not whether he is male." }
    },
    {
      "@type": "Question",
      "name": "Why is Elad priced at $1,600 when listings show $600 Timnehs?",
      "acceptedAnswer": { "@type": "Answer", "text": "A $600 'Timneh' is the price of a bird with no verifiable paperwork — no DNA certificate, no CITES documentation, no avian-vet health check, and often no breeder you can actually hold accountable. Elad is $1,600 — reduced from a $2,200 Timneh starting price — because that figure covers hand-rearing, his full documentation set, and a USDA AWA licensed aviary standing behind him. A documented hand-raised Timneh honestly cannot be produced for $600." }
    }
  ]
};

const eladTocItems = [
  { n: 1,  label: "Is Elad the right African Grey for me?",               href: "#takeaway" },
  { n: 2,  label: "What is Elad like to live with as a Timneh?",                      href: "#temperament" },
  { n: 3,  label: "Do male Timneh African Greys talk early?",             href: "#talking" },
  { n: 4,  label: "Why is Elad priced at $1,600 when listings show \"$600\" Timnehs?", href: "#price-counter" },
  { n: 5,  label: "What documentation comes with Elad?",                  href: "#documentation" },
  { n: 6,  label: "What's included when you reserve Elad?",               href: "#included" },
  { n: 7,  label: "How does Elad compare to our other available greys?",  href: "#comparison" },
  { n: 8,  label: "Is Elad a healthy Timneh? Our health standard",          href: "#health" },
  { n: 9,  label: "Who are Elad's parents?",                              href: "#parents" },
  { n: 10, label: "What should you weigh before buying a Timneh African Grey?",href: "#decisions" },
  { n: 11, label: "What is life with a Timneh African Grey like over the decades?",     href: "#lifestyle" },
  { n: 12, label: "Reviews — families who brought home a C.A.Gs grey",   href: "#reviews-mid" },
  { n: 13, label: "How do you tame and train a young Timneh like Elad?",          href: "#training" },
  { n: 14, label: "What do C.A.Gs feed a Timneh African Grey like Elad?",      href: "#food" },
  { n: 15, label: "Elad's photo & video gallery",                         href: "#gallery" },
  { n: 16, label: "How do you buy Elad, step by step?",                   href: "#buy" },
  { n: 17, label: "Where do C.A.Gs deliver Timneh African Greys?",              href: "#shipping" },
  { n: 18, label: "Elad — frequently asked questions",                    href: "#faq" },
  { n: 19, label: "Timneh care guides for Elad's new family",      href: "#resources" },
  { n: 20, label: "Why buy Elad from C.A.Gs instead of a marketplace?",       href: "#marketplace" },
  { n: 21, label: "Ready to bring Elad home?",                           href: "#reserve" },
];

const eladCounterStats = [
  { num: "6 mo",    label: "Current Age" },
  { num: "$1,600",  label: "Asking Price" },
  { num: "100%",    label: "CITES Documented" },
  { num: "24h",     label: "Reply Guarantee" },
];

const eladKeyTakeawayItems = [
  { stat: "Male",       label: "DNA-Sexed",        body: "Lab-confirmed male — no guesswork. His DNA sex certificate travels home with him." },
  { stat: "6 months",   label: "Age",              body: "Young enough to shape his routine, old enough to show a real personality. He is curious, confident, and busy." },
  { stat: "$1,600",     label: "Price",            body: "Now $1,600 — reduced from a $2,200 Timneh starting price. Covers a hand-raised, fully documented Timneh; a $200 deposit reserves him." },
  { stat: "Timneh",     label: "Variant",          body: "Psittacus erithacus timneh — the smaller, darker grey with a maroon tail and horn-coloured beak, bred in our Midland, TX family aviary since 2014." },
  { stat: "CITES I",    label: "Captive-Bred USA", body: "Full Appendix I captive-bred documentation — the paperwork that proves Elad is legal to own and transfer." },
  { stat: "Full set",   label: "Papers Included",  body: "DNA cert · AAV health cert · hatch cert + band · CITES docs · weaning guidance. No chasing paperwork after." },
  { stat: "Nationwide", label: "Ships",            body: "Airport Pickup $185 or Home Delivery $350. IATA LAR-coded via Delta, United, and American." },
  { stat: "Active",     label: "Temperament",      body: "Energetic forager, toy-shredder, problem-solver. Thrives with daily interaction and a full household." },
];

/* Mobile section-jump dial + desktop dot rail (page is >6,000 words) */
const eladJumpSections = [
  { id: "takeaway",     label: "Overview",    part: 1 },
  { id: "temperament",  label: "Personality", part: 1 },
  { id: "talking",      label: "Talking",     part: 1 },
  { id: "parents",      label: "Parents",     part: 1 },
  { id: "documentation",label: "Documents",   part: 2 },
  { id: "health",       label: "Health",      part: 2 },
  { id: "price-counter",label: "Why $1,600",  part: 2 },
  { id: "gallery",      label: "Gallery",     part: 3 },
  { id: "comparison",   label: "Compare",     part: 3 },
  { id: "reviews-mid",  label: "Reviews",     part: 3 },
  { id: "food",         label: "Diet",        part: 3 },
  { id: "included",     label: "Included",    part: 4 },
  { id: "buy",          label: "How to Buy",  part: 4 },
  { id: "shipping",     label: "Shipping",    part: 4 },
  { id: "faq",          label: "FAQ",         part: 4 },
  { id: "resources",    label: "Care Guides", part: 4 },
  { id: "reserve",      label: "Reserve",     part: 4 },
];
const eladJumpParts = {
  1: "Meet Elad",
  2: "Proof & Papers",
  3: "See & Compare",
  4: "Buying Elad",
};

const jumpLinks = [
  { label: "Temperament", href: "#temperament" },
  { label: "Talking", href: "#talking" },
  { label: "Price", href: "#price-counter" },
  { label: "What's included", href: "#documentation" },
  { label: "Health", href: "#health" },
  { label: "Gallery", href: "#gallery" },
  { label: "Shipping", href: "#shipping" },
  { label: "FAQ", href: "#faq" },
  { label: "Reserve", href: "#reserve" },
];
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <style>
    /* ── Elad page: homepage-parity rhythm (Direction D) ── */
    /* Compact section padding so the page reads tight, not endless */
    .elad-d .py-16 { padding-top: 2.4rem !important; padding-bottom: 2.4rem !important; }
    @media (min-width: 768px) {
      .elad-d .py-16 { padding-top: 3rem !important; padding-bottom: 3rem !important; }
    }
    .elad-d .py-12 { padding-top: 2rem !important; padding-bottom: 2rem !important; }

    /* Section-seam divider with the small footer logo (homepage pattern) */
    .elad-d .cag-seam { display: flex; align-items: center; gap: 26px; max-width: 1100px; margin: 0 auto; padding: 0.5rem 24px; }
    .elad-d .cag-seam__line { flex: 1; height: 1px; background: rgba(45,106,79,.16); }
    .elad-d .cag-seam img { height: 30px; width: auto; display: block; opacity: .92; flex-shrink: 0; }
    @media (max-width: 600px) { .elad-d .cag-seam { gap: 16px; } .elad-d .cag-seam img { height: 24px; } }

    /* Mobile sticky jump bar */
    .jump-mobile { position: sticky; top: 94px; z-index: 40; background: #faf7f4; }
    @media (min-width: 768px) { .jump-mobile { display: none; } }

    /* Hero H1 — match homepage clamp (was text-4xl/5xl = oversized) */
    .elad-d .elad-hero h1 { font-size: clamp(1.7rem, 1.1rem + 2.6vw, 2.35rem) !important; line-height: 1.14 !important; }

    /* Standard media height so portrait crops aren't cut at the edges */
    .elad-d .elad-feature-img { max-height: 420px !important; object-position: center top; }
    /* Constrained 16/9 video frame for non-hero clips */
    .elad-d .elad-video-frame { position: relative; max-width: 640px; margin-left: auto; margin-right: auto; aspect-ratio: 16/9; }
    .elad-d .elad-video-frame video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  </style>

  <div class="elad-d">

  {/* ── BREADCRUMB ── */}
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys For Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Elad — Male Timneh African Grey", url: "/available/elad/" }
    ]} />
  </div>


  {/* ── HERO C: Trust-first + click-to-play video ── */}
  <section class="elad-hero bg-logo-dark text-cream py-14 px-4 md:py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">

      {/* LEFT: Vitals + CTA */}
      <div class="order-2 md:order-1">
        <p class="font-sora text-[#f08070] text-xs font-medium tracking-wide mb-3">
          <em>Psittacus erithacus timneh</em> &middot; CITES Appendix&nbsp;I Captive-Bred &middot; Midland, TX
        </p>
        <h1 class="font-lora font-bold text-2xl sm:text-3xl leading-tight mb-5">
          Elad — Male Timneh African Grey For Sale ($1,600, was $2,200 &middot; Hand-Raised &amp; DNA-Sexed)
        </h1>

        {/* Snapshot vitals */}
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-6">
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Sex</span>
            Male (DNA-sexed)
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Age</span>
            6 months
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Variant</span>
            Timneh African Grey
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Price</span>
            $1,600
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Talking</span>
            Developing
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Status</span>
            Available
          </li>
        </ul>

        {/* Trust badges row */}
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>CITES Appendix&nbsp;I
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><path d="M9 3h6"/><path d="M10 3v6l-4.6 9.2A1.5 1.5 0 0 0 6.7 21h10.6a1.5 1.5 0 0 0 1.3-2.8L14 9V3"/></svg>DNA Sexed
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Avian Vet Cert
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 21 8 3 8"/></svg>USDA AWA Licensed
          </span>
        </div>

        <p class="font-sora text-cream/70 text-sm mb-7">Ships nationwide &middot; $185 airport &middot; $350 home</p>

        <a href="/contact-us/?bird=Elad"
           class="inline-block bg-clay text-white font-sora font-semibold px-8 py-4 rounded-full text-base hover:bg-clay-dk transition-colors"
           style="box-shadow:0 6px 20px rgba(232,96,76,0.35);">
          Ask About Elad
        </a>
      </div>

      {/* RIGHT: hero portrait (Elad has no video clip) */}
      <div class="order-1 md:order-2">
        <img
          src="/birds/elad/elad-timneh-african-grey-male-hero.webp"
          alt="Elad, a hand-raised male Timneh African Grey for sale at C.A.Gs in Midland, TX — compact charcoal-grey plumage and a horn-colored upper beak"
          width="640" height="480"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
          style="max-height:440px;object-fit:cover;object-position:center 30%;"
        />
        <p class="font-sora text-cream/50 text-xs text-center mt-2">Elad — our hand-raised male Timneh African Grey, 6 months, in our Midland, TX home.</p>
      </div>
    </div>
  </section>

  {/* ── COUNTER SNIPPET — moved directly under the hero (above "At a glance") ── */}
  <CounterSnippet stats={eladCounterStats} />

  {/* ── AEO SNAPSHOT — modern info card (green header band + spec tiles) ── */}
  <section class="py-12 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="overflow-hidden rounded-2xl border border-black/[0.07] bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">
        <div class="bg-logo-dark px-6 py-5 sm:px-8">
          <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.18em] text-[#f08070] mb-1.5">At a glance</p>
          <h2 class="font-lora font-bold text-xl sm:text-2xl text-cream leading-snug">Elad at a glance — Male Timneh African Grey for Sale Snapshot</h2>
        </div>
        <div class="p-6 sm:p-8">
          <figure class="mb-6">
            <img src="/birds/elad/elad-at-a-glance-card.webp" alt="Elad at a glance — male Timneh African Grey for sale, DNA-sexed, hand-raised and documented at C.A.Gs Midland, TX" width="600" height="1075" class="w-full rounded-xl border border-stone-200 bg-cream" loading="lazy" style="object-fit:contain;max-height:520px;box-shadow:0 4px 20px rgba(60,30,10,0.07);" />
            <figcaption class="font-sora text-xs text-stone-600 mt-2 text-center">Elad's at-a-glance card — male Timneh African Grey, now $1,600 (reduced from a $2,200 starting price).</figcaption>
          </figure>
          <p class="font-sora text-stone-700 leading-relaxed mb-6">Elad is a hand-raised male Timneh African Grey (<em>Psittacus erithacus timneh</em>), 6 months old, now $1,600 — reduced from a $2,200 Timneh starting price. He is DNA-sexed, CITES Appendix I documented, captive-bred in the USA at our USDA AWA licensed aviary, and ships nationwide ($185 airport / $350 home).</p>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              ["Variant", "Timneh African Grey"],
              ["Sex", "Male (DNA-sexed)"],
              ["Age", "6 months"],
              ["Price", "$1,600 · was $2,200 · $200 deposit"],
              ["Talking", "Early talker / developing"],
              ["Documentation", "DNA · CITES · health cert"],
            ].map(([k, v]) => (
              <div class="rounded-xl border border-stone-200 bg-cream/60 px-4 py-3">
                <dt class="font-sora text-[11px] uppercase tracking-wide text-stone-600">{k}</dt>
                <dd class="font-sora text-sm font-semibold text-logo-dark mt-1 leading-snug">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 1: KEY TAKEAWAY — Is Elad right for me?
      Placed ABOVE the TOC (after the counter snippet) so the "short version"
      lands before the long table of contents.
      ══════════════════════════════════════════════ */}
  <section id="takeaway">
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Is Elad the right African Grey for me?"
      badge="8 facts · 90-sec read"
      items={eladKeyTakeawayItems}
    />
  </section>

  {/* ── MOBILE JUMP BAR (sticky, mobile only) ── */}
  <div class="jump-mobile px-4 py-2">
    <JumpNav links={jumpLinks} sticky={false} />
  </div>

  {/* ── TABLE OF CONTENTS ── */}
  <nav class="hidden md:block py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
    <div class="container mx-auto max-w-5xl">
      <div class="rounded-2xl border border-black/[0.07] bg-white px-6 py-7 md:px-10 md:py-9" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
        <div class="flex flex-col items-start justify-between gap-2 border-b border-black/[0.07] pb-5 md:flex-row md:items-end">
          <div>
            <p class="font-sora text-xs font-bold uppercase tracking-widest text-clay">Inside this page</p>
            <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark">On This Page</h2>
          </div>
          <p class="font-sora text-sm text-stone-600">22 sections · everything about Elad</p>
        </div>
        <div class="mt-6 grid grid-cols-1 gap-x-10 gap-y-1 md:grid-cols-2">
          {eladTocItems.map((item) => (
            <a href={item.href}
               class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/5 font-sora">
              <span class="text-xs font-semibold text-clay-ink">{String(item.n).padStart(2, "0")}</span>
              <span class="text-sm leading-snug text-stone-700">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  {/* ══════════════════════════════════════════════
      SECTION 2: TEMPERAMENT — What is Elad like to live with?
      Framework: EBP · Cat: A · ~180w
      Source: BUILD-1 section 5 (lines 128-138) — reused + image added
      ══════════════════════════════════════════════ */}
  <section id="temperament" class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-logo-dark mb-4">What is Elad like to live with as a Timneh?</h2>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Elad is a busy, confident male Timneh African Grey who is happiest with a job to do and a household around him. If your home hums with activity, he is built for it. We have watched him grow from a clumsy chick into a young bird who treats an empty afternoon as a problem to solve, and he rewards an engaged family with a big, expressive personality.</p>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Here at C.A.Gs we hand-raised Elad ourselves, in our Midland, Texas home, so what we tell you about him comes from feeding him every day rather than from a sales sheet. One thing we noticed early: he works a foraging toy methodically, twisting and testing a knot until it gives, then looking up to check whether anyone caught the win. That drive is the whole personality. Give him stimulation and company and he gives it straight back.</p>

      {/* Personality infographic — placed mid-text to break up the section */}
      <figure class="my-7">
        <img
          src="/birds/elad/elad-personality-profile.webp"
          alt="Elad' personality profile — a hand-raised male Timneh African Grey rated for energy, talking potential, beginner-friendliness, social needs, and noise"
