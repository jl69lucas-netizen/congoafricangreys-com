---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustBar from '../../../components/TrustBar.astro';
import CTA from '../../../components/CTA.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const title = "Elad — Male Timneh African Grey For Sale | $1,600 | C.A.Gs – Midland, TX";
const description = "Meet Elad, our hand-raised male Timneh African Grey — 5 months old, fully social-trained and ready to go, $1,600. DNA sexed, CITES-documented, captive-bred. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/elad/";

const productSchema = {
  "name": "Elad — Male Timneh African Grey",
  "description": "Elad is a hand-raised male Timneh African Grey (Psittacus erithacus timneh), 5 months old, with full social training and a confident, ready-to-go temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/elad-timneh-african-grey-male-5-months.webp",
  "category": "Timneh African Grey Parrot",
  "sku": "cag-elad",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-18",
  "offers": {
    "@type": "Offer",
    "price": "1600",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/elad/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Elad DNA sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Elad goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork." }
    },
    {
      "@type": "Question",
      "name": "How old is Elad and what is his temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Elad is a 5-month-old Timneh. We hand-raised him ourselves with full social training, and he is confident, steady, and ready to go — comfortable being handled and settled enough that the bird you reserve is the bird who arrives." }
    },
    {
      "@type": "Question",
      "name": "How is a Timneh different from a Congo African Grey?",
      "acceptedAnswer": { "@type": "Answer", "text": "Timnehs like Elad are a little smaller, with a darker charcoal-grey body and a maroon tail rather than the Congo's bright red. Temperamentally many owners find them a touch steadier. Our Congo vs Timneh comparison covers the full picture." }
    },
    {
      "@type": "Question",
      "name": "Can Elad be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Elad ships nationwide. Airport Pickup is $185 (you collect him at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350." }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Elad — Male Timneh African Grey", url: "/available/elad/" }
      ]} />
  </div>

  {/* 1 — HERO / BIRD VITALS + inquiry CTA */}
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <div>
        <img
          src="/elad-timneh-african-grey-male-5-months.webp"
          alt="Elad, a hand-raised male Timneh African Grey parrot, five months old, perched and looking toward the camera"
          width="640" height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
        />
      </div>
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Psittacus erithacus timneh &middot; CITES Appendix I Captive-Bred</p>
        <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-5">Elad — Male Timneh African Grey For Sale</h1>
        <p class="text-cream/80 text-lg mb-6 leading-relaxed">Here at C.A.Gs, our Elad is a confident young Timneh boy we hand-raised with full social training from the start. At 5 months old he is steady on the hand, comfortable with people, and ready to go to the home that has been waiting for a Timneh.</p>
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-7">
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Sex</span>Male (DNA sexed)</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Age</span>5 months</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Variant</span>Timneh African Grey</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Price</span>$1,600</li>
        </ul>
        <p class="text-cream/70 text-sm mb-6">Ships nationwide &middot; $185 airport &middot; $350 home</p>
        <a href="/contact-us/?bird=Elad" class="inline-block bg-clay text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors">Inquire About Elad</a>
      </div>
    </div>
  </section>
  <TrustBar />

  {/* 2 — ABOUT ELAD (Timneh, confident ready-to-go) */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What is Elad like to live with?</h2>
      <p class="text-stone-600 leading-relaxed mb-4">Elad is the kind of young grey who makes the transition home easy. We have raised him with full social training, and at 5 months he is already confident with people — he steps up without hesitation, settles quickly into a routine, and is unbothered by the ordinary commotion of a household. His personality has come into focus, so the bird you reserve is the bird who arrives, and that settled steadiness is exactly what we aim for when we hand-raise a Timneh ourselves.</p>
      <p class="text-stone-600 leading-relaxed mb-4">As a <a href="/timneh-african-grey-for-sale/" class="text-clay-text underline">Timneh</a>, Elad is a little smaller than a Congo, with a darker charcoal body and a maroon tail rather than the Congo's bright red — and many owners find the Timneh temperament a touch steadier. He suits an owner or family who wants a self-assured, people-ready grey and likes the Timneh's calmer reputation. If you are deciding between the two, our <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh comparison</a> walks through the differences.</p>
      <p class="text-stone-600 leading-relaxed">Greys are remarkable talkers and problem-solvers with 40–60 year lifespans — we cover the full species background in our <a href="/african-grey-parrot-guide/" class="text-clay-text underline">African Grey parrot guide</a> so this page can stay about Elad himself.</p>
    </div>
  </section>

  {/* 3 — HEALTH & DOCUMENTATION (ledger only) */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What documentation comes with Elad?</h2>
      <p class="text-stone-600 leading-relaxed mb-6">We never ask a buyer to take our word for it. Elad is captive-bred here in the USA and goes home with a complete paperwork set, the same standard we hold every C.A.Gs grey to:</p>
      <ul class="space-y-3 text-stone-600">
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>DNA sex certificate</strong> — lab-confirmed that Elad is male, so there is no guesswork.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Avian-vet health certificate</strong> — issued before he travels.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Hatch certificate + closed leg band</strong> — his traceable identity as a captive-bred bird.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>CITES captive-bred documentation</strong> — African Greys are CITES Appendix I; captive-bred birds are legal to own and transfer domestically with the right paperwork, and Elad has it. See our <a href="/cites-african-grey-documentation/" class="text-clay-text underline">CITES documentation page</a> for what that means.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Weaned</strong> — Elad is eating independently and ready to go to his new home.</span></li>
      </ul>
      <p class="text-stone-600 leading-relaxed mt-6">We are a USDA AWA licensed family aviary, and Elad is also covered by our <a href="/african-grey-parrot-health-guarantee/" class="text-clay-text underline">African Grey health guarantee</a>. Want proof a grey is DNA-tested before you commit? That is the whole point of our <a href="/dna-tested-african-grey-for-sale/" class="text-clay-text underline">DNA-tested greys</a>.</p>
    </div>
  </section>

  {/* 4 — WHY ELAD */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Why Elad might be the right grey for you</h2>
      <p class="text-stone-600 leading-relaxed mb-4">A ready-to-go, fully socialized Timneh like Elad has real advantages. He is past the hand-feeding stage, his temperament is already clear, and his Timneh nature gives you a slightly smaller, often steadier grey at a friendlier price point than a Congo. For a first serious parrot owner who wants a confident bird, or for someone who specifically prefers the Timneh, Elad is a forgiving and rewarding match — with decades of companionship still ahead.</p>
      <p class="text-stone-600 leading-relaxed">Because we hand-raised him ourselves, we can tell you honestly how he responds to handling, to new people, and to a quiet evening at home — and we would rather he go to the home that genuinely fits him than the first one to ask. That is the conversation we want to have with you.</p>
    </div>
  </section>

  {/* 5 — PRICING & WHAT'S INCLUDED */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">How much is Elad, and what's included?</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Price & reservation</h3>
          <ul class="space-y-3 text-stone-600 text-sm">
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Elad (male Timneh, 5 months)</span><strong class="text-logo-dark">$1,600</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Deposit to reserve</span><strong class="text-logo-dark">$200</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Airport Pickup (IATA, LAR)</span><strong class="text-logo-dark">$185</strong></li>
            <li class="flex justify-between"><span>Home Delivery (door-to-door)</span><strong class="text-logo-dark">$350</strong></li>
          </ul>
          <p class="text-stone-500 text-xs mt-3">Ships nationwide &middot; $185 airport &middot; $350 home &middot; Delta / United / American</p>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Included in his price</h3>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> DNA sex certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Avian-vet health certificate</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Hatch certificate + leg band</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> CITES captive-bred documentation</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Health guarantee + go-home support</li>
          </ul>
        </div>
      </div>
      <p class="text-stone-600 leading-relaxed mt-6">A $200 deposit reserves Elad and pauses his listing for you; the balance is due before he travels. For how his price sits against the wider range, see our <a href="/african-grey-parrot-price/" class="text-clay-text underline">African Grey price guide</a>.</p>
    </div>
  </section>

  {/* 6 — PARENT BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Who are Elad's parents?</h2>
      <p class="text-stone-600 leading-relaxed">Elad was hatched and hand-raised inside our family aviary in Midland, Texas, which we have run since 2014. We are happy to share his specific parentage and pairing details on request during the reservation conversation, along with anything else you would like to verify before you commit. We would rather walk you through it directly than post it on a page.</p>
    </div>
  </section>

  {/* 7 — FAQ */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Elad — frequently asked questions</h2>
      <div class="space-y-4">
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Is Elad DNA sexed and documented?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes. Elad goes home with his DNA sex certificate confirming he is male, his avian-vet health certificate, his hatch certificate with leg-band number, and his CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How old is Elad and what is his temperament?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Elad is a 5-month-old Timneh. We hand-raised him ourselves with full social training, and he is confident, steady, and ready to go — comfortable being handled and settled enough that the bird you reserve is the bird who arrives.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How is a Timneh different from a Congo African Grey?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Timnehs like Elad are a little smaller, with a darker charcoal-grey body and a maroon tail rather than the Congo's bright red. Temperamentally many owners find them a touch steadier. Our <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh comparison</a> covers the full picture.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Can Elad be shipped to me?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes — Elad ships nationwide. Airport Pickup is $185 (you collect him at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350.</p>
        </details>
      </div>
    </div>
  </section>

  {/* 8 — OTHER AVAILABLE BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Other African Greys we have available</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/available/bery/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Bery</h3><p class="text-stone-500 text-sm">Female Congo &middot; 1 year</p><p class="text-clay-text font-semibold text-sm mt-1">$1,700</p></a>
        <a href="/available/amie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Amie</h3><p class="text-stone-500 text-sm">Female Congo &middot; 3 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,500</p></a>
        <a href="/available/roys/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Roys</h3><p class="text-stone-500 text-sm">Male Congo &middot; 4 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,300</p></a>
        <a href="/available/jins-jeni/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Jins &amp; Jeni</h3><p class="text-stone-500 text-sm">Congo pair &middot; must go together</p><p class="text-clay-text font-semibold text-sm mt-1">$3,500</p></a>
        <a href="/available/evie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Evie</h3><p class="text-stone-500 text-sm">Female Timneh &middot; 6 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,500</p></a>
        <a href="/african-grey-parrots-for-sale/" class="block bg-logo-dark text-cream rounded-2xl p-5 hover:opacity-90 transition-opacity"><h3 class="font-lora font-semibold">See every available grey</h3><p class="text-cream/70 text-sm mt-1">Browse the full nursery &rarr;</p></a>
      </div>
    </div>
  </section>

  <Schema type="product" data={productSchema} />
  <Schema type="faq" data={faqSchema} />
  <Schema type="organization" />

  {/* 9 — INQUIRY CTA */}
  <CTA headline="Ready to bring Elad home?" sub="Elad is a hand-raised, CITES-documented, DNA-sexed male Timneh grey at $1,600. A $200 deposit reserves him — reach out and we reply within 24 hours." />
</BaseLayout>
