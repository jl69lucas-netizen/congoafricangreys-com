---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CounterSnippet from '../../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../../components/cag-library/KeyTakeawayV2.astro';
import NewsletterV2 from '../../../components/cag-library/NewsletterV2.astro';
import JumpNav from '../../../components/cag-jump-nav.astro';

const title = "Female Timneh African Grey for Sale | Want a Hand-Raised, DNA-Sexed Girl? Meet Evie — 1 Healthy 6-Month Timneh, $1,500 (was $2,200) | C.A.Gs – Midland, TX";
const description = "Evie is a hand-raised female Timneh African Grey for sale — 6 months old, an early-talking, even-tempered young Timneh, now $1,500 (reduced from a $2,200 starting price). DNA sexed, CITES Appendix I documented, captive-bred in the USA. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/evie/";

const productSchema = {
  "name": "Evie — Female Timneh African Grey For Sale",
  "description": "Evie is a hand-raised female Timneh African Grey (Psittacus erithacus timneh), 6 months old, with an early-talking, even-tempered, family-friendly temperament. Captive-bred in the USA, DNA sexed, CITES Appendix I documented, USDA AWA licensed aviary. Now $1,500, reduced from a $2,200 starting price. Offered by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/birds/evie/evie-timneh-african-grey-female-hero.webp",
  "category": "Timneh African Grey Parrot",
  "sku": "cag-evie",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-19",
  "offers": {
    "@type": "Offer",
    "price": "1500",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/evie/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Evie DNA-sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Evie goes home with her DNA sex certificate confirming she is female, her avian-vet health certificate, her hatch certificate with closed leg-band number, and her CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with the full paperwork set." }
    },
    {
      "@type": "Question",
      "name": "How old is Evie and what is her temperament?",
      "acceptedAnswer": { "@type": "Answer", "text": "Evie is 6 months old. We hand-raised her ourselves, and she has grown into an energetic, playful young grey who thrives on activity and does beautifully with a lively household. She is a confident bird who loves toys, foraging, and an engaged family around her." }
    },
    {
      "@type": "Question",
      "name": "How much is Evie and how do I reserve her?",
      "acceptedAnswer": { "@type": "Answer", "text": "Evie is $1,500. A $200 deposit reserves her and pauses her listing for you. The balance is due before she travels. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Evie be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — Evie ships nationwide. Airport Pickup is $185, where you collect her at your nearest major airport via IATA-compliant live-animal cargo (IATA code LAR) on Delta, United, or American. Home Delivery is door-to-door for $350. An Avian Flight Nanny who carries her in-cabin is available too, quoted per route from about $750." }
    },
    {
      "@type": "Question",
      "name": "Do female Timneh African Greys learn to talk well?",
      "acceptedAnswer": { "@type": "Answer", "text": "Timneh African Greys of either sex are among the most capable talking parrots, and Timnehs are reputed to start talking earlier than Congos — sometimes around 6–12 months. Sex is not a reliable predictor of how much an individual will say. Evie is developing at 6 months; what shapes her eventual vocabulary most is daily interaction in the home, not whether she is female." }
    },
    {
      "@type": "Question",
      "name": "Why is Evie priced at $1,500 when listings show $600 Timnehs?",
      "acceptedAnswer": { "@type": "Answer", "text": "A $600 'Timneh' is the price of a bird with no verifiable paperwork — no DNA certificate, no CITES documentation, no avian-vet health check, and often no breeder you can actually hold accountable. Evie is $1,500 — reduced from a $2,200 Timneh starting price — because that figure covers hand-rearing, her full documentation set, and a USDA AWA licensed aviary standing behind her. A documented hand-raised Timneh honestly cannot be produced for $600." }
    }
  ]
};

const evieTocItems = [
  { n: 1,  label: "Is Evie the right African Grey for me?",               href: "#takeaway" },
  { n: 2,  label: "What is Evie like as a companion Timneh?",                      href: "#temperament" },
  { n: 3,  label: "Can a female Timneh African Grey learn to talk?",             href: "#talking" },
  { n: 4,  label: "Why does Evie cost $1,500 when some Timnehs list far cheaper?", href: "#price-counter" },
  { n: 5,  label: "What paperwork comes with Evie?",                  href: "#documentation" },
  { n: 6,  label: "What do you receive when you reserve Evie?",               href: "#included" },
  { n: 7,  label: "How does Evie compare with our other available greys?",  href: "#comparison" },
  { n: 8,  label: "Is Evie a healthy hen? Our health standard",          href: "#health" },
  { n: 9,  label: "Who are Evie's parents?",                              href: "#parents" },
  { n: 10, label: "What should you think through before buying a female Timneh?",href: "#decisions" },
  { n: 11, label: "What does living with a Timneh hen look like long-term?",     href: "#lifestyle" },
  { n: 12, label: "Reviews — families who chose a C.A.Gs grey",   href: "#reviews-mid" },
  { n: 13, label: "How do you tame and bond with a young hen like Evie?",          href: "#training" },
  { n: 14, label: "What do C.A.Gs feed a female Timneh like Evie?",      href: "#food" },
  { n: 15, label: "Evie's photo & video gallery",                         href: "#gallery" },
  { n: 16, label: "How do you reserve and buy Evie, step by step?",                   href: "#buy" },
  { n: 17, label: "Which states do C.A.Gs deliver a Timneh to?",              href: "#shipping" },
  { n: 18, label: "Evie — frequently asked questions",                    href: "#faq" },
  { n: 19, label: "Timneh care guides for Evie's family",      href: "#resources" },
  { n: 20, label: "Why reserve Evie with C.A.Gs rather than a marketplace?",       href: "#marketplace" },
  { n: 21, label: "Ready to welcome Evie home?",                           href: "#reserve" },
];

const evieCounterStats = [
  { num: "6 mo",    label: "Current Age" },
  { num: "$1,500",  label: "Asking Price" },
  { num: "100%",    label: "CITES Documented" },
  { num: "24h",     label: "Reply Guarantee" },
];

const evieKeyTakeawayItems = [
  { stat: "Female",     label: "DNA-Sexed",        body: "Lab-confirmed female — no guesswork. Her DNA sex certificate travels home with her." },
  { stat: "6 months",   label: "Age",              body: "Young enough to shape her routine, old enough to show a real personality. She is curious, gentle, and people-oriented." },
  { stat: "$1,500",     label: "Price",            body: "Now $1,500 — reduced from a $2,200 Timneh starting price. Covers a hand-raised, fully documented Timneh; a $200 deposit reserves her." },
  { stat: "Timneh",     label: "Variant",          body: "Psittacus erithacus timneh — the smaller, darker grey with a maroon tail and horn-coloured beak, bred in our Midland, TX family aviary since 2014." },
  { stat: "CITES I",    label: "Captive-Bred USA", body: "Full Appendix I captive-bred documentation — the paperwork that proves Evie is legal to own and transfer." },
  { stat: "Full set",   label: "Papers Included",  body: "DNA cert · AAV health cert · hatch cert + band · CITES docs · weaning guidance. No chasing paperwork after." },
  { stat: "Nationwide", label: "Ships",            body: "Airport Pickup $185 or Home Delivery $350. IATA LAR-coded via Delta, United, and American." },
  { stat: "Gentle",     label: "Temperament",      body: "Calm, affectionate and observant. A people-loving hen who bonds closely and thrives on steady company." },
];

/* Mobile section-jump dial + desktop dot rail (page is >6,000 words) */
const evieJumpSections = [
  { id: "takeaway",     label: "Overview",    part: 1 },
  { id: "temperament",  label: "Personality", part: 1 },
  { id: "talking",      label: "Talking",     part: 1 },
  { id: "parents",      label: "Parents",     part: 1 },
  { id: "documentation",label: "Documents",   part: 2 },
  { id: "health",       label: "Health",      part: 2 },
  { id: "price-counter",label: "Why $1,500",  part: 2 },
  { id: "gallery",      label: "Gallery",     part: 3 },
  { id: "comparison",   label: "Compare",     part: 3 },
  { id: "reviews-mid",  label: "Reviews",     part: 3 },
  { id: "food",         label: "Diet",        part: 3 },
  { id: "included",     label: "Included",    part: 4 },
  { id: "buy",          label: "How to Buy",  part: 4 },
  { id: "shipping",     label: "Shipping",    part: 4 },
  { id: "faq",          label: "FAQ",         part: 4 },
  { id: "resources",    label: "Care Guides", part: 4 },
  { id: "reserve",      label: "Reserve",     part: 4 },
];
const evieJumpParts = {
  1: "Meet Evie",
  2: "Proof & Papers",
  3: "See & Compare",
  4: "Buying Evie",
};

const jumpLinks = [
  { label: "Temperament", href: "#temperament" },
  { label: "Talking", href: "#talking" },
  { label: "Price", href: "#price-counter" },
  { label: "What's included", href: "#documentation" },
  { label: "Health", href: "#health" },
  { label: "Gallery", href: "#gallery" },
  { label: "Shipping", href: "#shipping" },
  { label: "FAQ", href: "#faq" },
  { label: "Reserve", href: "#reserve" },
];
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <style>
    /* ── Evie page: homepage-parity rhythm (Direction D) ── */
    /* Compact section padding so the page reads tight, not endless */
    .evie-d .py-16 { padding-top: 2.4rem !important; padding-bottom: 2.4rem !important; }
    @media (min-width: 768px) {
      .evie-d .py-16 { padding-top: 3rem !important; padding-bottom: 3rem !important; }
    }
    .evie-d .py-12 { padding-top: 2rem !important; padding-bottom: 2rem !important; }

    /* Section-seam divider with the small footer logo (homepage pattern) */
    .evie-d .cag-seam { display: flex; align-items: center; gap: 26px; max-width: 1100px; margin: 0 auto; padding: 0.5rem 24px; }
    .evie-d .cag-seam__line { flex: 1; height: 1px; background: rgba(45,106,79,.16); }
    .evie-d .cag-seam img { height: 30px; width: auto; display: block; opacity: .92; flex-shrink: 0; }
    @media (max-width: 600px) { .evie-d .cag-seam { gap: 16px; } .evie-d .cag-seam img { height: 24px; } }

    /* Mobile sticky jump bar */
    .jump-mobile { position: sticky; top: 94px; z-index: 40; background: #faf7f4; }
    @media (min-width: 768px) { .jump-mobile { display: none; } }

    /* Hero H1 — match homepage clamp (was text-4xl/5xl = oversized) */
    .evie-d .evie-hero h1 { font-size: clamp(1.7rem, 1.1rem + 2.6vw, 2.35rem) !important; line-height: 1.14 !important; }

    /* Standard media height so portrait crops aren't cut at the edges */
    .evie-d .evie-feature-img { max-height: 420px !important; object-position: center top; }
    /* Constrained 16/9 video frame for non-hero clips */
    .evie-d .evie-video-frame { position: relative; max-width: 640px; margin-left: auto; margin-right: auto; aspect-ratio: 16/9; }
    .evie-d .evie-video-frame video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  </style>

  <div class="evie-d">

  {/* ── BREADCRUMB ── */}
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys For Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Evie — Female Timneh African Grey", url: "/available/evie/" }
    ]} />
  </div>


  {/* ── HERO C: Trust-first + click-to-play video ── */}
  <section class="evie-hero bg-logo-dark text-cream py-14 px-4 md:py-20">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">

      {/* LEFT: Vitals + CTA */}
      <div class="order-2 md:order-1">
        <p class="font-sora text-[#f08070] text-xs font-medium tracking-wide mb-3">
          <em>Psittacus erithacus timneh</em> &middot; CITES Appendix&nbsp;I Captive-Bred &middot; Midland, TX
        </p>
        <h1 class="font-lora font-bold text-2xl sm:text-3xl leading-tight mb-5">
          Evie — Female Timneh African Grey For Sale ($1,500, was $2,200 &middot; Hand-Raised &amp; DNA-Sexed)
        </h1>

        {/* Snapshot vitals */}
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-6">
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Sex</span>
            Female (DNA-sexed)
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Age</span>
            6 months
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Variant</span>
            Timneh African Grey
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Price</span>
            $1,500
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Talking</span>
            Developing
          </li>
          <li class="border-l-2 border-gold pl-3">
            <span class="block text-cream/60 text-xs uppercase tracking-wide font-sora">Status</span>
            Available
          </li>
        </ul>

        {/* Trust badges row */}
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>CITES Appendix&nbsp;I
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><path d="M9 3h6"/><path d="M10 3v6l-4.6 9.2A1.5 1.5 0 0 0 6.7 21h10.6a1.5 1.5 0 0 0 1.3-2.8L14 9V3"/></svg>DNA Sexed
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Avian Vet Cert
          </span>
          <span class="font-sora text-xs bg-white/10 text-cream/90 rounded-full px-3 py-1">
            <svg viewBox="0 0 24 24" width="0.85em" height="0.85em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.1em;margin-right:4px" aria-hidden="true"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 21 8 3 8"/></svg>USDA AWA Licensed
          </span>
        </div>

        <p class="font-sora text-cream/70 text-sm mb-7">Ships nationwide &middot; $185 airport &middot; $350 home</p>

        <a href="/contact-us/?bird=Evie"
           class="inline-block bg-clay text-white font-sora font-semibold px-8 py-4 rounded-full text-base hover:bg-clay-dk transition-colors"
           style="box-shadow:0 6px 20px rgba(232,96,76,0.35);">
          Ask About Evie
        </a>
      </div>

      {/* RIGHT: hero portrait (Evie has no video clip) */}
      <div class="order-1 md:order-2">
        <img
          src="/birds/evie/evie-timneh-african-grey-female-hero.webp"
          alt="Evie, a hand-raised female Timneh African Grey for sale at C.A.Gs in Midland, TX — compact charcoal-grey plumage and a horn-colored upper beak"
          width="640" height="480"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
          style="max-height:440px;object-fit:cover;object-position:center 30%;"
        />
        <p class="font-sora text-cream/50 text-xs text-center mt-2">Evie — our hand-raised female Timneh African Grey, 6 months, in our Midland, TX home.</p>
      </div>
    </div>
  </section>

  {/* ── COUNTER SNIPPET — moved directly under the hero (above "At a glance") ── */}
  <CounterSnippet stats={evieCounterStats} />

  {/* ── AEO SNAPSHOT — modern info card (green header band + spec tiles) ── */}
  <section class="py-12 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="overflow-hidden rounded-2xl border border-black/[0.07] bg-white" style="box-shadow:0 10px 40px rgba(60,30,10,0.08);">
        <div class="bg-logo-dark px-6 py-5 sm:px-8">
          <p class="font-sora text-[11px] font-semibold uppercase tracking-[0.18em] text-[#f08070] mb-1.5">At a glance</p>
          <h2 class="font-lora font-bold text-xl sm:text-2xl text-cream leading-snug">Evie at a glance — Female Timneh African Grey for Sale Snapshot</h2>
        </div>
        <div class="p-6 sm:p-8">
          <p class="font-sora text-stone-700 leading-relaxed mb-6">Evie is a hand-raised female Timneh African Grey (<em>Psittacus erithacus timneh</em>), 6 months old, now $1,500 — reduced from a $2,200 Timneh starting price. She is DNA-sexed, CITES Appendix I documented, captive-bred in the USA at our USDA AWA licensed aviary, and ships nationwide ($185 airport / $350 home).</p>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              ["Variant", "Timneh African Grey"],
              ["Sex", "Female (DNA-sexed)"],
              ["Age", "6 months"],
              ["Price", "$1,500 · was $2,200 · $200 deposit"],
              ["Talking", "Early talker / developing"],
              ["Documentation", "DNA · CITES · health cert"],
            ].map(([k, v]) => (
              <div class="rounded-xl border border-stone-200 bg-cream/60 px-4 py-3">
                <dt class="font-sora text-[11px] uppercase tracking-wide text-stone-600">{k}</dt>
                <dd class="font-sora text-sm font-semibold text-logo-dark mt-1 leading-snug">{v}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════════════════════════════════════
      SECTION 1: KEY TAKEAWAY — Is Evie right for me?
      Placed ABOVE the TOC (after the counter snippet) so the "short version"
      lands before the long table of contents.
      ══════════════════════════════════════════════ */}
  <section id="takeaway">
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="Is Evie the right African Grey for me?"
      badge="8 facts · 90-sec read"
      items={evieKeyTakeawayItems}
    />
  </section>

  {/* ── MOBILE JUMP BAR (sticky, mobile only) ── */}
  <div class="jump-mobile px-4 py-2">
    <JumpNav links={jumpLinks} sticky={false} />
  </div>

  {/* ── TABLE OF CONTENTS ── */}
  <nav class="hidden md:block py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
    <div class="container mx-auto max-w-5xl">
      <div class="rounded-2xl border border-black/[0.07] bg-white px-6 py-7 md:px-10 md:py-9" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
        <div class="flex flex-col items-start justify-between gap-2 border-b border-black/[0.07] pb-5 md:flex-row md:items-end">
          <div>
            <p class="font-sora text-xs font-bold uppercase tracking-widest text-clay">Inside this page</p>
            <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark">On This Page</h2>
          </div>
          <p class="font-sora text-sm text-stone-600">22 sections · everything about Evie</p>
        </div>
        <div class="mt-6 grid grid-cols-1 gap-x-10 gap-y-1 md:grid-cols-2">
          {evieTocItems.map((item) => (
            <a href={item.href}
               class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/5 font-sora">
              <span class="text-xs font-semibold text-clay-ink">{String(item.n).padStart(2, "0")}</span>
              <span class="text-sm leading-snug text-stone-700">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </nav>

  {/* ══════════════════════════════════════════════
      SECTION 2: TEMPERAMENT — What is Evie like to live with?
      Framework: EBP · Cat: A · ~180w
      Source: BUILD-1 section 5 (lines 128-138) — reused + image added
      ══════════════════════════════════════════════ */}
  <section id="temperament" class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-logo-dark mb-4">What is Evie like as a companion Timneh?</h2>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Evie is a gentle, affectionate female Timneh African Grey who is happiest in a calm home with people who include her in the day. She does not demand the spotlight — as we like to say, she does not ask for attention so much as earn attachment. We have watched her grow from a clumsy chick into an observant young hen who reads a room, leans into a head scratch, and rewards a patient family with a deep, trusting bond.</p>
      <p class="font-sora text-stone-600 leading-relaxed mb-4">Here at C.A.Gs we hand-raised Evie ourselves, in our Midland, Texas home, so what we tell you about her comes from feeding her every day rather than from a sales sheet. One thing we noticed early: she watches before she acts, then settles onto a shoulder and stays. That quiet steadiness is the whole personality. Give her gentle company and a predictable routine and she gives back a calm, devoted attachment.</p>

      {/* Personality infographic — placed mid-text to break up the section */}
      <figure class="my-7">
        <img
          src="/birds/evie/evie-personality-fit-card.webp"
          alt="Is Evie right for you — a gentle, affectionate female Timneh African Grey suited to calm, loving homes"
          width="760" height="430"
          class="w-full rounded-2xl border border-stone-200"
          loading="lazy"
          style="box-shadow:0 4px 20px rgba(60,30,10,0.07);"
        />
        <figcaption class="font-sora text-xs text-stone-600 mt-2 text-center">Evie at 6 months — alert, confident, always watching</figcaption>
      </figure>

      <p class="font-sora text-stone-600 leading-relaxed mb-4">At 6 months she is curious about everything and still forming her sense of the world. Timneh greys are famously bright — the species, <em>Psittacus erithacus timneh</em>, sits among the most studied talking parrots in the world, and <a href="https://parrots.org/encyclopedia/grey-parrot/" target="_blank" rel="noopener noreferrer" class="text-clay-text underline">the World Parrot Trust's grey parrot profile ↗</a> covers their cognition in depth. She suits a calm owner or household ready to give a sensitive, people-oriented hen steady attention and gentle company.</p>
      <h3 class="font-lora font-semibold text-xl text-logo-dark mb-2 mt-5">How quickly does Evie settle in?</h3>
      <p class="font-sora text-stone-600 leading-relaxed mb-3">Her first 30 days at home tend to follow a pattern we have seen across our greys. Week one she watches more than she plays, learning the rhythm of your house. By week two she starts claiming a favourite perch and testing which sounds get a reaction. By the end of the month, in a home that shows up for her daily, she is asking to come out and beginning the soft babble that comes before real words.</p>
      <h4 class="font-lora font-semibold text-lg text-logo-dark mb-2 mt-4">Will Evie do well around young children?</h4>
      <p class="font-sora text-stone-600 leading-relaxed">She does well with older children who understand that a bird is not a toy. She reads energy quickly — a calm, curious kid who offers a finger consistently is exactly the kind of relationship she builds on. Chaotic or grabbing handling is another matter. We are honest about that.</p>
    </div>
  </section>

