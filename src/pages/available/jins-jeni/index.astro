---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrustBar from '../../../components/TrustBar.astro';
import CTA from '../../../components/CTA.astro';
import Schema from '../../../components/Schema.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const title = "Jins & Jeni — Congo African Grey Pair For Sale | $3,500 | C.A.Gs – Midland, TX";
const description = "Meet Jins & Jeni, our hand-raised Congo African Grey pair — sold together, $3,500. Both DNA sexed, CITES-documented, captive-bred, fully social-trained. Ships nationwide · $185 airport · $350 home.";
const canonical = "https://congoafricangreys.com/available/jins-jeni/";

const productSchema = {
  "name": "Jins & Jeni — Congo African Grey Pair",
  "description": "Jins & Jeni are a hand-raised, unrelated Congo African Grey (Psittacus erithacus) pair sold together — Jins is a 6-month-old male and Jeni is a 4-month-old female, both with full social training. Captive-bred in the USA, DNA sexed, CITES Appendix I documented. Offered as a pair by C.A.Gs – Midland, TX.",
  "image": "https://congoafricangreys.com/jins-jeni-congo-african-grey-pair.webp",
  "category": "Congo African Grey Parrot",
  "sku": "cag-jins-jeni",
  "datePublished": "2026-06-01",
  "dateModified": "2026-06-18",
  "offers": {
    "@type": "Offer",
    "price": "3500",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "url": "https://congoafricangreys.com/available/jins-jeni/",
    "seller": { "@type": "Organization", "name": "C.A.Gs – Midland, TX" }
  }
};

const faqSchema = {
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can Jins and Jeni be bought separately?",
      "acceptedAnswer": { "@type": "Answer", "text": "No — Jins and Jeni must go together. They are an unrelated, hand-raised Congo pair we are placing as one. The $3,500 price covers both birds and they travel to the same home." }
    },
    {
      "@type": "Question",
      "name": "Are Jins and Jeni DNA sexed and documented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Both go home with their DNA sex certificates — Jins confirmed male, Jeni confirmed female — plus their avian-vet health certificates, hatch certificates with leg-band numbers, and CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork." }
    },
    {
      "@type": "Question",
      "name": "How much is the Jins & Jeni pair and how do I reserve them?",
      "acceptedAnswer": { "@type": "Answer", "text": "The pair is $3,500 together. A $200 deposit reserves them and pauses the listing for you. The balance is due before they travel. Reach out through our contact form and we reply within 24 hours." }
    },
    {
      "@type": "Question",
      "name": "Can Jins and Jeni be shipped to me?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — the pair ships nationwide to the same home. Airport Pickup is $185 (you collect them at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350." }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "Jins & Jeni — Congo African Grey Pair", url: "/available/jins-jeni/" }
      ]} />
  </div>

  {/* 1 — HERO / BIRD VITALS + inquiry CTA */}
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <div>
        <img
          src="/jins-jeni-congo-african-grey-pair.webp"
          alt="Jins and Jeni, a hand-raised pair of Congo African Grey parrots, perched together and sold as a bonded pair"
          width="640" height="640"
          class="w-full rounded-3xl shadow-lg object-cover"
          loading="eager" fetchpriority="high"
        />
      </div>
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Psittacus erithacus &middot; CITES Appendix I Captive-Bred</p>
        <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-5">Jins &amp; Jeni — Congo African Grey Pair For Sale</h1>
        <p class="text-cream/80 text-lg mb-6 leading-relaxed">Here at C.A.Gs, Jins and Jeni are an unrelated Congo pair we hand-raised together with full social training — and they must go together. Jins is a steady 6-month-old male, Jeni a bright 4-month-old female, and they are looking for one home that wants two greys at once.</p>
        <ul class="grid grid-cols-2 gap-3 text-sm text-cream/90 mb-7">
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Jins</span>Male &middot; 6 months (DNA sexed)</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Jeni</span>Female &middot; 4 months (DNA sexed)</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Variant</span>Congo African Grey pair</li>
          <li class="border-l-2 border-gold pl-3"><span class="block text-cream/60 text-xs uppercase tracking-wide">Price</span>$3,500 (pair)</li>
        </ul>
        <p class="text-cream/70 text-sm mb-6">Ships nationwide &middot; $185 airport &middot; $350 home</p>
        <a href="/contact-us/?bird=Jins+%26+Jeni" class="inline-block bg-clay text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-clay-dk transition-colors">Inquire About Jins &amp; Jeni</a>
      </div>
    </div>
  </section>
  <TrustBar />

  {/* 2 — ABOUT JINS & JENI (pair / unrelated bonded) */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What are Jins and Jeni like to live with?</h2>
      <p class="text-stone-600 leading-relaxed mb-4">Jins and Jeni are an unrelated pair we hand-raised side by side, and we are placing them as one for a reason — they keep each other company in a way two greys raised together naturally do. Jins, the older of the two at 6 months, is the steadier presence: confident, even-tempered, the one who settles first. Jeni, at 4 months, brings the spark — curious, quick, and always exploring. Together they balance each other, and a home that takes both gets the full picture rather than half of it.</p>
      <p class="text-stone-600 leading-relaxed mb-4">Because they are unrelated, this pair is also a genuine option for an owner thinking about the long term. If you are interested in a male-and-female grey duo, our <a href="/african-grey-breeding-pair-for-sale/" class="text-clay-text underline">breeding pair page</a> covers what that involves. Either way, both birds carry full social training, so they are comfortable with people, not just with each other. They suit a committed owner or family ready for the company — and the joy — of two greys. If you are weighing whether a Congo or a Timneh fits your home, our <a href="/congo-vs-timneh-african-grey/" class="text-clay-text underline">Congo vs Timneh comparison</a> walks through the differences.</p>
      <p class="text-stone-600 leading-relaxed">Greys are remarkable talkers and problem-solvers with 40–60 year lifespans — we cover the full species background in our <a href="/african-grey-parrot-guide/" class="text-clay-text underline">African Grey parrot guide</a> so this page can stay about Jins and Jeni themselves.</p>
    </div>
  </section>

  {/* 3 — HEALTH & DOCUMENTATION (ledger only) */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What documentation comes with Jins and Jeni?</h2>
      <p class="text-stone-600 leading-relaxed mb-6">We never ask a buyer to take our word for it. Both birds are captive-bred here in the USA and go home with a complete paperwork set each, the same standard we hold every C.A.Gs grey to:</p>
      <ul class="space-y-3 text-stone-600">
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>DNA sex certificates</strong> — lab-confirmed that Jins is male and Jeni is female, so there is no guesswork on either bird.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Avian-vet health certificates</strong> — issued for both before they travel.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Hatch certificates + closed leg bands</strong> — each bird's traceable identity as a captive-bred grey.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>CITES captive-bred documentation</strong> — African Greys are CITES Appendix I; captive-bred birds are legal to own and transfer domestically with the right paperwork, and both birds have it. See our <a href="/cites-african-grey-documentation/" class="text-clay-text underline">CITES documentation page</a> for what that means.</span></li>
        <li class="flex gap-3"><span class="text-green font-bold">✔</span><span><strong>Weaning underway</strong> — both are progressing on schedule and will leave us only once they are eating independently.</span></li>
      </ul>
      <p class="text-stone-600 leading-relaxed mt-6">We are a USDA AWA licensed family aviary, and both Jins and Jeni are covered by our <a href="/african-grey-parrot-health-guarantee/" class="text-clay-text underline">African Grey health guarantee</a>. Want proof a grey is DNA-tested before you commit? That is the whole point of our <a href="/dna-tested-african-grey-for-sale/" class="text-clay-text underline">DNA-tested greys</a>.</p>
    </div>
  </section>

  {/* 4 — WHY JINS & JENI */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Why Jins and Jeni might be the right greys for you</h2>
      <p class="text-stone-600 leading-relaxed mb-4">Taking on a pair is a different decision than taking on a single bird, and for the right home it is a wonderful one. Jins and Jeni already have company in each other, which means neither is ever truly alone, and the dynamic between a steady older male and a lively younger female makes for a household full of personality. For an owner who has wanted two greys, or who is drawn to an unrelated male-and-female duo, this is a ready-made pair — no introductions, no guesswork about whether two birds will get along.</p>
      <p class="text-stone-600 leading-relaxed">Because we hand-raised them ourselves, we can tell you honestly how each one responds to handling, to new people, and to each other — and we would rather they go to the home that genuinely fits a pair than the first one to ask. That is the conversation we want to have with you.</p>
    </div>
  </section>

  {/* 5 — PRICING & WHAT'S INCLUDED */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">How much is the pair, and what's included?</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Price & reservation</h3>
          <ul class="space-y-3 text-stone-600 text-sm">
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Jins &amp; Jeni (pair, sold together)</span><strong class="text-logo-dark">$3,500</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Deposit to reserve</span><strong class="text-logo-dark">$200</strong></li>
            <li class="flex justify-between border-b border-stone-200 pb-2"><span>Airport Pickup (IATA, LAR)</span><strong class="text-logo-dark">$185</strong></li>
            <li class="flex justify-between"><span>Home Delivery (door-to-door)</span><strong class="text-logo-dark">$350</strong></li>
          </ul>
          <p class="text-stone-500 text-xs mt-3">Ships nationwide &middot; $185 airport &middot; $350 home &middot; Delta / United / American</p>
        </div>
        <div>
          <h3 class="font-lora font-semibold text-xl text-logo-dark mb-3">Included for both birds</h3>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> DNA sex certificate (each)</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Avian-vet health certificate (each)</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Hatch certificate + leg band (each)</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> CITES captive-bred documentation</li>
            <li class="flex gap-2"><span class="text-green font-bold">✔</span> Health guarantee + go-home support</li>
          </ul>
        </div>
      </div>
      <p class="text-stone-600 leading-relaxed mt-6">The $3,500 price is for the pair together — they are not sold separately. A $200 deposit reserves both and pauses the listing for you; the balance is due before they travel. For how this sits against the wider range, see our <a href="/african-grey-parrot-price/" class="text-clay-text underline">African Grey price guide</a>.</p>
    </div>
  </section>

  {/* 6 — PARENT BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Who are Jins and Jeni's parents?</h2>
      <p class="text-stone-600 leading-relaxed">Jins and Jeni are unrelated birds, both hatched and hand-raised inside our family aviary in Midland, Texas, which we have run since 2014. We are happy to share each bird's specific parentage and pairing details on request during the reservation conversation, along with anything else you would like to verify before you commit. We would rather walk you through it directly than post it on a page.</p>
    </div>
  </section>

  {/* 7 — FAQ */}
  <section class="py-16 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Jins &amp; Jeni — frequently asked questions</h2>
      <div class="space-y-4">
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Can Jins and Jeni be bought separately?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">No — Jins and Jeni must go together. They are an unrelated, hand-raised Congo pair we are placing as one. The $3,500 price covers both birds and they travel to the same home.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Are Jins and Jeni DNA sexed and documented?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes. Both go home with their DNA sex certificates — Jins confirmed male, Jeni confirmed female — plus their avian-vet health certificates, hatch certificates with leg-band numbers, and CITES captive-bred documentation. Here at C.A.Gs, every grey is captive-bred in the USA and leaves with full paperwork.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">How much is the Jins &amp; Jeni pair and how do I reserve them?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">The pair is $3,500 together. A $200 deposit reserves them and pauses the listing for you. The balance is due before they travel. Reach out through our contact form and we reply within 24 hours.</p>
        </details>
        <details class="bg-white border border-stone-200 rounded-2xl p-5">
          <summary class="font-lora font-semibold text-logo-dark cursor-pointer">Can Jins and Jeni be shipped to me?</summary>
          <p class="text-stone-600 text-sm mt-3 leading-relaxed">Yes — the pair ships nationwide to the same home. Airport Pickup is $185 (you collect them at your nearest major airport via IATA-compliant live-animal cargo, IATA code LAR, on Delta, United, or American) and Home Delivery is door-to-door for $350.</p>
        </details>
      </div>
    </div>
  </section>

  {/* 8 — OTHER AVAILABLE BIRDS */}
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">Other African Greys we have available</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/available/bery/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Bery</h3><p class="text-stone-500 text-sm">Female Congo &middot; 1 year</p><p class="text-clay-text font-semibold text-sm mt-1">$1,700</p></a>
        <a href="/available/amie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Amie</h3><p class="text-stone-500 text-sm">Female Congo &middot; 3 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,500</p></a>
        <a href="/available/roys/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Roys</h3><p class="text-stone-500 text-sm">Male Congo &middot; 4 months</p><p class="text-clay-text font-semibold text-sm mt-1">$2,300</p></a>
        <a href="/available/elad/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Elad</h3><p class="text-stone-500 text-sm">Male Timneh &middot; 5 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,600</p></a>
        <a href="/available/evie/" class="block bg-white border border-stone-200 rounded-2xl p-5 hover:shadow-md transition-shadow"><h3 class="font-lora font-semibold text-logo-dark">Evie</h3><p class="text-stone-500 text-sm">Female Timneh &middot; 6 months</p><p class="text-clay-text font-semibold text-sm mt-1">$1,500</p></a>
        <a href="/african-grey-parrots-for-sale/" class="block bg-logo-dark text-cream rounded-2xl p-5 hover:opacity-90 transition-opacity"><h3 class="font-lora font-semibold">See every available grey</h3><p class="text-cream/70 text-sm mt-1">Browse the full nursery &rarr;</p></a>
      </div>
    </div>
  </section>

  <Schema type="product" data={productSchema} />
  <Schema type="faq" data={faqSchema} />
  <Schema type="organization" />

  {/* 9 — INQUIRY CTA */}
  <CTA headline="Ready to bring Jins & Jeni home?" sub="Jins & Jeni are a hand-raised, CITES-documented, DNA-sexed Congo pair sold together at $3,500. A $200 deposit reserves both — reach out and we reply within 24 hours." />
</BaseLayout>
