---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Newsletter from '../../components/cag-library/NewsletterV2.astro';
import clutch from '../../../data/clutch-inventory.json';
import breederData from '../../../data/breeder-comparison.json';

const title = "African Grey Parrot Breeders Comparison: Choosing a Reputable, USDA-Documented Breeder & Avoiding Scams | C.A.Gs – Honest Breeder Buyer's Guide";
const description = "African Grey parrot breeders compared honestly by breeders who document every bird: direct licensed breeder vs classified site vs rescue, the paperwork a reputable breeder actually shows (USDA license, CITES, PBFD/APV PCR, DNA sexing), red flags, safe payment, and what our 30-breeder audit found.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-breeders-comparison/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Comparisons", url: "/african-grey-comparison/" },
  { name: "African Grey Breeders Comparison", url: "/african-grey-parrot-breeders-comparison/" },
];

const bd = breederData as any;
const cag = bd.cag;
const competitors = (bd.competitors as any[]) || [];
const accessibleCompetitors = competitors.filter((c) => c.site_accessible === true || c.site_accessible === "true");
const inaccessibleCompetitors = competitors.filter((c) => c.site_accessible === false || c.site_accessible === "false");
function yesNo(v:any){ if(v===true||v==="true")return "Yes — stated"; if(v===false||v==="false")return "Not on site"; return String(v ?? "Verify"); }
function yesCls(v:any){ if(v===true||v==="true")return "bc-yes"; if(v===false||v==="false")return "bc-no"; return "bc-verify"; }

const channels = [
  { ic: "M3 21V7l9-4 9 4v14M3 21h18M9 21v-6h6v6", name: "Direct licensed breeder", desc: "You buy the bird from the person who hatched it — the only channel that can hand you a USDA license number, per-bird PCR results and a CITES paper trail.", tag: "Safest — documents at source", best: true },
  { ic: "M4 5h16v4H4zM4 11h16v8H4zM8 15h8", name: "Classified listing site", desc: "A directory that lists other people's birds. A green “verified” badge means the listing paid a fee, not that anyone checked a credential.", tag: "Verify each seller yourself", best: false },
  { ic: "M3 9l1-4h16l1 4M4 9v10h16V9M9 13h6", name: "Online marketplace / Facebook", desc: "Facebook Marketplace, Hoobly and Craigslist mix a few real sellers with the bulk of reported parrot scams — deposit-and-vanish is the pattern buyers describe most.", tag: "Highest scam risk", best: false },
  { ic: "M12 21s-7-5-7-11a7 7 0 0114 0c0 6-7 11-7 11z", name: "Rescue / adoption", desc: "A legitimate, meaningful route for experienced owners — a Petfinder-listed rescue rehomes greys for a documented $200–$600 fee, history disclosed as far as it is known.", tag: "Great for experienced owners", best: false },
];

// 4-tier documentation VERDICT CARDS (refresh delta #3) — matrix stays in DOM below too
const tiers = [
  { name: "Direct licensed breeder", verdict: "Documented at source", win: true, docs: [["y","USDA AWA license number"],["y","CITES captive-bred paperwork"],["y","DNA-sexing certificate"],["y","PBFD & APV PCR results"],["y","Written health guarantee"],["y","Card / PayPal G&S accepted"]], strip: "Every document traces to the bird you are buying" },
  { name: "Classified listing site", verdict: "Depends on the seller", win: false, docs: [["p","USDA license"],["p","CITES paperwork"],["p","DNA certificate"],["n","PBFD & APV PCR"],["p","Health guarantee"],["p","Safe payment"]], strip: "The platform verifies payment, not credentials" },
  { name: "Online marketplace / Facebook", verdict: "Buyer beware", win: false, docs: [["n","USDA license"],["n","CITES paperwork"],["n","DNA certificate"],["n","PBFD & APV PCR"],["n","Health guarantee"],["n","Safe payment"]], strip: "Where most reported parrot scams concentrate" },
  { name: "Rescue / adoption", verdict: "Honest, history-limited", win: false, docs: [["p","Prior USDA history"],["y","Legal transfer paperwork"],["p","DNA certificate"],["p","Health screening"],["y","Adoption contract"],["y","Documented adoption fee"]], strip: "What paperwork exists is disclosed openly" },
];

const auditStats = [
  { big: "30", sub: "African Grey breeder and listing sites we audited on 2026-07-12" },
  { big: "0", sub: "surfaced a USDA license number anywhere on the homepage we could scan" },
  { big: "4 of 11", sub: "sites listed as “direct breeders” were offline the day we checked" },
];

// verification checklist — breeder-SELECTION framing (worded apart from the scam page)
const checklist = [
  "Ask for the USDA AWA license number, then confirm it yourself in the USDA APHIS Animal Care public search — a real breeder gives the number without flinching.",
  "Request paperwork for the exact bird you are buying, band or microchip number included, not a generic certificate that could belong to any chick.",
  "Confirm the bird is captive-bred with CITES documentation — for an Appendix I species there is no legitimate sale without it.",
  "Ask which lab ran the DNA sexing and the PBFD/Avian Polyomavirus PCR, and to see the individual result.",
  "Get the written health guarantee terms in advance, including the window you have for an independent avian-vet exam.",
  "Ask for a live video call with the specific bird moving in its current room — a stolen listing photo cannot do that.",
  "Keep payment on a credit card or PayPal Goods & Services; treat wire, Zelle, Venmo, gift cards and crypto as the deal-breakers they are.",
  "Search the seller name, phone number and website with the words review and scam before any money moves.",
];

const redFlags = [
  "No USDA license, or a refusal to give the number",
  "Won't video-call you with the specific bird",
  "Wire transfer, Zelle, gift cards or crypto only",
  "A Congo priced far under $1,500",
  "Pressure to pay a deposit before you can verify anything",
  "No CITES, DNA or health paperwork on offer",
];
const greenFlags = [
  "USDA AWA license number you can confirm at APHIS",
  "A live video call with your actual bird, any time",
  "Credit card or PayPal Goods & Services accepted",
  "A genuine $1,700–$3,500 Congo range",
  "A documented, refundable reservation with terms in writing",
  "Full CITES, DNA-sexing and PCR paperwork per bird",
];

const qSpecific = [
  "May I video-call to see this exact bird move around its room today?",
  "How old is it, and is it fully weaned onto solid food?",
  "Who are the parents, and can I see them?",
  "What is the band or microchip number on this bird?",
];
const qDocs = [
  "What is your USDA AWA license number?",
  "Which lab did the DNA sexing and the PBFD / APV PCR?",
  "What exactly does your written health guarantee cover, and for how long?",
  "What paperwork travels home with the bird, and how is it shipped?",
];

const takeaways = [
  { big: "1 axis", sub: "we judge every breeder on the same thing — the documents they can produce" },
  { big: "USDA", sub: "an AWA license number you can verify yourself at APHIS is the fastest legitimacy test" },
  { big: "Appendix I", sub: "African Greys are CITES Appendix I — no captive-bred paperwork, no legal sale" },
  { big: "PBFD + APV", sub: "per-bird PCR screening is the health entity almost no competitor names" },
  { big: "$1,700–$3,500", sub: "our Congo range; a price far below the floor is a scam signal, not a bargain" },
  { big: "$800 grey", sub: "the classic too-good-to-be-true bait behind deposit-and-vanish scams" },
  { big: "$185 / $350", sub: "airport pickup or home delivery, the paperwork folder travels either way" },
  { big: "4.9 / 52", sub: "our verified review rating and count — real names and cities on our reviews page" },
];

const faqs = [
  { q: "How do I find a reputable African Grey breeder?", a: "Judge every candidate on documentation, not vibes. A reputable African Grey breeder gives you a USDA AWA license number you can verify in the USDA APHIS public search, produces CITES captive-bred paperwork, a DNA-sexing certificate and PBFD/Avian Polyomavirus PCR results for the specific bird, offers a written health guarantee, and takes payment by card or PayPal Goods & Services. If any of those is missing or waved away, keep looking." },
  { q: "How can you tell if a bird breeder is legit?", a: "Ask for the USDA license number and confirm it yourself, request a live video call with the exact bird in its current room, and insist on per-bird paperwork rather than a generic certificate. A legitimate breeder answers detailed questions happily and never pressures you to pay by wire, Zelle or crypto before you can verify anything. Refusal on any of those points is the tell." },
  { q: "Is it safe to buy an African Grey from a classified listing site?", a: "Classified sites like BirdBreeders, BirdsNow and Hoobly aggregate other people's listings; the platform verifies that a listing fee was paid, not that the seller holds a single credential. A green “verified” badge is not a verified USDA license or CITES paperwork. Some sellers there are genuine breeders, but the due-diligence burden is entirely on you — request the same documents you would from any direct breeder before sending money." },
  { q: "How much should an African Grey parrot cost from a real breeder?", a: "Expect roughly $1,700–$3,500 for a documented Congo African Grey and $1,500–$1,600 for a Timneh from a licensed U.S. breeder, plus $185 airport or $350 home-delivery shipping. A Congo advertised at $800 is not a bargain — it is the single most common scam signal, because a real breeder cannot cover a decade of raising, PCR screening, DNA sexing and veterinary care at that price." },
  { q: "What questions should I ask an African Grey breeder before buying?", a: "Ask for the USDA license number, a live video call with the specific bird, the band or microchip number, which lab ran the DNA and PCR tests, exactly what the written health guarantee covers, and what paperwork ships with the bird. A genuine breeder gives full, specific answers; evasion or one-word replies are your answer." },
  { q: "What documents should a captive-bred African Grey come with?", a: "CITES captive-bred documentation, a DNA-sexing certificate, PBFD and Avian Polyomavirus PCR results, an avian-veterinarian health certificate, and a hatch record with a closed leg-band or microchip number. Because the African Grey is CITES Appendix I, that paper trail is what makes a domestic sale legal — there is no legitimate reason for it to be missing." },
  { q: "What should I do if a breeder cannot show CITES documentation?", a: "Do not buy the bird. For an Appendix I species, inability to produce captive-bred CITES paperwork means the bird is either wild-caught (illegal) or the seller is not who they claim. Walk away and, if money already changed hands, report it to the USDA APHIS Animal Care line and to IC3.gov." },
  { q: "Are adopted or rescued African Greys a good option?", a: "Yes, particularly for experienced owners who can handle uncertainty about a bird's past. A legitimate parrot rescue rehomes African Greys for a documented $200–$600 fee and discloses what history it has. Petfinder lists greys available through vetted rescues — filter by species and distance. Documentation differs from a breeder purchase, but a real rescue is transparent about exactly what it can and cannot confirm." },
  { q: "How do I report a suspected African Grey parrot scam?", a: "Report to the USDA APHIS Animal Care line for CITES and animal-welfare concerns, to IC3.gov (the FBI's Internet Crime Complaint Center) if money was sent online, and to your state attorney general's consumer-protection office. Then contact your card issuer or PayPal to attempt a chargeback. Save every message and screenshot before you file." },
  { q: "What payment methods are safe when buying a parrot online?", a: "A credit card or PayPal Goods & Services — both give you a dispute and chargeback path if the bird or the seller turns out to be fake. Wire transfer, Zelle, Venmo, Cash App, gift cards and cryptocurrency are effectively irreversible, which is exactly why scammers insist on them. A documented, refundable reservation paid by card is normal; a demand for untraceable payment is the deal-breaker." },
];

const available = ((clutch as any).birds as any[]).filter((b) => b.status === 'available' && b.sex !== 'pair').sort((a, b) => (a.variant === 'congo_african_grey' ? -1 : 1));
const availablePair = ((clutch as any).birds as any[]).find((b) => b.sex === 'pair' && b.status === 'available');
const birdImg: Record<string, { src: string; alt: string }> = {
  "bery": { src: "/bery-congo-african-grey-cuddly-tamed-card.webp", alt: "Bery, a documented female Congo African Grey at the C.A.Gs aviary, resting on her keeper's lap" },
  "amie": { src: "/amie-congo-african-grey-handfed-baby-card.webp", alt: "Amie, a hand-fed female Congo African Grey with full captive-bred paperwork" },
  "roys": { src: "/roys-congo-african-grey-male-tame-card.webp", alt: "Roys, a tame young male Congo African Grey documented from hatch at C.A.Gs" },
  "jins-jeni": { src: "/jins-jeni-congo-african-grey-pair-card.webp", alt: "Jins and Jeni, a documented Congo African Grey companion pair raised together" },
  "elad": { src: "/elad-timneh-african-grey-male-wings-card.webp", alt: "Elad, a documented young male Timneh African Grey stretching his wings" },
  "evie": { src: "/evie-timneh-african-grey-female-perched-card.webp", alt: "Evie, a documented female Timneh African Grey with her CITES paperwork folder" },
};
const docBadges = ["CITES Cert", "PCR DNA-Sexed", "Vet Certified", "PBFD & APV Screened", "Fully Weaned"];

// grouped-by-mode metros (refresh delta #5) — 5 fresh location slugs unused by any sibling spoke
const shipAirport = [
  { href: "/african-grey-parrot-for-sale-cleveland/", label: "Cleveland" },
  { href: "/african-grey-parrot-for-sale-jacksonville/", label: "Jacksonville" },
];
const shipHome = [
  { href: "/african-grey-parrot-for-sale-sacramento/", label: "Sacramento" },
  { href: "/african-grey-parrot-for-sale-nyc/", label: "New York City metro" },
];
const shipCourier = [
  { href: "/african-grey-parrot-for-sale-near-me/", label: "Find your nearest route" },
];

const tocItems = [
  { id: "quick-answer", label: "Where to Buy" },
  { id: "takeaways", label: "Key Takeaways" },
  { id: "documentation", label: "What a Breeder Shows" },
  { id: "tiers", label: "Breeder Types" },
  { id: "direct", label: "Direct Breeders" },
  { id: "classified", label: "Classified Sites" },
  { id: "scams", label: "How Scams Work" },
  { id: "rescue", label: "Rescue & Adoption" },
  { id: "audit", label: "Our 30-Breeder Audit" },
  { id: "questions", label: "Questions to Ask" },
  { id: "flags", label: "Red vs Green Flags" },
  { id: "payment", label: "Paying in Advance" },
  { id: "price", label: "What It Should Cost" },
  { id: "checklist", label: "Verification Checklist" },
  { id: "shipping", label: "Documented & Shipped" },
  { id: "legit", label: "Is C.A.Gs Legit?" },
  { id: "owners", label: "Mark & Teri" },
  { id: "available", label: "Documented Birds" },
  { id: "faq", label: "FAQ" },
  { id: "report", label: "Report a Scam" },
  { id: "learn", label: "Keep Reading" },
];
const num = (i: number) => String(i + 1).padStart(2, "0");

const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
const articleSchema = {
  "@context": "https://schema.org", "@type": "Article",
  headline: "African Grey Parrot Breeders: An Honest, Documented Comparison",
  description: description,
  author: { "@type": "Organization", name: "C.A.Gs – Congo African Greys, Midland TX" },
  publisher: { "@type": "Organization", name: "CongoAfricanGreys.com" },
  mainEntityOfPage: canonical, datePublished: "2026-06-02", dateModified: "2026-07-13",
};
const orgSchema = {
  "@context": "https://schema.org", "@type": "Organization",
  name: "C.A.Gs – Congo African Greys", url: "https://congoafricangreys.com/",
  address: { "@type": "PostalAddress", addressLocality: "Midland", addressRegion: "TX", postalCode: "79707", addressCountry: "US" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52", bestRating: "5" },
};
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta
  heroPreload="/african-grey-breeder-comparison-hero.webp"
  heroPreloadSrcset="/african-grey-breeder-comparison-hero-480.webp 480w, /african-grey-breeder-comparison-hero.webp 900w"
  heroPreloadSizes="(max-width: 900px) 60vw, 300px">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <div class="cvt">
  <div class="container"><Breadcrumb items={breadcrumbs} /></div>

  <!-- S1 HERO — single trust hero + credential pill-row -->
  <section class="cvt-hero hero-trust">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><span class="eb-tick" aria-hidden="true"></span>Every breeder here judged on one axis — the paperwork</p>
        <h1 class="cag-h1">African Grey Parrot Breeders: An Honest, Documented Comparison</h1>
        <p class="lead">Where can you actually buy an African Grey, and which route is safe? We are a USDA-licensed African Grey breeder, so we will name our bias up front — then compare direct breeders, classified sites, marketplaces and rescue on the one thing that separates them: the documents each can put in your hands.</p>
        <ul class="cred-pills">
          <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>USDA-licensed</li>
          <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>CITES-documented</li>
          <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>PBFD/APV PCR</li>
          <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>DNA-sexed</li>
        </ul>
        <p class="hero-cta"><a class="btn-clay" href="#tiers">Compare Breeder Types</a> <a class="btn-ghost" href="#checklist">Verification Checklist</a></p>
        <p class="hero-meta"><span>30 breeders audited</span><span>0 posted a USDA license</span><span>Breeder-written</span></p>
      </div>
      <div class="hero-imgs">
        <figure class="hero-single">
          <img src="/african-grey-breeder-comparison-hero.webp"
            srcset="/african-grey-breeder-comparison-hero-480.webp 480w, /african-grey-breeder-comparison-hero.webp 900w"
            sizes="(max-width: 900px) 60vw, 300px"
            width="900" height="675" alt="A reputable African Grey parrot breeder comparison scene at the C.A.Gs aviary in Midland, Texas, a documented Congo grey beside its paperwork" fetchpriority="high">
          <figcaption class="chip">Documented · Midland, TX</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- S2 COUNTER — page-specific -->
  <section class="cvt-counter"><div class="container counter-row">
    <div class="cs"><b>30</b><span class="cs-l">Breeders we audited</span></div>
    <div class="cs"><b>0</b><span class="cs-l">Posted a USDA license</span></div>
    <div class="cs"><b>100%</b><span class="cs-l">CITES documented (ours)</span></div>
    <div class="cs"><b>24h</b><span class="cs-l">Reply to inquiries</span></div>
  </div></section>

  <!-- S3 mobile jump rail -->
  <nav class="cvt-rail" aria-label="Jump to section"><div class="container rail-row">
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </div></nav>

  <div class="container cvt-body">
  <aside class="cvt-toc" aria-label="On this page">
    <p class="toc-title"><span class="toc-tick" aria-hidden="true"></span>On this page</p>
    {tocItems.map((t, i) => (<a href={`#${t.id}`}><b>{num(i)}</b> {t.label}</a>))}
  </aside>

  <div class="cvt-main">

  <!-- S4 QUICK ANSWER — four channels -->
  <section id="quick-answer">
    <h2 class="cag-h2">Where Can You Actually Buy an African Grey, and Which Is Safe?</h2>
    <div class="qa-cream">
      <p><strong>Quick answer:</strong> There are four places people buy an African Grey — a direct licensed breeder, a classified listing site, an online marketplace, and a rescue. Only the first can hand you a USDA license number, per-bird CITES paperwork and PCR health results at the source. Everything else on this page follows from that single difference, because the African Grey is a CITES Appendix I bird and its documentation is what makes a sale legal.</p>
    </div>
    <div class="door-grid">
      {channels.map((c) => (
        <div class={c.best ? "door-c best" : "door-c"}>
          <svg class="door-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.ic}/></svg>
          <span class="door-t">{c.name}</span>
          <p>{c.desc}</p>
          <span class="door-tag">{c.tag}</span>
        </div>
      ))}
    </div>
    <a class="inf" href="/african-grey-comparison/"><img class="sec-img inf-img" src="/where-to-buy-african-grey-four-channels.webp" srcset="/where-to-buy-african-grey-four-channels-760.webp 760w, /where-to-buy-african-grey-four-channels.webp 1408w" sizes="(max-width:900px) 92vw, 760px" width="1408" height="768" alt="Four buying channels for an African Grey shown as labelled doorways, the direct licensed breeder highlighted as the documented route" loading="lazy"></a>
    <p>Our full African Grey comparison hub maps how this breeder-selection page fits alongside the species and variant guides, if you are still deciding which grey — or whether a grey at all — suits your home. The rest of this page settles the harder question: once you know you want an African Grey, how do you tell a real breeder from a good-looking listing?</p>
  </section>

  <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy"></div>

  <!-- S5 KEY TAKEAWAYS -->
  <section id="takeaways">
    <h2 class="cag-h2">The Numbers That Should Drive Your Breeder Choice</h2>
    <p>Eight figures, screenshot-ready — the documentation axis this whole comparison turns on. Every number below traces to our own aviary, our 30-breeder audit, or a public source we name; nothing here is a guess wearing a fact's clothing.</p>
    <div class="kt-grid">
      {takeaways.map((k) => (<div class="kt-c"><span class="kt-tick" aria-hidden="true"></span><b>{k.big}</b><span class="kt-sub">{k.sub}</span></div>))}
    </div>
  </section>

  <div class="seam"><img src="/cag-header-logo-160.webp" width="54" height="54" alt="" loading="lazy"></div>

  <!-- S6 DOCUMENTATION -->
  <section id="documentation">
    <h2 class="cag-h2">What Does a Reputable African Grey Breeder Actually Show You?</h2>
    <a class="inf" href="/cites-african-grey-documentation/"><img class="sec-img inf-img" src="/african-grey-breeder-documentation-flat-lay.webp" srcset="/african-grey-breeder-documentation-flat-lay-760.webp 760w, /african-grey-breeder-documentation-flat-lay.webp 1408w" sizes="(max-width:900px) 92vw, 760px" width="1408" height="768" alt="Flat-lay of captive-bred African Grey documentation, a DNA sexing certificate, health certificate, CITES paperwork and a closed leg band" loading="lazy"></a>
    <h3 class="cag-h3">The Documentation a Real Breeder Can Produce</h3>
    <p>Facilities photograph well and say little. What separates a reputable African Grey breeder from a confident listing is the paper trail — and it is a short, specific list you can ask any seller to produce on the spot.</p>
    <h4 class="cag-h4">How Do You Verify a USDA Breeder License?</h4>
    <p>Ask for the number, then check it yourself. Commercial breeders selling across state lines are generally required to hold an Animal Welfare Act license, and the fastest legitimacy test in this entire comparison is a name that matches a live record.</p>
    <h5 class="cag-h5">Using the USDA APHIS Public Search</h5>
    <p><a href="https://aphis.usda.gov/aphis/ourfocus/animalwelfare" target="_blank" rel="noopener">The USDA APHIS Animal Care public search ↗</a> lets anyone look up a licensee by name or number. When we audited 30 African Grey sellers, not one surfaced a license number on its homepage — a gap you can close in thirty seconds by simply asking.</p>
    <h4 class="cag-h4">What Paperwork Proves the Bird Is Captive-Bred?</h4>
    <p>Because the African Grey sits at CITES Appendix I, captive-bred documentation is not a nicety — it is the thing that makes a domestic sale legal at all.</p>
    <h5 class="cag-h5">CITES Appendix I Documentation</h5>
    <p>Our CITES documentation page details exactly what an Appendix I paper trail contains and why wild-caught birds cannot legally enter the pet trade. A closed leg band, sealed on in the nest and impossible to add to a wild adult, is the physical proof that outlasts any receipt — the heart of a genuinely <a href="/captive-bred-african-grey-parrot/">captive-bred African Grey</a> claim.</p>
    <h5 class="cag-h5">DNA-Sexing Certificate and Closed Leg Band</h5>
    <p>African Greys are not visually sexable, so a lab DNA-sexing certificate is the only honest way to state a bird's sex — the same standard behind our <a href="/dna-tested-african-grey-for-sale/">DNA-tested African Greys</a>, and the reason a listing that promises a sex without a certificate is guessing.</p>
    <h4 class="cag-h4">What Health Screening Should Be Documented?</h4>
    <p>Two viral PCR tests separate a documented aviary from a hopeful one, and they are the health entities almost no competitor page names.</p>
    <h5 class="cag-h5">PBFD and Avian Polyomavirus PCR Screening</h5>
    <p>Per-bird PCR results for Psittacine Beak and Feather Disease and Avian Polyomavirus are the difference between a lab-verified result and a sentence promising a seller screens for everything. Every <a href="/hand-raised-african-grey-parrot-for-sale/">hand-raised African Grey we place</a> ships with both.</p>
    <h6 class="cag-h6">Breeder note: how we screen each C.A.Gs chick</h6>
    <p>Every chick is PCR-tested individually, not sampled as a clutch — the result on the certificate belongs to the bird in the photo, and it goes into that bird's own file the day it comes back from the lab.</p>
    <h5 class="cag-h5">The Avian-Vet Health Certificate</h5>
    <p>A health certificate from a licensed avian veterinarian, issued shortly before transport, is required by most airlines for live-bird shipping anyway — so its absence tells you a seller either is not shipping legally or is not shipping at all.</p>
    <h6 class="cag-h6">Citation: Association of Avian Veterinarians</h6>
    <p><a href="https://www.aav.org/" target="_blank" rel="noopener">The Association of Avian Veterinarians ↗</a> maintains find-a-vet and health-standard resources worth using to confirm the certifying vet is real and licensed.</p>
  </section>

