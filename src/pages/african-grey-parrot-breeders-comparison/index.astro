---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';
import breederData from '../../../data/breeder-comparison.json';

const title = "African Grey Parrot Breeders Comparison | Honest Buyer's Guide";
const description = "Compare African Grey parrot breeders honestly: direct breeders, classified listings, and adoption — what each publicly states about CITES docs, health guarantees, and pricing.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-breeders-comparison/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Breeder Comparison", url: "/african-grey-parrot-breeders-comparison/" },
];

const { cag, competitors, aggregators, confirmed_scams } = breederData;

const accessibleCompetitors = competitors.filter(
  (c: any) => c.site_accessible === true || c.site_accessible === "true"
);
const inaccessibleCompetitors = competitors.filter(
  (c: any) => c.site_accessible === false || c.site_accessible === "false"
);

const verificationChecklist = [
  "Ask for the breeder's USDA AWA license number — verify at the USDA APHIS Animal Care public database",
  "Request documentation for the specific bird you're purchasing, not a generic certificate",
  "Confirm the bird is captive-bred — documentation should reference a band or microchip number from the breeding pair",
  "Be cautious of prices below $1,500 for Congo African Greys or $1,200 for Timnehs",
  "Safe payment methods only: credit card or PayPal Goods & Services. Wire transfer, Zelle, and cryptocurrency are red flags",
  "Ask for the avian veterinarian's name and contact who issued the health certificate",
  "Request photos or video of the specific bird in its current environment before paying",
  "Search the seller's name and website on Google with the word 'scam' or 'review' before sending any money",
];

const buyerFaqs = [
  {
    q: "Is it safe to buy an African Grey from a classified listing site?",
    a: "Classified listing sites like BirdsNow and BirdBreeders aggregate listings from individual sellers. The platform does not verify seller credentials, CITES documentation, or health claims. Some individual sellers on these platforms are legitimate breeders; others are not. Buying from a classified listing requires more buyer due diligence than purchasing from a licensed breeder directly. Always request CITES documentation, a health certificate, and a USDA AWA license number regardless of where you find the seller.",
  },
  {
    q: "What should I do if a breeder cannot show CITES documentation?",
    a: "Do not purchase the bird. Inability to produce CITES documentation for a captive-bred African Grey indicates either that the bird is wild-caught (illegal) or that the seller is fraudulent. There is no legitimate explanation for a legally sold African Grey to lack captive-bred documentation. Walk away and report the seller to the USDA APHIS Animal Care reporting line at 1-844-820-2234.",
  },
  {
    q: "Are adopted or rescued African Greys a good option?",
    a: "Adopting an African Grey through a legitimate parrot rescue organization is a valid and meaningful option, particularly for experienced bird owners who can manage uncertainty about a bird's history or potential behavioral issues from prior neglect. Adoption fees are typically $200–$600. Petfinder.com lists African Grey parrots available for adoption through rescue organizations — filter by species and distance. Documentation requirements differ for adopted birds, but any legitimate rescue provides what paperwork they have.",
  },
  {
    q: "How do I report a suspected African Grey parrot scam?",
    a: "Report to: (1) USDA APHIS Animal Care at 1-844-820-2234 for CITES and animal welfare violations; (2) your state attorney general's consumer protection office for financial fraud; (3) the IC3 (Internet Crime Complaint Center) at ic3.gov if money was sent online; and (4) your bank or PayPal to attempt a chargeback. Document all seller communication before reporting.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: buyerFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};

function yesNo(val: any): string {
  if (val === true || val === "true") return "Yes — stated";
  if (val === false || val === "false") return "Not found on site";
  return String(val ?? "Verify directly");
}
function yesClass(val: any): string {
  if (val === true || val === "true") return "bc-yes";
  if (val === false || val === "false") return "bc-no";
  return "bc-verify";
}
---

<BaseLayout title={title} description={description} canonical={canonical} hideGlobalCta>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- HERO -->
  <section class="bc-hero">
    <div class="bc-container">
      <h1 class="bc-h1">African Grey Parrot Breeders: An Honest Comparison</h1>
      <p class="bc-sub">
        Where can you get an African Grey parrot — and what does each option actually offer?
        This guide compares direct breeders, classified listing sites, and adoption based on
        verified, publicly available information. No sales pitch. No bias.
      </p>
      <p class="bc-meta">Research date: {breederData.research_date}</p>
    </div>
  </section>

  <!-- WHAT TO LOOK FOR -->
  <section class="bc-section">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Five Things to Verify Before Buying Any African Grey</h2>
      <p class="bc-p">
        African Greys are CITES Appendix I. Any legal captive-bred sale requires documentation.
        Apply these five checks to every seller — including this one.
      </p>
      <div class="bc-criteria-list">
        {[
          ["CITES Documentation", "Written proof the bird is captive-bred, with a band or microchip number tracing back to the breeding pair or aviary of origin."],
          ["Avian Vet Health Certificate", "A health certificate from a licensed avian veterinarian issued within 10 days of transport — required by most airlines for live bird shipping."],
          ["USDA AWA License", "Commercial breeders selling across state lines are typically required to hold an Animal Welfare Act license. Ask for the number and verify at USDA APHIS."],
          ["DNA Sex Certificate", "African Greys are not visually sexable. DNA sexing from a certified lab is the only reliable method. A certificate should accompany every bird."],
          ["Written Health Guarantee", "Terms documented in writing covering at minimum congenital and genetic conditions, with a defined window for veterinary examination."],
        ].map(([title, desc]) => (
          <div class="bc-criterion">
            <span class="bc-check-icon">✅</span>
            <div>
              <strong class="bc-criterion-title">{title}</strong>
              <p class="bc-criterion-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="bc-section bc-alt">
    <div class="bc-container">
      <h2 class="bc-h2">Direct Breeder Comparison</h2>
      <p class="bc-intro-p">
        Comparison based on publicly available information from each breeder's website as of {breederData.research_date}.
        {breederData.methodology}
      </p>
      <div class="bc-table-wrap">
        <table class="bc-table">
          <thead>
            <tr>
              <th scope="col">Breeder</th>
              <th scope="col">Location</th>
              <th scope="col">Price Range</th>
              <th scope="col">Ships Nationally</th>
              <th scope="col">CITES Mentioned</th>
              <th scope="col">DNA Sexed</th>
              <th scope="col">Health Guarantee</th>
              <th scope="col">USDA License</th>
            </tr>
          </thead>
          <tbody>
            <!-- CAG row — highlighted as this site -->
            <tr class="bc-row-cag">
              <th scope="row">
                <a href={cag.url} class="bc-breeder-link">{cag.name}</a>
                <span class="bc-this-badge">This site</span>
              </th>
              <td>{cag.location}</td>
              <td>{cag.price_congo} (Congo)<br />{cag.price_timneh} (Timneh)</td>
              <td class="bc-yes">Yes — all 50 states</td>
              <td class="bc-yes">Yes — documented</td>
              <td class="bc-yes">Yes — certified</td>
              <td class="bc-yes">Yes — written</td>
              <td class="bc-yes">Yes — licensed</td>
            </tr>
            <!-- Accessible competitors -->
            {accessibleCompetitors.map((c: any) => (
              <tr>
                <th scope="row">
                  <a href={c.url} class="bc-breeder-link" target="_blank" rel="noopener noreferrer">
                    {c.name}
                  </a>
                </th>
                <td>{c.location || "Not stated"}</td>
                <td>{c.price_range || "Not displayed"}</td>
                <td class={yesClass(c.ships_nationally)}>{yesNo(c.ships_nationally)}</td>
                <td class={yesClass(c.cites_mentioned)}>{yesNo(c.cites_mentioned)}</td>
                <td class={yesClass(c.dna_sexed_mentioned)}>{yesNo(c.dna_sexed_mentioned)}</td>
                <td class={yesClass(c.health_guarantee_mentioned)}>{yesNo(c.health_guarantee_mentioned)}</td>
                <td class={c.usda_license && c.usda_license !== "not found" ? "bc-yes" : "bc-verify"}>
                  {c.usda_license && c.usda_license !== "not found" ? c.usda_license : "Verify directly"}
                </td>
              </tr>
            ))}
            <!-- Inaccessible sites -->
            {inaccessibleCompetitors.map((c: any) => (
              <tr class="bc-row-inactive">
                <th scope="row">{c.name}</th>
                <td colspan="7" class="bc-inactive-note">
                  Website was not accessible as of {breederData.research_date}. Cannot verify current status.
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bc-disclaimer">
        "Not found on site" means this information was not present on the breeder's public pages at time of research — not a judgment about whether the breeder has it. Contact each seller directly to verify before purchasing.
      </p>
    </div>
  </section>

  <!-- AGGREGATORS -->
  <section class="bc-section">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Classified Listing Sites</h2>
      <p class="bc-p">
        Classified bird listing sites connect buyers with individual sellers. The platform itself
        does not typically verify seller credentials, CITES documentation, or health practices.
        They are useful for discovering sellers but require more buyer diligence than a licensed
        breeder with a verifiable track record.
      </p>
      <div class="bc-agg-grid">
        {aggregators.map((agg: any) => (
          <div class="bc-agg-card">
            <h3 class="bc-agg-name">
              <a href={agg.url} target="_blank" rel="noopener noreferrer">{agg.name}</a>
            </h3>
            <p class="bc-agg-type">{agg.type}</p>
            {agg.cites_policy && (
              <p class="bc-agg-detail"><strong>CITES policy:</strong> {agg.cites_policy}</p>
            )}
            {agg.verified_seller_program && (
              <p class="bc-agg-detail"><strong>Seller verification:</strong> {agg.verified_seller_program}</p>
            )}
          </div>
        ))}
      </div>
      <p class="bc-p">
        Apply the five-point verification checklist above to any individual seller found on these platforms. A platform's general reputation does not transfer to its individual listings.
      </p>
    </div>
  </section>

  <!-- ADOPTION -->
  <section class="bc-section bc-alt">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Parrot Adoption: A Legitimate Alternative</h2>
      <p class="bc-p">
        African Greys are frequently surrendered to rescue organizations due to owner illness, death, or behavioral challenges from prior neglect. Adopting a surrendered African Grey is a genuine and meaningful option, particularly for experienced bird owners.
      </p>
      <ul class="bc-adopt-list">
        <li><strong>Cost:</strong> Adoption fees typically $200–$600, significantly below breeder prices</li>
        <li><strong>Age:</strong> Often adult birds with established, observable personalities</li>
        <li><strong>History:</strong> May be unknown; behavioral issues from previous neglect are possible</li>
        <li><strong>Documentation:</strong> Varies by rescue — CITES paperwork may or may not transfer</li>
        <li><strong>Best for:</strong> Experienced bird owners comfortable with behavioral rehabilitation if needed</li>
      </ul>
      <p class="bc-p">
        <a href="https://www.petfinder.com" class="bc-link" target="_blank" rel="noopener noreferrer">Petfinder.com</a> lists African Grey parrots available for adoption through registered rescue organizations. Filter by species and your zip code.
      </p>
    </div>
  </section>

  <!-- SCAM WARNING -->
  <section class="bc-section bc-scam-section">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Sites to Avoid</h2>
      <p class="bc-p">
        The following were flagged during competitor research as confirmed scam operations.
        This is documented evidence, not opinion.
      </p>
      {confirmed_scams.map((scam: any) => (
        <div class="bc-scam-card">
          <h3 class="bc-scam-name">{scam.name}</h3>
          <p class="bc-scam-reason">{scam.reason}</p>
        </div>
      ))}
      <p class="bc-p">
        Any site offering African Grey parrots at $400–$800, demanding wire transfer or gift card payment, or unable to produce CITES documentation is almost certainly a scam. See our <a href="/how-to-avoid-african-grey-parrot-scams/" class="bc-link">full scam identification guide</a> for complete red flags and reporting instructions.
      </p>
    </div>
  </section>

  <!-- VERIFICATION CHECKLIST -->
  <section class="bc-section">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Before You Buy: Verification Checklist</h2>
      <p class="bc-p">Apply this to any seller — including us. Documentation protects you legally and ensures your bird is what the seller claims.</p>
      <ul class="bc-checklist">
        {verificationChecklist.map((item) => (
          <li class="bc-checklist-item">
            <span class="bc-check-mark">✅</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bc-section bc-alt">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Buyer FAQ</h2>
      <div class="bc-faq-list">
        {buyerFaqs.map((f) => (
          <details class="bc-faq-item">
            <summary class="bc-faq-q">{f.q}</summary>
            <p class="bc-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="bc-section">
    <div class="bc-container bc-text-wrap">
      <h2 class="bc-h2">Related Reading</h2>
      <ul class="bc-links">
        <li><a href="/african-grey-parrot-faq/" class="bc-link">African Grey Parrot FAQ</a> — 22 buyer questions answered</li>
        <li><a href="/how-to-avoid-african-grey-parrot-scams/" class="bc-link">How to Avoid African Grey Parrot Scams</a> — full guide to red flags and reporting</li>
        <li><a href="/african-grey-parrot-price/" class="bc-link">African Grey Parrot Price Guide</a> — first-year and lifetime cost breakdown</li>
        <li><a href="/congo-vs-timneh-african-grey/" class="bc-link">Congo vs Timneh African Grey</a> — which subspecies fits your situation</li>
      </ul>
    </div>
  </section>

  <CTA
    headline="Questions About Our Documentation or Birds?"
    sub="Every bird from CongoAfricanGreys.com is hand-raised, CITES-documented, DNA-sexed, and vet-certified. We're happy to answer any question before you commit."
  />
</BaseLayout>

<style>
  .bc-container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .bc-text-wrap { max-width: 760px; }
  .bc-hero { background: #2D6A4F; padding: 3.5rem 0 3rem; text-align: center; }
  .bc-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .bc-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto 0.75rem;
  }
  .bc-meta {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.82rem;
    color: rgba(250,247,244,0.55);
    margin: 0;
  }
  .bc-section { padding: 3rem 0; }
  .bc-alt { background: #faf7f4; }
  .bc-scam-section { background: #fff8f7; border-top: 3px solid #e8604c; border-bottom: 3px solid #e8604c; }
  .bc-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    margin: 0 0 1.25rem;
  }
  .bc-p, .bc-intro-p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.1rem;
  }
  .bc-intro-p { font-size: 0.9rem; color: #57534e; }
  .bc-criteria-list { display: flex; flex-direction: column; gap: 0.85rem; }
  .bc-criterion {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  .bc-check-icon { font-size: 1.1rem; flex-shrink: 0; }
  .bc-criterion-title {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #2D6A4F;
    display: block;
    margin-bottom: 0.2rem;
  }
  .bc-criterion-desc {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.9rem;
    line-height: 1.55;
    color: #57534e;
    margin: 0;
  }
  .bc-table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid #e7e5e4;
    box-shadow: 0 2px 8px rgba(60,30,10,0.07);
    margin-bottom: 1rem;
  }
  .bc-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.85rem;
    min-width: 820px;
  }
  .bc-table thead tr { background: #2D6A4F; }
  .bc-table thead th {
    color: #faf7f4;
    font-weight: 600;
    text-align: left;
    padding: 0.85rem 1rem;
    white-space: nowrap;
  }
  .bc-table tbody tr:nth-child(even) { background: #faf7f4; }
  .bc-table tbody tr:nth-child(odd) { background: #fff; }
  .bc-table tbody th { font-weight: 600; color: #2D6A4F; padding: 0.75rem 1rem; text-align: left; }
  .bc-table tbody td { padding: 0.75rem 1rem; color: #44403c; line-height: 1.45; }
  .bc-row-cag th, .bc-row-cag td { background: #f0fdf4 !important; }
  .bc-row-inactive { opacity: 0.65; }
  .bc-inactive-note { font-style: italic; color: #78716c; }
  .bc-yes { color: #2D6A4F; font-weight: 600; }
  .bc-no { color: #78716c; }
  .bc-verify { color: #78716c; font-style: italic; }
  .bc-this-badge {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    background: #2D6A4F;
    color: #fff;
    padding: 0.1rem 0.45rem;
    border-radius: 50px;
    vertical-align: middle;
  }
  .bc-breeder-link { color: #e8604c; text-decoration: underline; }
  .bc-breeder-link:hover { color: #d44e3b; }
  .bc-disclaimer {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.83rem;
    color: #78716c;
    font-style: italic;
  }
  .bc-agg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.25rem 0; }
  .bc-agg-card { background: #fff; border: 1px solid #e7e5e4; border-radius: 12px; padding: 1.25rem; }
  .bc-agg-name { font-family: 'Lora', Georgia, serif; font-size: 1rem; font-weight: 700; color: #2D6A4F; margin: 0 0 0.35rem; }
  .bc-agg-name a { color: inherit; text-decoration: none; }
  .bc-agg-name a:hover { text-decoration: underline; }
  .bc-agg-type { font-family: 'Sora', system-ui, sans-serif; font-size: 0.88rem; color: #57534e; line-height: 1.5; margin: 0 0 0.5rem; }
  .bc-agg-detail { font-family: 'Sora', system-ui, sans-serif; font-size: 0.85rem; color: #44403c; margin: 0.25rem 0 0; }
  .bc-adopt-list { padding-left: 1.5rem; margin: 0 0 1.1rem; }
  .bc-adopt-list li {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.97rem;
    line-height: 1.65;
    color: #44403c;
    margin-bottom: 0.45rem;
  }
  .bc-scam-card {
    background: #fff;
    border: 1px solid #f5c6c0;
    border-left: 4px solid #e8604c;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }
  .bc-scam-name {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.97rem;
    font-weight: 700;
    color: #c0392b;
    margin: 0 0 0.35rem;
  }
  .bc-scam-reason { font-family: 'Sora', system-ui, sans-serif; font-size: 0.92rem; line-height: 1.55; color: #44403c; margin: 0; }
  .bc-checklist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .bc-checklist-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.97rem;
    line-height: 1.6;
    color: #44403c;
  }
  .bc-check-mark { flex-shrink: 0; }
  .bc-faq-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .bc-faq-item { border: 1px solid #e7e5e4; border-radius: 12px; padding: 1rem 1.25rem; background: #fff; }
  .bc-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .bc-faq-q::-webkit-details-marker { display: none; }
  .bc-faq-a { font-family: 'Sora', system-ui, sans-serif; font-size: 0.98rem; line-height: 1.7; color: #44403c; margin: 0.75rem 0 0; max-width: 70ch; }
  .bc-links { padding-left: 1.5rem; margin: 0; }
  .bc-links li { font-family: 'Sora', system-ui, sans-serif; font-size: 1rem; line-height: 1.7; color: #44403c; margin-bottom: 0.5rem; }
  .bc-link { color: #e8604c; text-decoration: underline; }
  .bc-link:hover { color: #d44e3b; }
  @media (max-width: 767px) {
    .bc-container { padding: 0 16px; }
    .bc-agg-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) and (max-width: 1024px) { .bc-container { padding: 0 32px; } }
</style>
