      />
    </section>

    <!-- 8. AVAILABLE C.A.Gs GREYS -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="available-birds" class="py-16 px-4 scroll-mt-20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
          <div class="border-l-4 border-green pl-4">
            <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">This Week's Aviary</p>
            <h2 class="font-lora font-bold text-logo-dark">Which Hand-Raised C.A.Gs African Greys Are Ready Right Now?</h2>
            <p class="text-stone-500 mt-2 max-w-2xl text-sm leading-relaxed">Every Congo and Timneh African Grey we hand-feed here at C.A.Gs is PCR DNA-sexed, examined by a board-certified avian vet, CITES Appendix I-documented, and fully weaned at 12–16 weeks — and each one goes home on the exact diet and routine these care guides describe, with lifetime support from Mark &amp; Teri.</p>
          </div>
          <a href="/african-grey-parrot-for-sale/" class="inline-block bg-clay hover:bg-clay-dk text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors whitespace-nowrap">View All Birds →</a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
