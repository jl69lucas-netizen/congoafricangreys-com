    <!-- 9. FAQ -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="faq" class="scroll-mt-20 py-16 px-4 bg-warm-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Hub Questions</p>
          <h2 class="font-lora font-bold text-logo-dark">African Grey Care Questions, Answered</h2>
        </div>
        <div class="cag-faq-acc max-w-3xl mx-auto space-y-3">
          {faqs.map((item, i) => (
            <div class:list={["cag-faq-item bg-white rounded-2xl border border-line overflow-hidden", i === 0 && "open"]} style="box-shadow:0 2px 16px rgba(60,30,10,0.05);">
              <button type="button" class="cag-faq-q w-full flex items-center justify-between gap-4 text-left px-5 py-4" aria-expanded={i === 0 ? "true" : "false"}>
                <h3 class="font-lora font-bold text-[16px] text-logo-dark leading-snug m-0">{item.q}</h3>
                <svg class="cag-faq-chevron flex-shrink-0" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#e8604c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
