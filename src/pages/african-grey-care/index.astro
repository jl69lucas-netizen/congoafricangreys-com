---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot Care Hub | Diet, Training & Health Guides | CongoAfricanGreys.com";
const description = "Complete African Grey parrot care resource: diet, taming, lifespan, cage setup, and health guides — written by USDA-licensed breeders with 10+ years raising Congos and Timnehs in Midland, TX.";
const canonical = "https://congoafricangreys.com/african-grey-care/";
const ogType = "website";

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://congoafricangreys.com/african-grey-care/",
      "url": "https://congoafricangreys.com/african-grey-care/",
      "name": "African Grey Parrot Care Hub",
      "description": "Complete African Grey parrot care guides: diet, taming, lifespan, cage setup, and health — by USDA-licensed breeders.",
      "isPartOf": { "@id": "https://congoafricangreys.com/#website" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://congoafricangreys.com/" },
          { "@type": "ListItem", "position": 2, "name": "African Grey Care", "item": "https://congoafricangreys.com/african-grey-care/" }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How hard is it to care for an African Grey parrot?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "African Grey parrots require a significant time commitment — minimum 2–3 hours of daily interaction, a varied fresh-food diet, a large cage (minimum 36×24×48 inches), and annual avian vet visits. They are not beginner birds, but captive-bred hand-raised birds from reputable breeders are calmer and easier to manage than parent-raised or rescue Greys."
          }
        },
        {
          "@type": "Question",
          "name": "What do African Grey parrots eat?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A healthy African Grey diet is 60–70% high-quality pellets, 20–30% fresh vegetables and fruits (leafy greens, carrots, bell peppers, pomegranate), and 10% seeds/nuts as treats. Avoid avocado, chocolate, caffeine, onion, and xylitol — all toxic to parrots."
          }
        },
        {
          "@type": "Question",
          "name": "How long do African Grey parrots live?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "African Grey parrots live 40–60 years in captivity with proper care. Congo African Greys typically live 45–60 years; Timneh African Greys average 40–50 years. The primary lifespan factors are diet quality, veterinary care, mental stimulation, and stress reduction."
          }
        },
        {
          "@type": "Question",
          "name": "Do African Greys need an avian vet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes — African Greys should see a board-certified avian veterinarian for a wellness exam within 72 hours of arrival and annually thereafter. Parrots hide illness until critically sick, so proactive exams catch problems early. Budget $150–$300 per wellness visit."
          }
        }
      ]
    }
  ]
});
---

<BaseLayout title={title} description={description} canonical={canonical} ogType={ogType} schemaJson={schemaJson}>

<style>
  :root {
    --green: #2D6A4F;
    --clay: #e8604c;
    --cream: #faf7f4;
    --dark: #1c1a18;
    --muted: #6b6560;
    --border: #ede5dc;
    --green-lt: #eaf4ef;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .container-text { max-width: 760px; margin: 0 auto; }

  .breadcrumb a { color: var(--green); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .care-hero { background: var(--green); color: #fff; padding: 56px 0 48px; }
  .care-hero h1 { font-family: Lora, serif; font-size: clamp(1.7rem, 3.5vw, 2.6rem); font-weight: 700; margin: 0 0 16px; line-height: 1.2; }
  .care-hero p { font-family: Sora, sans-serif; font-size: 1.05rem; opacity: 0.9; max-width: 640px; margin: 0 0 28px; line-height: 1.65; }
  .hero-badge { display: inline-block; background: rgba(255,255,255,0.18); color: #fff; font-family: Sora, sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; padding: 6px 14px; border-radius: 50px; margin-bottom: 18px; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--clay); color: #fff; font-family: Sora, sans-serif; font-weight: 600; font-size: 0.95rem; padding: 13px 28px; border-radius: 50px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #c94d3a; }

  .spokes-section { padding: 64px 0; }
  .spokes-section h2 { font-family: Lora, serif; font-size: 1.7rem; color: var(--green); margin: 0 0 8px; }
  .spokes-intro { font-family: Sora, sans-serif; color: var(--muted); margin: 0 0 40px; max-width: 600px; font-size: 0.98rem; line-height: 1.65; }
  .spokes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .spoke-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 28px 24px; text-decoration: none; color: var(--dark); transition: box-shadow 0.2s, transform 0.15s; display: flex; flex-direction: column; }
  .spoke-card:hover { box-shadow: 0 6px 24px rgba(60,30,10,0.1); transform: translateY(-2px); }
  .spoke-icon { font-size: 1.6rem; margin-bottom: 12px; }
  .spoke-card h3 { font-family: Lora, serif; font-size: 1.1rem; color: var(--green); margin: 0 0 8px; }
  .spoke-card p { font-family: Sora, sans-serif; font-size: 0.87rem; color: var(--muted); margin: 0; line-height: 1.6; flex: 1; }
  .spoke-tag { display: inline-block; margin-top: 14px; font-size: 0.78rem; font-family: Sora, sans-serif; color: var(--clay); font-weight: 600; }

  .faq-section { padding: 56px 0; background: var(--cream); }
  .faq-section h2 { font-family: Lora, serif; font-size: 1.65rem; color: var(--green); margin: 0 0 32px; }
  details { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 12px; background: #fff; }
  summary { font-family: Sora, sans-serif; font-weight: 600; font-size: 0.97rem; padding: 18px 20px; cursor: pointer; list-style: none; color: var(--dark); }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; float: right; color: var(--clay); font-size: 1.2rem; font-weight: 400; }
  details[open] summary::after { content: '−'; }
  .faq-body { padding: 0 20px 18px; font-family: Sora, sans-serif; font-size: 0.92rem; color: var(--muted); line-height: 1.7; }

  .cta-section { padding: 64px 0; text-align: center; }
  .cta-section h2 { font-family: Lora, serif; font-size: 1.65rem; color: var(--dark); margin: 0 0 12px; }
  .cta-section p { font-family: Sora, sans-serif; color: var(--muted); max-width: 520px; margin: 0 auto 28px; font-size: 0.98rem; line-height: 1.65; }

  @media (max-width: 767px) {
    .spokes-grid { grid-template-columns: 1fr; gap: 16px; }
    .care-hero { padding: 40px 0 36px; }
    .spokes-section { padding: 48px 0; }
    .faq-section { padding: 44px 0; }
    .cta-section { padding: 48px 0; }
  }
  @media (min-width: 768px) and (max-width: 1024px) {
    .spokes-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<main id="main-content">

  <section class="care-hero">
    <div class="container">
      <Breadcrumb items={[
        { name: "Home", url: "/" },
        { name: "African Grey Care", url: "/african-grey-care/" }
      ]} />
      <div class="hero-badge">Care Resource Hub</div>
      <h1>African Grey Parrot Care: Complete Owner's Resource</h1>
      <p>Breeder-written care guides covering everything from day-one taming to lifelong diet, health, and enrichment — so your Grey thrives for 40–60 years.</p>
      <a href="/contact-us/" class="btn-primary">Ask a Care Question</a>
    </div>
  </section>

  <section class="spokes-section">
    <div class="container">
      <h2>African Grey Care Guides</h2>
      <p class="spokes-intro">Each guide below covers one core area of African Grey ownership in depth. Start with the complete care guide, then dive into the topics most relevant to you.</p>

      <div class="spokes-grid">

        <a href="/african-grey-parrot-care-guide/" class="spoke-card">
          <div class="spoke-icon">✅</div>
          <h3>Complete Care Guide</h3>
          <p>Housing, diet, enrichment, health, and socialization — everything you need from day one through the lifetime of your Grey.</p>
          <span class="spoke-tag">Start here →</span>
        </a>

        <a href="/african-grey-parrot-diet/" class="spoke-card">
          <div class="spoke-icon">🥦</div>
          <h3>Diet &amp; Nutrition</h3>
          <p>What African Greys eat, what to avoid, pellet brands, fresh food ratios, and supplement guidelines for optimal health.</p>
          <span class="spoke-tag">Read guide →</span>
        </a>

        <a href="/african-grey-parrot-lifespan/" class="spoke-card">
          <div class="spoke-icon">📅</div>
          <h3>Lifespan &amp; Aging</h3>
          <p>How long Congo and Timneh Greys live, what affects longevity, and how to support your bird at every life stage.</p>
          <span class="spoke-tag">Read guide →</span>
        </a>

        <a href="/best-african-grey-parrot-food/" class="spoke-card">
          <div class="spoke-icon">🌿</div>
          <h3>Best Foods &amp; Pellets</h3>
          <p>Top-rated pellet brands, safe fresh foods, foraging treat ideas, and foods that are toxic to African Greys.</p>
          <span class="spoke-tag">Read guide →</span>
        </a>

        <a href="/how-to-tame-african-grey-parrot/" class="spoke-card">
          <div class="spoke-icon">🤝</div>
          <h3>Taming &amp; Trust Training</h3>
          <p>Step-by-step taming method for new birds — covering first-day handling, step-up command, bite prevention, and bonding.</p>
          <span class="spoke-tag">Read guide →</span>
        </a>

        <a href="/buy-african-grey-parrot-near-me/" class="spoke-card">
          <div class="spoke-icon">🏡</div>
          <h3>Before You Buy</h3>
          <p>Is an African Grey right for your lifestyle? Time commitment, real cost, and what to expect in year one as a new Grey owner.</p>
          <span class="spoke-tag">Read guide →</span>
        </a>

      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container container-text">
      <h2>African Grey Care — Common Questions</h2>

      <details>
        <summary>How hard is it to care for an African Grey parrot?</summary>
        <div class="faq-body">African Grey parrots require a significant time commitment — minimum 2–3 hours of daily interaction, a varied fresh-food diet, a large cage (minimum 36×24×48 inches), and annual avian vet visits. They are not beginner birds, but captive-bred hand-raised birds from reputable breeders are calmer and easier to manage than parent-raised or rescue Greys.</div>
      </details>

      <details>
        <summary>What do African Grey parrots eat?</summary>
        <div class="faq-body">A healthy African Grey diet is 60–70% high-quality pellets, 20–30% fresh vegetables and fruits (leafy greens, carrots, bell peppers, pomegranate), and 10% seeds/nuts as treats. Avoid avocado, chocolate, caffeine, onion, and xylitol — all toxic to parrots.</div>
      </details>

      <details>
        <summary>How long do African Grey parrots live?</summary>
        <div class="faq-body">African Grey parrots live 40–60 years in captivity with proper care. Congo African Greys typically live 45–60 years; Timneh African Greys average 40–50 years. The primary lifespan factors are diet quality, veterinary care, mental stimulation, and stress reduction.</div>
      </details>

      <details>
        <summary>Do African Greys need an avian vet?</summary>
        <div class="faq-body">Yes — African Greys should see a board-certified avian veterinarian (not a general small-animal vet) for a wellness exam within 72 hours of arrival and annually thereafter. Parrots hide illness until they are critically sick, so proactive exams catch problems early. Budget $150–$300 per wellness visit.</div>
      </details>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Bring Home an African Grey?</h2>
      <p>Our captive-bred, hand-raised Congos and Timnehs are raised under these same care standards from day one.</p>
      <a href="/contact-us/" class="btn-primary">Inquire About Availability</a>
    </div>
  </section>

</main>

</BaseLayout>
