---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';

const title = "African Grey Care | Your Hub for African Grey Parrot Care Resources | Diet, Lifespan, Health & Taming Guides for Congo & Timneh Greys | C.A.Gs – Midland, TX";
const description = "The C.A.Gs African Grey care hub — one place routing you to every African Grey parrot care resource we publish: the full care guide, diet & best foods, lifespan, the health guarantee, taming, and FAQ. Breeder-written by Mark & Teri Benjamin for captive-bred, CITES Appendix I Congo & Timneh Greys.";
const canonical = "https://congoafricangreys.com/african-grey-care/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Care", url: "/african-grey-care/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + scam/adoption pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'care-resources',  label: 'All Guides',      part: 1 },
  { id: 'care-basics',     label: 'The Basics',      part: 1 },
  { id: 'congo-vs-timneh', label: 'Congo v Timneh',  part: 2 },
  { id: 'available-birds', label: 'Available',       part: 2 },
  { id: 'faq',             label: 'FAQ',             part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',      part: 3 },
];
const jumpPartNames = {
  1: 'Care Guides',
  2: 'Compare & Choose',
  3: 'Next Steps',
};

// ─── Available birds (cross-sell grid) — verified against data/clutch-inventory.json + price-matrix.json ───
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Energetic, curious, and impossible to ignore.',
    notes: "Hand-raised male, 4 months old. Thrives in a lively home where there's always something to watch." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'She mimics your laugh before you finish it.',
    notes: 'Premium hand-raised female, 3 months old. Full social training. Responds to her name already.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, easy, and the bird first-time owners dream of.',
    notes: 'Soft temperament, easy to handle. 1-year-old female — personality fully developed, ready to bond.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird. Bigger personality than you expected.',
    notes: 'Hand-raised male Timneh African Grey, 5 months old. Full social training. Ready to go home.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, and ready to come home.',
    notes: 'Hand-raised female Timneh African Grey, 6 months old. Full social training. Gentle and sociable.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two birds, one bond. They go together — and so do you.',
    notes: 'Unrelated pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised with full social training.' },
];

// ─── Care resource spokes — each routes to one deep guide (this is the hub's core) ───
const spokes = [
  {
    href: "/african-grey-parrot-care-guide/",
    eyebrow: "Start here",
    title: "Complete African Grey Care Guide",
    body: "Our full pillar guide — diet ratios, exact cage specs, enrichment, UV-B lighting, grooming, the common health issues, and vet schedule in one long read. Everything below is a deeper cut of a section in here.",
    cta: "Read the full care guide",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    href: "/african-grey-parrot-diet/",
    eyebrow: "Feeding",
    title: "African Grey Diet & Feeding Schedule",
    body: "The day-to-day plan: the 60–80% pellet base, which fresh vegetables deliver vitamin A, how we handle calcium, and a realistic feeding routine for a Congo or Timneh.",
    cta: "See the diet guide",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.5 19 2c1 2 2 4.2 2 8 0 5.5-4.8 10-10 10z"/><path d="M2 21c0-3 1.85-5.4 5.1-6"/></svg>`,
  },
  {
    href: "/best-african-grey-parrot-food/",
    eyebrow: "Food",
    title: "Best African Grey Parrot Food",
    body: "Which pellet brands we trust (and why), the safe fresh foods, foraging treat ideas, and the full toxic-food list every Grey owner must memorize before the first meal.",
    cta: "Compare the best foods",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
  },
  {
    href: "/african-grey-parrot-lifespan/",
    eyebrow: "Longevity",
    title: "African Grey Lifespan & Aging",
    body: "How long Congo and Timneh Greys really live, the husbandry factors that decide whether a bird hits the upper end of 40–60 years, and how to support a Grey at every life stage.",
    cta: "Read the lifespan guide",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>`,
  },
  {
    href: "/african-grey-parrot-health-guarantee/",
    eyebrow: "Health",
    title: "African Grey Health Guarantee",
    body: "The written health guarantee behind every C.A.Gs Grey, the avian-vet exam and screening we do before placement, and exactly what your documentation covers when your bird arrives.",
    cta: "See the health guarantee",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15.5 9.5"/></svg>`,
  },
  {
    href: "/how-to-tame-african-grey-parrot/",
    eyebrow: "Training",
    title: "How to Tame an African Grey",
    body: "Our step-by-step taming and trust-building method for a new bird — first-day handling, the step-up command, bite prevention, and building a bond that lasts decades.",
    cta: "Learn the taming method",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    href: "/african-grey-parrot-faq/",
    eyebrow: "Answers",
    title: "African Grey Parrot FAQ",
    body: "Quick, direct answers to the questions buyers and new owners ask us most — noise, being left alone, talking, sexing, legality, and the things people only think to ask after they own one.",
    cta: "Browse the full FAQ",
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#2D6A4F" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  },
];

// ─── FAQ (PAA-style HUB questions — routing-flavored, distinct from the pillar's care-detail FAQ) — mirrored into FAQPage schema ───
const faqs = [
  { q: "Where do I start with African Grey care?",
    a: "Start with our complete African Grey parrot care guide — it walks the whole picture (diet, cage, enrichment, lighting, health, and vet care) in order. From there, dive into the specific resource you need next: the diet guide for feeding, the best-food guide for pellet brands and the toxic list, the lifespan guide for the long view, or the taming guide for a brand-new bird. This hub page exists to point you to the right one fast." },
  { q: "What does African Grey care actually involve?",
    a: "At a glance: a pellet-based diet (60–80% formulated pellets plus fresh vegetables), a large stainless-steel cage (at least 36\" W × 24\" D × 48\" H for a Congo), 3–4 hours of daily interaction and out-of-cage time, full-spectrum UV-B light for vitamin D3, regular bathing, and an annual avian-vet wellness exam. Each of those areas has its own deep-dive guide linked from this hub — this page is the map, the linked guides are the detail." },
  { q: "Is the care different for a Congo versus a Timneh African Grey?",
    a: "The husbandry is identical — diet, lighting, enrichment, and vet care don't change between the two species. The differences are size and temperament: a Congo African Grey is larger and needs the bigger end of every cage and perch spec, and is more sensitive to change, while a Timneh is smaller, calmer, and often a more forgiving first bird. Our care guide covers the shared routine, and our Congo vs Timneh comparison shows the day-to-day differences side by side." },
  { q: "How much daily time does an African Grey really need?",
    a: "Plan on 3–4 hours of direct interaction and supervised out-of-cage time every day. Greys are intensely social and as intelligent as a young child, so chronic boredom and loneliness are the leading causes of feather-plucking and screaming. A Grey is not a low-maintenance pet — it needs your time, not just your space." },
  { q: "How long do African Grey parrots live, and what does that mean for me?",
    a: "Properly cared-for African Greys commonly live 40 to 60 years, and some reach 70+. That makes a Grey a genuine multi-decade, lifetime commitment — many owners name a guardian for their bird in their estate documents. We talk every C.A.Gs buyer through that reality before placement, and our lifespan guide explains the husbandry that decides whether a bird reaches the upper end of that range." },
  { q: "Are your African Greys captive-bred and documented?",
    a: "Yes. African Greys are protected under CITES Appendix I, and every C.A.Gs Grey is captive-bred in the USA — never wild-caught — and placed with full documentation: a CITES captive-bred certificate, a PCR DNA sexing certificate, a board-certified avian-vet health certificate, a hatch certificate, and a closed band. Captive-bred Appendix I birds are legal to own and transfer domestically with that paperwork, which we hand you before any money moves." },
  { q: "Do I need an avian vet before I bring an African Grey home?",
    a: "Yes — find one first. African Greys are prey animals that mask illness until it is advanced, so they need a board-certified avian or exotics vet (not a general small-animal clinic) for an annual wellness exam and any emergency. Lining up that vet before your bird arrives means you are never scrambling. Every C.A.Gs Grey also ships with an avian-vet health certificate dated within 10 days of travel." },
  { q: "How much does it cost to own an African Grey beyond the purchase price?",
    a: "Budget for first-year setup — a large cage ($300–$800), perches and toys ($100–$300), and an initial avian-vet visit ($75–$200) — plus ongoing annual costs for quality food ($200–$400), a wellness exam ($75–$200), and replacement enrichment. Shipping a C.A.Gs Grey is $185 for airport pickup or $350 for home delivery. The bird is a decades-long companion, so we encourage every family to plan the lifetime cost, not just the sticker price." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Care — Hub for Every African Grey Parrot Care Resource",
  description: "The C.A.Gs African Grey care hub: a breeder-written overview that routes owners to every African Grey parrot care resource — the full care guide, diet and best-food guides, lifespan, the health guarantee, taming, and FAQ — for captive-bred, CITES Appendix I Congo and Timneh Greys.",
  image: "https://congoafricangreys.com/african-grey-parrot-free-exploration.webp",
  inLanguage: "en-US",
  datePublished: "2024-09-01",
  dateModified: "2026-06-06",
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.png" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta
  extraHeadHtml={'<link rel="preload" as="image" href="/african-grey-parrot-free-exploration.webp" fetchpriority="high" type="image/webp" />'}>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="care-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green · photo-led) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="font-sora text-[11px] font-medium tracking-[0.12em] text-white/80">Care Resource Hub · Guides for Every Stage</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              African Grey Care
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">This is our hub for every African Grey parrot care resource we publish here at C.A.Gs — a quick overview of what owning a Grey involves, with a clear link out to the deep-dive guide for each topic.</p>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Mark &amp; Teri Benjamin have hand-raised <a href="/captive-bred-african-grey-parrot/">captive-bred Congo and Timneh African Greys</a> in Midland, Texas since 2014, and this is where we point families to the answer they need next.</p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#care-resources" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Browse Care Guides →</a>
              <a href="#available-birds" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">See Available Greys →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/african-grey-parrot-free-exploration.webp"
                  alt="Hand-raised Congo African Grey parrot out of its cage during daily enrichment time at the C.A.Gs aviary in Midland, Texas — the kind of daily care this hub helps you plan."
                  title="African Grey care hub — C.A.Gs, Midland TX"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "3–4h", label: "Daily Out-of-Cage" },
      { num: "60–80%", label: "Pellet Base" },
      { num: "40–60", label: "Yrs Commitment" },
      { num: "2014", label: "Hand-Raising Since" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The short version"
      heading="What Does African Grey Care Involve?"
      badge="6 essentials · 60-sec read"
      items={[
        { stat: "Pellets", label: "Daily Diet", body: "A base of 60–80% formulated pellets plus fresh veg — never seed-only, never avocado. Full plan in our diet guide." },
        { stat: '48"', label: "Cage Height", body: "A Congo needs at least 36\" W × 24\" D × 48\" H in stainless steel; the care guide has the full spec." },
        { stat: "3–4 hr", label: "Daily Time", body: "Greys are as social as a young child — they need hours of interaction and out-of-cage time, not just space." },
        { stat: "UV-B", label: "Light + D3", body: "Full-spectrum UV-B lets a Grey make the vitamin D3 it needs to absorb calcium and avoid hypocalcemia." },
        { stat: "Annual", label: "Avian Vet", body: "A yearly wellness exam catches the illness a Grey instinctively hides until it is advanced." },
        { stat: "40–60 yr", label: "Lifespan", body: "An African Grey is a multi-decade commitment — care planning is care for life, not just for a year." },
      ]}
    />

    <!-- 4. TOC (grouped-by-part) -->
    <nav class="toc-care py-10 px-4 bg-warm-white md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this hub</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">6 sections · your map to every care resource</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Find your guide</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "Every African Grey Care Guide, in One Place", href: "#care-resources" },
                  { n: 2, t: "The 5 Pillars of African Grey Care", href: "#care-basics" },
                  { n: 3, t: "Do Congo & Timneh Greys Need Different Care?", href: "#congo-vs-timneh" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Birds & answers</p>
              <ol class="space-y-0">
                {[
                  { n: 4, t: "Which Hand-Raised C.A.Gs Greys Are Available?", href: "#available-birds" },
                  { n: 5, t: "African Grey Care Questions, Answered", href: "#faq" },
                  { n: 6, t: "Bring Home a Captive-Bred African Grey", href: "#contact" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- 5. CARE RESOURCE GRID (the hub's core — one card per spoke) -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.png" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="care-resources" class="py-16 px-4 scroll-mt-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-8 border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">Care Resource Library</p>
          <h2 class="font-lora font-bold text-logo-dark">What's Inside Our African Grey Care Library?</h2>
          <p class="text-stone-600 leading-relaxed mt-3 text-[15px]" style="max-width:70ch;">Rather than cram every detail onto one page, here at C.A.Gs we keep a focused guide for each part of African Grey ownership — and this hub is the index that points you to the right one. New to Greys?</p>
          <p class="text-stone-600 leading-relaxed mt-3 text-[15px]" style="max-width:70ch;">Begin with our <a href="/african-grey-parrot-care-guide/">complete African Grey care guide</a>, then branch into the specific topics below. Each card links straight to a guide written from the same routine we use to hand-raise our own birds.</p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {spokes.map((s) => (
            <a href={s.href} class="spoke-card group flex flex-col bg-white rounded-2xl border border-line p-7 no-underline" style="box-shadow:0 4px 24px rgba(60,30,10,0.06);">
              <div class="spoke-icon mb-3.5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-green/[0.08]" set:html={s.icon}></div>
              <p class="font-sora text-[11px] font-bold uppercase tracking-[0.14em] text-clay-ink mb-1">{s.eyebrow}</p>
              <h3 class="font-lora font-bold text-xl text-logo-dark leading-snug">{s.title}</h3>
              <p class="font-sora text-stone-600 mt-2 text-[14px] leading-relaxed flex-1">{s.body}</p>
              <span class="font-sora mt-4 inline-flex items-center gap-1 text-sm font-semibold text-clay-ink group-hover:gap-2 transition-all">{s.cta} →</span>
            </a>
