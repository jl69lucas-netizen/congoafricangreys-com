  <script is:inline>
    // FAQ accordion (smooth open/close) — mirrors homepage/care-guide pattern
    (function () {
      const qs = document.querySelectorAll('.cag-faq-q');
      if (!qs.length) return;
      qs.forEach(btn => btn.addEventListener('click', () => {
        const item = btn.closest('.cag-faq-item');
        const open = item.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['care-resources','care-basics','congo-vs-timneh','available-birds','faq','contact'];
      var labels = {
        'care-basics':     'The Five Care Basics',
        'congo-vs-timneh': 'Congo vs Timneh Care',
        'available-birds': 'Available Greys',
        'faq':             'Care FAQ',
        'contact':         'Ask C.A.Gs',
      };
      for (var i = 0; i < ids.length - 1; i++) {
        var cur = document.getElementById(ids[i]);
        if (!cur) continue;
        var nav = document.createElement('div');
        nav.className = 'section-next-nav';
        nav.innerHTML = '<a href="#' + ids[i + 1] + '" class="section-next-link">&#8595; Continue: ' + (labels[ids[i + 1]] || ids[i + 1]) + '</a>';
        cur.appendChild(nav);
      }
    })();
  </script>
</BaseLayout>

<style is:global>
  /* ============================================================
     CARE-HUB PAGE — Direction-D-aware interior wrapper (.care-d)
     Mirrors the homepage .home-d + care-guide seam/lead scope so the
     global body.theme-d (Newsreader/IBM Plex, lead paragraphs, eyebrow
     ticks, card + button motion) applies and the seam-logo divider
     renders correctly. Theme is NOT re-implemented here.
     ============================================================ */
  .care-d { --rule: rgba(45,106,79,.16); }

  /* AA: clay as small readable text on this page's LIGHT sections → #b04228 (4.5:1).
     Mirrors the homepage .home-d rule. Clay on the green hero/CTA stays bright. */
  .care-d a.text-clay, .care-d .text-clay { color:#b04228; }
  /* Hero clay accent stays bright; clay FILLS keep white text (global .bg-clay =
     --clay-ink #bd4129, 5.3:1 — the old color:inherit leaked dark stone = FAIL). */
  .care-d .hero-v3-b .text-clay { color:inherit; }
  .care-d .bg-clay { color:#fff; }

  /* CompareTableE ships text-3xl (30px) on its H2 — ties mobile H1. Cap on small
     screens, desktop unchanged at 30px. */
  .care-d h2.text-3xl { font-size:clamp(1.375rem, 3.8vw, 1.875rem); }

  /* Jump targets clear the 96px sticky header; respect reduced motion. */
  .care-d section[id], .care-d div[id] { scroll-margin-top:110px; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior:auto; } }

  /* "↓ Continue:" section next-nav (JS-injected; this block is is:global). */
  .care-d .section-next-nav { text-align:right; padding-top:18px; margin-top:14px; border-top:1px solid #ede5dc; }
  .care-d .section-next-link { font-family:'IBM Plex Sans',sans-serif; font-size:.85rem; font-weight:600;
    color:#b04228; text-decoration:none; display:inline-block; padding:10px 0 10px 12px; margin:-10px 0; }
  .care-d .section-next-link:hover { text-decoration:underline; }

  /* Woven in-content links: clay, underlined, AA-safe — applies to the
     mid-sentence internal/external links in body copy (not buttons/spoke cards). */
  .care-d p a:not(.rounded-full):not(.bg-clay):not(.no-underline),
  .care-d li a:not(.rounded-full):not(.bg-clay):not(.no-underline) {
    color:#b04228; font-weight:500; text-decoration:underline;
    text-decoration-color:rgba(176,66,40,.35); text-underline-offset:2px;
    transition:text-decoration-color .2s ease;
  }
  .care-d p a:not(.rounded-full):not(.bg-clay):not(.no-underline):hover,
  .care-d li a:not(.rounded-full):not(.bg-clay):not(.no-underline):hover { text-decoration-color:#b04228; }

  /* Spoke resource cards — soft-warm lift on hover (matches Direction-D article cards) */
  .care-d .spoke-card { color:#1c1a18; transition:transform .18s cubic-bezier(.22,1,.36,1), box-shadow .18s ease; }
  .care-d .spoke-card:hover { transform:translateY(-4px); box-shadow:0 14px 38px rgba(60,30,10,0.14) !important; }
  .care-d .spoke-card h3 { color:#2D6A4F; }

  /* External-link outward arrow affordance (decision 2026-06-03) on this page's
     in-content links, mirroring .home-d. Internal links stay marker-free. */
  .care-d a[target="_blank"]::after { content:"\2197"; font-size:.7em; line-height:0; vertical-align:super; opacity:.5; margin-left:.12em; }

  /* Section seam — centered wordmark divider (verbatim scope from index.astro / care-guide) */
  .care-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
  .care-d .cag-seam img{ height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
  @media (max-width:600px){ .care-d > .cag-seam{ gap:16px; } .care-d .cag-seam img{ height:24px; } }
</style>
