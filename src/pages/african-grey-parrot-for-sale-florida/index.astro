---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "African Grey Parrot for Sale Florida | Congo African Greys";
const description = "Meet Carl — a 1-year-old male Congo African Grey parrot for sale in Florida. $2,500. Hand-raised, DNA sexed, vet-certified. Ships nationwide. USDA licensed breeder.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-florida/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">Available Now · Ships Nationwide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">African Grey Parrot for Sale Florida</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Meet Carl — a bold, confident 1-year-old male Congo African Grey. Hand-raised in Midland, TX. CITES documented, DNA sexed, vet-certified.</p>
    </div>
  </section>

  <!-- Bird profile -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Images -->
      <div class="space-y-4">
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-African-Grey-Parrot-for-sale--600x743.jpeg"
          alt="Carl — trained Congo African Grey parrot for sale in Florida"
          class="w-full rounded-2xl shadow-md"
          loading="eager"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-old-African-Grey-Parrot-for-sale--600x531.jpeg"
          alt="2-year-old African Grey parrot for sale"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Product card -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8 sticky top-24">
        <div class="mb-2">
          <span class="bg-clay text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">Sale</span>
        </div>
        <h2 class="font-lora font-bold text-2xl text-logo-dark mb-1">Carl — Congo African Grey</h2>
        <p class="text-stone-500 text-sm mb-4">1-year-old male · Midland, Texas</p>
        <div class="mb-6">
          <span class="text-stone-400 line-through text-sm mr-2">$4,500</span>
          <span class="font-lora font-bold text-3xl text-clay">$2,500</span>
        </div>
        <ul class="text-sm text-stone-600 space-y-2 mb-8">
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ships daily nationwide</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ready to leave</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> DNA sexed &amp; vet-certified</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> CITES Appendix II documented</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> 3-day health guarantee</li>
        </ul>
        <a
          href="/contact-us/"
          class="block text-center bg-clay text-white font-semibold py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
        >
          Send Inquiry About Carl
        </a>
        <p class="text-xs text-stone-400 text-center mt-3">$200 deposit reserves your bird · We reply within 24 hrs</p>
      </div>
    </div>
  </section>

  <!-- About Carl -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Meet Carl — "Big C"</h2>
      <p class="text-stone-600 leading-relaxed mb-4">
        Carl is a bold, confident 1-year-old male Congo African Grey with a big personality to match his nickname. Nicknamed "Big C," Carl is a playful, intelligent bird who enjoys exploring, mimicking sounds, and engaging with people. His charming personality and affectionate nature make him an ideal family pet.
      </p>
      <p class="text-stone-600 leading-relaxed mb-6">
        Carl has been hand-raised from hatching in Mark &amp; Teri Benjamin's home aviary in Midland, Texas — socialized with the family daily so he's comfortable around people of all ages.
      </p>
      <ul class="space-y-3 text-stone-600 text-sm">
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Vet-Checked &amp; Vaccinated</strong> — Carl is in perfect health, with regular check-ups documented.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Tame &amp; Friendly</strong> — Hand-raised to ensure a loving and social temperament.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">CITES Documented</strong> — Full captive-bred documentation including hatch certificate, band number, and DNA cert.</div></li>
      </ul>
    </div>
  </section>

  <!-- Why African Grey -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Why Choose an African Grey Parrot?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Intelligence Beyond Compare', body: 'African Greys are capable of learning hundreds of words and phrases — considered the Einsteins of the bird world.' },
          { title: 'Strong Bond with Owners', body: 'These parrots develop deep emotional connections with their caregivers and thrive on daily interaction.' },
          { title: 'Long Lifespan', body: 'With proper care, an African Grey can live up to 60 years — a true lifelong companion.' },
          { title: 'Playful & Entertaining', body: 'Their curiosity, mimicking skills, and playful behavior make them endlessly fun for the whole family.' },
        ].map(card => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-stone-100">
            <h3 class="font-lora font-semibold text-logo-dark mb-2">{card.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does Carl cost?', a: 'Carl is priced at $2,500. A $200 deposit reserves him. Nationwide shipping is $185 via Delta or United Airlines.' },
          { q: 'Do you ship to Florida?', a: 'Yes — we ship IATA-compliant to all 50 states including Florida. Birds arrive at your nearest airport with a health certificate.' },
          { q: 'What documentation comes with Carl?', a: 'Carl ships with CITES captive-bred certificate, hatch certificate, band number, DNA sexing certificate, and avian vet health certificate dated within 10 days of shipment.' },
          { q: 'Can I visit before buying?', a: 'Yes — aviary visits are by appointment at our Midland, Texas location. Contact us to schedule.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />
  <CTA headline="Reserve Carl Today" sub="Limited availability. A $200 deposit holds your bird while we finalize shipping details." />
  <Schema type="organization" />

</BaseLayout>
