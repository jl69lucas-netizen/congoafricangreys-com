---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot for Sale Florida | Congo African Greys";
const description = "Meet Roys — a 4-month-old male Congo African Grey parrot for sale in Florida. $2,300. Hand-raised, DNA sexed, vet-certified. Ships nationwide. USDA licensed breeder.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-florida/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Grey Parrots for Sale", url: "/african-grey-parrot-for-sale/" },
      { name: "African Grey for Sale in Florida", url: "/african-grey-parrot-for-sale-florida/" }
      ]} />
  </div>

  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">Available Now · Ships Nationwide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">African Grey Parrot for Sale Florida</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Meet Roys — an energetic, curious 4-month-old male Congo African Grey. Hand-raised in Midland, TX. CITES documented, DNA sexed, vet-certified.</p>
    </div>
  </section>

  <!-- Bird profile -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Images -->
      <div class="space-y-4">
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-African-Grey-Parrot-for-sale--600x743.jpeg"
          alt="Roys — hand-raised Congo African Grey parrot for sale in Florida"
          class="w-full rounded-2xl shadow-md"
          loading="eager"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-old-African-Grey-Parrot-for-sale--600x531.jpeg"
          alt="4-month-old male Congo African Grey parrot for sale"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Product card -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8 sticky top-24">
        <div class="mb-2">
          <span class="bg-clay text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">Available</span>
        </div>
        <h2 class="font-lora font-bold text-2xl text-logo-dark mb-1">Roys — Congo African Grey</h2>
        <p class="text-stone-500 text-sm mb-4">4-month-old male · Midland, Texas</p>
        <div class="mb-6">
          <span class="font-lora font-bold text-3xl text-clay">$2,300</span>
        </div>
        <ul class="text-sm text-stone-600 space-y-2 mb-8">
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ships daily nationwide</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ready to leave</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> DNA sexed &amp; vet-certified</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> CITES Appendix II documented</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> 3-day health guarantee</li>
        </ul>
        <a
          href="/contact-us/"
          class="block text-center bg-clay text-white font-semibold py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
        >
          Send Inquiry About Roys
        </a>
        <p class="text-xs text-stone-400 text-center mt-3">$200 deposit reserves your bird · We reply within 24 hrs</p>
      </div>
    </div>
  </section>

  <!-- About Roys -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Meet Roys — Your New Best Friend</h2>
      <p class="text-stone-600 leading-relaxed mb-4">
        Roys is an energetic, curious 4-month-old male Congo African Grey with a personality that fills the room. Playful and impossible to ignore, Roys is a hand-raised baby who is already bonding with everyone around him. His affectionate nature and quick mind make him an ideal companion for an active family or a first-time African Grey owner.
      </p>
      <p class="text-stone-600 leading-relaxed mb-6">
        Roys has been hand-raised from hatching in Mark &amp; Teri Benjamin's home aviary in Midland, Texas — socialized with the family daily so he's comfortable around people of all ages.
      </p>
      <ul class="space-y-3 text-stone-600 text-sm">
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Vet-Checked &amp; Healthy</strong> — Roys is in perfect health, with avian vet clearance documented.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Tame &amp; Friendly</strong> — Hand-raised to ensure a loving and social temperament.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">CITES Documented</strong> — Full captive-bred documentation including hatch certificate, band number, and DNA cert.</div></li>
      </ul>
    </div>
  </section>

  <!-- Why African Grey -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Why Choose an African Grey Parrot?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Intelligence Beyond Compare', body: 'African Greys are capable of learning hundreds of words and phrases — considered the Einsteins of the bird world.' },
          { title: 'Strong Bond with Owners', body: 'These parrots develop deep emotional connections with their caregivers and thrive on daily interaction.' },
          { title: 'Long Lifespan', body: 'With proper care, an African Grey can live up to 60 years — a true lifelong companion.' },
          { title: 'Playful & Entertaining', body: 'Their curiosity, mimicking skills, and playful behavior make them endlessly fun for the whole family.' },
        ].map(card => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-stone-100">
            <h3 class="font-lora font-semibold text-logo-dark mb-2">{card.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does Roys cost?', a: 'Roys is priced at $2,300. A $200 deposit reserves him. Nationwide shipping is $185 via Delta, United, or American Airlines.' },
          { q: 'Do you ship to Florida?', a: 'Yes — we ship IATA-compliant to all 50 states including Florida. Birds arrive at your nearest airport with a health certificate.' },
          { q: 'What documentation comes with Roys?', a: 'Roys ships with CITES captive-bred certificate, hatch certificate, band number, DNA sexing certificate, and avian vet health certificate dated within 10 days of shipment.' },
          { q: 'Can I visit before buying?', a: 'Yes — aviary visits are by appointment at our Midland, Texas location. Contact us to schedule.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:2.5rem 0;background:#faf7f4;">
    <div class="container">
      <h2 style="font-family:'Lora',serif;font-weight:700;color:#2D6A4F;margin-bottom:1rem;">Browse Our African Grey Variants</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;margin-top:1rem;">
        <a href="/congo-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Congo African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The classic large variant — $1,700–$3,500. Bright red tail, exceptional talker.</div>
        </a>
        <a href="/timneh-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Timneh African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The compact, apartment-friendly variant — $1,500–$1,600. Maroon tail, calmer temperament.</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Florida city navigation -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-lora font-bold text-xl text-logo-dark mb-6">Browse African Grey Parrots by City in Florida</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { name: "Miami", slug: "african-grey-parrot-for-sale-miami" },
          { name: "Orlando", slug: "african-grey-parrot-for-sale-orlando" },
          { name: "Tampa", slug: "african-grey-parrot-for-sale-tampa" },
          { name: "Jacksonville", slug: "african-grey-parrot-for-sale-jacksonville" },
        ].map((c) => (
          <a href={`/${c.slug}/`} class="bg-white border border-stone-200 rounded-full px-5 py-2 font-sora text-sm font-semibold text-logo-dark hover:border-clay hover:text-clay transition-colors shadow-sm">
            {c.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />
  <CTA headline="Reserve Roys Today" sub="Limited availability. A $200 deposit holds your bird while we finalize shipping details." />
  <Schema type="organization" />

</BaseLayout>
