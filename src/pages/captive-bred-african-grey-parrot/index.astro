<style is:global>
  /* ============================================================
     CAPTIVE-BRED PAGE — Direction-D-aware interior wrapper (.captive-d)
     body.theme-d already supplies Newsreader/IBM Plex, lead paragraphs,
     eyebrow ticks, card + button motion. This only scopes seam + links.
     ============================================================ */
  .captive-d { --rule: rgba(45,106,79,.16); }

  /* Smooth in-page jumps (JumpRail + TOC + next-nav) with reduced-motion guard. */
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

  /* Sticky header is ~96px tall — keep jumped-to headings visible below it. */
  .captive-d [id] { scroll-margin-top: 110px; }

  /* Hero eyebrow — homepage HeroV3 pattern: no pill, no uppercase. */
  .captive-d .hero-eyebrow { font-size:10px; font-weight:500; letter-spacing:.12em; color:rgba(255,255,255,.75); text-transform:none; }
  @media (min-width:768px) { .captive-d .hero-eyebrow { font-size:11px; } }

  /* H2 must stay below the 30px mobile H1 — CompareTableE ships text-3xl (30px).
     Clamp keeps desktop at 36px, drops mobile to ~22px. */
  .captive-d h2.text-3xl { font-size: clamp(1.375rem, 3.8vw, 2.25rem); }

  /* AA: clay as small readable text on LIGHT sections → #b04228 (4.5:1). */
