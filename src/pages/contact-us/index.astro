---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';
import MapPin from '../../components/MapPin.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';

const title = "Contact Us — Inquire About Our Available African Grey Parrots, Pricing & Nationwide Shipping (We Reply Within 24 Hours) | C.A.Gs – Midland, TX";
const description = "Reach us — Mark & Teri Benjamin, USDA AWA licensed African Grey breeders in Midland, Texas. Send your inquiry through our adoption application and we reply within 24 hours. We ship nationwide ($185 airport pickup · $350 home delivery) with free local pickup here in Midland, TX.";
const canonical = "https://congoafricangreys.com/contact-us/";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": "https://congoafricangreys.com/contact-us/#webpage",
  "url": "https://congoafricangreys.com/contact-us/",
  "name": "Contact C.A.Gs – Midland, TX",
  "description": "Inquiry and adoption application page for C.A.Gs, captive-bred African Grey parrot breeders in Midland, Texas.",
  "inLanguage": "en-US",
  "about": { "@id": "https://congoafricangreys.com/#organization" },
  "isPartOf": { "@type": "WebSite", "url": "https://congoafricangreys.com/", "name": "C.A.Gs – Midland, TX" }
};
---

<BaseLayout {title} {description} {canonical} hideGlobalCta>

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "Contact Us", url: "/contact-us/" }
    ]} />
  </div>

  <section class="bg-logo-dark text-cream py-9 md:py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Contact Us</h1>
      <p class="text-cream/80 text-lg">We reply to every inquiry within 24 hours. Please tell us which bird or variant you're interested in.</p>
      <p class="cag-updated cag-updated--hero">Updated June 2026</p>
    </div>
  </section>

  <CounterSnippet stats={[
    { num: "24h", label: "Reply Guarantee" },
    { num: "$185", label: "Airport Pickup" },
    { num: "$350", label: "Home Delivery" },
    { num: "Midland, TX", label: "Home Aviary" },
  ]} />

  <InquiryForm />

  <!-- Google Map -->
  <section class="py-8 px-4">
    <div class="max-w-4xl mx-auto text-center mb-6">
      <h2 class="font-lora font-bold text-2xl text-logo-dark">Local Pickup &amp; Where to Find Us</h2>
    </div>
    <div class="cag-map-wrap max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-md" style="height: 300px;">
      <iframe
        src="https://maps.google.com/maps?q=Briaroaks+Ct%2C+Midland%2C+TX%2C+USA&z=14&hl=en&t=m&output=embed&iwloc=near"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        title="Congo African Greys — Midland, TX"
      ></iframe>
      <MapPin />
    </div>
    <div class="max-w-4xl mx-auto text-center mt-4">
      <p class="text-ink font-semibold text-[15px]"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M5 17H3v-5l2-5h12l2 5v5h-2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><line x1="6" y1="7" x2="18" y2="7"/></svg> Local Pickup · Free pickup in Midland, TX — call to schedule.</p>
      <p class="text-stone-600 text-sm mt-1 mx-auto" style="max-width:60ch;"><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.125em" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> For the privacy and safety of our birds and family, the exact pickup address is confirmed by phone once your inquiry is verified.</p>
    </div>
  </section>

  <Schema type="local-business" />
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <script is:inline>
    if (window.location.search.includes('success=true')) {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'generate_lead', {
          event_category: 'inquiry_form',
          event_label: 'bird_inquiry',
          page_location: window.location.href
        });
      }
    }
  </script>
</BaseLayout>
