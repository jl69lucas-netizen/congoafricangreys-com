---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickAnswer from '../components/cag-blog-quick-answer.astro';
import Callout from '../components/cag-blog-callout.astro';
import ComparisonTable from '../components/cag-blog-comparison-table.astro';
import BreederNote from '../components/cag-blog-breeder-note.astro';
import MythFact from '../components/cag-blog-myth-fact.astro';
import DecisionTree from '../components/cag-blog-decision-tree.astro';
---
<BaseLayout
  title="scratch"
  description="scratch"
  canonical="https://congoafricangreys.com/scratch-blog-components/"
  robots="noindex, nofollow"
  hideGlobalCta
>
  <main class="container container-text" style="padding:2rem 0">
    <QuickAnswer title="African Grey Cage Quick Answer" rows={[
      { label: 'Minimum cage', value: '36" × 24" × 48"' },
      { label: 'Recommended',  value: '48" wide, 5–7 perches' },
      { label: 'Daily out-time', value: '4–5 hours' },
    ]} />
    <BreederNote>We hand-raise every chick here in Midland, TX — each one is weaned on Harrison's High Potency pellets before leaving our aviary.</BreederNote>
    <BreederNote label="From our aviary">Custom label example — works for section-specific notes too.</BreederNote>
    <MythFact
      heading="Common misconception"
      myth="African Greys bond to only one person and ignore everyone else."
      fact="With proper early socialisation, Greys build trust with every household member — we handle every chick in rotation from day one here at C.A.Gs."
    />
    <MythFact
      myth="A bigger cage is always better for an African Grey."
      fact="Cage dimensions matter less than perch variety, foraging enrichment, and 4–5 hours of supervised out-of-cage time daily."
    />
    <Callout variant="mistake">Never place food bowls directly under perches.</Callout>
    <DecisionTree
      question="Is an African Grey parrot right for you?"
      branches={[
        { answer: 'I have 4+ hours daily', result: 'A Congo African Grey is an excellent fit — ours thrive with full household engagement.' },
        { answer: 'I travel 2+ weeks at a time', result: 'Consider a trusted bird-sitter network before committing; Greys bond deeply and hate disruption.' },
        { answer: 'I have young children (under 5)', result: 'Supervise all interactions — our Greys are hand-raised and social, but still need calm introductions.' },
        { answer: 'First-time bird owner', result: 'Talk to us first — we match each bird to the buyer\'s experience level.' },
      ]}
    />
    <Callout variant="tip">Rotate cage toys weekly to prevent boredom.</Callout>
    <ComparisonTable
      columns={['Setup Item','Minimum','Recommended','Ideal']}
      rows={[
        {item:'Cage Width', values:['36"','48"','60"+']},
        {item:'Perches', values:['2','4','5–7']},
        {item:'Toys', values:['3','6','Weekly rotation']},
        {item:'Daily Out-Time', values:['2h','4h','5h+']},
      ]}
      verdict="A 48-inch cage with 4–7 rotating perches and 4–5 hours out daily is the sweet spot we raise our Greys in."
    />
  </main>
</BaseLayout>
