---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot Guide: Complete Species Overview | CongoAfricanGreys.com";
const description = "Complete African Grey parrot guide: Congo vs Timneh variants, intelligence, 40–60 year lifespan, size, diet, cage needs, CITES status and a buyer's checklist.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-guide/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Parrot Guide", url: "/african-grey-parrot-guide/" },
];

const toc = [
  { id: "overview", label: "Species Overview" },
  { id: "variants", label: "Congo vs Timneh Variants" },
  { id: "intelligence", label: "Intelligence & Talking" },
  { id: "lifespan", label: "Lifespan" },
  { id: "size", label: "Size & Appearance" },
  { id: "diet", label: "Diet & Nutrition" },
  { id: "environment", label: "Cage & Environment" },
  { id: "cites", label: "CITES Status" },
  { id: "buying", label: "Buying Guide" },
  { id: "faq", label: "FAQ" },
];

const faqs = [
  {
    q: "What is an African Grey parrot?",
    a: "The African Grey parrot (Psittacus erithacus) is a medium-sized parrot native to the rainforests of equatorial Africa. It is widely regarded as the most intelligent companion parrot, capable of learning hundreds of words and using them in context. There are two recognized variants: the Congo African Grey and the Timneh African Grey. Both are CITES Appendix II species and must be captive-bred with documentation to be sold legally in the United States.",
  },
  {
    q: "What is the difference between a Congo and a Timneh African Grey?",
    a: "The Congo African Grey is the larger variant, roughly 12–14 inches long and 400–600 grams, with light silver-grey plumage, a bright red tail and a solid black beak. The Timneh African Grey is smaller at 9–11 inches and 275–375 grams, with darker charcoal plumage, a maroon tail and a horn-colored upper beak. Both are equally intelligent; Timnehs often talk earlier and tend to be calmer.",
  },
  {
    q: "How long do African Grey parrots live?",
    a: "African Grey parrots live 40–50 years in the wild and up to 60 years in captivity with proper nutrition, veterinary care and enrichment. Owning an African Grey is a multi-decade commitment that should be planned as a lifelong responsibility, including arrangements for the bird's care should it outlive its owner.",
  },
  {
    q: "Can African Grey parrots really talk?",
    a: "Yes. African Grey parrots are the most accomplished talking birds in the world. They can learn hundreds of words and, as demonstrated by Dr. Irene Pepperberg's decades of research with the African Grey named Alex, they can use words in correct context, count, identify colors and shapes, and grasp simple abstract concepts comparable to a young child.",
  },
  {
    q: "How big does an African Grey parrot get?",
    a: "A Congo African Grey grows to about 12–14 inches (33 cm) long and weighs 400–600 grams. A Timneh African Grey is smaller, reaching 9–11 inches and 275–375 grams. Both have a wingspan of roughly 18–20 inches and reach full adult size by about one year of age.",
  },
  {
    q: "What do African Grey parrots eat?",
    a: "A healthy African Grey diet is built on a high-quality formulated pellet making up 60–70% of intake, supplemented with fresh vegetables, leafy greens and limited fruit. Calcium-rich foods are especially important because African Greys are prone to calcium deficiency. Avocado, chocolate, caffeine and salty or sugary human foods are toxic and must never be fed.",
  },
  {
    q: "Are African Grey parrots legal to own?",
    a: "Yes, captive-bred African Greys are legal to own in the United States. African Greys are listed under CITES Appendix II, which regulates international trade to protect wild populations. Wild-caught birds cannot be legally sold; every African Grey from CongoAfricanGreys.com is captive-bred and supplied with CITES captive-bred documentation, a hatch certificate, DNA sexing results and an avian veterinary health certificate.",
  },
  {
    q: "How much does an African Grey parrot cost?",
    a: "At CongoAfricanGreys.com a captive-bred Congo African Grey ranges from $1,700 to $3,500 depending on age and training, and a Timneh African Grey ranges from $1,500 to $1,600. First-year setup — cage, perches, toys and an initial vet visit — typically adds $475 to $1,300. See our African Grey parrot price guide for a full breakdown.",
  },
  {
    q: "Are African Grey parrots good pets for beginners?",
    a: "African Greys are intelligent, sensitive birds that need daily interaction, mental enrichment and a consistent routine, so they suit committed owners more than casual first-time bird keepers. Beginners who are ready for the commitment often do well starting with a calm, fully weaned, hand-raised Timneh from a reputable breeder.",
  },
  {
    q: "How much space and attention does an African Grey need?",
    a: "An African Grey needs a cage at least 24 x 24 x 36 inches with horizontal bars, plenty of out-of-cage time, and 2–4 hours of daily social interaction and enrichment. They are flock animals that bond closely with their family and can develop feather-destructive behavior or stress if left isolated for long periods.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Guide: Complete Species Overview",
  description: description,
  about: {
    "@type": "Thing",
    name: "African Grey Parrot",
    alternateName: "Psittacus erithacus",
    description:
      "The African Grey parrot (Psittacus erithacus) is a medium-sized Old World parrot native to equatorial Africa, recognized as the most intelligent companion parrot and listed under CITES Appendix II.",
  },
  author: {
    "@type": "Organization",
    name: "Congo African Greys",
    url: "https://congoafricangreys.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    url: "https://congoafricangreys.com",
  },
  mainEntityOfPage: canonical,
};

const variantRows = [
  { attr: "Scientific name", congo: "Psittacus erithacus erithacus", timneh: "Psittacus erithacus timneh" },
  { attr: "Body length", congo: "12–14 in (33–36 cm)", timneh: "9–11 in (28–33 cm)" },
  { attr: "Weight", congo: "400–600 grams", timneh: "275–375 grams" },
  { attr: "Plumage", congo: "Light silver-grey", timneh: "Darker charcoal-grey" },
  { attr: "Tail color", congo: "Bright cherry-red", timneh: "Dark maroon" },
  { attr: "Upper beak", congo: "Solid black", timneh: "Horn / bone-colored tip" },
  { attr: "Temperament", congo: "Affectionate, sensitive, can be reserved", timneh: "Calm, confident, easygoing" },
  { attr: "Talking", congo: "Exceptional clarity, large vocabulary", timneh: "Often talks earlier, slightly softer" },
  { attr: "Price range", congo: "$1,700 – $3,500", timneh: "$1,500 – $1,600" },
  { attr: "Lifespan", congo: "40–60 years", timneh: "40–60 years" },
  { attr: "CITES status", congo: "Appendix II — fully documented", timneh: "Appendix II — fully documented" },
];

const taxonomy = [
  { k: "Common name", v: "African Grey Parrot" },
  { k: "Scientific name", v: "Psittacus erithacus" },
  { k: "Family", v: "Psittacidae (true parrots)" },
  { k: "Order", v: "Psittaciformes" },
  { k: "Native range", v: "Equatorial Africa — rainforest belt" },
  { k: "Variants", v: "Congo (P. e. erithacus), Timneh (P. e. timneh)" },
  { k: "Conservation listing", v: "CITES Appendix II" },
  { k: "Lifespan", v: "40–50 years wild, up to 60 in captivity" },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- HERO -->
  <section class="agg-hero">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
      <h1 class="cag-h1">African Grey Parrot Guide: Complete Species Overview</h1>
      <p class="agg-sub">
        Everything you need to know about the African Grey parrot
        (<em>Psittacus erithacus</em>) — the world's most intelligent
        companion bird. This guide covers the Congo and Timneh variants,
        talking ability, lifespan, diet, housing, CITES documentation and how
        to buy a healthy, captive-bred African Grey with confidence.
      </p>
      <div class="agg-hero-cta">
        <a class="btn-primary" href="/contact-us/">Talk to Our Breeder Team</a>
        <a class="btn-secondary" href="/congo-african-grey-for-sale/">See Available Birds</a>
      </div>
    </div>
  </section>

  <!-- TABLE OF CONTENTS -->
  <section class="agg-section">
    <div class="container container-text">
      <nav class="agg-toc" aria-label="Guide contents">
        <h2 class="agg-toc-title">In This Guide</h2>
        <ol class="agg-toc-list">
          {toc.map((t) => (
            <li><a href={`#${t.id}`}>{t.label}</a></li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section id="overview" class="agg-section">
    <div class="container container-text">
      <h2 class="cag-h2">What Makes the African Grey Parrot Special</h2>
      <p>
        The African Grey parrot is a medium-sized parrot native to the lowland
        rainforests of equatorial Africa. It is the most intelligent companion
        parrot kept by humans and one of the most studied birds in cognitive
        science. African Greys are prized for their near-human speech clarity,
        problem-solving ability and the deep, lasting bonds they form with
        their families.
      </p>
      <p>
        Unlike the brightly colored macaws and cockatoos, the African Grey
        wears understated silver-grey plumage offset by a striking red or
        maroon tail. Its appeal is behavioral rather than ornamental: this is a
        bird that watches, listens, learns and engages. With a 40–60 year
        lifespan, an African Grey is genuinely a lifelong companion.
      </p>

      <h3 class="cag-h3">African Grey Parrot at a Glance</h3>
      <div class="agg-tax-wrap">
        <table class="agg-tax-table">
          <tbody>
            {taxonomy.map((row) => (
              <tr>
                <th scope="row">{row.k}</th>
                <td>{row.v}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="agg-note">
        Every African Grey placed by CongoAfricanGreys.com is captive-bred,
        hand-raised and fully weaned, supplied with complete CITES and health
        documentation. We never sell wild-caught birds.
      </p>
    </div>
  </section>

  <!-- VARIANTS -->
  <section id="variants" class="agg-section agg-alt">
    <div class="container">
      <h2 class="cag-h2">The Two Variants: Congo vs Timneh African Grey</h2>
      <div class="container-text agg-inset">
        <p>
          The African Grey parrot has two recognized variants — often treated
          as subspecies — the <strong>Congo African Grey</strong>
          (<em>Psittacus erithacus erithacus</em>) and the
          <strong>Timneh African Grey</strong>
          (<em>Psittacus erithacus timneh</em>). They share the same
          intelligence, lifespan and CITES status, but differ in size, color
          and temperament.
        </p>
        <p>
          The Congo is the larger, classic silver-grey bird with a bright red
          tail that most people picture when they hear "African Grey." The
          Timneh is smaller and darker with a maroon tail, often calmer in
          temperament, and frequently begins talking at a younger age.
        </p>
      </div>
      <div class="agg-table-wrap">
        <table class="agg-table">
          <thead>
            <tr>
              <th>Attribute</th>
              <th>Congo African Grey</th>
              <th>Timneh African Grey</th>
            </tr>
          </thead>
          <tbody>
            {variantRows.map((row) => (
              <tr>
                <th scope="row">{row.attr}</th>
                <td>{row.congo}</td>
                <td>{row.timneh}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="container-text agg-inset">
        <p class="agg-note">
          For a full side-by-side breakdown, read our
          <a href="/congo-vs-timneh-african-grey/">Congo vs Timneh African Grey comparison</a>.
          Browse current availability on the
          <a href="/congo-african-grey-for-sale/">Congo African Grey for sale</a> and
          <a href="/timneh-african-grey-for-sale/">Timneh African Grey for sale</a> pages.
        </p>
      </div>
    </div>
  </section>

  <!-- INTELLIGENCE -->
  <section id="intelligence" class="agg-section">
    <div class="container container-text">
      <h2 class="cag-h2">Intelligence and Talking Ability</h2>
      <p>
        African Grey parrots are ranked among the most intelligent animals on
        Earth and are the most accomplished talking birds of any species. A
        well-socialized African Grey can learn hundreds of words and short
        phrases and — crucially — use them in the correct context rather than
        simply mimicking sounds.
      </p>
      <p>
        The species' cognitive ability is best documented through the decades
        of research conducted by Dr. Irene Pepperberg with an African Grey
        named Alex. Alex demonstrated the ability to identify colors, shapes
        and materials, count small quantities, and understand concepts such as
        "same" and "different" — abilities researchers compare to those of a
        young human child.
      </p>
      <p>
        That intelligence is also a responsibility. A bored or under-stimulated
        African Grey can develop feather-destructive behavior, screaming or
        anxiety. Daily mental enrichment — foraging toys, training sessions,
        rotating puzzles and genuine social interaction — is not optional; it
        is essential to the bird's wellbeing.
      </p>
    </div>
  </section>

  <!-- LIFESPAN -->
  <section id="lifespan" class="agg-section agg-alt">
    <div class="container container-text">
      <h2 class="cag-h2">Lifespan: A 40–60 Year Commitment</h2>
      <p>
        African Grey parrots live <strong>40–50 years in the wild and up to
        60 years in captivity</strong> with proper nutrition, veterinary care
        and enrichment. They are among the longest-lived companion parrots, and
        bringing one home is a decades-long commitment.
      </p>
      <p>
        Responsible ownership means planning for the bird's entire life,
        including the realistic possibility that an African Grey will outlive
        its owner. Many owners name a caretaker or include the bird in their
        long-term plans. Longevity also depends on prevention: an annual avian
        veterinary wellness exam, a calcium-adequate diet and a clean,
        enriched environment all add healthy years.
      </p>
      <p class="agg-note">
        Learn more in our dedicated
        <a href="/african-grey-parrot-guide/">African Grey parrot lifespan</a> guide.
      </p>
    </div>
  </section>

  <!-- SIZE -->
  <section id="size" class="agg-section">
    <div class="container container-text">
      <h2 class="cag-h2">Size, Weight and Appearance</h2>
      <p>
        The African Grey is a medium-sized parrot. A
        <strong>Congo African Grey measures about 12–14 inches (33 cm)</strong>
        from head to tail and weighs <strong>400–600 grams</strong>. The
        <strong>Timneh African Grey is smaller</strong>, at 9–11 inches and
        <strong>275–375 grams</strong>. Both reach full adult size by roughly
        one year of age and have a wingspan of around 18–20 inches.
      </p>
      <p>
        Plumage is the clearest visual difference between the variants. The
        Congo wears light silver-grey feathers with a vivid cherry-red tail and
        an all-black beak. The Timneh is a darker charcoal-grey with a deep
        maroon tail and a horn-colored tip on the upper beak. Both have pale,
        bare facial skin and intelligent, expressive eyes that lighten from
        dark to pale yellow as the bird matures.
      </p>
      <p>
        Males and females look nearly identical — African Greys are not
        reliably sexed by appearance, which is why every bird we place is DNA
        sexed with a certificate included.
      </p>
    </div>
  </section>

  <!-- DIET -->
  <section id="diet" class="agg-section agg-alt">
    <div class="container container-text">
      <h2 class="cag-h2">Diet and Nutrition Requirements</h2>
      <p>
        A healthy African Grey diet is built on a
        <strong>high-quality formulated pellet</strong>, which should make up
        roughly 60–70% of daily intake. Pellets provide consistent, balanced
        nutrition that an all-seed diet cannot. The remainder should be fresh
        vegetables, leafy greens and a smaller portion of fruit.
      </p>
      <p>
        African Greys are particularly prone to
        <strong>calcium deficiency</strong>, so calcium-rich foods such as
        leafy greens, and access to safe sunlight or full-spectrum lighting to
        support vitamin D, are important. Foods that are
        <strong>toxic and must never be fed</strong> include avocado,
        chocolate, caffeine, alcohol, and salty or sugary human foods.
      </p>
      <p class="agg-note">
        For a complete feeding plan, portion guidance and a safe-foods list,
        read our
        <a href="/african-grey-parrot-guide/">African Grey parrot diet and nutrition</a> guide.
      </p>
    </div>
  </section>

  <!-- ENVIRONMENT -->
  <section id="environment" class="agg-section">
    <div class="container container-text">
      <h2 class="cag-h2">Cage and Environment Needs</h2>
      <p>
        An African Grey needs a cage measuring <strong>at least 24 x 24 x 36
        inches</strong>, with horizontal bars that allow climbing and a bar
        spacing of about 3/4 to 1 inch. Bigger is always better — the cage is
        the bird's home base, not its whole world.
      </p>
      <p>
        Equally important is daily out-of-cage time. African Greys are
        intelligent flock animals that need <strong>2–4 hours of social
        interaction and enrichment</strong> every day. Provide a variety of
        natural-wood perches at different diameters, foraging and chewing toys,
        and a quiet location away from kitchen fumes, drafts and round-the-clock
        noise.
      </p>
      <p>
        A consistent routine, a predictable sleep schedule of 10–12 hours of
        dark, quiet rest, and a stable household help an African Grey stay
        calm and confident. Isolation and chaos are the leading causes of
        stress-related feather damage in the species.
      </p>
      <p class="agg-note">
        For housing, training and daily-care detail, see our full
        <a href="/african-grey-parrot-guide/">African Grey parrot care guide</a>.
      </p>
    </div>
  </section>

  <!-- CITES -->
  <section id="cites" class="agg-section agg-alt">
    <div class="container container-text">
      <h2 class="cag-h2">CITES Appendix II Status — Why Documentation Matters</h2>
      <p>
        The African Grey parrot is listed under <strong>CITES Appendix II</strong>,
        the international agreement that regulates trade in species that could
        become threatened without controls. This listing protects wild
        populations — it does not restrict responsible ownership of
        captive-bred birds within the United States.
      </p>
      <p>
        The practical takeaway for buyers is simple: <strong>wild-caught
        African Greys cannot be legally sold</strong>, and a legitimate breeder
        will always supply documentation proving a bird is captive-bred. If a
        seller cannot produce paperwork, that is a serious red flag.
      </p>
      <p>Every African Grey placed by CongoAfricanGreys.com ships with:</p>
      <ul class="agg-doc-list">
        <li>CITES captive-bred documentation</li>
        <li>Hatch certificate with leg-band number</li>
        <li>DNA sexing certificate</li>
        <li>Avian veterinary health certificate</li>
        <li>USDA Animal Welfare Act compliance under our licensed facility</li>
      </ul>
      <p class="agg-note">
        Read more about paperwork and compliance on our
        <a href="/cites-african-grey-documentation/">CITES African Grey documentation</a> page.
      </p>
    </div>
  </section>

  <!-- BUYING GUIDE -->
  <section id="buying" class="agg-section">
    <div class="container">
      <h2 class="cag-h2">African Grey Buying Guide: What to Look For</h2>
      <div class="container-text agg-inset">
        <p>
          Buying an African Grey is a significant, decades-long decision. The
          single biggest predictor of a healthy, well-adjusted bird is choosing
          a fully weaned, hand-raised parrot from a reputable, documented
          breeder. Use the checklist below before you commit.
        </p>
      </div>
      <div class="agg-buy-grid">
        <div class="agg-buy-card agg-buy-good">
          <h3>Signs of a Trustworthy Breeder</h3>
          <ul>
            <li>Provides CITES captive-bred documentation in writing</li>
            <li>Includes a hatch certificate with a leg-band number</li>
            <li>Supplies DNA sexing and an avian vet health certificate</li>
            <li>Sells only fully weaned, hand-raised birds</li>
            <li>Holds a USDA Animal Welfare Act license</li>
            <li>Welcomes questions and offers post-sale support</li>
            <li>Offers a written health guarantee</li>
          </ul>
        </div>
        <div class="agg-buy-card agg-buy-bad">
          <h3>Red Flags to Walk Away From</h3>
          <ul>
            <li>No paperwork, or refuses to discuss CITES documentation</li>
            <li>Prices far below market — a lure used in scams</li>
            <li>Pressure to pay by gift card or wire transfer only</li>
            <li>Will not provide recent photos or a video call</li>
            <li>Claims a bird is "wild-caught" or imported</li>
            <li>Pushes unweaned chicks on inexperienced buyers</li>
            <li>No verifiable address, reviews or breeder history</li>
          </ul>
        </div>
      </div>
      <div class="container-text agg-inset">
        <p class="agg-note">
          Learn how to protect yourself in our
          <a href="/how-to-avoid-african-grey-parrot-scams/">African Grey scam-avoidance guide</a>,
          and review full pricing in the
          <a href="/african-grey-parrot-price/">African Grey parrot price guide</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- HUB LINKS -->
  <section class="agg-section agg-alt">
    <div class="container">
      <h2 class="cag-h2">Explore the Full African Grey Resource Library</h2>
      <div class="agg-hub-grid">
        <a class="agg-hub-card" href="/african-grey-parrot-guide/">
          <h3>African Grey Parrot Care Guide</h3>
          <p>Day-to-day care, housing, training and health basics.</p>
        </a>
        <a class="agg-hub-card" href="/african-grey-parrot-guide/">
          <h3>African Grey Parrot Diet &amp; Nutrition</h3>
          <p>Pellets, fresh foods, calcium needs and toxic foods to avoid.</p>
        </a>
        <a class="agg-hub-card" href="/african-grey-parrot-guide/">
          <h3>African Grey Parrot Lifespan</h3>
          <p>How long African Greys live and how to maximize healthy years.</p>
        </a>
        <a class="agg-hub-card" href="/congo-vs-timneh-african-grey/">
          <h3>Congo vs Timneh Comparison</h3>
          <p>Full side-by-side breakdown of both African Grey variants.</p>
        </a>
        <a class="agg-hub-card" href="/congo-african-grey-for-sale/">
          <h3>Congo African Grey for Sale</h3>
          <p>Captive-bred, hand-raised Congo African Greys available now.</p>
        </a>
        <a class="agg-hub-card" href="/timneh-african-grey-for-sale/">
          <h3>Timneh African Grey for Sale</h3>
          <p>Smaller, calmer captive-bred Timneh African Greys available now.</p>
        </a>
        <a class="agg-hub-card" href="/hand-raised-african-grey-parrot-for-sale/">
          <h3>Hand-Raised African Greys</h3>
          <p>What hand-raising means, our 12–16 week process, and why it produces better companion birds.</p>
        </a>
        <a class="agg-hub-card" href="/dna-tested-african-grey-for-sale/">
          <h3>DNA-Tested African Greys</h3>
          <p>Every bird laboratory DNA-sexed before placement — sex certificate included at no extra charge.</p>
