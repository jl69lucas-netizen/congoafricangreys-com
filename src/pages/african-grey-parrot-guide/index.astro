  <!-- MID-PAGE CTA -->
  <section class="agg-cta">
    <div class="container">
      <h2 class="cag-h2">Ready to Bring Home an African Grey?</h2>
      <p>
        Tell our breeder team about your home and experience level — we will
        help you choose the right Congo or Timneh African Grey and walk you
