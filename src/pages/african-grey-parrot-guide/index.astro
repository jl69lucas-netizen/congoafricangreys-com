  <script is:inline>
    // FAQ accordion (smooth open/close) — mirrors homepage / cites / captive-bred pattern
    (function () {
      const qs = document.querySelectorAll('.cag-faq-q');
      if (!qs.length) return;
      qs.forEach(btn => btn.addEventListener('click', () => {
        const item = btn.closest('.cag-faq-item');
        const open = item.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }));
    })();

    // Section jump-nav auto-injector — "↓ Continue: <next section>"
    (function () {
      var ids = ['overview','variants','intelligence','size','temperament','lifespan','care','cites','available-birds','faq','contact'];
      var labels = {
        'variants':        'Congo vs Timneh',
        'intelligence':    'Talking & Intelligence',
        'size':            'Size & Appearance',
        'temperament':     'Temperament',
        'lifespan':        'Lifespan',
        'care':            'Daily Care',
        'cites':           'CITES & Legality',
        'available-birds': 'Available Greys',
        'faq':             'Species FAQ',
        'contact':         'Ask C.A.Gs',
      };
      for (var i = 0; i < ids.length - 1; i++) {
        var cur = document.getElementById(ids[i]);
        if (!cur) continue;
        var nav = document.createElement('div');
        nav.className = 'section-next-nav';
        nav.innerHTML = '<a href="#' + ids[i + 1] + '" class="section-next-link">&#8595; Continue: ' + (labels[ids[i + 1]] || ids[i + 1]) + '</a>';
        cur.appendChild(nav);
      }
    })();
  </script>
