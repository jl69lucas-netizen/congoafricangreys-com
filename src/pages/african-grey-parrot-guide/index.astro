      </p>
      <a class="btn-primary" href="/contact-us/">Contact Our Breeder Team</a>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="agg-section">
    <div class="container container-text">
      <h2 class="cag-h2">African Grey Parrot Guide: FAQ</h2>
      <div class="agg-faq">
        {faqs.map((f) => (
          <details class="agg-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
