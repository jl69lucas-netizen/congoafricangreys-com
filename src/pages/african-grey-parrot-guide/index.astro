---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';

const title = "African Grey Parrot Guide | Complete Species Profile — Psittacus erithacus, Congo vs Timneh, Intelligence, Lifespan, Diet & CITES Status + How to Buy Captive-Bred | C.A.Gs – Midland, TX";
const description = "Complete African Grey parrot guide from USDA-licensed breeders C.A.Gs — Congo vs Timneh, talking ability (the Alex/Pepperberg legacy), 40–60 year lifespan, diet, housing, CITES Appendix I, and how to buy a documented captive-bred Grey. Congo $1,700–$2,500 · Timneh $1,500–$1,600 · ships $185/$350.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-guide/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Parrot Guide", url: "/african-grey-parrot-guide/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + diet/care pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'overview',        label: 'Overview',     part: 1 },
  { id: 'variants',        label: 'Variants',     part: 1 },
  { id: 'intelligence',    label: 'Intelligence', part: 1 },
  { id: 'size',            label: 'Size',         part: 1 },
  { id: 'temperament',     label: 'Temperament',  part: 2 },
  { id: 'lifespan',        label: 'Lifespan',     part: 2 },
  { id: 'care',            label: 'Care',         part: 2 },
  { id: 'cites',           label: 'CITES',        part: 2 },
  { id: 'available-birds', label: 'Available',    part: 3 },
  { id: 'eggs-pairs',      label: 'Eggs & Pairs', part: 3 },
  { id: 'faq',             label: 'FAQ',          part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',   part: 3 },
];
const jumpPartNames = {
  1: 'The Species',
  2: 'Living With One',
  3: 'Choose & Reserve',
};

// ─── Available birds (cross-sell grid) — verified against price-matrix.json + clutch-inventory.json ───
// Shipping line + trust badges are hardwired inside BirdCard.astro (Ships nationwide · $185 airport · $350 home).
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300',
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Hand-raised in our home from day one.',
    notes: "Hand-raised male Congo, 4 months old — captive-bred, PCR DNA-sexed, vet-checked, and CITES Appendix I documented before he ever ships." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500',
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Socialized by our whole family.',
    notes: 'Premium hand-raised female Congo, 3 months old. Closed-banded, hatch-certified, CITES Appendix I documented.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700',
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, settled, paperwork in hand.',
    notes: 'Soft temperament, easy to handle. 1-year-old captive-bred female Congo with full health and CITES documentation.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600',
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird, same documentation standard.',
    notes: 'Hand-raised male Timneh, 5 months old. PCR DNA-sexed, avian-vet certified, captive-bred and never wild-caught.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500',
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, ready to come home.',
    notes: 'Hand-raised female Timneh, 6 months old. Closed band, hatch certificate, and CITES Appendix I paperwork included.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair',
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two bonded birds, one documented package.',
    notes: 'Unrelated captive-bred pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised and fully documented.' },
];

// ─── Taxonomy entity table (encyclopedic, neutral) ───
const taxonomy = [
  { k: "Common name", v: "African Grey Parrot" },
  { k: "Scientific name", v: "<em>Psittacus erithacus</em>" },
  { k: "Family", v: "Psittacidae (true parrots)" },
  { k: "Order", v: "Psittaciformes" },
  { k: "Native range", v: "Rainforest belt of West &amp; Central Africa" },
  { k: "Variants", v: "Congo (<em>P. erithacus</em>), Timneh (<em>P. timneh</em>)" },
  { k: "Adult size", v: "9–14 in (28–36 cm), 275–600 g" },
  { k: "Lifespan", v: "40–50 yr wild · up to 60 yr in human care" },
  { k: "Conservation listing", v: "CITES Appendix I · IUCN Endangered (wild)" },
];

// ─── FAQ (PAA-sourced: current page + competitor union + Google PAA) — mirrored into FAQPage schema ───
const faqs = [
  { q: "What is an African Grey parrot?",
    a: "An African Grey parrot (Psittacus erithacus) is a medium-sized parrot native to the rainforests of West and Central Africa, widely regarded as the most intelligent companion bird in the world. There are two recognized variants — the larger, red-tailed Congo and the smaller, maroon-tailed Timneh — and both are CITES Appendix I species, so a Grey sold in the USA must be captive-bred and documented. Here at C.A.Gs we hand-raise both Congos and Timnehs in our Midland, Texas home, and every bird ships with full CITES, hatch, DNA and avian-vet paperwork." },
  { q: "What is the difference between a Congo and a Timneh African Grey?",
    a: "The Congo African Grey is the larger variant — roughly 12–14 inches and 400–600 grams — with light silver-grey plumage, a bright cherry-red tail and an all-black beak. The Timneh African Grey is smaller at 9–11 inches and 275–375 grams, with darker charcoal plumage, a maroon tail and a horn-colored upper beak. Both are equally intelligent and equally long-lived; Timnehs tend to talk earlier and stay a touch calmer. We place both here at C.A.Gs — Congos from $1,700 and Timnehs from $1,500 — under the exact same captive-bred documentation standard." },
  { q: "Can African Grey parrots really talk?",
    a: "Yes — African Greys are the most accomplished talking birds of any species. A well-socialized Grey can learn hundreds of words and short phrases and use them in the correct context rather than simply mimicking. The species' cognition is documented through Dr. Irene Pepperberg's three decades of work with a Congo Grey named Alex, who could identify colors, shapes and materials, count small quantities, and grasp concepts such as 'same' and 'different.' Our own talking Congo, Maxy, greets visitors by name — proof of what a hand-raised Grey becomes when it is socialized from a chick." },
  { q: "How long do African Grey parrots live?",
    a: "African Grey parrots live 40–50 years in the wild and up to 60 years in human care with proper nutrition, annual avian-vet wellness exams and daily enrichment. That makes a Grey one of the longest-lived companion parrots and a genuine multi-decade commitment — many owners name a future caretaker for the bird. Read our dedicated African Grey lifespan guide for the full picture of what shortens and what extends those years." },
  { q: "How big does an African Grey parrot get?",
    a: "A Congo African Grey grows to about 12–14 inches (33–36 cm) from head to tail and weighs 400–600 grams. A Timneh African Grey is smaller, reaching 9–11 inches and 275–375 grams. Both reach full adult size by roughly one year of age and have a wingspan of around 18–20 inches. Males and females look nearly identical, which is why every Grey we place is PCR DNA-sexed with a certificate included." },
  { q: "What do African Grey parrots eat?",
    a: "A healthy African Grey diet is built on a formulated, dye-free pellet making up roughly 60–70% of daily intake, supplemented with fresh vegetables, leafy greens and a smaller portion of fruit. African Greys are especially prone to calcium deficiency, so calcium-rich greens and safe access to UV-B light (which lets the body make vitamin D3) matter. Avocado, chocolate, caffeine, alcohol and salty or sugary human foods are toxic and must never be fed. See our African Grey diet guide and best-food guide for full feeding plans." },
  { q: "Are African Grey parrots legal to own in the USA?",
    a: "Yes — a captive-bred African Grey is legal to own and transfer domestically within the United States with proper documentation. African Greys were uplisted to CITES Appendix I at CoP17, effective January 2017, which bans commercial trade in wild-caught birds; captive-bred birds are unaffected. Every Grey from C.A.Gs is U.S. captive-bred and ships with a CITES Appendix I captive-bred certificate, hatch certificate, closed band, PCR DNA sexing certificate and a board-certified avian-vet health certificate. See our CITES documentation page for the full breakdown." },
  { q: "How much does an African Grey parrot cost?",
    a: "Here at C.A.Gs a captive-bred Congo African Grey ranges from $1,700 to $2,500 depending on age, and a Timneh ranges from $1,500 to $1,600; a bonded pair is $3,500. Shipping is $185 to your nearest major airport or $350 for home delivery, IATA-compliant via Delta, United or American. First-year setup — cage, perches, toys and an initial vet visit — typically adds several hundred dollars. Our African Grey price guide has the complete cost breakdown." },
  { q: "Are African Grey parrots good pets for beginners?",
    a: "African Greys are sensitive, highly intelligent birds that need daily interaction, mental enrichment and a consistent routine, so they reward committed owners more than casual first-time keepers. That said, a beginner ready for the commitment often does very well starting with a calm, fully weaned, hand-raised Timneh from a documented breeder. We talk through your home and experience before placing any bird, so the match is right for both you and the Grey." },
  { q: "How much space and attention does an African Grey need?",
    a: "An African Grey needs a cage at least 24 x 24 x 36 inches with horizontal bars, several hours of supervised out-of-cage time, and 2–4 hours of daily social interaction and enrichment. They are flock animals that bond closely with their family and can develop feather-destructive behavior or stress if isolated for long stretches. A predictable 10–12 hour dark sleep schedule and a quiet location away from kitchen fumes keep a Grey calm and confident." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Guide — The Complete Species Profile",
  description: "A complete African Grey species guide: Psittacus erithacus taxonomy and wild origin, the Congo vs Timneh variants, intelligence and talking ability, size, temperament, the 40–60 year lifespan, diet, housing, CITES Appendix I status, and how to buy a documented captive-bred Grey.",
  inLanguage: "en-US",
  about: {
    "@type": "Thing",
    name: "African Grey Parrot",
    alternateName: "Psittacus erithacus",
    description: "The African Grey parrot (Psittacus erithacus) is a medium-sized Old World parrot native to equatorial Africa, recognized as the most intelligent companion parrot and listed under CITES Appendix I.",
    sameAs: "https://parrots.org/encyclopedia/grey-parrot/",
  },
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  datePublished: "2024-09-01",
  dateModified: "2026-06-10",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// ─── Care-overview entity cards (routes to spokes) ───
const careCards = [
  { n: 1, t: "Diet & nutrition",
    d: "A dye-free formulated pellet is the foundation (60–70%), rounded out with fresh greens and limited fruit. Greys are prone to calcium deficiency, so calcium-rich foods and UV-B exposure for vitamin D3 are key.",
    href: "/african-grey-parrot-diet/", link: "Full diet guide" },
  { n: 2, t: "Housing & cage",
    d: "A cage of at least 24 x 24 x 36 inches with horizontal bars and 3/4–1 inch bar spacing, plus varied natural-wood perches and a quiet spot away from kitchen fumes and drafts.",
    href: "/african-grey-parrot-care-guide/", link: "Complete care guide" },
  { n: 3, t: "Enrichment & training",
    d: "Foraging toys, rotating puzzles and short daily training sessions keep that powerful mind busy. A bored Grey is a feather-plucking Grey, so enrichment is care, not a luxury.",
    href: "/how-to-tame-african-grey-parrot/", link: "How to tame a Grey" },
  { n: 4, t: "Health & vet care",
    d: "An annual avian-vet wellness exam, a calcium-adequate diet and 10–12 hours of dark sleep add healthy years. Every Grey we place is PBFD and Polyomavirus screened before it leaves.",
    href: "/african-grey-parrot-health-guarantee/", link: "Our health guarantee" },
  { n: 5, t: "Lifespan planning",
    d: "At 40–60 years, an African Grey may outlive arrangements you make today, so responsible owners plan for the bird's whole life, including a named future caretaker.",
    href: "/african-grey-parrot-lifespan/", link: "Lifespan guide" },
  { n: 6, t: "Cost of ownership",
    d: "Purchase price is only the start: cage, perches, toys, food and vet care add up over decades. We lay out first-year setup and lifetime cost honestly.",
    href: "/african-grey-parrot-price/", link: "Price & cost guide" },
];
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="guide-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="font-sora text-[11px] font-medium tracking-[0.12em] text-white/80">Species Pillar · <em>Psittacus erithacus</em> · Congo &amp; Timneh</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              The Complete African Grey Parrot Guide
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">The African Grey (<em>Psittacus erithacus</em>) is the most intelligent companion parrot on Earth — and choosing one is a 40-to-60-year decision.</p>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Here at C.A.Gs in Midland, Texas, we hand-raise both Congo and Timneh Greys, so this guide is written from the aviary floor: taxonomy and wild origin, the two variants, talking ability, size, temperament, lifespan, diet, housing, CITES Appendix I status, and how to bring home a documented, captive-bred Grey.</p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#variants" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">Congo or Timneh? →</a>
              <a href="#available-birds" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">See Available Greys →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/congo-african-grey-variant.webp"
                  alt="A captive-bred Congo African Grey (Psittacus erithacus) with silver-grey plumage and a bright red tail, hand-raised at the C.A.Gs aviary in Midland, Texas — the classic African Grey species the world recognizes."
                  title="Congo African Grey — Psittacus erithacus — C.A.Gs, Midland TX"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover object-center" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "2", label: "Subspecies Covered" },
      { num: "40–60", label: "Yrs Lifespan" },
      { num: "App. I", label: "CITES Listing" },
      { num: "$1,500", label: "Our Floor Price" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The species in 60 seconds"
      heading="What Is an African Grey Parrot? (The Facts That Matter)"
      badge="8 facts · 60-sec read"
      items={[
        { stat: "Most",      label: "Intelligent Parrot",  body: "The African Grey (Psittacus erithacus) is widely ranked the most intelligent companion bird, with the talking ability to match." },
        { stat: "2",         label: "Variants",             body: "The larger red-tailed Congo and the smaller maroon-tailed Timneh — equally clever, equally long-lived, different in size and pace." },
        { stat: "40–60 yr",  label: "Lifespan",             body: "Greys live up to 60 years in human care, making one a genuine multi-decade, plan-for-life commitment." },
        { stat: "100s",      label: "Words in Context",     body: "A socialized Grey learns hundreds of words and uses them meaningfully — the Alex/Pepperberg research proved real comprehension." },
        { stat: "Appx I",    label: "CITES Status",         body: "African Greys are CITES Appendix I (since Jan 2017); only documented captive-bred birds are legal to own and transfer in the USA." },
        { stat: "$1,500+",   label: "From C.A.Gs",          body: "Timneh Greys from $1,500 and Congos from $1,700 — captive-bred, hand-raised, never a bait listing." },
        { stat: "9–14 in",   label: "Adult Size",           body: "Medium parrot: 9–11 in for a Timneh, 12–14 in for a Congo, 275–600 g — fully grown by about one year." },
        { stat: "USDA",      label: "Family-Bred Since '14",body: "Mark & Teri Benjamin hand-raise every Grey in their USDA-licensed Midland, TX home — documented from the first day." },
      ]}
    />

    <!-- 4. TOC (jump links) -->
    <nav class="toc-guide py-10 px-4 bg-cream md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this guide</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">9 sections · the whole species, plainly</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part One</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">The species &amp; its two variants</p>
              <ol class="space-y-0">
                {[
                  { n: 1, t: "What Is an African Grey Parrot — Taxonomy & Origin?", href: "#overview" },
                  { n: 2, t: "Congo vs Timneh — Which African Grey Variant?", href: "#variants" },
                  { n: 3, t: "How Intelligent Are African Greys, and Can They Talk?", href: "#intelligence" },
                  { n: 4, t: "How Big Do African Greys Get — Size & Appearance?", href: "#size" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
            <div>
              <div class="mb-2.5 flex items-baseline gap-2.5">
                <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">Part Two</span>
                <span class="h-px flex-1 bg-black/[0.08]"></span>
              </div>
              <p class="font-lora mb-3 text-lg font-semibold italic text-green">Living with &amp; buying a Grey</p>
              <ol class="space-y-0">
                {[
                  { n: 5, t: "What Is an African Grey's Temperament Like?", href: "#temperament" },
                  { n: 6, t: "How Long Do African Greys Live, and Stay Healthy?", href: "#lifespan" },
                  { n: 7, t: "How Do You Care for an African Grey Day to Day?", href: "#care" },
                  { n: 8, t: "Are African Greys Legal — CITES Status Explained?", href: "#cites" },
                  { n: 9, t: "Can You Buy African Grey Eggs to Incubate, or a Pair to Breed?", href: "#eggs-pairs" },
                  { n: 10, t: "African Grey Parrot Guide — Your Questions", href: "#faq" },
                ].map((it) => (
                  <li><a href={it.href} class="grid grid-cols-[28px_1fr] items-baseline gap-1 rounded-lg py-1.5 transition-colors hover:bg-green/[0.05]"><span class="font-sora text-[13px] font-semibold text-clay-ink">{String(it.n).padStart(2, "0")}</span><span class="font-sora text-[15px] leading-snug text-stone-700">{it.t}</span></a></li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- 5a. OVERVIEW / TAXONOMY -->
    <div class="cag-seam" aria-hidden="true"><span class="cag-seam__line"></span><img src="/cag-footer-logo.webp" alt="" width="200" height="66" loading="lazy" /><span class="cag-seam__line"></span></div>

    <section id="overview" class="scroll-mt-20 py-14 px-4 md:py-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6 border-l-4 border-green pl-4">
          <p class="text-clay font-sora text-xs font-semibold uppercase tracking-widest mb-2">The Species</p>
          <h2 class="font-lora font-bold text-logo-dark">What Is an African Grey Parrot — Taxonomy &amp; Wild Origin?</h2>
        </div>
        <p class="font-sora text-green text-[15px] font-semibold leading-relaxed mb-5" style="max-width:70ch;">The African Grey parrot (<em>Psittacus erithacus</em>) is a medium-sized Old World parrot native to the lowland rainforests of West and Central Africa, and it is widely regarded as the most intelligent companion bird in the world.</p>
        <div class="grid gap-8 md:grid-cols-[1fr_minmax(280px,360px)] md:items-start">
          <div class="space-y-4 text-stone-600 leading-relaxed text-[15px]" style="max-width:70ch;">
            <p>Taxonomically the African Grey belongs to the order Psittaciformes and the family Psittacidae — the true parrots — and the genus <em>Psittacus</em>.</p>
            <p>As <a href="https://parrots.org/encyclopedia/grey-parrot/" target="_blank" rel="noopener noreferrer">the World Parrot Trust species encyclopedia</a> records, the bird ranges across the equatorial forest belt from Côte d'Ivoire and Ghana eastward through the Congo Basin, where it nests in tree cavities and forages on fruit, seeds and palm nuts in large, vocal flocks.</p>
            <p>Two forms are recognized — once treated as subspecies and now often as separate species — the larger Congo (<em>P. erithacus</em>) and the smaller Timneh (<em>P. timneh</em>).</p>
            <p>Both share the understated silver-grey plumage, the pale bare facial patch and the famously expressive eyes that lighten from dark to pale yellow as the bird matures.</p>
            <p>Unlike a macaw or cockatoo, the Grey's appeal is behavioral rather than ornamental: this is a bird that watches, listens, reasons and engages.</p>
            <p>That same intelligence is why the species needs protection. Decades of trapping for the pet trade thinned wild flocks so severely that the bird is now listed as Endangered on the <a href="https://www.iucnredlist.org/species/22724813/154068728" target="_blank" rel="noopener noreferrer">IUCN Red List</a> and was uplisted to CITES Appendix I in 2017.</p>
            <p>Every Grey we place at C.A.Gs is <a href="/captive-bred-african-grey-parrot/">U.S. captive-bred</a>, hand-raised and fully documented — we never touch a wild bird.</p>
          </div>
          <div class="agg-tax-card rounded-2xl border border-black/[0.07] bg-white p-5" style="box-shadow:0 4px 18px rgba(60,30,10,0.05);">
