---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot for Sale Oregon | Congo African Greys";
const description = "Hand-raised Congo African Grey parrots for sale in Oregon. CITES documented, DNA sexed, ships to Portland, Salem and statewide. USDA-licensed breeders.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-oregon/";
---

<BaseLayout {title} {description} {canonical}>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Grey Parrots for Sale", url: "/african-grey-parrots-for-sale/" },
      { name: "African Grey for Sale in Oregon", url: "/african-grey-parrot-for-sale-oregon/" }
    ]} />
  </div>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">Available Now · Ships Nationwide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">African Grey Parrot for Sale Oregon</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Hand-raised Congo African Grey parrots bred in Midland, TX. CITES documented, DNA sexed, vet-certified — ships to Portland, Salem, Eugene and all of Oregon.</p>
    </div>
  </section>

  <!-- Bird profile -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Images -->
      <div class="space-y-4">
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-African-Grey-Parrot-for-sale--600x743.jpeg"
          alt="Hand-raised Congo African Grey parrot for sale in Oregon"
          class="w-full rounded-2xl shadow-md"
          loading="eager"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/2-year-old-African-Grey-Parrot-for-sale--600x531.jpeg"
          alt="Congo African Grey parrot available for Oregon families"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Product card -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8 sticky top-24">
        <div class="mb-2">
          <span class="bg-clay text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">Available</span>
        </div>
        <h2 class="font-lora font-bold text-2xl text-logo-dark mb-1">Congo African Grey — Oregon</h2>
        <p class="text-stone-500 text-sm mb-4">Hand-raised baby · Midland, Texas</p>
        <div class="mb-6">
          <span class="font-lora font-bold text-3xl text-clay">$1,700–$3,500</span>
        </div>
        <ul class="text-sm text-stone-600 space-y-2 mb-8">
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ships daily to Portland &amp; statewide</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> DNA sexed &amp; vet-certified</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> CITES Appendix II documented</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> 3-day health guarantee</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> USDA-licensed breeder</li>
        </ul>
        <a
          href="/contact-us/"
          class="block text-center bg-clay text-white font-semibold py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
        >
          Inquire About Oregon Availability
        </a>
        <p class="text-xs text-stone-400 text-center mt-3">$200 deposit reserves your bird · We reply within 24 hrs</p>
      </div>
    </div>
  </section>

  <!-- About our birds -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Hand-Raised Congo African Greys for Oregon Families</h2>
      <p class="text-stone-600 leading-relaxed mb-4">
        Every Congo African Grey we place in Oregon comes from our family aviary in Midland, Texas — operated by Mark &amp; Teri Benjamin since 2014. Each bird is hand-raised from hatching, socialized daily with our family, and cleared by an avian veterinarian before shipping.
      </p>
      <p class="text-stone-600 leading-relaxed mb-6">
        Oregon buyers receive full CITES captive-bred documentation, a hatch certificate, DNA sexing certificate, band number, and an avian vet health certificate dated within 10 days of shipment. Your bird arrives at Portland International Airport or the Oregon airport nearest to you.
      </p>
      <ul class="space-y-3 text-stone-600 text-sm">
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Vet-Checked &amp; Healthy</strong> — Full avian vet clearance before every shipment.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Tame &amp; Friendly</strong> — Hand-raised for a loving, social temperament.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">CITES Documented</strong> — Full captive-bred documentation included with every bird.</div></li>
      </ul>
    </div>
  </section>

  <!-- Why African Grey -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">Why Choose an African Grey Parrot?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Intelligence Beyond Compare', body: 'African Greys are capable of learning hundreds of words and phrases — considered the Einsteins of the bird world.' },
          { title: 'Strong Bond with Owners', body: 'These parrots develop deep emotional connections with their caregivers and thrive on daily interaction.' },
          { title: 'Long Lifespan', body: 'With proper care, an African Grey can live up to 60 years — a true lifelong companion.' },
          { title: 'Playful & Entertaining', body: 'Their curiosity, mimicking skills, and playful behavior make them endlessly fun for the whole family.' },
        ].map(card => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-stone-100">
            <h3 class="font-lora font-semibold text-logo-dark mb-2">{card.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'Where can I find an African Grey parrot for sale in Oregon?', a: 'Congo African Greys ships CITES-documented, hand-raised Congo African Greys directly to Oregon buyers. Birds arrive at Portland International Airport or your nearest regional airport with a full health certificate.' },
          { q: 'Do you ship African Grey parrots to Oregon?', a: 'Yes — we ship IATA-compliant to all 50 states including Oregon. Birds arrive at Portland International or your nearest airport with a health certificate dated within 10 days of shipment.' },
          { q: 'Are African Grey parrots legal to own in Oregon?', a: 'Yes. African Grey parrots are legal to own in Oregon with proper CITES captive-bred documentation. Wild-caught birds are prohibited under federal law. All our birds are captive-bred with full CITES paperwork.' },
          { q: 'How much does an African Grey parrot cost in Oregon?', a: 'Congo African Greys are priced $1,700–$3,500 depending on age and training level. Nationwide shipping is $185 via Delta, United, or American Airlines. A $200 deposit reserves your bird.' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:2.5rem 0;background:#faf7f4;">
    <div class="container">
      <h2 style="font-family:'Lora',serif;font-weight:700;color:#2D6A4F;margin-bottom:1rem;">Browse Our African Grey Variants</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;margin-top:1rem;">
        <a href="/congo-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Congo African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The classic large variant — $1,700–$3,500. Bright red tail, exceptional talker.</div>
        </a>
        <a href="/timneh-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Timneh African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The compact, apartment-friendly variant — $1,500–$1,600. Maroon tail, calmer temperament.</div>
        </a>
      </div>
    </div>
  </section>

  <TrustBar />
  <CTA headline="Reserve Your African Grey for Oregon" sub="Limited availability. A $200 deposit holds your bird while we finalize shipping details." />
  <Schema type="organization" />

</BaseLayout>
