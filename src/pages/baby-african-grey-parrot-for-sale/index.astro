---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "Baby African Grey Parrot for Sale | Hand-Raised, Weaned | CongoAfricanGreys.com";
const description = "Hand-raised baby African Grey parrots for sale from USDA-licensed breeders in Midland, TX. Every baby is fully weaned, DNA sexed, CITES documented, and vet certified before shipping.";
const canonical = "https://congoafricangreys.com/baby-african-grey-parrot-for-sale/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Baby African Grey for Sale", url: "/baby-african-grey-parrot-for-sale/" },
];

const faqs = [
  {
    q: "How old are baby African Greys when they're sold?",
    a: "We never place baby African Greys before they are fully weaned, which typically occurs at 12–16 weeks of age. Any offer to sell an unweaned baby African Grey is a serious red flag — unweaned birds have a very high mortality rate and require professional hand-feeding equipment and expertise.",
  },
  {
    q: "What does 'hand-raised' mean for an African Grey baby?",
    a: "Hand-raised means the bird was removed from its parents at a young age and raised by humans using hand-feeding formula. This produces birds that are tame, trusting of people, and bonded to human interaction from day one. All birds from CongoAfricanGreys.com are hand-raised.",
  },
  {
    q: "How much does a baby African Grey parrot cost?",
    a: "Baby Congo African Greys from CongoAfricanGreys.com are priced from $1,700 to $3,500 depending on age, training level, and documentation. Baby Timneh African Greys range from $1,500 to $1,600. See our price guide for a full cost breakdown.",
  },
  {
    q: "Can baby African Grey parrots be shipped?",
    a: "Yes. We ship IATA-compliant to all 50 states. Every shipment uses an airline-approved live animal carrier with climate control. We only ship birds that are fully weaned, vet-certified healthy, and legally documented.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="baby-hero">
    <div class="page-container">
      <h1 class="baby-h1">Baby African Grey Parrots for Sale</h1>
      <p class="baby-sub">
        Hand-raised, fully weaned, CITES-documented baby African Greys from a USDA-licensed
        facility in Midland, Texas. Every bird ships with a vet health certificate and DNA
        sexing results.
      </p>
      <div class="baby-hero-cta">
        <a class="btn-primary" href="/african-grey-parrot-for-sale/">View Available Birds</a>
        <a class="btn-secondary" href="/contact-us/">Ask About a Baby</a>
      </div>
    </div>
  </section>

  <!-- AVAILABLE BIRDS -->
  <section class="baby-section">
    <div class="page-container">
      <h2 class="baby-h2">Currently Available Baby African Greys</h2>
      <p class="baby-p">
        Our availability changes as clutches are born and weaned. To see which baby African Greys
        are currently available — and their estimated ready dates — visit our main listings page.
      </p>
      <div class="baby-avail-card">
        <div class="baby-avail-inner">
          <h3 class="baby-h3">View All Available Birds</h3>
          <p>Listings include hatch date, sex, documentation status, and current price.
          Updated as birds become available.</p>
          <a class="btn-primary" href="/african-grey-parrot-for-sale/">See Available African Greys</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WEANING WARNING -->
  <section class="baby-section baby-alt">
    <div class="page-container text-wrap">
      <h2 class="baby-h2">What "Fully Weaned" Means — and Why It Matters</h2>
      <div class="baby-warning">
        <p class="baby-warning-text">
          <strong>Critical:</strong> Never purchase an unweaned baby African Grey.
        </p>
      </div>
      <p class="baby-p">
        African Grey babies complete the weaning process at approximately <strong>12 to 16 weeks
        of age</strong>. A fully weaned bird eats independently from a dish without requiring
        hand-feeding formula from a syringe. This is the earliest point at which a baby bird
        can safely transition to a new home.
      </p>
      <p class="baby-p">
        Any breeder offering an "unweaned baby" African Grey for sale — especially at a discount —
        is a serious red flag. Unweaned birds have very high mortality rates outside a professional
        breeding facility because they require precise temperature control, sterile feeding syringes,
        properly mixed formula at exact temperatures, and monitoring for aspiration pneumonia. These
        conditions cannot be replicated by a first-time buyer.
      </p>
      <p class="baby-p">
        We never place a bird before it has been eating independently for a minimum of two weeks.
        This brief waiting period significantly reduces post-placement mortality and produces a
        more confident, better-adjusted bird in its new home.
      </p>
    </div>
  </section>

  <!-- DOCUMENTATION -->
  <section class="baby-section">
    <div class="page-container text-wrap">
      <h2 class="baby-h2">What Documentation Every Baby Comes With</h2>
      <p class="baby-p">
        Every baby African Grey placed by CongoAfricanGreys.com ships with a complete documentation
        package. These documents are legally required for CITES Appendix I species and are your
        proof of legitimate captive-bred origin:
      </p>
      <div class="baby-docs-grid">
        <div class="baby-doc-card">
          <h3 class="baby-doc-title">CITES Captive-Bred Letter</h3>
          <p>Issued by our USDA-licensed facility confirming the bird was bred in captivity in
          the United States — not imported from the wild.</p>
        </div>
        <div class="baby-doc-card">
          <h3 class="baby-doc-title">Closed Leg Band</h3>
          <p>A permanent, closed aluminum band applied at approximately 2 weeks of age,
          stamped with the hatch year. This band cannot be removed without cutting — it
          proves the bird was banded as a nestling.</p>
        </div>
        <div class="baby-doc-card">
          <h3 class="baby-doc-title">DNA Sexing Certificate</h3>
          <p>African Greys are monomorphic — males and females look identical. DNA sexing
          from an accredited genetics laboratory provides a definitive sex determination.</p>
        </div>
        <div class="baby-doc-card">
          <h3 class="baby-doc-title">Avian Vet Health Certificate</h3>
          <p>Issued within 10 days of shipping by a licensed avian veterinarian, certifying
          the bird is free of infectious disease and fit for transport.</p>
        </div>
      </div>
      <p class="baby-p" style="margin-top: 1.5rem;">
        Keep all documents for the bird's entire life. CITES documentation must transfer with
        the bird if you ever re-home or sell it. Learn more at
        <a href="/cites-african-grey-documentation/" class="baby-link">/cites-african-grey-documentation/</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="baby-section baby-alt">
    <div class="page-container text-wrap">
      <h2 class="baby-h2">Baby African Grey FAQ</h2>
      <div class="baby-faq">
        {faqs.map((f) => (
          <details class="baby-faq-item">
            <summary class="baby-faq-q">{f.q}</summary>
            <p class="baby-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA
    headline="Interested in a Baby African Grey?"
    sub="Tell us about your home and experience — we will match you with the right bird and walk you through every step of the documentation and shipping process."
  />
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .text-wrap { max-width: 760px; }
  .baby-h1 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #faf7f4;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .baby-h2 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    margin: 0 0 1.25rem;
  }
  .baby-h3 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }
  .baby-doc-title {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 700;
    color: #2D6A4F;
    font-size: 1rem;
    margin: 0 0 0.4rem;
  }
  .baby-hero {
    background: #2D6A4F;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .baby-sub {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(250,247,244,0.88);
    max-width: 70ch;
    margin: 0 auto 1.75rem;
  }
  .baby-hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary, .btn-secondary {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 1.9rem;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
  }
  .btn-primary { background: #e8604c; color: #fff; }
  .btn-primary:hover { background: #d44e3b; }
  .btn-secondary { background: #fff; color: #2D6A4F; border: 2px solid #2D6A4F; }
  .btn-secondary:hover { background: #2D6A4F; color: #fff; }
  .baby-section { padding: 3rem 0; }
  .baby-alt { background: #faf7f4; }
  .baby-p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: #44403c;
    max-width: 70ch;
    margin: 0 0 1.2rem;
  }
  .baby-avail-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 20px;
    padding: 2rem;
    max-width: 480px;
    box-shadow: 0 2px 8px rgba(60,30,10,0.07);
  }
  .baby-avail-inner p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0 0 1.25rem;
    max-width: 60ch;
  }
  .baby-warning {
    background: #fff3cd;
    border-left: 4px solid #e8604c;
    border-radius: 8px;
    padding: 0.9rem 1.2rem;
    margin-bottom: 1.25rem;
  }
  .baby-warning-text {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 1rem;
    color: #7a3a00;
    margin: 0;
    max-width: 70ch;
  }
  .baby-docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }
  .baby-doc-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: 0 1px 4px rgba(60,30,10,0.06);
  }
  .baby-doc-card p {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #44403c;
    margin: 0;
  }
  .baby-link { color: #e8604c; text-decoration: underline; }
  .baby-link:hover { color: #d44e3b; }
  .baby-faq { display: flex; flex-direction: column; gap: 0.75rem; }
  .baby-faq-item {
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background: #fff;
  }
  .baby-faq-q {
    font-family: 'Sora', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2D6A4F;
    cursor: pointer;
    list-style: none;
  }
  .baby-faq-q::-webkit-details-marker { display: none; }
  .baby-faq-a {
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.65;
    color: #44403c;
    margin: 0.75rem 0 0;
    max-width: 70ch;
  }
  @media (max-width: 767px) { .page-container { padding: 0 16px; } }
  @media (min-width: 768px) and (max-width: 1024px) { .page-container { padding: 0 32px; } }
</style>
