---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';

const title = "Affordable African Grey Birds for Sale | Honest Pricing, Full Documentation";
const description = "Affordable African Grey parrots for sale from USDA licensed breeders. Transparent pricing: Congo $1,700–$3,500, Timneh $1,200–$2,500. Every bird fully CITES documented.";
const canonical = "https://congoafricangreys.com/affordable-african-grey-birds-for-sale/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Affordable African Grey Birds for Sale", url: "/affordable-african-grey-birds-for-sale/" },
];

const faqs = [
  {
    q: "What is the most affordable African Grey parrot?",
    a: "Timneh African Greys are generally more affordable than Congos, priced $1,200–$2,500 vs. $1,700–$3,500 for Congo African Greys. Both prices include CITES documentation. If you see African Greys advertised below $1,200 with documentation included, exercise extreme caution — it is likely a scam or an undocumented bird.",
  },
  {
    q: "Why do African Grey parrots cost so much?",
    a: "African Greys are CITES Appendix I species — wild capture is illegal, so all legal birds must be captive-bred. The cost reflects DNA sexing, vet certification, CITES documentation filing, hand-raising labor (12–16 weeks of weaning), and USDA AWA compliance overhead. It is not possible to legitimately produce a documented African Grey for under $1,000.",
  },
  {
    q: "Are cheaper African Greys less healthy?",
    a: "Price alone doesn't determine health, but extreme discounts often indicate missing documentation, inadequate veterinary care, or early weaning. We price our birds to cover all mandatory documentation and veterinary care — not as a profit maximization exercise.",
  },
  {
    q: "What's included in the price?",
    a: "Our price covers the bird, CITES Appendix I documentation, DNA sexing certificate, vet health certificate, hatch certificate, and our written health guarantee. Shipping is quoted separately based on destination airport and is IATA-compliant.",
  },
  {
    q: "Is there a payment plan available?",
    a: "We accept deposits to hold a bird while it completes weaning (12–16 weeks). Contact us to discuss the deposit amount and payment schedule. We do not offer financing arrangements beyond a hold deposit.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: `https://congoafricangreys.com${b.url}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div style="max-width:1200px;margin:0 auto;">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section style="background:#2D6A4F;padding:4rem 1rem">
    <div style="max-width:900px;margin:0 auto;text-align:center">
      <p style="color:#f0c674;font-family:var(--font-sora,sans-serif);font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:1rem">Transparent Pricing · Full CITES Documentation</p>
      <h1 style="font-family:var(--font-lora,serif);font-weight:700;font-size:clamp(2rem,5vw,3rem);color:#faf7f4;margin-bottom:1rem">Affordable African Grey Birds for Sale</h1>
      <p style="color:rgba(250,247,244,.8);font-size:1.1rem;max-width:680px;margin:0 auto 2rem">Congo African Greys $1,700–$3,500 · Timneh African Greys $1,200–$2,500. Every bird CITES documented, DNA sexed, and vet certified. No hidden fees.</p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center">
        <a href="/african-grey-parrot-price/" style="display:inline-block;background:#e8604c;color:white;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.875rem 1.75rem;border-radius:50px;text-decoration:none">Full Price Guide →</a>
        <a href="/contact-us/" style="display:inline-block;background:white;color:#2D6A4F;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.875rem 1.75rem;border-radius:50px;text-decoration:none">Inquire Now →</a>
      </div>
    </div>
  </section>

  <!-- Price Cards -->
  <section style="padding:4rem 1rem;background:#faf7f4">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;text-align:center;margin-bottom:2rem">Current Pricing</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem">
        <div style="background:white;border-radius:16px;padding:2rem;border:2px solid #e8604c;text-align:center">
          <h3 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.25rem;color:#2D6A4F;margin-bottom:.5rem">Timneh African Grey</h3>
          <p style="font-family:var(--font-sora,sans-serif);font-size:2rem;font-weight:700;color:#e8604c;margin-bottom:.5rem">$1,200–$2,500</p>
          <p style="color:#4b5563;font-size:.9rem;line-height:1.6">9–11 inches · Maroon tail · Faster maturity · Recommended for first-time owners</p>
          <a href="/timneh-african-grey-for-sale/" style="display:block;margin-top:1.5rem;background:#2D6A4F;color:white;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.75rem 1.5rem;border-radius:50px;text-decoration:none;font-size:.9rem">View Timnehs →</a>
        </div>
        <div style="background:white;border-radius:16px;padding:2rem;border:1px solid #e7e2db;text-align:center">
          <h3 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.25rem;color:#2D6A4F;margin-bottom:.5rem">Congo African Grey</h3>
          <p style="font-family:var(--font-sora,sans-serif);font-size:2rem;font-weight:700;color:#e8604c;margin-bottom:.5rem">$1,700–$3,500</p>
          <p style="color:#4b5563;font-size:.9rem;line-height:1.6">12–14 inches · Bright red tail · Larger vocabulary · Classic species</p>
          <a href="/congo-african-grey-for-sale/" style="display:block;margin-top:1.5rem;background:#2D6A4F;color:white;font-family:var(--font-sora,sans-serif);font-weight:700;padding:.75rem 1.5rem;border-radius:50px;text-decoration:none;font-size:.9rem">View Congos →</a>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:4rem 1rem;background:white">
    <div style="max-width:760px;margin:0 auto">
      <h2 style="font-family:var(--font-lora,serif);font-weight:700;font-size:1.75rem;color:#2D6A4F;margin-bottom:2rem">Pricing Questions</h2>
      <div style="display:flex;flex-direction:column;gap:1rem">
        {faqs.map((faq) => (
          <details style="background:#faf7f4;border:1px solid #e7e2db;border-radius:12px;padding:1.25rem">
            <summary style="font-family:var(--font-sora,sans-serif);font-weight:600;cursor:pointer;color:#1f2937;list-style:none">{faq.q}</summary>
            <p style="margin-top:.75rem;color:#4b5563;line-height:1.7;max-width:70ch">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
