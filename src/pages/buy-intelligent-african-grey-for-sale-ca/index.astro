---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';

const title = "Intelligent African Grey For Sale California | Congo African Greys";
const description = "Meet Loti — a 5-year-old male Congo African Grey for sale in California. $1,800. Ships to LA, San Diego, San Francisco, and all of CA. USDA licensed, CITES documented.";
const canonical = "https://congoafricangreys.com/buy-intelligent-african-grey-for-sale-ca/";
---

<BaseLayout {title} {description} {canonical}>

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-4">Available Now · Ships to California</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">Intelligent African Grey For Sale CA</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto">Meet Loti — a 5-year-old male Congo African Grey with remarkable talking ability. Ships to Los Angeles, San Diego, San Francisco, and all of California.</p>
    </div>
  </section>

  <!-- Bird profile -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">

      <!-- Images -->
      <div class="space-y-4">
        <img
          src="https://congoafricangreys.com/wp-content/uploads/buy-african-grey-parrot-ca-600x450.jpg"
          alt="Loti — intelligent talking African Grey parrot for sale California"
          class="w-full rounded-2xl shadow-md"
          loading="eager"
        />
        <img
          src="https://congoafricangreys.com/wp-content/uploads/african-grey-southern-california-1-600x480.jpg"
          alt="African Grey parrot available for sale in Southern California"
          class="w-full rounded-2xl shadow-md"
          loading="lazy"
        />
      </div>

      <!-- Product card -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8 sticky top-24">
        <div class="mb-2">
          <span class="bg-clay text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">Sale</span>
        </div>
        <h2 class="font-lora font-bold text-2xl text-logo-dark mb-1">Loti — Congo African Grey</h2>
        <p class="text-stone-500 text-sm mb-4">5-year-old male · Midland, Texas</p>
        <div class="mb-6">
          <span class="text-stone-400 line-through text-sm mr-2">$3,000</span>
          <span class="font-lora font-bold text-3xl text-clay">$1,800</span>
        </div>
        <ul class="text-sm text-stone-600 space-y-2 mb-8">
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ships daily nationwide</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> Ready to leave</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> DNA sexed &amp; vet-certified</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> CITES Appendix II documented</li>
          <li class="flex items-center gap-2"><span class="text-gold">✓</span> 3-day health guarantee</li>
        </ul>
        <a
          href="/contact-us/"
          class="block text-center bg-clay text-white font-semibold py-4 rounded-full text-lg hover:bg-clay-dk transition-colors"
        >
          Send Inquiry About Loti
        </a>
        <p class="text-xs text-stone-400 text-center mt-3">$200 deposit reserves your bird · We reply within 24 hrs</p>
      </div>
    </div>
  </section>

  <!-- California shipping info -->
  <section class="bg-warm-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">We Ship to All of California</h2>
      <p class="text-stone-600 leading-relaxed mb-6">
        Whether you're in Southern California, the Bay Area, or anywhere in between — we ship IATA-compliant via Delta or United Airlines for just $185. Your bird arrives at your nearest airport with a health certificate and full CITES documentation.
      </p>
      <div class="grid sm:grid-cols-2 gap-4 text-sm text-stone-600">
        {[
          'Los Angeles', 'San Diego', 'San Francisco', 'Sacramento',
          'San Jose', 'Fresno', 'Long Beach', 'Oakland'
        ].map(city => (
          <div class="flex items-center gap-2"><span class="text-gold">📍</span> {city}, CA</div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Loti -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-6">About Loti</h2>
      <p class="text-stone-600 leading-relaxed mb-4">
        Loti is a 5-year-old male Congo African Grey with exceptional talking ability and a calm, confident temperament. At this age, Loti has already developed strong mimicking skills and is comfortable with people — making him an ideal companion for families and experienced bird owners alike.
      </p>
      <p class="text-stone-600 leading-relaxed mb-6">
        Hand-raised in Mark &amp; Teri Benjamin's home aviary in Midland, Texas since 2014. Every bird leaves our care with full CITES captive-bred documentation, DNA sexing certificate, and an avian vet health certificate.
      </p>
      <ul class="space-y-3 text-stone-600 text-sm">
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Talking Ability</strong> — At 5 years old, Loti has an established vocabulary and continues to learn new words.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Calm Temperament</strong> — Socialized from hatching. Comfortable with new people and environments.</div></li>
        <li class="flex items-start gap-3"><span class="text-gold text-lg">✔</span><div><strong class="text-logo-dark">Full Documentation</strong> — CITES cert, hatch cert, band number, DNA cert, vet health certificate.</div></li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-warm-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-2xl text-logo-dark mb-8 text-center">Common Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does Loti cost?', a: 'Loti is priced at $1,800 (sale from $3,000). A $200 deposit reserves him. Shipping to California is $185.' },
          { q: 'Does Loti already talk?', a: 'Yes — at 5 years old, Loti has developed a vocabulary and continues adding new words and phrases. We can provide video of him talking before purchase.' },
          { q: 'What documentation comes with Loti?', a: 'CITES captive-bred certificate, hatch certificate, band number, DNA sexing certificate, and avian vet health certificate dated within 10 days of shipment.' },
          { q: 'How long does shipping to California take?', a: 'Birds typically travel same-day to California via Delta or United Airlines and arrive at your nearest major airport (LAX, SFO, SAN, SMF, etc.).' },
        ].map(faq => (
          <details class="border border-stone-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-sora font-semibold text-logo-dark hover:bg-stone-50 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-stone-600 text-sm leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />
  <CTA headline="Reserve Loti Today" sub="Ships to Los Angeles, San Diego, San Francisco and all of California. Limited availability." />
  <Schema type="organization" />

</BaseLayout>
