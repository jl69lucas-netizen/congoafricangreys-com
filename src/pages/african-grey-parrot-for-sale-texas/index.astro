---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = "African Grey Parrot For Sale Texas | Congo African Greys | Midland, TX";
const description = "African Grey parrots for sale in Texas. Based in Midland, TX — available for local pickup or IATA shipping statewide. USDA AWA licensed, CITES documented, DNA sexed.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-for-sale-texas/";
---

<BaseLayout {title} {description} {canonical}>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumb items={[
      { name: "Home", url: "/" },
      { name: "African Grey Parrots for Sale", url: "/african-grey-parrot-for-sale/" },
      { name: "African Grey for Sale in Texas", url: "/african-grey-parrot-for-sale-texas/" }
    ]} />
  </div>

  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-3">Based in Midland, TX &middot; Available for Pickup or Statewide Shipping</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-6">African Grey Parrot For Sale &mdash; Texas</h1>
      <p class="text-cream/80 text-lg max-w-2xl mx-auto mb-8">We are Texas-based African Grey breeders — Mark and Teri Benjamin's family aviary is in Midland, West Texas. Texas buyers can pick up in person or receive IATA-compliant shipping.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact-us/" class="bg-gold text-logo-dark font-semibold px-8 py-4 rounded-full text-lg hover:bg-cream transition-colors">Inquire &mdash; Texas Buyers</a>
        <a href="tel:+19565646067" class="border-2 border-gold text-gold font-semibold px-8 py-4 rounded-full text-lg hover:bg-gold hover:text-logo-dark transition-colors">Call (956) 564-6067</a>
      </div>
    </div>
  </section>
  <TrustBar />
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">Why Texas Buyers Choose Us</h2>
    <div class="grid sm:grid-cols-2 gap-6 text-sm text-stone-600">
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Local Pickup Available</h3>
        <p>We're in Midland — Dallas, Houston, San Antonio, and Austin buyers can arrange a visit and pickup by appointment. Meet the aviary, meet the birds.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">Texas-Licensed</h3>
        <p>We hold a USDA Animal Welfare Act license. Our facility meets federal standards for captive bird breeding in Texas.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">CITES Compliant</h3>
        <p>All our African Greys are CITES Appendix II captive-bred — fully legal to own in Texas with proper documentation we provide.</p>
      </div>
      <div class="bg-white border border-stone-100 rounded-xl p-6 shadow-sm">
        <h3 class="font-semibold text-logo-dark mb-2">12 Years in Texas</h3>
        <p>Founded 2014 in Midland, West Texas. Hundreds of Texas families have brought home a bird from our aviary.</p>
      </div>
    </div>
  </section>
  <section style="padding:2.5rem 0;background:#faf7f4;">
    <div class="container">
      <h2 style="font-family:'Lora',serif;font-weight:700;color:#2D6A4F;margin-bottom:1rem;">Browse Our African Grey Variants</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;margin-top:1rem;">
        <a href="/congo-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Congo African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The classic large variant — $1,700–$3,500. Bright red tail, exceptional talker.</div>
        </a>
        <a href="/timneh-african-grey-for-sale/" style="display:block;padding:1.25rem 1.5rem;background:#fff;border:1px solid #e0d8d0;border-radius:16px;text-decoration:none;">
          <div style="font-family:'Lora',serif;font-weight:700;font-size:1.1rem;color:#2D6A4F;margin-bottom:0.5rem;">Timneh African Grey for Sale</div>
          <div style="font-family:'Sora',sans-serif;font-size:0.9rem;color:#555;">The compact, apartment-friendly variant — $1,500–$1,600. Maroon tail, calmer temperament.</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Texas city navigation -->
  <section class="py-10 px-4 bg-cream">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-lora font-bold text-xl text-logo-dark mb-6">Browse African Grey Parrots by City in Texas</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { name: "Dallas", slug: "african-grey-parrot-for-sale-dallas" },
          { name: "Houston", slug: "african-grey-parrot-for-sale-houston" },
          { name: "Austin", slug: "african-grey-parrot-for-sale-austin" },
        ].map((c) => (
          <a href={`/${c.slug}/`} class="bg-white border border-stone-200 rounded-full px-5 py-2 font-sora text-sm font-semibold text-logo-dark hover:border-clay hover:text-clay transition-colors shadow-sm">
            {c.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Schema type="local-business" />
  <CTA headline="African Grey Parrots Available for Texas Buyers" />
</BaseLayout>
