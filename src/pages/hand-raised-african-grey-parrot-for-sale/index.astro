              <p class="hp"><label>Don't fill this out: <input name="bot-field" /></label></p>
              <label>Which grey are you interested in?
                <select name="bird" required>
                  <option value="">Choose a hand-raised grey…</option>
                  {available.map((b) => (<option value={b.name + " ($" + b.price.toLocaleString() + ")"}>{b.name.replace(" (pair)", "")} — {catLabel(b)} (${b.price.toLocaleString()})</option>))}
                  <option value="Not sure — help me choose">Not sure — help me choose</option>
                </select>
              </label>
              <div class="f2">
                <label>First name<input name="first-name" required autocomplete="given-name" /></label>
                <label>Last name<input name="last-name" required autocomplete="family-name" /></label>
              </div>
              <div class="f2">
                <label>Cell phone<input name="phone" type="tel" required autocomplete="tel" /></label>
                <label>Email<input name="email" type="email" required autocomplete="email" /></label>
              </div>
              <label>Delivery preference
                <select name="delivery" required>
                  <option value="">How would you like your grey?</option>
                  <option value="Airport pickup ($185)">Airport pickup — $185</option>
                  <option value="Home delivery ($350)">Home delivery — $350</option>
                  <option value="Pickup in Midland, TX">Pickup in Midland, TX (within 2–3 hours)</option>
                </select>
              </label>
              <label>Anything you'd like us to know?<textarea name="message" rows="3" placeholder="Your home, other pets, questions about Congo vs Timneh…"></textarea></label>
              <button class="btn btn-clay btn-submit" type="submit">Send my hand-raised grey inquiry →</button>
              <p class="form-note">We reply within 24 hours, personally. Your details go only to C.A.Gs.</p>
            </form>
          </div>
        </section>

      </div><!-- /content -->
    </div><!-- /body-grid -->

    <!-- Rail B green ticker (mobile) -->
    <nav class="railB" aria-label="Jump to section">
      <ul>
        {sections.map((s) => (<li><a href={"#" + s.id} data-id={s.id}><span class="p">{s.n}</span><span class="l">{s.label}</span></a></li>))}
      </ul>
    </nav>
  </main>

  <script is:inline define:vars={{ N }}>
    // Dial 2 scroll-spy + conic ring + Rail B active state
    (function () {
      const secs = Array.from(document.querySelectorAll('.handraised .content .sec'));
      const ring = document.getElementById('dialRing');
      const num = document.getElementById('dialNum');
      const dialLinks = Array.from(document.querySelectorAll('#dialList a'));
      const railLinks = Array.from(document.querySelectorAll('.railB a'));
      if (!secs.length) return;
      let active = '';
      const setActive = (id, idx) => {
        if (id === active) return;
        active = id;
        const p = Math.round(((idx + 1) / N) * 100);
        if (ring) ring.style.setProperty('--p', p);
        if (num) num.textContent = String(idx + 1).padStart(2, '0');
        dialLinks.forEach((a) => a.classList.toggle('on', a.dataset.id === id));
        railLinks.forEach((a) => {
          const on = a.dataset.id === id;
          a.classList.toggle('on', on);
          // keep the active chip in view so the mobile rail tracks the reader
          if (on && a.scrollIntoView) a.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'auto' });
        });
      };
      const io = new IntersectionObserver((ents) => {
        ents.forEach((e) => {
          if (e.isIntersecting) {
            const idx = secs.indexOf(e.target);
            if (idx > -1) setActive(e.target.id, idx);
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      secs.forEach((s) => io.observe(s));

      // Avail-B subspecies filter
      const grid = document.getElementById('birdGrid');
      if (grid) {
        const cards = Array.from(grid.querySelectorAll('.bcard'));
        document.querySelectorAll('.availB-rail .fbtn').forEach((btn) => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('.availB-rail .fbtn').forEach((b) => b.classList.remove('is-on'));
            btn.classList.add('is-on');
            const f = btn.dataset.f;
            cards.forEach((c) => { c.classList.toggle('hide', f !== 'all' && c.dataset.cat !== f); });
          });
        });
      }
    })();
  </script>
</BaseLayout>

