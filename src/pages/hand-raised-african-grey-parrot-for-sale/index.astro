---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import clutch from '../../../data/clutch-inventory.json';

// ============================================================================
//  /hand-raised-african-grey-parrot-for-sale/  — for-sale cluster page 4
//  Tuple (distinct from egg/congo/timneh — sessions/2026-07-19-for-sale-component-map.md):
//    Hero-A Scattered Flock · Dial 2 Dark-Aviary + Rail B green ticker · T4 Magazine Index
//    · K3 Green Ledger + K2 Price-Tag · Avail-B sidebar filtered by Congo/Timneh/Pair
//    · Table C Outlined matrix + top-pick badge · FAQ-C refreshed forest-green · small seam
//  Spine: Trust-First / welfare-authority · Engine: EEBP · AIO (C) Both
//  Prose written fresh from sessions/2026-07-22-hand-raised-outline.md (Write-From-Outline)
// ============================================================================

const title = "Hand-Raised African Grey Parrots for Sale — Tame, People-Bonded & DNA-Tested | Are Hand-Fed Greys Really Tamer? | 6 Documented Congos & Timnehs Ready | C.A.Gs, Midland TX — Raised In-Home, Video-Call Before You Deposit, From $1,500";
const description = "Hand-raised African Grey parrots for sale from a USDA-licensed Texas breeder — Congo and Timneh greys we hand-fed, weaned and socialized in-home, DNA-sexed and CITES-documented from $1,500. Tame, people-bonded birds raised right, not pulled early. Video-call before any deposit; 24-hour reply.";
const canonical = "https://congoafricangreys.com/hand-raised-african-grey-parrot-for-sale/";

const IMG = "/images/hand-raised-page/";
const site = "https://congoafricangreys.com";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Greys for Sale", url: "/african-grey-parrots-for-sale/" },
  { name: "Hand-Raised African Grey Parrots for Sale", url: "/hand-raised-african-grey-parrot-for-sale/" },
];

// Real inventory — ALL hand-raised birds available, BOTH subspecies + the pair (method umbrella).
const variantRank: Record<string, number> = { congo_african_grey: 0, timneh_african_grey: 1 };
const available = ((clutch as any).birds as any[])
  .filter((b) => b.status === "available")
  .sort((a, b) => (variantRank[a.variant] - variantRank[b.variant]) || (a.sex === "pair" ? 1 : -1));

const catFor = (b: any) => (b.sex === "pair" ? "pair" : (b.variant === "timneh_african_grey" ? "timneh" : "congo"));
const catLabel = (b: any) => (b.sex === "pair" ? "Companion Pair" : (b.variant === "timneh_african_grey" ? "Timneh Grey" : "Congo Grey"));
const catCount = (c: string) => available.filter((b) => catFor(b) === c).length;

const birdImg: Record<string, { src: string; alt: string; pos: string }> = {
  "Bery":  { src: "/images/congo-page/bery-congo-african-grey-female-card.webp",  pos: "center 30%", alt: "Bery, a hand-raised female Congo African Grey for sale, perched calmly and looking to camera" },
  "Amie":  { src: "/images/congo-page/amie-congo-african-grey-female-card.webp",  pos: "center 28%", alt: "Amie, a hand-fed female Congo African Grey who steps up for visitors, on a play stand" },
  "Roys":  { src: "/images/congo-page/roys-congo-african-grey-male-card.webp",    pos: "center 30%", alt: "Roys, a people-friendly hand-raised male Congo African Grey mid head-tilt" },
  "Jins & Jeni (pair)": { src: "/images/congo-page/jins-jeni-congo-african-grey-pair-card.webp", pos: "center 32%", alt: "Jins and Jeni, a bonded hand-raised Congo African Grey companion pair side by side" },
  "Elad":  { src: "/images/timneh-page/elad-timneh-african-grey-male-card.webp",  pos: "center 34%", alt: "Elad, a hand-raised male Timneh African Grey leaning into a gentle head scratch" },
  "Evie":  { src: "/images/timneh-page/evie-timneh-african-grey-female-card.webp",pos: "center 38%", alt: "Evie, a gentle young female Timneh African Grey socialized daily from weaning" },
};
const birdBlurb: Record<string, string> = {
  "Bery": "Steady, affectionate Congo hen — hand-fed and unflappable, an easy grey to live with day to day.",
  "Amie": "Bright Congo hen who steps up for strangers because we rotated her handling across the household.",
  "Roys": "Curious, confident Congo cock — thrives in a busy, interactive home where there's always something on.",
  "Jins & Jeni (pair)": "A bonded Congo pair that must stay together — two hand-raised greys who already keep each other company.",
  "Elad": "Even-tempered young Timneh male, an early talker who bonds fast in a hands-on home.",
  "Evie": "Tractable Timneh hen who takes new things calmly and loves quiet, gentle interaction.",
};

// Hero-A scattered-flock polaroids (both subspecies + the human-bond anchor)
// 4 face-forward polaroids in a rotated 2x2 grid — no absolute stacking, so no
// polaroid can ever cover another bird's head (the 5-card scatter did, 2026-07-23).
// `pos` keeps each bird's eye in frame inside the square crop.
const heroPolaroids = [
  { src: IMG + "hero-mark-hand-scratch-grey.webp", alt: "Mark hand-raising a Congo African Grey with a gentle head scratch", cap: "Mark & a Congo", cls: "p1", pos: "center 55%" },
  { src: IMG + "hero-amie-congo-hand-raised.webp", alt: "Amie, a hand-raised female Congo African Grey looking to camera", cap: "Amie · Congo", cls: "p2", pos: "center 60%" },
  { src: IMG + "hero-young-timneh-hand-raised.webp", alt: "A young hand-raised Timneh African Grey with a maroon tail", cap: "Young Timneh", cls: "p3", pos: "center 32%" },
  { src: IMG + "hero-bery-congo-hand-raised.webp", alt: "Bery, a calm hand-raised female Congo African Grey on a perch", cap: "Bery · Congo", cls: "p4", pos: "center 40%" },
];

// Counter strip (Ledger-verified only)
const counters = [
  { n: "$1,500", l: "Honest floor price" },
  { n: "12–16 wk", l: "Weaned, never rushed" },
  { n: "100%", l: "Hand-raised in-home" },
  { n: "2", l: "Subspecies, one method" },
  { n: "0", l: "Wild-caught, ever" },
  { n: "24h", l: "We reply, personally" },
];

// DISTINCT geo set vs Congo + Timneh pages (cannibalization guard); real live slugs.
const shipPlaces = [
  { href: "/african-grey-parrot-for-sale-florida/", label: "Hand-raised African Greys for sale Florida", note: "Orlando & Miami cargo hubs" },
  { href: "/african-grey-parrot-for-sale-michigan/", label: "Tame hand-fed greys Michigan", note: "Detroit Metro live-animal desk" },
  { href: "/african-grey-parrot-for-sale-north-carolina/", label: "Hand-raised African Grey breeder North Carolina", note: "Charlotte cargo route" },
  { href: "/african-grey-parrot-for-sale-new-jersey/", label: "Hand-fed African Greys for sale New Jersey", note: "Newark Liberty desk" },
  { href: "/african-grey-parrot-for-sale-minnesota/", label: "People-bonded greys Minnesota", note: "Minneapolis–St. Paul cargo" },
  { href: "/african-grey-parrot-for-sale-indiana/", label: "Hand-raised African Grey parrots Indiana", note: "Indianapolis pickup route" },
  { href: "/african-grey-parrot-for-sale-maryland/", label: "Buy a hand-raised African Grey Maryland", note: "BWI live-animal cargo" },
  { href: "/african-grey-parrot-for-sale-wisconsin/", label: "Hand-fed African Greys for sale Wisconsin", note: "Milwaukee cargo desk" },
];

// Real, verified, PAGE-SPECIFIC reviews (breeder-supplied 2026-07-22). Never alter real reviews.
const stories = [
  { name: "Stanley Perkin", loc: "Oceanside, CA 92054", meta: "Verified C.A.Gs buyer",
    avatar: IMG + "stanley-perkin-oceanside-ca-african-gray-bird-review.webp",
    quote: "If you're looking for an african gray bird for sale, I highly recommend C.A.Gs. My bird arrived exactly as promised — healthy, curious, and already comfortable around people. The updates throughout the process and the professionalism of the C.A.Gs team gave me complete confidence. It's rare to find a breeder that truly cares about both the birds and their customers." },
  { name: "Jesse Ovalle", loc: "Baton Rouge, LA 70806", meta: "Verified C.A.Gs buyer",
    avatar: IMG + "jesse-ovalle-baton-rouge-la-african-grey-purchase-review.webp",
    quote: "My African grey parrot purchase through C.A.Gs couldn't have gone better. Every question I had was answered promptly, and I received regular updates before my bird arrived. My African Grey is healthy, intelligent, and already becoming a wonderful member of our family. The quality of care and customer service from C.A.Gs exceeded my expectations." },
];

const readMore = [
  { href: "/how-to-avoid-african-grey-parrot-scams/", img: IMG + "fake-hand-raised-listing-red-flags-760.webp", kicker: "Scam guide", title: "How to avoid African Grey parrot scams", sub: "How a fake 'hand-raised' listing gives itself away — and why the sub-$1,000 ones collapse first." },
  { href: "/congo-vs-timneh-african-grey/", img: IMG + "congo-or-timneh-hand-raised-fast-facts-760.webp", kicker: "Which grey", title: "Congo vs Timneh African Grey", sub: "Both hand-raised the same way here — this weighs which subspecies actually fits your home." },
  { href: "/african-grey-parrot-price/", img: IMG + "what-a-hand-raised-grey-costs-760.webp", kicker: "Pricing", title: "African Grey price — what you pay for", sub: "Where the $1,500 floor comes from, and why hand-rearing is most of the cost." },
  { href: "/african-grey-adoption/", img: IMG + "hand-raised-vs-rescue-grey-760.webp", kicker: "Adopt vs buy", title: "African Grey adoption, honestly", sub: "When a rescued grey is the right call, and when a hand-raised chick is the kinder start." },
];

const faqs = [
  { q: "Is a hand-fed African Grey the same as a hand-raised one?", a: "Not quite, and the difference matters. Hand-fed just means a person delivered the formula; hand-raised — the way we do it — means the chick was fed, handled, played with and talked to every day, then weaned on its own schedule and socialized across our whole household. A bird can be technically hand-fed and still barely tame if nobody put the hours in. Every grey we place is hand-raised, and we can show you the daily notes to prove it." },
  { q: "Are hand-raised African Greys tamer and easier to bond with?", a: "Generally yes — a properly hand-raised grey already sees people as safe, steps up without drama, and starts associating words with objects early. What we won't tell you is that tameness is automatic or permanent: a hand-raised bird still needs daily interaction to stay confident, which is why we coach every new owner through the first weeks rather than waving goodbye at the airport." },
  { q: "Is it bad to take a hand-raised grey away from its parents too early?", a: "Yes, and it's one of the clearest tells of a careless seller. A chick pulled or 'force-weaned' before it's ready can grow up anxious, phobic, or prone to feather-plucking. We co-parent first, let the chick wean on its own timeline between roughly 12 and 16 weeks, and only place a grey once it is eating independently and emotionally settled — never on a shipping deadline." },
  { q: "Why are some 'hand-raised' African Greys only $500 to $800?", a: "Because raising one properly costs real money — incubation, months of hand-feeding, DNA testing, avian-vet care and CITES paperwork — so a healthy, captive-bred, genuinely hand-raised grey does not sell for a few hundred dollars. A sub-$1,000 'hand-raised African Grey' is almost always a stolen photo, a wild-caught bird, or a deposit you'll never see again. Our floor is $1,500 for exactly that reason." },
  { q: "Do you hand-raise both Congo and Timneh African Greys?", a: "We do — every Congo and every Timneh we place is hand-raised here in Midland the same way, which is why this page lists both. Congos are the bigger, red-tailed, headline talkers; Timnehs are smaller, maroon-tailed and often a touch calmer and earlier to mimic. Same rearing, two temperaments — we help you match the bird to your home." },
  { q: "Will a hand-raised African Grey bond with my whole family?", a: "It can, and we set it up to. Because we rotate handling across several people from the start, our greys are used to more than one pair of hands, which lowers the risk of a one-person bird that only tolerates a single owner. Keep that rotation going at home and a hand-raised grey happily becomes a family bird rather than a jealous one." },
  { q: "How is a hand-raised African Grey shipped safely, and can I pick up instead?", a: "Your reserved grey flies domestic-only in a climate-controlled crate booked to IATA live-animal standards, on Delta, United or American — $185 to your closest airport or $350 brought to your door, with the full document folder riding along beside it. If you live roughly two to three hours from Midland, Texas, you're welcome to collect in person, and honestly that's the calmest handoff there is." },
];
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: "Hand-Raised African Grey Parrot for Sale (Congo & Timneh)",
  image: [ site + IMG + "hand-raised-african-grey-parrot-for-sale-hero.webp", site + "/images/congo-page/amie-congo-african-grey-female-card.webp" ],
  description: "A hand-raised, DNA-sexed African Grey parrot from C.A.Gs, a USDA-licensed family aviary in Midland, Texas. Congo and Timneh greys hand-fed, weaned and socialized in-home — captive-bred, CITES Appendix I documented, PBFD & Avian Polyomavirus PCR-screened, placed with lifetime breeder support.",
  category: "Companion parrot",
  brand: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "52" },
  review: stories.map((s) => ({ "@type": "Review", author: { "@type": "Person", name: s.name },
    reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" }, reviewBody: s.quote })),
  offers: { "@type": "AggregateOffer", lowPrice: "1500", highPrice: "3500", priceCurrency: "USD", offerCount: String(available.length),
    availability: "https://schema.org/InStock", url: canonical,
    seller: { "@type": ["Organization", "LocalBusiness"], name: "C.A.Gs – Midland, TX", alternateName: "Congo African Greys" } },
};
const itemListSchema = { "@context": "https://schema.org", "@type": "ItemList",
  itemListElement: available.map((b, i) => ({ "@type": "ListItem", position: i + 1,
    item: { "@type": "Product", name: b.name + " — Hand-Raised " + catLabel(b), category: "Companion parrot",
      offers: { "@type": "Offer", price: String(b.price), priceCurrency: "USD",
        availability: "https://schema.org/InStock", url: site + b.slug } } })) };

// Section spine (Dial 2 list). IDs map to the approved H1–H6 outline.
const sections = [
  { n: "01", id: "means",       label: "What hand-raised means", tag: "Defined" },
  { n: "02", id: "vs",          label: "Hand-fed vs parent-raised", tag: "Compare" },
  { n: "03", id: "available",   label: "Available greys now", tag: available.length + " birds" },
  { n: "04", id: "trust",       label: "Why families trust us", tag: "Verify" },
  { n: "05", id: "howraise",    label: "How we hand-raise", tag: "12–16 wk" },
  { n: "06", id: "downside",    label: "The honest downside", tag: "Bonding" },
  { n: "07", id: "cost",        label: "What it really costs", tag: "$1,500+" },
  { n: "08", id: "scams",       label: "Spot a fake listing", tag: "Red flags" },
  { n: "09", id: "why",         label: "Why greys are special", tag: "Talk" },
  { n: "10", id: "congotimneh", label: "Congo or Timneh?", tag: "Match" },
  { n: "11", id: "shipping",    label: "Safe shipping", tag: "$185/$350" },
  { n: "12", id: "included",    label: "What's included", tag: "Docs" },
  { n: "13", id: "health",      label: "Health & PCR", tag: "Screened" },
  { n: "14", id: "video",       label: "See them on video", tag: "Real" },
  { n: "15", id: "families",    label: "Buyer stories", tag: "5★" },
  { n: "16", id: "faq",         label: "Before you reserve", tag: "FAQ" },
  { n: "17", id: "resources",   label: "Keep reading", tag: "" },
  { n: "18", id: "reserve",     label: "Reserve your grey", tag: "24h" },
];
const N = sections.length;

// T4 Magazine Index Card (curated 6 anchors)
const indexCards = [
  { href: "#means",     n: "01", h: "What hand-raised really means", s: "The word sellers blur" },
  { href: "#available", n: "02", h: "See the greys available now", s: available.length + " Congos & Timnehs" },
  { href: "#howraise",  n: "03", h: "How we hand-raise, week by week", s: "Weaned at 12–16 weeks" },
  { href: "#cost",      n: "04", h: "What a real one costs", s: "Why the floor is $1,500" },
  { href: "#shipping",  n: "05", h: "Shipping, docs & guarantee", s: "$185 airport · $350 home" },
  { href: "#reserve",   n: "06", h: "Reserve & bring one home", s: "We reply within 24h" },
];
const seam = "/cag-fs-seam-emblem.webp";
const deposit = "$200";
const schemaGraph = JSON.stringify({ "@context": "https://schema.org", "@graph": [productSchema, itemListSchema, faqSchema] });
const ogExtra = `<meta property="og:image" content="${site}${IMG}hand-raised-african-grey-parrot-for-sale-hero.webp">`;
---
<BaseLayout title={title} description={description} canonical={canonical} ogType="product" hideGlobalCta={true} schemaJson={schemaGraph} heroPreload={IMG + "hero-mark-hand-scratch-grey.webp"} extraHeadHtml={ogExtra}>

  <main class="handraised">
    <div class="hr-container"><Breadcrumb items={breadcrumbs} /></div>

    <!-- ===================== HERO-A · SCATTERED FLOCK ===================== -->
    <header class="hero">
      <div class="hero-grid hr-container">
        <div class="hero-copy">
          <p class="eyebrow">Est. 2014 · Midland, TX · USDA-licensed family aviary</p>
          <h1>Hand-Raised African Grey Parrots for Sale — <em>tame, people-bonded</em> &amp; ready to reserve</h1>
          <p class="lead">Here at C.A.Gs, every Congo and Timneh African Grey is hand-fed, weaned and socialized in our own home — not pulled early, not warehouse-raised. What you meet is a grey that already trusts people, steps up without a fight, and settles into family life from day one.</p>
          <div class="hero-cta">
            <a class="btn btn-clay" href="#available">Reserve a hand-raised grey →</a>
            <a class="btn btn-ghost" href="#howraise">See how we raise them</a>
          </div>
          <ul class="hero-chips">
            <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> USDA-licensed</li>
            <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> CITES Appendix I documented</li>
            <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> DNA-sexed &amp; PCR-screened</li>
            <li><svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> Ships nationwide</li>
          </ul>
        </div>
        <div class="hero-scatter" aria-hidden="false">
          {heroPolaroids.map((p) => (
            <figure class={"pofig " + p.cls}>
              <img src={p.src}
                   srcset={p.src.replace(".webp", "-320.webp") + " 320w, " + p.src + " 620w"}
                   sizes="(max-width:980px) 42vw, 158px"
                   alt={p.alt} width="620" height="720" style={"object-position:" + p.pos}
                   loading={p.cls === "p1" ? "eager" : "lazy"} fetchpriority={p.cls === "p1" ? "high" : undefined} />
              <figcaption>{p.cap}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </header>

    <!-- ===================== COUNTER STRIP ===================== -->
    <section class="counter" aria-label="Hand-raised at a glance">
      <div class="hr-container counter-grid">
        {counters.map((c) => (<div class="cstat"><span class="cn">{c.n}</span><span class="cl">{c.l}</span></div>))}
      </div>
    </section>

    <div class="seam-wrap" role="presentation"><img class="seam" src={seam} alt="" loading="lazy" width="182" height="60" /></div>

    <!-- ===================== BODY: DIAL 2 SIDEBAR + CONTENT ===================== -->
    <div class="hr-container body-grid">

      <!-- Dial 2 Dark-Aviary (desktop sticky) -->
      <aside class="dial" aria-label="Section progress">
        <div class="dial-card">
          <div class="ring" id="dialRing" style="--p:0">
            <div class="ring-in"><span class="ring-n" id="dialNum">01</span><span class="ring-of">of {N}</span></div>
          </div>
          <ul class="dial-list" id="dialList">
            {sections.map((s) => (
              <li><a href={"#" + s.id} data-id={s.id}><span class="di">{s.n}</span><span class="dh">{s.label}</span>{s.tag && <span class="dt">{s.tag}</span>}</a></li>
            ))}
          </ul>
        </div>
      </aside>

      <div class="content">

        <!-- ===== 01 · MEANS ===== -->
        <section id="means" class="sec">
          <h2>What does "hand-raised" really mean for an African Grey?</h2>
          <p class="opener">"Hand-raised" is the single most abused phrase in this market, so let us define it the way we practice it: a hand-raised African Grey is a chick we fed, held, played with and talked to every single day, then weaned on its own timeline and introduced to normal household life before it ever met you. That daily investment is the whole difference between a bird that greets a stranger and one that lunges at a hand.</p>
          <img class="sec-img inf-img" src={IMG + "what-hand-raised-means.webp"} srcset={IMG + "what-hand-raised-means-760.webp 760w, " + IMG + "what-hand-raised-means.webp 1408w"} sizes="(max-width:900px) 92vw, 760px" width="1408" height="768" loading="lazy" alt="What a hand-raised African Grey is: hand-fed daily, handled and socialized, weaned at 12 to 16 weeks and bonded to people" />
          <h3>Hand-fed, hand-raised, hand-tamed: the words sellers blur</h3>
          <p>Read a dozen listings and you'll see the three terms used as if they mean the same thing. They don't. Because the labels carry different amounts of work, the temperament you take home varies wildly between them — and a seller who blurs them is usually hiding how little handling actually happened.</p>
          <h4>Is "hand-fed" the same as "hand-raised"?</h4>
          <p>Hand-fed only promises that a human held the feeding syringe; it says nothing about whether that chick was ever socialized. Hand-raised — our standard — bundles the feeding together with hours of daily handling, exposure to household sound and movement, and a patient weaning process.</p>
          <h5>Why a bird fed by hand can still be poorly socialized</h5>
          <p>We've met plenty of "hand-fed" greys that flinch at a towel and bite when they're nervous, because volume feeding in a back room produces a fed chick, not a confident companion. Confidence is built in the minutes between feedings — and those minutes are exactly what a rushed operation skips.</p>
          <h6>Breeder note: how we log daily handling from hatch day</h6>
          <p>We keep a simple per-chick log from hatch — who handled it, for how long, what new thing it met that day — and we're glad to walk you through it on a video call. It isn't marketing; it's how Teri makes sure no chick gets quietly under-socialized in a busy clutch.</p>
          <h3>What a properly hand-raised grey is like in your living room</h3>
          <p>A grey raised this way tends to step up on request, tolerate normal household chaos, and treat new people as interesting rather than threatening. It is not a robot and it will still have opinions — but the baseline it starts from is trust, which is the hardest thing to add later.</p>
          <p class="ticket"><a href="#available" class="ticket-cta">See the hand-raised greys we have now <span>→</span></a></p>
        </section>

        <div class="seam-wrap" role="presentation"><img class="seam" src={seam} alt="" loading="lazy" width="182" height="60" /></div>

        <!-- ===== 02 · VS ===== -->
        <section id="vs" class="sec">
          <h2>Hand-fed vs hand-raised vs parent-raised: which African Grey should you buy?</h2>
          <p class="opener">There are three honest ways a grey reaches you — hand-fed, hand-raised, or parent-raised — and each produces a different starting temperament. Because most buyers want a bird that bonds quickly, a properly hand-raised grey is usually the right answer, but we'd rather you choose it knowing the trade-offs than because a listing shouted "tame".</p>
          <img class="sec-img inf-img" src={IMG + "hand-fed-vs-hand-raised-vs-parent-raised.webp"} srcset={IMG + "hand-fed-vs-hand-raised-vs-parent-raised-760.webp 760w, " + IMG + "hand-fed-vs-hand-raised-vs-parent-raised.webp 1408w"} sizes="(max-width:900px) 92vw, 760px" width="1408" height="768" loading="lazy" alt="Comparison of hand-fed, hand-raised and parent-raised African Greys showing hand-raised as the tamest" />
          <h3>The three rearing paths, side by side</h3>
          <div class="tblwrap">
            <table class="tblC">
              <thead><tr><th>Rearing path</th><th>What it means</th><th>Starting tameness</th><th>Best for</th></tr></thead>
              <tbody>
                <tr><td>Hand-fed only</td><td>Fed by hand, little else</td><td>Variable</td><td>Owners who'll do the socializing</td></tr>
                <tr class="pick"><td>Hand-raised <span class="badge">Top pick</span></td><td>Fed, handled &amp; socialized daily</td><td>High, people-bonded</td><td>Most families &amp; first-grey homes</td></tr>
                <tr><td>Parent-raised</td><td>Raised by the parent birds</td><td>Shy at first</td><td>Patient, experienced keepers</td></tr>
              </tbody>
            </table>
          </div>
          <h4>Are parent-raised African Greys ever the better choice?</h4>
          <p>Sometimes, yes. A parent-raised grey often grows up more independent and can be wonderfully well-adjusted in the right hands, which is why we won't dismiss it.</p>
          <h5>When a parent-raised grey suits a patient, experienced owner</h5>
          <p>If you've kept parrots before, enjoy earning trust slowly, and don't need a bird that cuddles in week one, a parent-raised grey can be a deeply rewarding project. For a first-time owner hoping to bond fast, though, it's a harder road than a hand-raised chick.</p>
          <h6>Citation: avian-welfare findings on early socialization</h6>
          <p><a href="https://www.aav.org/" target="_blank" rel="noopener">The Association of Avian Veterinarians' guidance on companion-parrot socialization ↗</a> lines up with what we see in the nursery — the earliest months set a grey's temperament, which is exactly why we pour ourselves into them.</p>
          <h3>Why we co-parent first, then hand-raise</h3>
          <p>We leave chicks with their parents through the earliest days, then bring them into the nursery for hand-raising once they're strong. That order gives us the best of both: the security of parent care first, and the human bond that makes a grey a companion.</p>
        </section>

