                </figcaption>
              </figure>
            ))}
          </div>
        </section>

        <div class="seam-wrap" role="presentation"><img class="seam" src={seam} alt="" loading="lazy" width="182" height="60" /></div>

        <!-- ===== 16 · FAQ · FAQ-C refreshed green ===== -->
        <section id="faq" class="sec">
          <h2>Common questions before you reserve a hand-raised grey</h2>
