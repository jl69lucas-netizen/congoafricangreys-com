import Breadcrumb from '../../components/Breadcrumb.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system
// as the homepage; ids live on each .section-block. Document order required.
const jumpSections = [
