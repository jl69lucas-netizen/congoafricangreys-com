<script is:inline>
(function(){
  // FAQ accordion (smooth open/close) — mirrors homepage / cites-doc pattern
  var qs = document.querySelectorAll('.cag-faq-q');
  qs.forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = btn.closest('.cag-faq-item');
      var open = item.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  // Section jump-nav auto-injector
  var labels = {
    'why-rampant':'Why Scams Are Rampant',
    'five-types':'The 5 Types of Scams',
    'red-flags':'12 Red Flags Explained',
    'verify-usda':'Verify USDA License',
    'verify-cites':'Verify CITES Documents',
    'reverse-image':'Reverse Image Search',
    'whois':'Domain Age Check',
    'questions':'10 Questions to Ask',
    'inquiry':'Contact a Verified Breeder',
    'advance-fee':'Advance-Fee Fraud Script',
    'shipping-scams':'Fake Shipping Red Flags',
    'victim-stories':'Real Victim Stories',
    'known-scams':'Known Scam Patterns',
    'safe-payments':'Safe Payment Methods',
    'documentation':'Legitimate Documentation Guide',
    'why-cags':'Why C.A.Gs Is Verified',
    'report-scam':'How to Report a Scam',
    'faq':'Frequently Asked Questions',
    'final-cta':'Contact a Verified Breeder'
  };
  var body = document.querySelector('.content-body');
  if(!body) return;
  var anchors = Array.from(body.querySelectorAll('a[name]'));
  var pairings = [];
  anchors.forEach(function(a){
    var next = a.nextElementSibling;
    if(next && (next.classList.contains('section-block') || next.classList.contains('form-section'))){
      pairings.push({el: next, name: a.getAttribute('name')});
    }
  });
  for(var i=0; i<pairings.length-1; i++){
    var nextName = pairings[i+1].name;
    var lbl = labels[nextName] || nextName;
    var nav = document.createElement('div');
    nav.className = 'section-next-nav';
    nav.innerHTML = '<a href="#'+nextName+'" class="section-next-link">&#8595; Continue: '+lbl+'</a>';
    pairings[i].el.appendChild(nav);
  }
})();
</script>

