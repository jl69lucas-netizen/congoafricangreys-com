  // Part 2 — Verify the Breeder
  { id: 'verify-usda',    label: 'USDA Check',       part: 2 },
  { id: 'verify-cites',   label: 'CITES Check',      part: 2 },
  { id: 'reverse-image',  label: 'Photo Check',      part: 2 },
  { id: 'whois',          label: 'Domain Age',       part: 2 },
  { id: 'questions',      label: '10 Questions',     part: 2 },
  // Part 3 — How Scams Unfold
  { id: 'advance-fee',    label: 'Fraud Script',     part: 3 },
  { id: 'shipping-scams', label: 'Shipping Scam',    part: 3 },
  { id: 'victim-stories', label: 'Victim Stories',   part: 3 },
  { id: 'known-scams',    label: 'Listing Signals',  part: 3 },
  // Part 4 — Buy Safely
  { id: 'safe-payments',  label: 'Safe Payments',    part: 4 },
  { id: 'documentation',  label: 'CITES Docs',       part: 4 },
  { id: 'why-cags',       label: 'Why C.A.Gs',       part: 4 },
  { id: 'report-scam',    label: 'Report a Scam',    part: 4 },
  { id: 'faq',            label: 'FAQ',              part: 4 },
  { id: 'form-bottom',    label: 'Ask C.A.Gs',       part: 4 },
];
const jumpPartNames = {
  1: 'Spot the Scams',
  2: 'Verify the Breeder',
  3: 'How Scams Unfold',
  4: 'Buy Safely',
};

const title = "How to Avoid African Grey Parrot Scams: 12 Red Flags + CITES Verification Guide | C.A.Gs - Midland, TX";
const description = "African Grey parrot scams are rampant in 2025–2026. Learn the 12 red flags, how to verify a USDA AWA license, check CITES documentation, and buy safely. C.A.Gs — USDA-licensed, CITES-certified breeders in Midland, TX.";
const canonical = "https://congoafricangreys.com/how-to-avoid-african-grey-parrot-scams/";

const extraHeadHtml = `
<meta property="og:locale" content="en_US">
<meta property="og:image" content="https://congoafricangreys.com/cag-header-logo.png">
<meta property="og:image:alt" content="C.A.Gs — USDA-licensed captive-bred African Grey parrot breeders, Midland TX">
<meta property="article:published_time" content="2026-05-17T00:00:00+00:00">
<meta property="article:modified_time" content="2026-06-10T00:00:00+00:00">
<meta name="twitter:title" content="How to Avoid African Grey Parrot Scams: 12 Red Flags + CITES Verification Guide">
<meta name="twitter:description" content="Scammers stole $260–$1,000+ from real buyers. Learn the 12 red flags, USDA verification, safe payments, and how to report parrot fraud.">
`;

const schemaJson = `
