---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import CTA from '../../components/CTA.astro';

const title = "How to Avoid African Grey Parrot Scams | Red Flags & Safe Buying Guide";
const description = "African Grey parrot scams are rampant online. Learn the 8 red flags, how to verify a legitimate breeder, and what documents a real captive-bred bird must have.";
const canonical = "https://congoafricangreys.com/how-to-avoid-african-grey-parrot-scams/";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I know if an African Grey parrot seller is a scam?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The clearest scam signals: price below $800 for a baby African Grey (legitimate captive-bred birds cost $1,500–$3,500+), no CITES documentation offered, seller cannot provide USDA license number, payment only via wire transfer or gift cards, no video call or in-person visit allowed, website has no verifiable business address or phone number, and photos are stock images or low-quality generic parrot photos."
      }
    },
    {
      "@type": "Question",
      "name": "What documents should a legitimate African Grey breeder provide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A legitimate African Grey breeder should provide: (1) CITES Appendix II captive-bred certificate — proves the bird is legal to own and was bred in captivity, not wild-caught; (2) DNA sexing certificate from a certified lab; (3) USDA health certificate, required for interstate transport; (4) Avian vet health records. If a seller cannot provide all four documents, do not purchase."
      }
    },
    {
      "@type": "Question",
      "name": "Is it safe to buy an African Grey parrot online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It can be safe if you verify: USDA AWA license number (check the USDA APHIS database), CITES documentation policy, verifiable business address, phone number with real callback, and references from past buyers. Avoid any seller who won't do a video call showing the actual bird, won't provide documentation, or pressures you to pay immediately via untraceable payment methods."
      }
    },
    {
      "@type": "Question",
      "name": "Why are African Grey parrots targeted by scammers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "African Greys are one of the most expensive and sought-after parrot species — $1,500–$3,500 for captive-bred birds. This high price point makes them an attractive target for scammers who post fake listings at $400–$800, collect deposits or full payment, then disappear. The buyer is left with no bird and no recourse."
      }
    },
    {
      "@type": "Question",
      "name": "What is a fair price for an African Grey parrot?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Legitimate captive-bred, CITES-documented African Grey parrots cost $1,500–$3,500 for Congo African Greys and $1,200–$2,500 for Timneh African Greys. Prices below $800 for a baby should be treated as a major red flag. Adult birds from private rehome situations may be $800–$1,500 but require additional verification. The BirdBreeders.com platform shows premium breeders charging $5,999–$8,500 for show-quality birds."
      }
    },
    {
      "@type": "Question",
      "name": "How do I verify if a breeder is USDA licensed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ask the breeder for their USDA Animal Welfare Act (AWA) license number. You can verify any USDA license at the USDA APHIS Animal Care database at aphis.usda.gov. Licensed breeders are subject to USDA inspection and must maintain federal animal care standards. If a breeder refuses to provide their license number or the number doesn't verify, do not purchase."
      }
    },
    {
      "@type": "Question",
      "name": "What should I do if I think I've been scammed buying an African Grey parrot?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Report immediately to: (1) IC3.gov — the FBI's Internet Crime Complaint Center; (2) FTC at reportfraud.ftc.gov; (3) Your state Attorney General's consumer protection division; (4) The platform where you found the listing (Facebook, Craigslist, etc.) to get it removed. If you paid by credit card, dispute the charge immediately. Wire transfers and gift card payments are typically unrecoverable."
      }
    },
    {
      "@type": "Question",
      "name": "Are African Grey parrots from Craigslist or Facebook Marketplace safe to buy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Classified platforms like Craigslist, Facebook Marketplace, and Hoobly are unmoderated — scam listings appear freely alongside legitimate private seller listings. If you find a listing on these platforms, apply extra verification: demand a live video call with the actual bird visible, request CITES documentation photos, verify the seller's identity, and never pay before seeing documents. Better alternative: purchase directly from a USDA-licensed aviary where accountability is verifiable."
      }
    }
  ]
};
---

<BaseLayout {title} {description} {canonical}>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-logo-dark text-cream py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold font-sora text-sm font-semibold uppercase tracking-widest mb-3">Buyer Protection Guide</p>
      <h1 class="font-lora font-bold text-4xl sm:text-5xl mb-4">How to Avoid African Grey Parrot Scams</h1>
      <p class="text-cream/80 text-lg max-w-xl mx-auto">8 red flags that expose fake breeders — and the exact documents a real captive-bred African Grey must have before you buy.</p>
    </div>
  </section>

  <TrustBar />

  <!-- Intro -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg mb-8">
        <p class="text-red-800 font-semibold mb-1">African Grey scam listings are everywhere.</p>
        <p class="text-red-700 text-sm">Platforms like Hoobly, Craigslist, and even Facebook Marketplace host listings for African Grey parrots at $200–$600 — birds that don't exist, operated by scammers who collect deposits and disappear. Some sites (like exoticpetsavenue.com, which we've documented) sell illegally protected animals alongside stolen parrot photos. Knowing the red flags protects your money and prevents you from funding illegal trade.</p>
      </div>
      <p class="text-stone-700 text-lg leading-relaxed">
        We've been breeding African Grey parrots since 2014 under USDA AWA licensing. We've heard from dozens of buyers who almost fell for — or did fall for — scam listings before finding us. This guide summarizes what they wish they'd known first.
      </p>
    </div>
  </section>

  <!-- 8 Red Flags -->
  <section class="bg-stone-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">8 Red Flags in African Grey Parrot Listings</h2>
      <div class="space-y-4">
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">1</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Price below $800 for a baby African Grey</h3>
              <p class="text-stone-600 text-sm">Captive-bred, CITES-documented, vet-certified African Greys cost $1,500–$3,500. If a "breeder" lists a baby at $400–$800, they either don't have the bird, or it's wild-caught and undocumented. Either way, you shouldn't buy it.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">2</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">No CITES documentation offered</h3>
              <p class="text-stone-600 text-sm">African Greys are CITES Appendix II. Every captive-bred bird sold in the US must come with a CITES certificate confirming captive-bred status. If a seller says "I don't have paperwork" or "you don't need papers" — walk away. Buying an undocumented African Grey exposes you to seizure and legal penalties.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">3</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Payment only by wire transfer or gift cards</h3>
              <p class="text-stone-600 text-sm">Scammers demand untraceable payment. Wire transfers and gift cards cannot be reversed. Legitimate breeders accept traceable payments (check, bank transfer with verification, credit card through a payment processor). If you can't dispute the payment, you have no recourse when the bird never arrives.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">4</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">No live video call showing the actual bird</h3>
              <p class="text-stone-600 text-sm">Before sending any money, demand a live video call where you can see the actual bird, the environment it lives in, and the breeder. Scammers use stock photos and generic bird images. A live call with an unscripted bird in a real aviary setting is a basic verification step no legitimate breeder will refuse.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">5</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">No verifiable USDA license number</h3>
              <p class="text-stone-600 text-sm">Ask for the USDA AWA license number and verify it at aphis.usda.gov. A licensed facility is federally inspected and accountable. No license means no oversight — and no accountability if things go wrong.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">6</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Generic website with no physical address or phone number</h3>
              <p class="text-stone-600 text-sm">Scam sites are built fast and abandoned fast. A real breeding operation has a real address, a real phone number with a human who answers, and a Google My Business presence. If the site has no contact info beyond a generic email form, that's a warning sign.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">7</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Too-good-to-be-true shipping story</h3>
              <p class="text-stone-600 text-sm">Scam listings often claim the bird is "in transit" or "being held at an airport cargo facility" and need an immediate payment to release it. IATA-compliant bird shipping requires advance scheduling — birds don't get stranded waiting for "release fees." This narrative is a classic advance-fee fraud script.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-5 border-l-4 border-red-400">
          <div class="flex items-start gap-4">
            <span class="bg-red-100 text-red-700 font-bold text-lg rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">8</span>
            <div>
              <h3 class="font-semibold text-logo-dark mb-1">Pressure to pay immediately or "someone else will take it"</h3>
              <p class="text-stone-600 text-sm">Urgency pressure is a scam technique. A real breeder has relationships with buyers — they don't pressure you to wire money in 24 hours. If someone is rushing you, they need your money before you can verify their legitimacy.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Legitimate Looks Like -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-6">What a Legitimate Breeder Looks Like</h2>
      <p class="text-stone-700 mb-6">After 10+ years breeding African Greys, here's what buyers should expect from a legitimate, accountable breeder:</p>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-lg p-4 border border-green-200">
          <h3 class="font-semibold text-green-800 mb-3">Documentation</h3>
          <ul class="space-y-1 text-green-700 text-sm">
            <li>✓ USDA AWA license (verifiable)</li>
            <li>✓ CITES Appendix II certificate</li>
            <li>✓ DNA sexing certificate</li>
            <li>✓ Avian vet health certificate</li>
            <li>✓ Complete vet records</li>
          </ul>
        </div>
        <div class="bg-green-50 rounded-lg p-4 border border-green-200">
          <h3 class="font-semibold text-green-800 mb-3">Transparency</h3>
          <ul class="space-y-1 text-green-700 text-sm">
            <li>✓ Live video call before purchase</li>
            <li>✓ Physical address listed</li>
            <li>✓ Real phone number, human answers</li>
            <li>✓ Buyers can visit the aviary</li>
            <li>✓ References from past buyers</li>
          </ul>
        </div>
        <div class="bg-green-50 rounded-lg p-4 border border-green-200">
          <h3 class="font-semibold text-green-800 mb-3">Pricing</h3>
          <ul class="space-y-1 text-green-700 text-sm">
            <li>✓ Congo AG: $1,500–$3,500</li>
            <li>✓ Timneh AG: $1,200–$2,500</li>
            <li>✓ Pricing explained openly</li>
            <li>✓ Written receipt provided</li>
            <li>✓ Deposit under 30% of price</li>
          </ul>
        </div>
        <div class="bg-green-50 rounded-lg p-4 border border-green-200">
          <h3 class="font-semibold text-green-800 mb-3">Ongoing Support</h3>
          <ul class="space-y-1 text-green-700 text-sm">
            <li>✓ After-sale guidance provided</li>
            <li>✓ Nutrition and care guides included</li>
            <li>✓ Available by phone after purchase</li>
            <li>✓ Health guarantee in writing</li>
            <li>✓ Long-term relationship, not one transaction</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-stone-50 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-lora font-bold text-3xl text-logo-dark mb-8">African Grey Scam Prevention: FAQs</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item: any) => (
          <details class="bg-white border border-stone-200 rounded-lg">
            <summary class="p-4 font-semibold text-logo-dark cursor-pointer hover:text-clay transition-colors list-none flex justify-between items-center">
              {item.name}
              <span class="text-stone-400 text-lg">+</span>
            </summary>
            <div class="px-4 pb-4 text-stone-600 text-sm leading-relaxed border-t border-stone-100 pt-3">
              {item.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="bg-logo-dark text-cream rounded-2xl p-8 text-center">
        <h2 class="font-lora font-bold text-2xl mb-3">Buy With Confidence from a Verified USDA Breeder</h2>
        <p class="text-cream/80 mb-6">Congo African Greys — Mark & Teri Benjamin, Midland TX. USDA AWA licensed since 2014. Every bird CITES-documented, DNA-sexed, and vet-certified before placement.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/trusted-african-grey-parrot-breeders/" class="bg-gold text-logo-dark font-semibold px-6 py-3 rounded-full hover:bg-cream transition-colors">Meet the Breeders</a>
          <a href="/cites-african-grey-documentation/" class="border-2 border-gold text-gold font-semibold px-6 py-3 rounded-full hover:bg-gold hover:text-logo-dark transition-colors">Learn About CITES Docs</a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
