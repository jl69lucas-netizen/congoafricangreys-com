---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CounterSnippet from '../../components/cag-library/CounterSnippet.astro';
import KeyTakeawayV2 from '../../components/cag-library/KeyTakeawayV2.astro';
import CompareTableE from '../../components/cag-library/CompareTableE.astro';
import BirdCard from '../../components/BirdCard.astro';
import InquiryForm from '../../components/cag-inquiry-form.astro';
import JumpRail from '../../components/cag-library/JumpRail.astro';

const title = "African Grey Parrot Price 2026 — Complete Cost of Ownership: Congo $1,700–$2,500 · Timneh $1,500–$1,600 · Shipping $185/$350, First-Year Setup, Annual & 40–60 Yr Lifetime Costs | C.A.Gs – Midland, TX";
const description = "African Grey parrot price, published in full by C.A.Gs — USDA-licensed breeders in Midland, TX. Congo babies $2,300–$2,500, adults $1,700, Timnehs $1,500–$1,600, pairs $3,500. Documentation included, shipping $185 airport / $350 home, plus first-year, annual, and 40–60 yr lifetime costs.";
const canonical = "https://congoafricangreys.com/african-grey-parrot-price/";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "African Grey Parrot Price", url: "/african-grey-parrot-price/" },
];

// In-page section nav (desktop dot rail + mobile bottom sheet) — same system as
// the homepage + diet/care pages; ids live on each section. Document order.
const jumpSections = [
  { id: 'prices',          label: 'Prices',       part: 1 },
  { id: 'why-vary',        label: 'Why They Vary', part: 1 },
  { id: 'included',        label: "What's Included", part: 1 },
  { id: 'shipping',        label: 'Shipping',     part: 2 },
  { id: 'first-year',      label: 'First Year',   part: 2 },
  { id: 'ongoing',         label: 'Ongoing',      part: 2 },
  { id: 'available-birds', label: 'Available',    part: 3 },
  { id: 'eggs-pairs',      label: 'Eggs & Pairs', part: 3 },
  { id: 'faq',             label: 'FAQ',          part: 3 },
  { id: 'contact',         label: 'Ask C.A.Gs',   part: 3 },
];
const jumpPartNames = {
  1: 'The Price',
  2: 'Total Cost',
  3: 'Choose & Reserve',
};

// ─── EVERY figure below traces to data/price-matrix.json + data/financial-entities.json ───
// Purchase (price-matrix.json): baby $2,300–$2,500 · adult $1,700 · Timneh $1,500–$1,600 ·
//   pair $3,500 · breeding pair $3,000 · fertile egg $95 · deposit $200
// Delivery (financial-entities.json delivery_options): airport $185 · home $350 · flight nanny from $750
// First-year + annual ranges: financial-entities.json first_year_setup / annual_ongoing
// Lifetime: computed from annual_ongoing ($375–$1,350) × lifespan_years (40–60)

// ─── Published price list (rendered table + schema source) ───
const priceList = [
  { item: "Congo African Grey — baby (3–6 months)", price: "$2,300–$2,500", note: "Hand-raised, fully weaned at 12–16 weeks, socialized" },
  { item: "Congo African Grey — adult (1 yr+)", price: "$1,700", note: "Tame, established personality, full paperwork" },
  { item: "Timneh African Grey", price: "$1,500–$1,600", note: "Smaller variant, calmer, often an earlier talker" },
  { item: "Bonded pair (Jins + Jeni — must go together)", price: "$3,500", note: "Unrelated male + female, both hand-raised" },
  { item: "Proven breeding pair", price: "$3,000", note: "Bonded, DNA-certified — for established breeders" },
  { item: "Fertile egg (experienced breeders only)", price: "$95", note: "Buy 5 eggs, free US shipping · no incubation support" },
  { item: "Deposit to reserve any bird", price: "$200", note: "Applied in full to the final price" },
];

// ─── First-year setup (financial-entities.json first_year_setup) ───
const firstYear = [
  { item: "Large cage (wide, horizontal bars)", range: "$300–$800", type: "One-time" },
  { item: "Perches & starter toys", range: "$100–$300", type: "One-time" },
  { item: "Initial avian vet visit", range: "$75–$200", type: "One-time" },
  { item: "Food & pellets (first year)", range: "$200–$400", type: "Recurring" },
  { item: "Enrichment (first year)", range: "$150–$300", type: "Recurring" },
];

// ─── Annual ongoing (financial-entities.json annual_ongoing) ───
const annual = [
  { item: "Food & treats", range: "$200–$400" },
  { item: "Avian vet wellness exam", range: "$75–$200" },
  { item: "Toy replacement (chewed = healthy)", range: "$100–$250" },
  { item: "Unexpected vet buffer", range: "$0–$500" },
];

// ─── Available birds (verified against price-matrix.json; shipping line hardwired in BirdCard) ───
const birds = [
  { id: 'roys',  name: 'Roys',  sex: 'Male',   age: '4 mo',  price: '$2,300', priceVal: 2300,
    tag: 'Baby Boy', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/roys-congo-african-grey-male-4-months.webp', objectPos: 'object-center',
    hook: 'Hand-raised in our home from day one.',
    notes: "Hand-raised male Congo, 4 months old — captive-bred, PCR DNA-sexed, vet-checked, and CITES Appendix I documented before he ever ships." },
  { id: 'amie',  name: 'Amie',  sex: 'Female', age: '3 mo',  price: '$2,500', priceVal: 2500,
    tag: 'New Arrival', tagType: 'new' as const, variant: 'Congo African Grey',
    image: '/amie-congo-african-grey-female-3-months.webp', objectPos: 'object-center',
    hook: 'Socialized by our whole family.',
    notes: 'Premium hand-raised female Congo, 3 months old. Closed-banded, hatch-certified, CITES Appendix I documented.' },
  { id: 'bery',  name: 'Bery',  sex: 'Female', age: '1 yr',  price: '$1,700', priceVal: 1700,
    tag: 'Best Value', tagType: 'value' as const, variant: 'Congo African Grey',
    image: '/bery-congo-african-grey-female-1-year.webp',
    hook: 'Gentle, settled, paperwork in hand.',
    notes: 'Soft temperament, easy to handle. 1-year-old captive-bred female Congo with full health and CITES documentation.' },
  { id: 'elad',  name: 'Elad',  sex: 'Male',   age: '5 mo',  price: '$1,600', priceVal: 1600,
    tag: 'Timneh', tagType: 'new' as const, variant: 'Timneh African Grey',
    image: '/elad-timneh-african-grey-male-5-months.webp',
    hook: 'Smaller bird, same documentation standard.',
    notes: 'Hand-raised male Timneh, 5 months old. PCR DNA-sexed, avian-vet certified, captive-bred and never wild-caught.' },
  { id: 'evie',  name: 'Evie',  sex: 'Female', age: '6 mo',  price: '$1,500', priceVal: 1500,
    tag: 'Timneh', tagType: 'value' as const, variant: 'Timneh African Grey',
    image: '/evie-timneh-african-grey-female-6-months.webp', objectPos: 'object-top',
    hook: 'Calm, clever, ready to come home.',
    notes: 'Hand-raised female Timneh, 6 months old. Closed band, hatch certificate, and CITES Appendix I paperwork included.' },
  { id: 'jins-jeni', name: 'Jins + Jeni', sex: 'Pair', age: '4–6 mo', price: '$3,500 pair', priceVal: 3500,
    tag: 'Must-Go Pair', tagType: 'family' as const, variant: 'Congo African Grey',
    image: '/jins-jeni-congo-african-grey-pair.webp',
    hook: 'Two bonded birds, one documented package.',
    notes: 'Unrelated captive-bred pair, must be adopted together. Jins (male, 6mo) + Jeni (female, 4mo). Both hand-raised and fully documented.' },
];

// ─── FAQ (QAB: Question → Answer → Benefit) — mirrored exactly into FAQPage schema ───
const faqs = [
  { q: "How much does an African Grey parrot cost?",
    a: `Here at C.A.Gs, a captive-bred African Grey costs $1,500 to $3,500: Congo babies run $2,300–$2,500, Congo adults $1,700, Timnehs $1,500–$1,600, and a bonded pair $3,500. Every price includes the complete documentation packet — CITES Appendix I captive-bred paperwork, hatch certificate, closed band, PCR DNA sexing, PBFD and Polyomavirus screening, and our 72-hour written guarantee. Knowing the full published range up front means you can budget accurately and recognize a too-good-to-be-true listing instantly.` },
  { q: "How much is a baby Congo African Grey?",
    a: `A hand-raised baby Congo African Grey (3–6 months old) is $2,300–$2,500 from our aviary. Babies sit at the top of our range because they carry the most labor: 12–16 weeks of hand-feeding, daily socialization by our whole family, and full health screening before they travel. The benefit of paying baby pricing is a Grey that arrives already people-bonded — weeks of taming instead of months.` },
  { q: "How much does a Timneh African Grey cost?",
    a: `Our Timneh African Greys are $1,500–$1,600. Timnehs cost less than Congos because they are the smaller, less-recognized variant — not because they are lesser birds. They ship with the identical documentation packet, and many first-time owners actually do better with a Timneh's calmer temperament and earlier talking onset. The benefit: the same 40–60 year African Grey companionship at the most accessible entry price we publish.` },
  { q: "Why are African Grey parrots so expensive?",
    a: `An African Grey's price reflects what it takes to produce one bird legally and well: months of hand-feeding labor, PCR DNA sexing and disease screening at an avian lab, a veterinarian's certificate, CITES Appendix I captive-bred documentation, and a USDA AWA-licensed facility behind it all. Greys also lay small clutches and wean slowly at 12–16 weeks, so supply is genuinely limited. The benefit of that price is everything a cheap listing skips — verified health, legal paperwork, and a breeder who answers the phone for the life of the bird.` },
  { q: "Is a cheap African Grey under $1,500 legitimate?",
    a: `Treat any African Grey advertised well below $1,500 as a red flag until proven otherwise. The figure is not arbitrary — $1,500 is the realistic floor for a legally documented, health-screened captive-bred Grey, and listings far beneath it are usually one of two things: a scam with no bird at all, or a bird without the CITES paperwork that makes ownership legal. Our <a href="/how-to-avoid-african-grey-parrot-scams/">scam-prevention guide</a> walks through the exact scripts. The benefit of knowing the floor is that the most common parrot fraud online stops working on you.` },
  { q: "What does the African Grey price include?",
    a: `Every C.A.Gs price includes the bird's complete file at no extra charge: CITES Appendix I captive-bred documentation, hatch certificate with closed-band number, PCR DNA sexing certificate, PBFD and Avian Polyomavirus screening results, a board-certified avian veterinarian's health certificate, and our 72-hour written health guarantee. The benefit is a single honest number — you never get to deposit day and discover a "documentation fee" was waiting behind the price tag.` },
  { q: "How much is the deposit to reserve an African Grey?",
    a: `The deposit is $200, it reserves a specific named bird, and it is applied in full toward the final price — not added on top. We accept traceable payment methods only and never ask for gift cards, cryptocurrency, or wire transfers to personal accounts, because those are the hallmarks of parrot payment fraud. The benefit of a traceable $200 deposit is a paper trail that protects you before a single feather travels.` },
  { q: "How much does it cost to ship an African Grey parrot?",
    a: `We ship nationwide under IATA Live Animals Regulations on Delta, United, or American: airport pickup at your nearest major airport is $185, door-to-door home delivery is $350, and an in-cabin flight nanny — where the bird never enters the cargo hold — is quoted per route from $750. The benefit of flat published tiers is that your total cost is knowable before you commit, with no destination-based surprises.` },
  { q: "What is the first-year cost of owning an African Grey?",
    a: `Beyond the purchase price, plan on $825–$2,000 in first-year costs: a large cage ($300–$800), perches and starter toys ($100–$300), an initial avian vet visit ($75–$200), a year of food ($200–$400), and enrichment ($150–$300). The cage and vet figures are typical industry ranges — your local prices may differ. The benefit of budgeting the first year before the bird arrives is that the only surprise left is how fast you fall for the bird.` },
  { q: "What is the lifetime cost of an African Grey parrot?",
    a: `African Greys live 40–60 years, and ongoing care of $375–$1,350 per year compounds to roughly $15,000–$54,000 over a 40-year life and $22,500–$81,000 over 60 years — on top of the purchase price. A Grey can outlive its owner, so responsible ownership includes naming a future caretaker. The benefit of facing the lifetime math now is that you make a once-in-a-lifetime decision deliberately instead of discovering it by surprise in year three.` },
];

const stripHtml = (s: string) => s.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: stripHtml(f.a) },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "African Grey Parrot Price — the Complete, Published Cost of Ownership",
  description: "The full African Grey parrot price breakdown from a USDA AWA-licensed aviary: purchase price by variant and age, why prices vary and where the scam floor sits, the documentation included in every price, shipping tiers, first-year setup, annual ongoing costs, and the honest 40–60 year lifetime estimate.",
  inLanguage: "en-US",
  about: {
    "@type": "Thing",
    name: "African Grey Parrot Price",
    description: "Purchase price, first-year setup, annual, and lifetime cost of owning a Congo or Timneh African Grey parrot (Psittacus erithacus).",
    sameAs: "https://parrots.org/encyclopedia/grey-parrot/",
  },
  author: {
    "@type": "Organization",
    name: "C.A.Gs – Midland, TX",
    url: "https://congoafricangreys.com/trusted-african-grey-parrot-breeders/",
  },
  publisher: {
    "@type": "Organization",
    name: "Congo African Greys",
    logo: { "@type": "ImageObject", url: "https://congoafricangreys.com/cag-footer-logo.webp" },
  },
  datePublished: "2024-09-01",
  dateModified: "2026-06-11",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

// ─── Page-level Product + AggregateOffer (values from data/price-matrix.json) ───
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Captive-Bred African Grey Parrot (Congo & Timneh) — C.A.Gs, Midland TX",
  description: "Hand-raised, captive-bred Congo and Timneh African Grey parrots with complete CITES Appendix I documentation, hatch certificate, closed band, PCR DNA sexing, PBFD and Polyomavirus screening, board-certified avian-vet health certificate, and a 72-hour written guarantee. Ships nationwide — $185 airport pickup / $350 home delivery.",
  category: "Live pet bird / companion parrot",
  brand: { "@type": "Brand", name: "C.A.Gs – Midland, TX" },
  image: "https://congoafricangreys.com/hand-fed-african-grey-baby-breeder.webp",
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "USD",
    lowPrice: "1500",
    highPrice: "3500",
    offerCount: String(birds.length),
    availability: "https://schema.org/InStock",
    url: canonical,
    seller: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
  },
};

// ─── Per-bird ItemList Product/Offer (homepage pattern, data-driven) ───
const birdListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Available Congo & Timneh African Greys at C.A.Gs — Published Prices",
  itemListElement: birds.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: `${b.name} — ${b.variant} (${b.sex})`,
      description: `${b.notes} Hand-raised, PCR DNA-sexed, screened for PBFD and Polyomavirus, CITES Appendix I captive-bred, and fully weaned at 12–16 weeks. Includes a board-certified avian-vet health certificate, hatch certificate, closed band, and a 72-hour written health guarantee.`,
      category: "Live pet bird / companion parrot",
      brand: { "@type": "Brand", name: "C.A.Gs – Midland, TX" },
      image: `https://congoafricangreys.com${b.image}`,
      offers: {
        "@type": "Offer",
        priceCurrency: "USD",
        price: String(b.priceVal),
        availability: "https://schema.org/InStock",
        url: `https://congoafricangreys.com/contact-us/?bird=${b.id}`,
        seller: { "@type": "Organization", name: "C.A.Gs – Midland, TX" },
      },
    },
  })),
};

// BreadcrumbList JSON-LD is emitted by the <Breadcrumb> component — do not duplicate here.

// ─── TOC (grouped jump links) ───
const tocParts = [
  {
    label: "Part One",
    sub: "What the bird costs",
    rows: [
      { n: 1, t: "How Much Does an African Grey Parrot Cost? (The Published Price List)", href: "#prices" },
      { n: 2, t: "Why Do African Grey Prices Vary So Much — and Where Is the Scam Floor?", href: "#why-vary" },
      { n: 3, t: "What's Actually Included in Our Price?", href: "#included" },
      { n: 4, t: "How Much Does Shipping an African Grey Cost?", href: "#shipping" },
    ],
  },
  {
    label: "Part Two",
    sub: "What ownership costs",
    rows: [
      { n: 5, t: "What Does the First Year Cost, Beyond the Purchase Price?", href: "#first-year" },
      { n: 6, t: "What Are the Annual & 40–60 Year Lifetime Costs?", href: "#ongoing" },
      { n: 7, t: "Congo vs Timneh — Which Costs What?", href: "#compare" },
      { n: 8, t: "Which Greys Are Available Now, at Which Price?", href: "#available-birds" },
      { n: 9, t: "How Much Do African Grey Eggs and Breeding Pairs Cost?", href: "#eggs-pairs" },
      { n: 10, t: "African Grey Price — Your Questions, Answered", href: "#faq" },
    ],
  },
];
---

<BaseLayout {title} {description} {canonical} ogType="article" hideGlobalCta>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(birdListSchema)} />

  <div class="price-d cag-article">

    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-12">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <JumpRail sections={jumpSections} partNames={jumpPartNames} ctaLabel="Ask C.A.Gs →" ctaTarget="contact" />

    <!-- 1. HERO (cag-hero-v3 idiom · Authority Green) -->
    <section class="hero-v3-b relative overflow-hidden bg-green text-white scroll-mt-20">
      <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(900px 520px at 78% 28%, rgba(232,96,76,0.22), transparent 60%);"></div>
      <div class="container relative z-10 mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-12">
        <div class="grid items-center gap-10 py-10 md:grid-cols-2 md:gap-8 md:py-14">
          <!-- COPY -->
          <div class="order-2 text-center md:order-1 md:text-left">
            <p class="font-sora text-[11px] font-medium tracking-[0.12em] text-white/80">The Honest Cost Guide · Published Pricing · No Hidden Fees</p>
            <h1 class="font-lora mt-3 text-3xl font-bold leading-[1.1] sm:text-4xl md:text-[2.5rem]">
              African Grey Parrot Price — Every Dollar, Published and Explained
            </h1>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">Here at C.A.Gs in Midland, Texas, we publish our African Grey prices the way we wish every breeder did: in full, on the page, before you ever email us.</p>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">A documented captive-bred Grey runs $1,500–$3,500 from our aviary depending on variant and age — and that purchase price is only chapter one of a 40-to-60-year financial story.</p>
            <p class="font-sora mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-white/85 md:mx-0 md:text-base">This guide covers all of it: what each bird costs, why, what's included, what shipping runs, and what the first year and every year after will honestly ask of your budget.</p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
              <a href="#prices" class="font-sora rounded-full bg-clay px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dk">See the Full Price List →</a>
              <a href="#first-year" class="font-sora rounded-full border-2 border-white/60 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white hover:text-green">First-Year Budget →</a>
            </div>
          </div>
          <!-- CIRCULAR IMAGE STAGE -->
          <div class="order-1 flex justify-center md:order-2 md:justify-end">
            <div class="relative">
              <div class="absolute inset-0 -m-3 rounded-full border border-white/25 md:-m-5" aria-hidden="true"></div>
              <div class="relative flex h-[220px] w-[220px] items-center justify-center overflow-hidden rounded-full bg-[#0f3d2c] ring-4 ring-white/15 sm:h-[260px] sm:w-[260px] md:h-[300px] md:w-[300px]" style="box-shadow: 0 24px 60px rgba(60,30,10,0.35);">
                <img src="/hand-fed-african-grey-baby-breeder.webp"
                  alt="A baby African Grey parrot being hand-fed at the C.A.Gs aviary in Midland, Texas — the 12–16 weeks of hand-feeding labor that a documented African Grey parrot price actually pays for."
                  title="What an African Grey price pays for — hand-feeding at C.A.Gs, Midland TX"
                  width="400" height="400" loading="eager" fetchpriority="high" decoding="async"
                  class="h-full w-full object-cover object-center" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COUNTER SNIPPET -->
    <CounterSnippet stats={[
      { num: "$1,500", label: "CAG Floor" },
      { num: "$3,500", label: "CAG Ceiling" },
      { num: "$185", label: "Airport Pickup" },
      { num: "$350", label: "Home Delivery" },
    ]} />

    <!-- 3. KEY TAKEAWAY / BLUF -->
    <KeyTakeawayV2
      eyebrow="The numbers, up front"
      heading="What Does an African Grey Really Cost? (The 30-Second Answer)"
      badge="6 numbers · 30-sec read"
      items={[
        { stat: "$2,300–$2,500", label: "Congo Baby",        body: "Our hand-raised Congo babies (3–6 months) — weaned at 12–16 weeks, socialized, fully documented before they travel." },
        { stat: "$1,500–$1,700", label: "The Entry Tier",    body: "Timnehs run $1,500–$1,600 and settled adult Congos $1,700 — same documentation packet, gentler price." },
        { stat: "$1,500",        label: "The Scam Floor",    body: "A legally documented, health-screened Grey realistically can't sell far below $1,500. Listings way under it are bait." },
        { stat: "$185 / $350",   label: "Shipping Tiers",    body: "IATA-compliant nationwide on Delta, United, or American: $185 airport pickup, $350 to your door." },
        { stat: "$825–$2,000",   label: "First-Year Setup",  body: "Cage, perches, toys, first vet visit, food and enrichment — budget it before the bird arrives, not after." },
        { stat: "40–60 yrs",     label: "The Real Price Tag", body: "Ongoing care of $375–$1,350/yr across a Grey's lifespan is the biggest line item nobody advertises." },
      ]}
    />

    <!-- 4. TOC (jump links, grouped) -->
    <nav class="toc-price py-10 px-4 bg-cream md:py-12" aria-label="On this page">
      <div class="container mx-auto max-w-[1100px]">
        <div class="rounded-[20px] border border-black/[0.07] bg-white px-6 py-7 md:px-12 md:py-10" style="box-shadow:0 10px 40px rgba(60,30,10,0.07);">
          <div class="flex flex-col items-start justify-between gap-2 border-b-[1.5px] border-black/[0.07] pb-5 md:flex-row md:items-end">
            <div>
              <p class="font-sora text-xs font-bold uppercase tracking-[0.16em] text-clay">Inside this guide</p>
              <h2 class="font-lora mt-1.5 text-2xl font-bold leading-tight text-logo-dark md:text-3xl">On This Page</h2>
            </div>
            <p class="font-sora text-[13px] text-stone-500">10 sections · every cost covered · jump anywhere</p>
          </div>
          <div class="mt-7 grid grid-cols-1 gap-x-12 gap-y-7 md:grid-cols-2">
            {tocParts.map((part) => (
              <div>
                <div class="mb-2.5 flex items-baseline gap-2.5">
                  <span class="font-sora text-[11px] font-bold uppercase tracking-[0.12em] text-clay">{part.label}</span>
                  <span class="h-px flex-1 bg-black/[0.08]"></span>
                </div>
                <p class="font-lora mb-3 text-lg font-semibold italic text-green">{part.sub}</p>
                <ol class="space-y-0">
                  {part.rows.map((it) => (
