<style is:global>
  /* ============================================================
     PRICE GUIDE — Direction-D-aware interior wrapper (.price-d)
     body.theme-d supplies Newsreader/IBM Plex, lead paragraphs,
     eyebrow ticks, card + button motion. This scopes seam + links + accordion.
     ============================================================ */
  .price-d { --rule: rgba(45,106,79,.16); }

  /* AA: clay as small readable text on LIGHT sections → #b04228 (4.5:1). */
  .price-d a.text-clay, .price-d .text-clay { color:#b04228; }
  /* Hero clay accent stays bright; clay FILLS keep white text (global .bg-clay =
     --clay-ink #bd4129, 5.3:1 — the old color:inherit leaked dark stone = FAIL). */
  .price-d .hero-v3-b .text-clay { color:inherit; }
  .price-d .bg-clay { color:#fff; }

  /* Woven in-content links: clay, underlined, AA-safe. */
  .price-d p a:not(.rounded-full):not(.bg-clay),
  .price-d li a:not(.rounded-full):not(.bg-clay) {
    color:#b04228; font-weight:500; text-decoration:underline;
    text-decoration-color:rgba(176,66,40,.35); text-underline-offset:2px;
    transition:text-decoration-color .2s ease;
  }
  .price-d p a:not(.rounded-full):not(.bg-clay):hover,
  .price-d li a:not(.rounded-full):not(.bg-clay):hover { text-decoration-color:#b04228; }

  /* External links open in a new tab — subtle outward arrow affordance. */
  .price-d p a[target="_blank"]::after { content:"\2197"; font-size:.7em; line-height:0; vertical-align:super; opacity:.5; margin-left:.12em; }

  /* FAQ accordion mechanics (shared cag-faq-acc pattern) */
  .cag-faq-q { cursor: pointer; background: transparent; transition: background .2s ease; }
  .cag-faq-q:hover { background: rgba(45,106,79,.04); }
  .cag-faq-chevron { transition: transform .2s ease; }
  .cag-faq-item.open .cag-faq-chevron { transform: rotate(180deg); }
  .cag-faq-panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .2s ease; }
  .cag-faq-item.open .cag-faq-panel { grid-template-rows: 1fr; }
  .cag-faq-panel-inner { overflow: hidden; }

  /* Section seam — centered wordmark divider (verbatim scope). */
  .price-d > .cag-seam{ display:flex; align-items:center; gap:26px; max-width:1100px; margin:0 auto; padding:.6rem 24px !important; }
  .cag-seam__line{ flex:1; height:1px; background:var(--rule); }
  .price-d .cag-seam img{ height:30px; width:auto; display:block; opacity:.92; flex-shrink:0; }
  @media (max-width:600px){ .price-d > .cag-seam{ gap:16px; } .price-d .cag-seam img{ height:24px; } }

  /* CompareTableE ships text-3xl (30px) on its H2 — ties mobile H1. Cap on small
     screens, desktop unchanged. */
  .price-d h2.text-3xl { font-size:clamp(1.375rem, 3.8vw, 1.875rem); }

  /* Jump targets clear the 96px sticky header; respect reduced motion. */
  .price-d section[id], .price-d div[id] { scroll-margin-top:110px; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior:auto; } }

  /* "↓ Continue:" section next-nav (JS-injected; this block is is:global). */
  .price-d .section-next-nav { text-align:right; padding-top:18px; margin-top:14px; border-top:1px solid #ede5dc; }
  .price-d .section-next-link { font-family:'IBM Plex Sans',sans-serif; font-size:.85rem; font-weight:600;
    color:#b04228; text-decoration:none; display:inline-block; padding:10px 0 10px 12px; margin:-10px 0; }
  .price-d .section-next-link:hover { text-decoration:underline; }
</style>
