          <h2 class="font-lora font-bold text-logo-dark">African Grey Adoption — Your Questions, Answered</h2>
        </div>
        <p class="font-sora text-green text-[15px] font-semibold leading-relaxed mb-6" style="max-width:70ch;">The adoption questions people actually bring us — costs, legitimacy, bonding with a rehomed bird, paperwork, and the adopt-vs-buy decision — answered the same candid way we answer them on the phone.</p>
        <div class="cag-faq-acc max-w-3xl space-y-3">
          {faqs.map((item, i) => (
            <div class:list={["cag-faq-item bg-white rounded-2xl border border-line overflow-hidden", i === 0 && "open"]} style="box-shadow:0 2px 16px rgba(60,30,10,0.05);">
